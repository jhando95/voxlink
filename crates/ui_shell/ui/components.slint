import { LineEdit } from "std-widgets.slint";
import { VxTheme } from "theme.slint";

export component VxButton inherits Rectangle {
    in property <string> label: "";
    in property <bool> accent: false;
    in property <bool> danger: false;
    in property <bool> small: false;
    in property <bool> enabled: true;
    in property <bool> ghost: false;
    in property <bool> soft: false;
    callback clicked();

    height: (root.small ? 34px : 40px) * VxTheme.s;
    min-width: (root.small ? 56px : 88px) * VxTheme.s;
    border-radius: root.small ? (10px * VxTheme.s) : VxTheme.radius-control;
    clip: true;
    background: root.ghost ? transparent :
                !root.enabled ? VxTheme.bg-raised :
                touch.pressed ? (root.danger ? VxTheme.danger-pressed :
                                root.accent ? VxTheme.accent-pressed :
                                root.soft ? VxTheme.surface-active : VxTheme.bg-raised) :
                touch.has-hover ? (root.danger ? VxTheme.danger-hover :
                                  root.accent ? VxTheme.accent-hover :
                                  root.soft ? VxTheme.card-hover-bg : VxTheme.btn-hover-bg) :
                root.danger ? VxTheme.danger :
                root.accent ? VxTheme.accent :
                root.soft ? VxTheme.bg-soft : VxTheme.bg-raised;
    border-color: root.ghost ? transparent :
                  root.danger ? VxTheme.danger :
                  root.accent ? VxTheme.accent-border :
                  root.soft ? VxTheme.border-strong : VxTheme.border-subtle;
    border-width: root.ghost ? 0px : VxTheme.btn-border-width;

    animate background { duration: 90ms; easing: ease-out; }
    animate border-color { duration: 90ms; easing: ease-out; }

    Rectangle {
        width: parent.width;
        height: 1px;
        background: root.accent || root.danger
            ? #ffffff36
            : VxTheme.accent-subtle;
        opacity: root.ghost ? 0 : 1;
    }

    touch := TouchArea {
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            if root.enabled { root.clicked(); }
        }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 6px;
        padding-left: root.small ? 10px : 14px;
        padding-right: root.small ? 10px : 14px;

        Text {
            text: root.label;
            color: root.ghost ? (touch.has-hover ? VxTheme.text-primary : VxTheme.text-secondary) :
                   !root.enabled ? VxTheme.text-muted :
                   root.accent || root.danger ? VxTheme.text-inverse : VxTheme.text-primary;
            font-size: (root.small ? 11px : 12px) * VxTheme.s;
            font-weight: root.accent || root.danger ? 700 : 600;
            letter-spacing: VxTheme.btn-uppercase ? 1.0px : (root.small ? 0.1px : 0.15px);
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component VxCard inherits Rectangle {
    background: VxTheme.bg-card;
    border-radius: VxTheme.radius-card;
    border-color: VxTheme.card-border;
    border-width: VxTheme.btn-border-width;
    clip: true;

    // Default accent bar
    Rectangle {
        width: parent.width;
        height: VxTheme.card-accent-height;
        background: @linear-gradient(90deg, transparent 0%, VxTheme.accent-border 20%, transparent 100%);
        opacity: 0.9;
    }

    // ── Party/360: Blade-style double accent stripe ──
    if VxTheme.is-party : Rectangle {
        y: VxTheme.card-accent-height;
        width: parent.width * 0.6;
        height: 1px;
        background: #8be14f20;
    }

    // ── Retro/Amber: CRT scanline overlay ──
    if VxTheme.is-retro || VxTheme.is-amber : Rectangle {
        y: parent.height * 0.33;
        width: parent.width;
        height: 1px;
        background: VxTheme.is-amber ? #ffbe4f06 : #5cf3a606;
    }
    if VxTheme.is-retro || VxTheme.is-amber : Rectangle {
        y: parent.height * 0.66;
        width: parent.width;
        height: 1px;
        background: VxTheme.is-amber ? #ffbe4f06 : #5cf3a606;
    }

    // ── Space: tiny star dots in corner ──
    if VxTheme.is-space : Rectangle {
        x: parent.width - 12px; y: 8px;
        width: 2px; height: 2px; border-radius: 1px; background: #ffffff18;
    }
    if VxTheme.is-space : Rectangle {
        x: parent.width - 24px; y: 14px;
        width: 2px; height: 2px; border-radius: 1px; background: #ffffff10;
    }

    // ── Arctic: frost edge glow ──
    if VxTheme.is-arctic : Rectangle {
        width: parent.width;
        height: 3px;
        background: @linear-gradient(90deg, transparent 0%, #5fdaf40a 30%, #5fdaf40e 50%, #5fdaf40a 70%, transparent 100%);
    }
}

export component VxInput inherits Rectangle {
    in-out property <string> text <=> inner.text;
    in property <string> placeholder: "";
    in property <InputType> input-type: InputType.text;
    callback accepted();

    height: 42px;
    border-radius: VxTheme.radius-control;
    background: VxTheme.bg-input;
    border-color: inner.has-focus ? VxTheme.border-focus : VxTheme.border-subtle;
    border-width: inner.has-focus ? 2px : 1px;
    clip: true;

    animate border-color { duration: 100ms; easing: ease-out; }
    animate border-width { duration: 100ms; easing: ease-out; }

    Rectangle {
        width: parent.width;
        height: 1px;
        background: inner.has-focus ? VxTheme.accent-border : VxTheme.accent-subtle;
    }

    inner := LineEdit {
        x: 12px;
        y: 9px;
        width: parent.width - 24px;
        height: parent.height - 18px;
        placeholder-text: root.placeholder;
        input-type: root.input-type;
        accepted => { root.accepted(); }
    }
}

export component SectionLabel inherits Text {
    color: VxTheme.text-muted;
    font-size: 10px * VxTheme.s;
    font-weight: VxTheme.heading-weight;
    letter-spacing: VxTheme.section-spacing;
}

export component FieldLabel inherits Text {
    color: VxTheme.text-secondary;
    font-size: 11px;
    font-weight: 600;
}

export component KeyPill inherits Rectangle {
    in property <string> key-text: "";

    min-width: 30px;
    height: 24px;
    border-radius: 8px;
    background: VxTheme.bg-raised;
    border-color: VxTheme.border-subtle;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.key-text;
            color: VxTheme.text-primary;
            font-size: 10px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component StatusDot inherits Rectangle {
    in property <bool> active: false;

    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: root.active ? VxTheme.success : VxTheme.text-muted;
    border-color: root.active ? VxTheme.success-dim : transparent;
    border-width: root.active ? 3px : 0px;

    animate background { duration: 160ms; }
    animate border-color { duration: 160ms; }
    animate border-width { duration: 160ms; }
}

export component AccentBar inherits Rectangle {
    height: 2px;

    Rectangle {
        x: 0px;
        width: parent.width * 0.42;
        height: parent.height;
        background: VxTheme.header-accent-left;
    }
    Rectangle {
        x: parent.width * 0.42;
        width: parent.width * 0.28;
        height: parent.height;
        background: VxTheme.header-accent-mid;
    }
    Rectangle {
        x: parent.width * 0.70;
        width: parent.width * 0.30;
        height: parent.height;
        background: VxTheme.header-accent-right;
    }
}

export component VxStatusPill inherits Rectangle {
    in property <string> label: "";
    in property <color> tone: VxTheme.accent;
    in property <color> fill: VxTheme.accent-subtle;

    height: 24px;
    border-radius: VxTheme.radius-pill;
    background: root.fill;
    border-color: root.tone.transparentize(0.45);
    border-width: 1px;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 6px;
        Rectangle {
            width: 6px;
            height: 6px;
            border-radius: 3px;
            background: root.tone;
        }
        Text {
            text: root.label;
            color: root.tone;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

export component VxStatBlock inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "";
    in property <string> detail: "";
    in property <color> tone: VxTheme.accent;

    border-radius: VxTheme.radius-card;
    background: VxTheme.bg-soft;
    border-color: VxTheme.border-subtle;
    border-width: 1px;

    VerticalLayout {
        padding: 14px * VxTheme.s;
        spacing: 3px;
        Text {
            text: root.label;
            color: VxTheme.text-muted;
            font-size: 10px * VxTheme.s;
            font-weight: VxTheme.heading-weight;
            letter-spacing: VxTheme.section-spacing;
        }
        Text {
            text: root.value;
            color: root.tone;
            font-size: 17px * VxTheme.s;
            font-weight: VxTheme.heading-weight;
            wrap: word-wrap;
        }
        if root.detail != "" : Text {
            text: root.detail;
            color: VxTheme.text-secondary;
            font-size: 10px * VxTheme.s;
            wrap: word-wrap;
        }
    }
}

export component VxActionTile inherits Rectangle {
    in property <string> eyebrow: "";
    in property <string> title: "";
    in property <string> detail: "";
    in property <bool> active: false;
    in property <color> tone: VxTheme.accent;
    callback clicked();

    border-radius: VxTheme.radius-card;
    background: root.active ? root.tone.transparentize(0.86) : VxTheme.bg-soft;
    border-color: root.active ? root.tone.transparentize(0.40) : VxTheme.border-subtle;
    border-width: 1px;
    clip: true;

    animate background { duration: 90ms; easing: ease-out; }
    animate border-color { duration: 90ms; easing: ease-out; }

    Rectangle {
        width: parent.width;
        height: 2px;
        background: root.active ? root.tone : VxTheme.accent-subtle;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 5px;
        Text {
            text: root.eyebrow;
            color: VxTheme.text-muted;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.8px;
        }
        Text {
            text: root.title;
            color: root.active ? root.tone : VxTheme.text-primary;
            font-size: 17px;
            font-weight: 700;
            wrap: word-wrap;
        }
        Text {
            text: root.detail;
            color: VxTheme.text-secondary;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}

export component VxOptionRow inherits Rectangle {
    in property <string> label: "";
    in property <string> detail: "";
    in property <bool> selected: false;
    callback clicked();

    border-radius: VxTheme.radius-control;
    background: root.selected ? VxTheme.tab-active-bg :
                touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
    border-color: root.selected ? VxTheme.accent-border : VxTheme.border-subtle;
    border-width: 1px;

    animate background { duration: 80ms; easing: ease-out; }
    animate border-color { duration: 80ms; easing: ease-out; }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 10px;
        alignment: center;

        Rectangle {
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: root.selected ? VxTheme.accent : VxTheme.bg-panel;
            border-color: root.selected ? VxTheme.accent : VxTheme.border-strong;
            border-width: 2px;
        }

        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.label;
                color: VxTheme.text-primary;
                font-size: 11px;
                font-weight: 700;
                overflow: elide;
            }
            if root.detail != "" : Text {
                text: root.detail;
                color: VxTheme.text-muted;
                font-size: 9px;
                overflow: elide;
            }
        }

        if root.selected : VxStatusPill {
            label: "Active";
            tone: VxTheme.accent;
            fill: VxTheme.accent-subtle;
        }
    }
}

export component MetricRow inherits Rectangle {
    in property <string> metric-label: "";
    in property <string> metric-value: "";
    in property <color> indicator-color: VxTheme.success;

    height: 40px;
    background: VxTheme.bg-soft;
    border-radius: VxTheme.radius-control;
    border-color: VxTheme.border-subtle;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: space-between;

        HorizontalLayout {
            spacing: 8px;
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.indicator-color;
            }
            Text {
                text: root.metric-label;
                color: VxTheme.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.metric-value;
            color: VxTheme.text-primary;
            font-size: 11px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

export component VxSlider inherits Rectangle {
    in-out property <float> value: 1.0;
    callback changed(float);

    height: 32px;
    min-width: 80px;
    background: transparent;

    // Track background
    Rectangle {
        x: 0px;
        y: (parent.height - 8px) / 2;
        width: parent.width;
        height: 8px;
        border-radius: 4px;
        background: VxTheme.border-subtle;

        // Filled portion
        Rectangle {
            width: parent.width * root.value;
            height: parent.height;
            border-radius: 4px;
            background: VxTheme.accent;
            animate width { duration: 50ms; easing: ease-out; }
        }
    }

    // Handle
    Rectangle {
        x: (parent.width - 22px) * root.value;
        y: (parent.height - 22px) / 2;
        width: 22px;
        height: 22px;
        border-radius: 11px;
        background: touch.pressed ? VxTheme.text-primary :
                    touch.has-hover ? VxTheme.accent : VxTheme.bg-panel;
        border-color: touch.pressed ? VxTheme.text-primary : VxTheme.accent;
        border-width: 2.5px;
        drop-shadow-blur: touch.has-hover ? 4px : 0px;
        drop-shadow-color: VxTheme.accent.transparentize(0.7);

        animate background { duration: 80ms; easing: ease-out; }
        animate border-color { duration: 80ms; easing: ease-out; }
        animate drop-shadow-blur { duration: 120ms; }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        moved => {
            if self.pressed {
                root.value = clamp(self.mouse-x / root.width, 0.0, 1.0);
                root.changed(root.value);
            }
        }
        clicked => {
            root.value = clamp(self.mouse-x / root.width, 0.0, 1.0);
            root.changed(root.value);
        }
    }
}

export component Divider inherits Rectangle {
    height: 1px;
    background: VxTheme.border-subtle;
}

export component VxLogo inherits Rectangle {
    in property <length> logo-size: 28px;

    width: root.logo-size;
    height: root.logo-size;
    border-radius:
        VxTheme.is-party ? root.logo-size / 2 :   // 360: circle
        VxTheme.is-retro ? 2px :                   // Retro: sharp CRT
        VxTheme.is-amber ? 2px :                   // Amber: hard terminal
        VxTheme.is-noir  ? root.logo-size / 2 :    // Noir: monocle circle
        VxTheme.is-arctic ? root.logo-size * 0.35 : // Arctic: hexagonal feel
        root.logo-size * 0.26;                      // Default + Space
    background:
        VxTheme.is-party ? #1a1a1a :                                // 360: dark circle
        VxTheme.is-retro ? #0a1a10 :                                // Retro: dark CRT screen
        VxTheme.is-amber ? #1a1000 :                                // Amber: dark terminal
        VxTheme.is-noir  ? #16192240 :                              // Noir: translucent lens
        VxTheme.is-arctic ? #0d2530 :                               // Arctic: dark ice
        VxTheme.is-space ? #080818 :                                // Space: deep space
        @linear-gradient(145deg, VxTheme.header-accent-left 0%, VxTheme.header-accent-mid 55%, VxTheme.header-accent-right 100%);
    border-color:
        VxTheme.is-party ? #8be14f60 :
        VxTheme.is-retro ? #5cf3a640 :
        VxTheme.is-amber ? #ffbe4f40 :
        VxTheme.is-noir  ? #90a8ff30 :
        VxTheme.is-arctic ? #5fdaf440 :
        VxTheme.is-space ? #6cc9ff40 :
        transparent;
    border-width:
        VxTheme.is-party || VxTheme.is-retro || VxTheme.is-amber || VxTheme.is-noir || VxTheme.is-arctic || VxTheme.is-space
        ? 1px : 0px;
    clip: true;

    // ── Default Voxlink: gradient overlay + audio wave bars ──
    if !VxTheme.is-party && !VxTheme.is-retro && !VxTheme.is-amber && !VxTheme.is-noir && !VxTheme.is-arctic && !VxTheme.is-space : Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        background: @radial-gradient(circle, #ffffff20 0%, transparent 70%);
    }

    property <length> band-w: root.logo-size * 0.12;
    property <length> band-gap: root.logo-size * 0.07;
    property <length> band-start-x: (root.logo-size - (band-w * 3 + band-gap * 2)) / 2;

    if !VxTheme.is-party && !VxTheme.is-retro && !VxTheme.is-amber && !VxTheme.is-noir && !VxTheme.is-arctic && !VxTheme.is-space : Rectangle {
        x: root.band-start-x;
        y: root.logo-size * 0.34;
        width: root.band-w;
        height: root.logo-size * 0.34;
        border-radius: root.band-w / 2;
        background: #f3fbffcc;
    }
    if !VxTheme.is-party && !VxTheme.is-retro && !VxTheme.is-amber && !VxTheme.is-noir && !VxTheme.is-arctic && !VxTheme.is-space : Rectangle {
        x: root.band-start-x + root.band-w + root.band-gap;
        y: root.logo-size * 0.20;
        width: root.band-w;
        height: root.logo-size * 0.60;
        border-radius: root.band-w / 2;
        background: #f5fdff;
    }
    if !VxTheme.is-party && !VxTheme.is-retro && !VxTheme.is-amber && !VxTheme.is-noir && !VxTheme.is-arctic && !VxTheme.is-space : Rectangle {
        x: root.band-start-x + (root.band-w + root.band-gap) * 2;
        y: root.logo-size * 0.28;
        width: root.band-w;
        height: root.logo-size * 0.44;
        border-radius: root.band-w / 2;
        background: #f3fbffe0;
    }

    // ── Party 360: Ring of Light ──
    // Outer ring
    if VxTheme.is-party : Rectangle {
        x: root.logo-size * 0.15;
        y: root.logo-size * 0.15;
        width: root.logo-size * 0.70;
        height: root.logo-size * 0.70;
        border-radius: root.logo-size * 0.35;
        background: transparent;
        border-color: #4a6a3a;
        border-width: root.logo-size * 0.04;
    }
    // Ring of Light — top quadrant LED
    if VxTheme.is-party : Rectangle {
        x: (root.logo-size - root.logo-size * 0.18) / 2;
        y: root.logo-size * 0.10;
        width: root.logo-size * 0.18;
        height: root.logo-size * 0.12;
        border-radius: root.logo-size * 0.06;
        background: #8be14f;
    }
    // Ring of Light — bottom quadrant LED
    if VxTheme.is-party : Rectangle {
        x: (root.logo-size - root.logo-size * 0.18) / 2;
        y: root.logo-size * 0.78;
        width: root.logo-size * 0.18;
        height: root.logo-size * 0.12;
        border-radius: root.logo-size * 0.06;
        background: #8be14f;
    }
    // Ring of Light — left quadrant LED
    if VxTheme.is-party : Rectangle {
        x: root.logo-size * 0.10;
        y: (root.logo-size - root.logo-size * 0.12) / 2;
        width: root.logo-size * 0.12;
        height: root.logo-size * 0.18;
        border-radius: root.logo-size * 0.06;
        background: #8be14f;
    }
    // Ring of Light — right quadrant LED
    if VxTheme.is-party : Rectangle {
        x: root.logo-size * 0.78;
        y: (root.logo-size - root.logo-size * 0.12) / 2;
        width: root.logo-size * 0.12;
        height: root.logo-size * 0.18;
        border-radius: root.logo-size * 0.06;
        background: #8be14f;
    }
    // Central "X"
    if VxTheme.is-party : Text {
        text: "X";
        color: #8be14f;
        font-size: root.logo-size * 0.30;
        font-weight: 900;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    // Glow overlay
    if VxTheme.is-party : Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        background: @radial-gradient(circle, #8be14f0c 0%, transparent 65%);
    }

    // ── Space: Planet with orbit rings ──
    // Center planet
    if VxTheme.is-space : Rectangle {
        x: (root.logo-size - root.logo-size * 0.30) / 2;
        y: (root.logo-size - root.logo-size * 0.30) / 2;
        width: root.logo-size * 0.30;
        height: root.logo-size * 0.30;
        border-radius: root.logo-size * 0.15;
        background: @radial-gradient(circle, #6cc9ff 0%, #3a6ea8 100%);
    }
    // Inner orbit ring
    if VxTheme.is-space : Rectangle {
        x: (root.logo-size - root.logo-size * 0.55) / 2;
        y: (root.logo-size - root.logo-size * 0.55) / 2;
        width: root.logo-size * 0.55;
        height: root.logo-size * 0.55;
        border-radius: root.logo-size * 0.275;
        background: transparent;
        border-color: #6cc9ff30;
        border-width: 1px;
    }
    // Outer orbit ring
    if VxTheme.is-space : Rectangle {
        x: (root.logo-size - root.logo-size * 0.80) / 2;
        y: (root.logo-size - root.logo-size * 0.80) / 2;
        width: root.logo-size * 0.80;
        height: root.logo-size * 0.80;
        border-radius: root.logo-size * 0.40;
        background: transparent;
        border-color: #6cc9ff1a;
        border-width: 1px;
    }
    // Moon dot on inner orbit (top-right)
    if VxTheme.is-space : Rectangle {
        x: root.logo-size * 0.68;
        y: root.logo-size * 0.22;
        width: root.logo-size * 0.08;
        height: root.logo-size * 0.08;
        border-radius: root.logo-size * 0.04;
        background: #bb8cff;
    }
    // Moon dot on outer orbit (bottom-left)
    if VxTheme.is-space : Rectangle {
        x: root.logo-size * 0.16;
        y: root.logo-size * 0.70;
        width: root.logo-size * 0.06;
        height: root.logo-size * 0.06;
        border-radius: root.logo-size * 0.03;
        background: #f2b36c;
    }
    // Starfield twinkle dots
    if VxTheme.is-space : Rectangle {
        x: root.logo-size * 0.82; y: root.logo-size * 0.14;
        width: 2px; height: 2px; border-radius: 1px; background: #ffffff60;
    }
    if VxTheme.is-space : Rectangle {
        x: root.logo-size * 0.12; y: root.logo-size * 0.18;
        width: 2px; height: 2px; border-radius: 1px; background: #ffffff40;
    }
    if VxTheme.is-space : Rectangle {
        x: root.logo-size * 0.80; y: root.logo-size * 0.78;
        width: 2px; height: 2px; border-radius: 1px; background: #ffffff30;
    }

    // ── Retro-tech: CRT terminal with >_ prompt ──
    // CRT screen inset glow
    if VxTheme.is-retro : Rectangle {
        x: 2px; y: 2px;
        width: root.logo-size - 4px;
        height: root.logo-size - 4px;
        border-radius: 1px;
        background: @radial-gradient(circle, #5cf3a60a 0%, transparent 80%);
    }
    // Horizontal scanline 1
    if VxTheme.is-retro : Rectangle {
        y: root.logo-size * 0.30;
        width: parent.width;
        height: 1px;
        background: #5cf3a60c;
    }
    // Horizontal scanline 2
    if VxTheme.is-retro : Rectangle {
        y: root.logo-size * 0.55;
        width: parent.width;
        height: 1px;
        background: #5cf3a60c;
    }
    // Horizontal scanline 3
    if VxTheme.is-retro : Rectangle {
        y: root.logo-size * 0.80;
        width: parent.width;
        height: 1px;
        background: #5cf3a60c;
    }
    // Prompt ">_"
    if VxTheme.is-retro : Text {
        x: root.logo-size * 0.18;
        text: ">_";
        color: #5cf3a6;
        font-size: root.logo-size * 0.36;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Amber CRT: Phosphor terminal ──
    // Warm CRT glow
    if VxTheme.is-amber : Rectangle {
        x: 2px; y: 2px;
        width: root.logo-size - 4px;
        height: root.logo-size - 4px;
        border-radius: 1px;
        background: @radial-gradient(circle, #ffbe4f08 0%, transparent 80%);
    }
    // Scanlines
    if VxTheme.is-amber : Rectangle {
        y: root.logo-size * 0.25;
        width: parent.width; height: 1px; background: #ffbe4f0c;
    }
    if VxTheme.is-amber : Rectangle {
        y: root.logo-size * 0.50;
        width: parent.width; height: 1px; background: #ffbe4f0c;
    }
    if VxTheme.is-amber : Rectangle {
        y: root.logo-size * 0.75;
        width: parent.width; height: 1px; background: #ffbe4f0c;
    }
    // Amber prompt ">_"
    if VxTheme.is-amber : Text {
        x: root.logo-size * 0.18;
        text: ">_";
        color: #ffbe4f;
        font-size: root.logo-size * 0.36;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Noir: Film monocle / detective lens ──
    // Outer lens rim
    if VxTheme.is-noir : Rectangle {
        x: root.logo-size * 0.12;
        y: root.logo-size * 0.12;
        width: root.logo-size * 0.76;
        height: root.logo-size * 0.76;
        border-radius: root.logo-size * 0.38;
        background: transparent;
        border-color: #90a8ff40;
        border-width: root.logo-size * 0.035;
    }
    // Inner lens highlight (top-left reflection)
    if VxTheme.is-noir : Rectangle {
        x: root.logo-size * 0.26;
        y: root.logo-size * 0.22;
        width: root.logo-size * 0.20;
        height: root.logo-size * 0.10;
        border-radius: root.logo-size * 0.05;
        background: #90a8ff18;
    }
    // "Vx" monogram
    if VxTheme.is-noir : Text {
        text: "Vx";
        color: #cfd8f4;
        font-size: root.logo-size * 0.26;
        font-weight: 600;
        letter-spacing: -0.5px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // ── Arctic: Ice crystal / snowflake ──
    // Center crystal dot
    if VxTheme.is-arctic : Rectangle {
        x: (root.logo-size - root.logo-size * 0.16) / 2;
        y: (root.logo-size - root.logo-size * 0.16) / 2;
        width: root.logo-size * 0.16;
        height: root.logo-size * 0.16;
        border-radius: root.logo-size * 0.08;
        background: #5fdaf4;
    }
    // Vertical crystal arm
    if VxTheme.is-arctic : Rectangle {
        x: (root.logo-size - root.logo-size * 0.06) / 2;
        y: root.logo-size * 0.12;
        width: root.logo-size * 0.06;
        height: root.logo-size * 0.76;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf450;
    }
    // Horizontal crystal arm
    if VxTheme.is-arctic : Rectangle {
        x: root.logo-size * 0.12;
        y: (root.logo-size - root.logo-size * 0.06) / 2;
        width: root.logo-size * 0.76;
        height: root.logo-size * 0.06;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf450;
    }
    // Diagonal arm hint (top-right branch)
    if VxTheme.is-arctic : Rectangle {
        x: root.logo-size * 0.62;
        y: root.logo-size * 0.18;
        width: root.logo-size * 0.06;
        height: root.logo-size * 0.20;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf430;
    }
    // Diagonal arm hint (bottom-left branch)
    if VxTheme.is-arctic : Rectangle {
        x: root.logo-size * 0.32;
        y: root.logo-size * 0.62;
        width: root.logo-size * 0.06;
        height: root.logo-size * 0.20;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf430;
    }
    // Diagonal arm hint (top-left branch)
    if VxTheme.is-arctic : Rectangle {
        x: root.logo-size * 0.22;
        y: root.logo-size * 0.18;
        width: root.logo-size * 0.16;
        height: root.logo-size * 0.06;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf428;
    }
    // Diagonal arm hint (bottom-right branch)
    if VxTheme.is-arctic : Rectangle {
        x: root.logo-size * 0.62;
        y: root.logo-size * 0.76;
        width: root.logo-size * 0.16;
        height: root.logo-size * 0.06;
        border-radius: root.logo-size * 0.03;
        background: #5fdaf428;
    }
    // Frost glow
    if VxTheme.is-arctic : Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        background: @radial-gradient(circle, #5fdaf40a 0%, transparent 70%);
    }
}

export component VxLogoBig inherits Rectangle {
    width: 72px;
    height: 72px;

    VxLogo {
        logo-size: 72px;
    }
}

export component VxAvatar inherits Rectangle {
    in property <string> initial: "";
    in property <int> color-index: 0;
    in property <length> avatar-size: 36px;
    in property <bool> is-speaking: false;
    in property <bool> show-status: false;
    in property <bool> is-online: false;

    width: root.avatar-size;
    height: root.avatar-size;
    border-radius: root.avatar-size * VxTheme.avatar-roundness;
    background: VxTheme.avatar-color(root.color-index);
    border-color: root.is-speaking ? VxTheme.speaking-border : VxTheme.bg-panel;
    border-width: root.is-speaking ? (VxTheme.btn-border-width + 1px) : 1px;
    clip: true;

    animate border-color { duration: 180ms; }
    animate border-width { duration: 180ms; }

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: parent.border-radius;
        background: @linear-gradient(160deg, #ffffff1c 0%, transparent 55%, #00101a20 100%);
    }

    Text {
        text: root.initial;
        color: VxTheme.text-inverse;
        font-size: root.avatar-size * 0.38;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if root.show-status : Rectangle {
        x: parent.width - self.width - 1px;
        y: parent.height - self.height - 1px;
        width: root.avatar-size * 0.32;
        height: self.width;
        border-radius: self.width / 2;
        background: root.is-online ? VxTheme.success : VxTheme.text-muted;
        border-color: VxTheme.bg-panel;
        border-width: 2px;
    }
}

export component VxToggle inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled();

    width: 48px;
    height: 26px;
    border-radius: 13px;
    background: root.checked ? VxTheme.accent : VxTheme.bg-raised;
    border-color: root.checked ? VxTheme.accent-border : VxTheme.border-subtle;
    border-width: 1px;

    animate background { duration: 120ms; easing: ease-out; }
    animate border-color { duration: 120ms; easing: ease-out; }

    toggle-touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.toggled(); }
    }

    Rectangle {
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: #f7fcff;
        animate x { duration: 120ms; easing: ease-out; }
    }
}
