// ─── Data Structures ───

export struct ParticipantData {
    id: string,
    name: string,
    initial: string,
    is-muted: bool,
    is-deafened: bool,
    is-speaking: bool,
    volume: float,
    color-index: int,
}

export struct PerfData {
    cpu-percent: float,
    memory-mb: float,
    uptime-secs: int,
    audio-active: bool,
    network-connected: bool,
    dropped-frames: int,
}

export struct SpaceData {
    id: string,
    name: string,
    initial: string,
    member-count: int,
    channel-count: int,
    color-index: int,
}

export struct ChatMessage {
    sender-name: string,
    sender-initial: string,
    content: string,
    timestamp: string,
    is-self: bool,
    color-index: int,
    message-id: string,
    edited: bool,
    reactions: string,
}

export struct ChannelData {
    id: string,
    name: string,
    peer-count: int,
    is-voice: bool,
    is-active: bool,
    unread-count: int,
}

export struct MemberData {
    id: string,
    name: string,
    initial: string,
    channel-name: string,
    is-in-voice: bool,
    color-index: int,
    is-server-muted: bool,
}

// ─── Design Tokens — Voxlink ───
// Voice-first broadcast console aesthetic: calm, sharp, premium

export global VxTheme {
    in-out property <bool> dark-mode: true;

    // Core surfaces
    out property <color> bg-canvas:    dark-mode ? #071019 : #eef3f7;
    out property <color> bg-app:       dark-mode ? #0a141e : #f4f8fb;
    out property <color> bg-panel:     dark-mode ? #101b26 : #ffffff;
    out property <color> bg-card:      dark-mode ? #13202d : #ffffff;
    out property <color> bg-raised:    dark-mode ? #182736 : #e7eff6;
    out property <color> bg-input:     dark-mode ? #0d1722 : #f6f9fc;
    out property <color> bg-rail:      dark-mode ? #09121b : #e9f0f5;
    out property <color> bg-overlay:   dark-mode ? #04090fd0 : #ffffffdd;
    out property <color> bg-soft:      dark-mode ? #0e1721 : #edf4f8;
    out property <color> bg-stage:     dark-mode ? #0c151d : #f3f8fb;

    // Borders
    out property <color> border-subtle: dark-mode ? #213344 : #d6e0e8;
    out property <color> border-strong: dark-mode ? #2d465b : #bfd1df;
    out property <color> border-focus:  dark-mode ? #54d2ff : #1686c5;

    // Text
    out property <color> text-primary:   dark-mode ? #eaf3fb : #0f1720;
    out property <color> text-secondary: dark-mode ? #a4b6c7 : #425363;
    out property <color> text-muted:     dark-mode ? #6f8295 : #76899c;
    out property <color> text-inverse:   dark-mode ? #081018 : #ffffff;

    // Accent
    out property <color> accent:         dark-mode ? #54d2ff : #1686c5;
    out property <color> accent-hover:   dark-mode ? #7bddff : #0f7ab3;
    out property <color> accent-pressed: dark-mode ? #2cb6ef : #0f6fa6;
    out property <color> accent-glow:    dark-mode ? #54d2ff28 : #1686c518;
    out property <color> accent-subtle:  dark-mode ? #54d2ff12 : #1686c50f;
    out property <color> accent-border:  dark-mode ? #54d2ff58 : #1686c53a;
    out property <color> accent-warm:    dark-mode ? #7ce5c8 : #0ea88f;

    // States
    out property <color> success:        #2fd88a;
    out property <color> success-dim:    dark-mode ? #2fd88a24 : #2fd88a18;
    out property <color> danger:         #ff6b6b;
    out property <color> danger-hover:   #ff8585;
    out property <color> danger-pressed: #e35656;
    out property <color> warning:        #ffb84d;
    out property <color> warning-soft:   dark-mode ? #ffb84d20 : #ffb84d16;

    // Interactive / utility
    out property <color> card-hover-bg:     dark-mode ? #172535 : #edf4fa;
    out property <color> card-hover-border: dark-mode ? #2b4458 : #c4d8e6;
    out property <color> btn-hover-bg:      dark-mode ? #1d2d3f : #deebf4;
    out property <color> surface-active:    dark-mode ? #1a3144 : #d9ecf8;
    out property <color> row-hover-bg:      dark-mode ? #122131 : #ebf4fa;
    out property <color> speaking-row-bg:   dark-mode ? #163143 : #def3ff;
    out property <color> speaking-glow:     dark-mode ? #54d2ff18 : #1686c512;
    out property <color> speaking-border:   dark-mode ? #54d2ff6a : #1686c54a;
    out property <color> mute-badge-bg:     dark-mode ? #321a1d : #fff0f0;
    out property <color> deafen-badge-bg:   dark-mode ? #2e2617 : #fff7e9;
    out property <color> connection-lost-bg:dark-mode ? #31191d : #fff0f0;
    out property <color> mic-glow-green:    dark-mode ? #2fd88a30 : #2fd88a20;
    out property <color> mic-glow-yellow:   dark-mode ? #ffb84d30 : #ffb84d20;
    out property <color> mic-glow-red:      dark-mode ? #ff6b6b30 : #ff6b6b20;
    out property <color> msg-self-bg:       dark-mode ? #143041 : #e1f5ff;
    out property <color> msg-other-bg:      dark-mode ? #0f1923 : #f5f8fb;
    out property <color> tab-active-bg:     dark-mode ? #153043 : #dff1fb;

    // Layout tokens
    out property <length> radius-card:    16px;
    out property <length> radius-control: 12px;
    out property <length> radius-pill:    999px;
    out property <length> gutter:         18px;

    // Compatibility aliases for legacy components
    out property <color> bg-deep:                bg-canvas;
    out property <color> bg-surface:             bg-panel;
    out property <color> bg-elevated:            bg-raised;
    out property <color> sidebar-bg:             bg-rail;
    out property <color> sidebar-item-hover:     row-hover-bg;
    out property <color> sidebar-item-active:    tab-active-bg;
    out property <color> sidebar-divider:        border-subtle;
    out property <color> sidebar-user-bg:        bg-soft;
    out property <color> header-accent-left:     dark-mode ? #54d2ff : #1686c5;
    out property <color> header-accent-mid:      dark-mode ? #4fd5d0 : #0ea88f;
    out property <color> header-accent-right:    dark-mode ? #f5c86b : #d99b2b;
    out property <color> card-shadow:            dark-mode ? #00000044 : #6f86940a;
    out property <color> elevation-shadow:       dark-mode ? #00000055 : #6f869410;

    // Avatar color palette — distinct without feeling playful
    public pure function avatar-color(idx: int) -> color {
        if idx == 0 { return #54d2ff; }
        if idx == 1 { return #7ce5c8; }
        if idx == 2 { return #ffb84d; }
        if idx == 3 { return #ff8c6b; }
        if idx == 4 { return #89a8ff; }
        if idx == 5 { return #ff9bbd; }
        if idx == 6 { return #a8e65d; }
        return #8bd7ff;
    }
}
