// ─── Data Structures ───

export struct ParticipantData {
    id: string,
    name: string,
    initial: string,
    is-muted: bool,
    is-deafened: bool,
    is-speaking: bool,
    volume: float,
    color-index: int,
}

export struct PerfData {
    cpu-percent: float,
    memory-mb: float,
    uptime-secs: int,
    audio-active: bool,
    network-connected: bool,
    dropped-frames: int,
}

export struct SpaceData {
    id: string,
    name: string,
    initial: string,
    member-count: int,
    channel-count: int,
    color-index: int,
}

export struct ChatMessage {
    sender-name: string,
    content: string,
    timestamp: string,
    is-self: bool,
    color-index: int,
    message-id: string,
    edited: bool,
    reactions: string,
}

export struct ChannelData {
    id: string,
    name: string,
    peer-count: int,
    is-voice: bool,
}

export struct MemberData {
    id: string,
    name: string,
    initial: string,
    channel-name: string,
    is-in-voice: bool,
    color-index: int,
}

// ─── Design Tokens — Voxlink ───
// Refined engineering aesthetic: precision, depth, warmth

export global VxTheme {
    in-out property <bool> dark-mode: true;

    // Backgrounds — deep layered surfaces with blue-steel undertone
    out property <color> bg-deep:     dark-mode ? #07070c : #eef0f4;
    out property <color> bg-surface:  dark-mode ? #0e0e15 : #f5f6f9;
    out property <color> bg-card:     dark-mode ? #15151e : #ffffff;
    out property <color> bg-elevated: dark-mode ? #1c1c28 : #e6e8ee;
    out property <color> bg-input:    dark-mode ? #0b0b12 : #f0f1f6;

    // Sidebar — slightly offset from main bg for depth
    out property <color> sidebar-bg:          dark-mode ? #0a0a11 : #eaecf1;
    out property <color> sidebar-item-hover:  dark-mode ? #161620 : #dfe2ea;
    out property <color> sidebar-item-active: dark-mode ? #1e1e2c : #d4d8e4;
    out property <color> sidebar-divider:     dark-mode ? #181820 : #d0d4dc;
    out property <color> sidebar-user-bg:     dark-mode ? #0c0c14 : #e4e6ee;

    // Borders — precise, subtle
    out property <color> border-subtle: dark-mode ? #22222e : #d2d4de;
    out property <color> border-focus:  #6366f1;

    // Text — clean hierarchy
    out property <color> text-primary:   dark-mode ? #e8e8ee : #0e0e15;
    out property <color> text-secondary: dark-mode ? #8888a0 : #4e4e60;
    out property <color> text-muted:     dark-mode ? #484858 : #9898ac;

    // Accent — indigo, saturated, intentional
    out property <color> accent:         dark-mode ? #6366f1 : #4f46e5;
    out property <color> accent-hover:   dark-mode ? #818cf8 : #6366f1;
    out property <color> accent-pressed: dark-mode ? #4f46e5 : #4338ca;
    out property <color> accent-glow:    dark-mode ? #6366f138 : #4f46e518;
    out property <color> accent-subtle:  dark-mode ? #6366f114 : #4f46e50c;

    // States — refined palette
    out property <color> success:       #10b981;
    out property <color> success-dim:   #10b98124;
    out property <color> danger:        #ef4444;
    out property <color> danger-hover:  #f87171;
    out property <color> danger-pressed:#dc2626;
    out property <color> warning:       #f59e0b;

    // Shadows / Depth
    out property <color> card-shadow:      dark-mode ? #00000050 : #0000000a;
    out property <color> elevation-shadow: dark-mode ? #00000070 : #00000010;

    // Interactive states
    out property <color> card-hover-bg:     dark-mode ? #1a1a26 : #f2f3f7;
    out property <color> card-hover-border: dark-mode ? #2a2a3a : #c4c8d4;
    out property <color> btn-hover-bg:      dark-mode ? #242430 : #dde0e8;
    out property <color> row-hover-bg:      dark-mode ? #12121c : #eff0f5;
    out property <color> speaking-row-bg:   dark-mode ? #14142a : #eae8ff;

    // Status badge backgrounds
    out property <color> mute-badge-bg:       dark-mode ? #2a1414 : #fde8e8;
    out property <color> deafen-badge-bg:     dark-mode ? #14142a : #e8e8fd;
    out property <color> connection-lost-bg:  dark-mode ? #2a1414 : #fde8e8;

    // Header accent — indigo to violet to cyan
    out property <color> header-accent-left:  dark-mode ? #6366f1 : #4f46e5;
    out property <color> header-accent-mid:   dark-mode ? #8b5cf6 : #7c3aed;
    out property <color> header-accent-right: dark-mode ? #06b6d4 : #0891b2;

    // Speaking glow
    out property <color> speaking-glow:   dark-mode ? #6366f128 : #4f46e518;
    out property <color> speaking-border: dark-mode ? #6366f170 : #4f46e550;

    // Mic level glow
    out property <color> mic-glow-green:  dark-mode ? #10b98138 : #10b98128;
    out property <color> mic-glow-yellow: dark-mode ? #f59e0b38 : #f59e0b28;
    out property <color> mic-glow-red:    dark-mode ? #ef444438 : #ef444428;

    // Message bubbles
    out property <color> msg-self-bg:  dark-mode ? #18162e : #eae8ff;
    out property <color> msg-other-bg: dark-mode ? #12121c : #f0f1f6;

    // Tab bar
    out property <color> tab-active-bg: dark-mode ? #1e1e2c : #dce0f0;

    // Avatar color palette — saturated, modern, distinct
    public pure function avatar-color(idx: int) -> color {
        if idx == 0 { return #6366f1; }       // indigo (brand)
        if idx == 1 { return #ec4899; }       // pink
        if idx == 2 { return #10b981; }       // emerald
        if idx == 3 { return #f97316; }       // orange
        if idx == 4 { return #8b5cf6; }       // violet
        if idx == 5 { return #06b6d4; }       // cyan
        if idx == 6 { return #eab308; }       // yellow
        return #ef4444;                        // red
    }
}
