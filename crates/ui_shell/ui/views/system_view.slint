import { ScrollView } from "std-widgets.slint";
import { DirectMessageThreadData, FriendData, FriendRequestData, ParticipantData, PerfData, VxTheme } from "../theme.slint";
import { MetricRow, SectionLabel, VxAvatar, VxButton, VxCard, VxInput, VxLogo, VxStatusPill } from "../components.slint";

export component SystemView inherits Rectangle {
    in property <bool> wide: false;
    in property <PerfData> perf;
    in property <string> uptime-text: "";
    in property <string> version-text: "";
    in property <string> room-code: "";
    in property <[ParticipantData]> participants: [];
    in property <bool> is-open-mic: true;
    in property <int> ping-ms: -1;
    in property <string> current-space-name: "";
    in property <bool> member-widget-visible: false;
    in property <int> favorite-friends-count: 0;
    in property <int> online-friends-count: 0;
    in property <int> live-friends-count: 0;
    in property <[FriendData]> favorite-friends: [];
    in property <[FriendRequestData]> incoming-friend-requests: [];
    in property <[FriendRequestData]> outgoing-friend-requests: [];
    in property <[DirectMessageThreadData]> direct-message-threads: [];
    in property <int> unread-direct-messages-count: 0;
    callback navigate(int);
    callback toggle-member-widget();
    callback send-friend-request-by-name(string);
    callback accept-friend-request(string);
    callback decline-friend-request(string);
    callback cancel-friend-request(string);
    callback remove-friend(string);
    callback open-direct-message(string);

    property <string> add-friend-input: "";
    property <string> add-friend-status: "";
    property <length> side-column-width: clamp(root.width * 0.26, 248px, 288px);

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: root.wide ? 16px : 12px;
            spacing: 12px;

            VxCard {
                HorizontalLayout {
                    padding: 20px;
                    spacing: 16px;

                    VxLogo { logo-size: 54px; }

                    VerticalLayout {
                        alignment: center;
                        spacing: 6px;
                        horizontal-stretch: 1;
                        Text {
                            text: "System overview";
                            color: VxTheme.text-primary;
                            font-size: 24px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Keep the UI light, the audio fast, and the network honest.";
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxStatusPill {
                                label: root.perf.network-connected ? "Network online" : "Network offline";
                                tone: root.perf.network-connected ? VxTheme.success : VxTheme.danger;
                                fill: root.perf.network-connected ? VxTheme.success-dim : VxTheme.mute-badge-bg;
                            }
                            if root.ping-ms >= 0 : VxStatusPill {
                                label: root.ping-ms + " ms";
                                tone: root.ping-ms < 60 ? VxTheme.success :
                                      root.ping-ms < 150 ? VxTheme.warning : VxTheme.danger;
                                fill: VxTheme.bg-soft;
                            }
                        }
                    }
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 12px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "QUICK ACTIONS"; }
                            Text {
                                text: root.room-code != ""
                                    ? "Resume the live room, tweak audio, or keep the friend pop-out nearby."
                                    : "Audio controls, friend presence, and session shortcuts live here.";
                                color: VxTheme.text-secondary;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                if root.room-code != "" : VxButton {
                                    label: "Resume room";
                                    glyph: "GO";
                                    accent: true;
                                    horizontal-stretch: 1;
                                    clicked => { root.navigate(1); }
                                }
                                VxButton {
                                    label: "Audio settings";
                                    glyph: "IO";
                                    accent: root.room-code == "";
                                    soft: root.room-code != "";
                                    horizontal-stretch: 1;
                                    clicked => { root.navigate(2); }
                                }
                            }
                            VxButton {
                                label: root.member-widget-visible ? "Hide pop-out" : "Open pop-out";
                                glyph: root.member-widget-visible ? "CL" : "PO";
                                accent: !root.member-widget-visible && root.room-code != "";
                                soft: root.member-widget-visible || root.room-code == "";
                                horizontal-stretch: 1;
                                clicked => { root.toggle-member-widget(); }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.room-code != "" ? "Room live" : "Room idle";
                                    tone: root.room-code != "" ? VxTheme.success : VxTheme.text-muted;
                                    fill: root.room-code != "" ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: root.unread-direct-messages-count > 0
                                        ? root.unread-direct-messages-count + " unread"
                                        : "Inbox clear";
                                    tone: root.unread-direct-messages-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                    fill: root.unread-direct-messages-count > 0 ? VxTheme.accent-subtle : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: root.favorite-friends-count > 0
                                        ? root.online-friends-count + " online"
                                        : "No friends yet";
                                    tone: root.online-friends-count > 0 ? VxTheme.success : VxTheme.text-muted;
                                    fill: root.online-friends-count > 0 ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 8px;
                            SectionLabel { text: "RESOURCES"; }
                            MetricRow {
                                metric-label: "CPU";
                                metric-value: round(root.perf.cpu-percent) + "%";
                                indicator-color: root.perf.cpu-percent < 50 ? VxTheme.success :
                                                 root.perf.cpu-percent < 80 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Memory";
                                metric-value: round(root.perf.memory-mb * 10) / 10 + " MB";
                                indicator-color: root.perf.memory-mb < 100 ? VxTheme.success :
                                                 root.perf.memory-mb < 250 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Uptime";
                                metric-value: root.uptime-text;
                                indicator-color: VxTheme.accent;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 8px;
                            SectionLabel { text: "SESSION"; }
                            MetricRow {
                                metric-label: "Audio";
                                metric-value: root.perf.audio-active ? "Active" : "Idle";
                                indicator-color: root.perf.audio-active ? VxTheme.success : VxTheme.text-muted;
                            }
                            MetricRow {
                                metric-label: "Dropped frames";
                                metric-value: root.perf.dropped-frames + "";
                                indicator-color: root.perf.dropped-frames == 0 ? VxTheme.success :
                                                 root.perf.dropped-frames < 10 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Jitter buffer";
                                metric-value: root.perf.jitter-buffer-ms + " ms";
                                indicator-color: root.perf.jitter-buffer-ms <= 40 ? VxTheme.success :
                                                 root.perf.jitter-buffer-ms <= 80 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Frame loss";
                                metric-value: round(root.perf.frame-loss-percent * 10) / 10 + "%";
                                indicator-color: root.perf.frame-loss-percent < 1 ? VxTheme.success :
                                                 root.perf.frame-loss-percent < 5 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Bitrate";
                                metric-value: root.perf.encode-bitrate-kbps > 0 ? root.perf.encode-bitrate-kbps + " kbps" : "—";
                                indicator-color: VxTheme.accent;
                            }
                            MetricRow {
                                metric-label: "Peers";
                                metric-value: root.perf.decode-peers + "";
                                indicator-color: VxTheme.accent;
                            }
                            MetricRow {
                                metric-label: "Transport";
                                metric-value: root.perf.udp-active ? "UDP" : "WebSocket";
                                indicator-color: root.perf.udp-active ? VxTheme.success : VxTheme.text-muted;
                            }
                            MetricRow {
                                metric-label: "Ping";
                                metric-value: root.perf.ping-ms >= 0 ? root.perf.ping-ms + " ms" : "—";
                                indicator-color: root.perf.ping-ms < 0 ? VxTheme.text-muted :
                                                 root.perf.ping-ms < 60 ? VxTheme.success :
                                                 root.perf.ping-ms < 150 ? VxTheme.warning : VxTheme.danger;
                            }
                            MetricRow {
                                metric-label: "Voice mode";
                                metric-value: root.is-open-mic ? "Open mic" : "Push to talk";
                                indicator-color: VxTheme.accent;
                            }
                            MetricRow {
                                metric-label: "Room";
                                metric-value: root.room-code != "" ? root.room-code + "  ·  " + root.participants.length + " people" : "No active room";
                                indicator-color: root.room-code != "" ? VxTheme.accent : VxTheme.text-muted;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            HorizontalLayout {
                                spacing: 8px;
                                SectionLabel { text: "CONVERSATIONS"; }
                                if root.unread-direct-messages-count > 0 : VxStatusPill {
                                    label: root.unread-direct-messages-count + " unread";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.accent-subtle;
                                }
                            }
                            if root.direct-message-threads.length == 0 : Text {
                                text: "Open a direct message from any friend card and it will stay here for quick return trips.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            for thread in root.direct-message-threads : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: thread.unread-count > 0 ? VxTheme.accent-border :
                                              thread.is-in-voice ? VxTheme.speaking-border :
                                              thread.is-online ? VxTheme.border-strong : VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;
                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: center;
                                        VxAvatar {
                                            avatar-size: 30px;
                                            initial: thread.initial;
                                            color-index: thread.color-index;
                                            show-status: true;
                                            is-online: thread.is-online;
                                            is-speaking: thread.is-in-voice;
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            Text {
                                                text: thread.name;
                                                color: VxTheme.text-primary;
                                                font-size: 11px;
                                                font-weight: 700;
                                            }
                                            Text {
                                                text: thread.meta;
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                            }
                                        }
                                        if thread.unread-count > 0 : VxStatusPill {
                                            label: thread.unread-count + "";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                    }
                                    Text {
                                        text: thread.preview;
                                        color: VxTheme.text-secondary;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                        max-height: 28px;
                                    }
                                    VxButton {
                                        label: "Open conversation";
                                        glyph: "DM";
                                        small: true;
                                        accent: true;
                                        horizontal-stretch: 1;
                                        clicked => { root.open-direct-message(thread.user-id); }
                                    }
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: root.side-column-width;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "BUILD"; }
                            Text {
                                text: "Voxlink " + root.version-text;
                                color: VxTheme.text-primary;
                                font-size: 18px;
                                font-weight: 700;
                            }
                            Text {
                                text: "Rust core, Slint shell, no embedded browser runtime.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            VxStatusPill {
                                label: "Voice-first native stack";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "TARGETS"; }
                            Text {
                                text: "Low idle usage, clean redraw behavior, and stable audio throughput stay ahead of decorative effects.";
                                color: VxTheme.text-secondary;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            VxStatusPill {
                                label: "UI redraws only when state changes";
                                tone: VxTheme.success;
                                fill: VxTheme.success-dim;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "ADD FRIEND"; }
                            Text {
                                text: "You can add friends with their Voxlink username.";
                                color: VxTheme.text-secondary;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                add-friend-narrow := VxInput {
                                    placeholder: "Enter a username...";
                                    text <=> root.add-friend-input;
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.add-friend-input != "" {
                                            root.add-friend-status = "Sending...";
                                            root.send-friend-request-by-name(root.add-friend-input);
                                            root.add-friend-input = "";
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Send Request";
                                    glyph: "FR";
                                    small: true;
                                    accent: true;
                                    clicked => {
                                        if root.add-friend-input != "" {
                                            root.add-friend-status = "Sending...";
                                            root.send-friend-request-by-name(root.add-friend-input);
                                            root.add-friend-input = "";
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "FRIENDS"; }
                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.favorite-friends-count + " total";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.accent-subtle;
                                }
                                VxStatusPill {
                                    label: root.unread-direct-messages-count + " unread";
                                    tone: root.unread-direct-messages-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                    fill: root.unread-direct-messages-count > 0 ? VxTheme.accent-subtle : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: root.online-friends-count + " online";
                                    tone: root.online-friends-count > 0 ? VxTheme.success : VxTheme.text-muted;
                                    fill: root.online-friends-count > 0 ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: root.live-friends-count + " in voice";
                                    tone: root.live-friends-count > 0 ? VxTheme.warning : VxTheme.text-muted;
                                    fill: root.live-friends-count > 0 ? VxTheme.warning-soft : VxTheme.bg-soft;
                                }
                            }
                            if root.favorite-friends.length == 0 : VerticalLayout {
                                spacing: 4px;
                                padding-top: 4px;
                                Text {
                                    text: "No friends yet";
                                    color: VxTheme.text-secondary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "Add a friend to get started.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                }
                            }
                            if root.favorite-friends.length > 0 : VerticalLayout {
                                spacing: 8px;
                                for friend in root.favorite-friends : Rectangle {
                                    border-radius: VxTheme.radius-card;
                                    background: VxTheme.bg-soft;
                                    border-color: friend.is-in-voice ? VxTheme.speaking-border :
                                                  friend.is-online ? VxTheme.accent-border : VxTheme.border-subtle;
                                    border-width: 1px;
                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: center;
                                            VxAvatar {
                                                avatar-size: 28px;
                                                initial: friend.initial;
                                                color-index: friend.color-index;
                                                show-status: true;
                                                is-online: friend.is-online;
                                                is-speaking: friend.is-in-voice;
                                            }
                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                Text {
                                                    text: friend.name;
                                                    color: VxTheme.text-primary;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                }
                                                Text {
                                                    text: friend.detail;
                                                    color: VxTheme.text-muted;
                                                    font-size: 9px;
                                                    overflow: elide;
                                                }
                                                if !friend.is-online && friend.last-seen != "" : Text {
                                                    text: friend.last-seen;
                                                    color: VxTheme.text-muted;
                                                    font-size: 8px;
                                                }
                                            }
                                            VxStatusPill {
                                                label: friend.status-label;
                                                tone: friend.is-in-voice ? VxTheme.success :
                                                      friend.is-online ? VxTheme.text-secondary : VxTheme.text-muted;
                                                fill: friend.is-in-voice ? VxTheme.success-dim :
                                                      friend.is-online ? VxTheme.bg-panel : VxTheme.bg-soft;
                                            }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px;
                                            VxButton {
                                                label: "Message";
                                                glyph: "DM";
                                                small: true;
                                                accent: true;
                                                horizontal-stretch: 1;
                                                clicked => { root.open-direct-message(friend.user-id); }
                                            }
                                            VxButton {
                                                label: "Remove";
                                                glyph: "RM";
                                                small: true;
                                                soft: true;
                                                horizontal-stretch: 1;
                                                clicked => { root.remove-friend(friend.user-id); }
                                            }
                                        }
                                    }
                                }
                            }
                            if root.incoming-friend-requests.length == 0 && root.outgoing-friend-requests.length == 0 : Text {
                                text: "No pending requests right now. Add people from any member list and they will land here.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            if root.incoming-friend-requests.length > 0 : VerticalLayout {
                                spacing: 8px;
                                SectionLabel { text: "INCOMING"; }
                                for request in root.incoming-friend-requests : Rectangle {
                                    border-radius: VxTheme.radius-card;
                                    background: VxTheme.bg-soft;
                                    border-color: VxTheme.border-subtle;
                                    border-width: 1px;
                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: center;
                                            VxAvatar {
                                                avatar-size: 28px;
                                                initial: request.initial;
                                                color-index: request.color-index;
                                                show-status: false;
                                            }
                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                Text {
                                                    text: request.name;
                                                    color: VxTheme.text-primary;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                }
                                                Text {
                                                    text: request.detail;
                                                    color: VxTheme.text-muted;
                                                    font-size: 9px;
                                                }
                                            }
                                        }
                                        HorizontalLayout {
                                            spacing: 8px;
                                            VxButton {
                                                label: "Accept";
                                                glyph: "OK";
                                                small: true;
                                                accent: true;
                                                horizontal-stretch: 1;
                                                clicked => { root.accept-friend-request(request.user-id); }
                                            }
                                            VxButton {
                                                label: "Decline";
                                                glyph: "NO";
                                                small: true;
                                                soft: true;
                                                horizontal-stretch: 1;
                                                clicked => { root.decline-friend-request(request.user-id); }
                                            }
                                        }
                                    }
                                }
                            }
                            if root.outgoing-friend-requests.length > 0 : VerticalLayout {
                                spacing: 8px;
                                SectionLabel { text: "OUTGOING"; }
                                for request in root.outgoing-friend-requests : Rectangle {
                                    border-radius: VxTheme.radius-card;
                                    background: VxTheme.bg-soft;
                                    border-color: VxTheme.border-subtle;
                                    border-width: 1px;
                                    VerticalLayout {
                                        padding: 12px;
                                        spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 10px;
                                            alignment: center;
                                            VxAvatar {
                                                avatar-size: 28px;
                                                initial: request.initial;
                                                color-index: request.color-index;
                                                show-status: false;
                                            }
                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                spacing: 2px;
                                                Text {
                                                    text: request.name;
                                                    color: VxTheme.text-primary;
                                                    font-size: 11px;
                                                    font-weight: 700;
                                                }
                                                Text {
                                                    text: request.detail;
                                                    color: VxTheme.text-muted;
                                                    font-size: 9px;
                                                }
                                            }
                                            VxStatusPill {
                                                label: "Pending";
                                                tone: VxTheme.text-secondary;
                                                fill: VxTheme.bg-panel;
                                            }
                                        }
                                        VxButton {
                                            label: "Cancel request";
                                            glyph: "CN";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.cancel-friend-request(request.user-id); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "POP-OUT"; }
                            Text {
                                text: "Friend widget";
                                color: VxTheme.text-primary;
                                font-size: 18px;
                                font-weight: 700;
                            }
                            Text {
                                text: root.favorite-friends-count > 0
                                    ? "Your friends stay in a tiny always-on-top window. Live status appears anywhere on the server, and cached last-seen details remain when they drop offline."
                                    : (root.current-space-name != ""
                                        ? "Add people from " + root.current-space-name + " and keep them in a tiny always-on-top window. It only updates when friend or presence state changes."
                                        : "Open a tiny always-on-top friends window. It stays idle until you add someone.");
                                color: VxTheme.text-secondary;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.member-widget-visible ? "Pop-out live" : "Pop-out hidden";
                                    tone: root.member-widget-visible ? VxTheme.success : VxTheme.text-muted;
                                    fill: root.member-widget-visible ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: root.favorite-friends-count > 0 ? root.favorite-friends-count + " friends" :
                                          root.current-space-name != "" ? root.current-space-name : "No friends yet";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.accent-subtle;
                                }
                            }
                            VxButton {
                                label: root.member-widget-visible ? "Hide pop-out" : "Open pop-out";
                                accent: !root.member-widget-visible;
                                soft: root.member-widget-visible;
                                horizontal-stretch: 1;
                                clicked => { root.toggle-member-widget(); }
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 12px;

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "QUICK ACTIONS"; }
                        Text {
                            text: root.room-code != ""
                                ? "Resume the live room, jump to settings, or keep the friend pop-out nearby."
                                : "Jump to settings or keep the friend pop-out nearby without leaving the control deck.";
                            color: VxTheme.text-secondary;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        if root.room-code != "" : VxButton {
                            label: "Resume room";
                            glyph: "GO";
                            accent: true;
                            horizontal-stretch: 1;
                            clicked => { root.navigate(1); }
                        }
                        VxButton {
                            label: "Audio settings";
                            glyph: "IO";
                            soft: true;
                            horizontal-stretch: 1;
                            clicked => { root.navigate(2); }
                        }
                        VxButton {
                            label: root.member-widget-visible ? "Hide pop-out" : "Open pop-out";
                            glyph: root.member-widget-visible ? "CL" : "PO";
                            accent: !root.member-widget-visible;
                            soft: root.member-widget-visible;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-member-widget(); }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxStatusPill {
                                label: root.unread-direct-messages-count > 0
                                    ? root.unread-direct-messages-count + " unread"
                                    : "Inbox clear";
                                tone: root.unread-direct-messages-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                fill: root.unread-direct-messages-count > 0 ? VxTheme.accent-subtle : VxTheme.bg-soft;
                            }
                            VxStatusPill {
                                label: root.favorite-friends-count > 0
                                    ? root.online-friends-count + " online"
                                    : "No friends yet";
                                tone: root.online-friends-count > 0 ? VxTheme.success : VxTheme.text-muted;
                                fill: root.online-friends-count > 0 ? VxTheme.success-dim : VxTheme.bg-soft;
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 8px;
                        SectionLabel { text: "RESOURCES"; }
                        MetricRow {
                            metric-label: "CPU";
                            metric-value: round(root.perf.cpu-percent) + "%";
                            indicator-color: root.perf.cpu-percent < 50 ? VxTheme.success :
                                             root.perf.cpu-percent < 80 ? VxTheme.warning : VxTheme.danger;
                        }
                        MetricRow {
                            metric-label: "Memory";
                            metric-value: round(root.perf.memory-mb * 10) / 10 + " MB";
                            indicator-color: root.perf.memory-mb < 100 ? VxTheme.success :
                                             root.perf.memory-mb < 250 ? VxTheme.warning : VxTheme.danger;
                        }
                        MetricRow {
                            metric-label: "Transport";
                            metric-value: root.perf.udp-active ? "UDP" : "WebSocket";
                            indicator-color: root.perf.udp-active ? VxTheme.success : VxTheme.text-muted;
                        }
                        MetricRow {
                            metric-label: "Ping";
                            metric-value: root.perf.ping-ms >= 0 ? root.perf.ping-ms + " ms" : "—";
                            indicator-color: root.perf.ping-ms < 0 ? VxTheme.text-muted :
                                             root.perf.ping-ms < 60 ? VxTheme.success :
                                             root.perf.ping-ms < 150 ? VxTheme.warning : VxTheme.danger;
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "CONVERSATIONS"; }
                        if root.direct-message-threads.length == 0 : Text {
                            text: "Recent direct messages will appear here.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                        }
                        for thread in root.direct-message-threads : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: dm-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                            border-color: thread.unread-count > 0 ? VxTheme.accent-border :
                                          thread.is-online ? VxTheme.accent-border : VxTheme.border-subtle;
                            border-width: 1px;

                            dm-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-direct-message(thread.user-id); }
                            }

                            HorizontalLayout {
                                padding: 10px;
                                spacing: 10px;

                                // Avatar with status dot
                                Rectangle {
                                    width: 32px;
                                    height: 32px;

                                    VxAvatar {
                                        avatar-size: 32px;
                                        initial: thread.initial;
                                        color-index: thread.color-index;
                                    }

                                    Rectangle {
                                        x: 22px;
                                        y: 22px;
                                        width: 10px;
                                        height: 10px;
                                        border-radius: 5px;
                                        background: thread.is-in-voice ? VxTheme.speaking-border :
                                                    thread.is-online ? VxTheme.success : VxTheme.text-muted;
                                        border-color: VxTheme.bg-panel;
                                        border-width: 2px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: thread.name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: thread.unread-count > 0 ? 800 : 700;
                                        }
                                        if thread.unread-count > 0 : Rectangle {
                                            width: 16px;
                                            height: 16px;
                                            border-radius: 8px;
                                            background: VxTheme.accent;
                                            Text {
                                                text: thread.unread-count;
                                                color: VxTheme.text-inverse;
                                                font-size: 8px;
                                                font-weight: 700;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                    Text {
                                        text: thread.preview;
                                        color: VxTheme.text-secondary;
                                        font-size: 9px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "ADD FRIEND"; }
                        Text {
                            text: "You can add friends with their Voxlink username.";
                            color: VxTheme.text-secondary;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            add-friend-wide := VxInput {
                                placeholder: "Enter a username...";
                                text <=> root.add-friend-input;
                                horizontal-stretch: 1;
                                accepted => {
                                    if root.add-friend-input != "" {
                                        root.add-friend-status = "Sending...";
                                        root.send-friend-request-by-name(root.add-friend-input);
                                        root.add-friend-input = "";
                                    }
                                }
                            }
                            VxButton {
                                label: "Send Request";
                                glyph: "FR";
                                small: true;
                                accent: true;
                                clicked => {
                                    if root.add-friend-input != "" {
                                        root.add-friend-status = "Sending...";
                                        root.send-friend-request-by-name(root.add-friend-input);
                                        root.add-friend-input = "";
                                    }
                                }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "FRIENDS"; }
                        HorizontalLayout {
                            spacing: 8px;
                            VxStatusPill {
                                label: root.favorite-friends-count + " total";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                            VxStatusPill {
                                label: root.online-friends-count + " online";
                                tone: root.online-friends-count > 0 ? VxTheme.success : VxTheme.text-muted;
                                fill: root.online-friends-count > 0 ? VxTheme.success-dim : VxTheme.bg-soft;
                            }
                            VxStatusPill {
                                label: root.live-friends-count + " in voice";
                                tone: root.live-friends-count > 0 ? VxTheme.speaking-border : VxTheme.text-muted;
                                fill: root.live-friends-count > 0 ? VxTheme.warning-soft : VxTheme.bg-soft;
                            }
                            VxStatusPill {
                                label: root.incoming-friend-requests.length + " incoming";
                                tone: root.incoming-friend-requests.length > 0 ? VxTheme.warning : VxTheme.text-muted;
                                fill: root.incoming-friend-requests.length > 0 ? VxTheme.warning-soft : VxTheme.bg-soft;
                            }
                        }
                        if root.favorite-friends.length == 0 : VerticalLayout {
                            spacing: 4px;
                            padding-top: 4px;
                            Text {
                                text: "No friends yet";
                                color: VxTheme.text-secondary;
                                font-size: 11px;
                                font-weight: 600;
                            }
                            Text {
                                text: "Add a friend to get started.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }
                        }
                        if root.favorite-friends.length > 0 : VerticalLayout {
                            spacing: 6px;
                            for friend in root.favorite-friends : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: friend-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: friend.is-in-voice ? VxTheme.speaking-border :
                                              friend.is-online ? VxTheme.accent-border : VxTheme.border-subtle;
                                border-width: 1px;

                                friend-touch := TouchArea {}

                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 10px;

                                    // Avatar with status dot
                                    Rectangle {
                                        width: 32px;
                                        height: 32px;

                                        VxAvatar {
                                            avatar-size: 32px;
                                            initial: friend.initial;
                                            color-index: friend.color-index;
                                        }

                                        // Status dot overlay (bottom-right)
                                        Rectangle {
                                            x: 22px;
                                            y: 22px;
                                            width: 10px;
                                            height: 10px;
                                            border-radius: 5px;
                                            background: friend.is-in-voice ? VxTheme.speaking-border :
                                                        friend.is-online ? VxTheme.success : VxTheme.text-muted;
                                            border-color: VxTheme.bg-panel;
                                            border-width: 2px;
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: friend.name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: 700;
                                        }
                                        Text {
                                            text: friend.detail;
                                            color: friend.is-in-voice ? VxTheme.speaking-border :
                                                   friend.is-online ? VxTheme.accent : VxTheme.text-muted;
                                            font-size: 9px;
                                        }
                                        if !friend.is-online && friend.last-seen != "" : Text {
                                            text: friend.last-seen;
                                            color: VxTheme.text-muted;
                                            font-size: 8px;
                                        }
                                    }

                                    HorizontalLayout {
                                        alignment: center;
                                        spacing: 6px;
                                        VxButton {
                                            label: "Message";
                                            glyph: "DM";
                                            small: true;
                                            accent: true;
                                            clicked => { root.open-direct-message(friend.user-id); }
                                        }
                                        VxButton {
                                            label: "Remove";
                                            glyph: "RM";
                                            small: true;
                                            soft: true;
                                            clicked => { root.remove-friend(friend.user-id); }
                                        }
                                    }
                                }
                            }
                        }
                        if root.incoming-friend-requests.length == 0 && root.outgoing-friend-requests.length == 0 : Text {
                            text: "No pending requests right now.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                        }
                        if root.incoming-friend-requests.length > 0 : VerticalLayout {
                            spacing: 8px;
                            for request in root.incoming-friend-requests : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;
                                    Text {
                                        text: request.name;
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: request.detail;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        VxButton {
                                            label: "Accept";
                                            glyph: "OK";
                                            small: true;
                                            accent: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.accept-friend-request(request.user-id); }
                                        }
                                        VxButton {
                                            label: "Decline";
                                            glyph: "NO";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.decline-friend-request(request.user-id); }
                                        }
                                    }
                                }
                            }
                        }
                        if root.outgoing-friend-requests.length > 0 : VerticalLayout {
                            spacing: 8px;
                            for request in root.outgoing-friend-requests : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;
                                    Text {
                                        text: request.name;
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: request.detail;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                    VxButton {
                                        label: "Cancel request";
                                        glyph: "CN";
                                        small: true;
                                        soft: true;
                                        horizontal-stretch: 1;
                                        clicked => { root.cancel-friend-request(request.user-id); }
                                    }
                                }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "POP-OUT"; }
                        Text {
                            text: "Friend widget";
                            color: VxTheme.text-primary;
                            font-size: 18px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.favorite-friends-count > 0
                                ? "Friends stay in the pop-out between spaces. Live status appears anywhere on the server."
                                : (root.current-space-name != ""
                                    ? "Add people from " + root.current-space-name + " and keep them in a tiny always-on-top window."
                                    : "Open a tiny always-on-top friends window. It stays idle until you add someone.");
                            color: VxTheme.text-secondary;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxStatusPill {
                                label: root.member-widget-visible ? "Pop-out live" : "Pop-out hidden";
                                tone: root.member-widget-visible ? VxTheme.success : VxTheme.text-muted;
                                fill: root.member-widget-visible ? VxTheme.success-dim : VxTheme.bg-soft;
                            }
                            VxStatusPill {
                                label: root.favorite-friends-count > 0 ? root.favorite-friends-count + " friends" :
                                      root.current-space-name != "" ? root.current-space-name : "No friends yet";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }
                        VxButton {
                            label: root.member-widget-visible ? "Hide pop-out" : "Open pop-out";
                            glyph: root.member-widget-visible ? "CL" : "PO";
                            accent: !root.member-widget-visible;
                            soft: root.member-widget-visible;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-member-widget(); }
                        }
                    }
                }
            }
        }
    }
}
