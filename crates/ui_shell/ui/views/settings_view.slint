import { ScrollView } from "std-widgets.slint";
import { SoundboardClipData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, KeyPill, SectionLabel, VxButton, VxCard, VxGlyphTile, VxInput, VxOptionRow, VxSlider, VxStatBlock, VxStatusPill, VxToggle } from "../components.slint";

component ThemePresetCard inherits Rectangle {
    in property <string> label: "";
    in property <bool> selected: false;
    in property <color> tone: VxTheme.accent;
    in property <color> swatch-a: VxTheme.accent;
    in property <color> swatch-b: VxTheme.accent-warm;
    in property <color> swatch-c: VxTheme.bg-raised;
    callback clicked();

    horizontal-stretch: 1;
    border-radius: VxTheme.radius-card;
    background: root.selected
        ? @linear-gradient(180deg, root.tone.transparentize(0.90) 0%, root.tone.transparentize(0.94) 100%)
        : touch.has-hover
            ? @linear-gradient(180deg, VxTheme.card-hover-bg.brighter(0.02) 0%, VxTheme.card-hover-bg 100%)
            : @linear-gradient(180deg, VxTheme.bg-soft.brighter(0.02) 0%, VxTheme.bg-soft 100%);
    border-color: root.selected ? root.tone.transparentize(0.42) : VxTheme.border-subtle;
    border-width: 1px;
    clip: true;
    height: 54px;

    animate background { duration: 90ms; easing: ease-out; }
    animate border-color { duration: 90ms; easing: ease-out; }

    Rectangle {
        width: parent.width;
        height: 3px;
        background: @linear-gradient(90deg, root.swatch-a 0%, root.swatch-b 58%, root.swatch-c 100%);
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: @linear-gradient(125deg, root.tone.transparentize(0.92) 0%, transparent 56%, VxTheme.header-accent-right.transparentize(0.96) 100%);
        opacity: root.selected ? 1.0 : 0.6;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 6px;
            alignment: center;
            Rectangle { width: 12px; height: 12px; border-radius: 6px; background: root.swatch-a; }
            Rectangle { width: 12px; height: 12px; border-radius: 6px; background: root.swatch-b; }
            Rectangle { width: 12px; height: 12px; border-radius: 6px; background: root.swatch-c; }
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.selected ? root.tone : VxTheme.border-subtle;
            }
        }

        Text {
            text: root.label;
            color: root.selected ? root.tone : VxTheme.text-primary;
            font-size: 11px;
            font-weight: root.selected ? 700 : 600;
            overflow: elide;
        }
    }
}

export component SettingsView inherits Rectangle {
    in property <bool> wide: false;
    in property <int> previous-view: 0;
    in property <bool> dark-mode: true;
    in property <int> theme-preset: 0;
    in property <[string]> input-devices: [];
    in property <[string]> output-devices: [];
    in-out property <int> selected-input: 0;
    in-out property <int> selected-output: 0;
    in-out property <float> input-volume: 1.0;
    in-out property <float> output-volume: 1.0;
    in property <bool> is-open-mic: true;
    in property <float> mic-level: 0.0;
    in-out property <bool> mic-preview-active: false;
    in-out property <bool> speaker-test-active: false;
    in-out property <float> noise-suppression: 0.5;
    in property <bool> feedback-sound: true;
    in property <bool> notifications-enabled: true;
    in property <bool> minimize-to-tray: true;
    in property <bool> neural-noise-suppression: false;
    in property <bool> echo-cancellation: false;
    in property <bool> join-leave-sounds: true;
    in property <bool> show-spoilers: false;
    in property <bool> compact-chat: false;
    in property <bool> streamer-mode: false;
    in property <bool> desktop-notifications: true;
    callback toggle-streamer-mode();
    callback toggle-desktop-notifications();
    in-out property <string> listening-keybind: "";
    in property <string> ptt-key-display: "";
    in property <string> mute-key-display: "";
    in property <string> deafen-key-display: "";
    callback navigate(int);
    callback toggle-dark-mode();
    callback select-theme-preset(int);
    callback refresh-devices();
    callback input-volume-changed(float);
    callback output-volume-changed(float);
    callback toggle-mic-preview();
    callback play-speaker-test();
    callback toggle-mic-mode();
    callback noise-suppression-changed(float);
    callback toggle-feedback-sound();
    callback toggle-notifications();
    callback toggle-minimize-to-tray();
    callback toggle-neural-noise-suppression();
    callback toggle-echo-cancellation();
    callback toggle-join-leave-sounds();
    callback toggle-show-spoilers();
    callback toggle-compact-chat();
    callback clear-keybind(string);
    // Notification sound style
    in property <int> notification-sound-index: 0; // 0=Default, 1=Subtle, 2=Chime, 3=None
    callback set-notification-sound(int);
    // Status preset
    in property <int> status-preset: 0;
    callback set-status-preset(int);
    // Idle timeout
    in property <int> idle-timeout-mins: 5;
    callback set-idle-timeout(int);
    // Account
    in property <bool> is-logged-in: false;
    in property <string> account-email: "";
    callback logout();
    callback show-login();
    callback show-about();
    callback revoke-all-sessions();
    callback change-password(string, string);
    callback change-display-name(string);
    callback delete-account();
    property <length> side-column-width: clamp(root.width * 0.24, 236px, 284px);
    in-out property <string> acct-old-pw: "";
    in-out property <string> acct-new-pw: "";
    in-out property <string> acct-new-name: "";
    in-out property <string> acct-delete-confirm: "";
    // Soundboard
    in property <[SoundboardClipData]> soundboard-clips: [];
    callback play-soundboard-clip(int);
    callback remove-soundboard-clip(int);
    callback add-soundboard-clip(string, string, string); // name, path, keybind
    in-out property <string> new-clip-name: "";
    in-out property <string> new-clip-path: "";
    in-out property <string> new-clip-keybind: "";
    // Privacy dashboard
    in property <string> privacy-config-path: "";
    in property <string> privacy-log-path: "";
    callback clear-local-data();
    callback export-my-data();
    // Audio processing transparency
    in property <string> audio-noise-gate-threshold: "-42 dB";
    in property <string> audio-opus-bitrate: "64 kbps";

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: root.wide ? 16px : 12px;
            spacing: 12px;

            VxCard {
                HorizontalLayout {
                    padding: 18px;
                    spacing: 14px;
                    alignment: center;

                    Rectangle {
                        width: root.wide ? 66px : 56px;
                        height: root.wide ? 66px : 56px;
                        border-radius: VxTheme.radius-card;
                        background: @linear-gradient(145deg, VxTheme.accent-subtle 0%, VxTheme.bg-soft 78%, transparent 100%);
                        border-color: VxTheme.accent-border;
                        border-width: 1px;
                        clip: true;

                        Rectangle {
                            width: parent.width;
                            height: 2px;
                            background: VxTheme.accent;
                            opacity: 0.85;
                        }

                        VxGlyphTile {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            tile-size: root.wide ? 38px : 32px;
                            glyph: "IO";
                            tone: VxTheme.accent;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        spacing: 6px;

                        Text {
                            text: "Audio and preferences";
                            color: VxTheme.text-primary;
                            font-size: 24px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Tune devices, voice behavior, and alerts without adding runtime drag.";
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxStatusPill {
                                label: root.dark-mode ? "Dark shell" : "Light shell";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                            VxStatusPill {
                                label: root.is-open-mic ? "Open mic" : "Push to talk";
                                tone: root.is-open-mic ? VxTheme.success : VxTheme.warning;
                                fill: root.is-open-mic ? VxTheme.success-dim : VxTheme.warning-soft;
                            }
                            if root.input-devices.length > 0 || root.output-devices.length > 0 : VxStatusPill {
                                label: root.input-devices.length + " in · " + root.output-devices.length + " out";
                                tone: VxTheme.text-secondary;
                                fill: VxTheme.bg-soft;
                            }
                        }
                    }

                    if root.previous-view == 1 : VxButton {
                        label: "Back to call";
                        glyph: "GO";
                        soft: true;
                        clicked => { root.navigate(root.previous-view); }
                    }
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 12px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "APPEARANCE"; }
                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text:
                                            root.theme-preset == 1 ? (root.dark-mode ? "360 party dark" : "360 party light") :
                                            root.theme-preset == 2 ? (root.dark-mode ? "Deep space dark" : "Deep space light") :
                                            root.theme-preset == 3 ? (root.dark-mode ? "Retro tech dark" : "Retro tech light") :
                                            root.theme-preset == 4 ? (root.dark-mode ? "Amber CRT dark" : "Amber CRT light") :
                                            root.theme-preset == 5 ? (root.dark-mode ? "Midnight noir dark" : "Midnight noir light") :
                                            root.theme-preset == 6 ? (root.dark-mode ? "Arctic glass dark" : "Arctic glass light") :
                                            root.dark-mode ? "Voxlink dark" : "Voxlink light";
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text:
                                            root.theme-preset == 1 ? "Retro console party energy with green glass surfaces and warm highlights." :
                                            root.theme-preset == 2 ? "A colder orbital palette with blue-black surfaces and neon trim." :
                                            root.theme-preset == 3 ? "Retro control-room styling with phosphor green and amber accents." :
                                            root.theme-preset == 4 ? "Warm amber phosphor styling with CRT-era contrast and sepia depth." :
                                            root.theme-preset == 5 ? "A stripped-back noir shell with ink-dark surfaces and cold blue trim." :
                                            root.theme-preset == 6 ? "Frosted cyan glass with brighter surfaces and cleaner contrast." :
                                            "The default premium shell. Theme changes apply instantly without touching the audio pipeline.";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                                VxToggle {
                                    checked: root.dark-mode;
                                    toggled => { root.toggle-dark-mode(); }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Theme preset"; }

                                HorizontalLayout {
                                    spacing: 8px;
                                    ThemePresetCard {
                                        label: "Voxlink";
                                        selected: root.theme-preset == 0;
                                        tone: #54d2ff;
                                        swatch-a: #54d2ff;
                                        swatch-b: #7ce5c8;
                                        swatch-c: #13202d;
                                        clicked => { root.select-theme-preset(0); }
                                    }
                                    ThemePresetCard {
                                        label: "360 Party";
                                        selected: root.theme-preset == 1;
                                        tone: #8be14f;
                                        swatch-a: #8be14f;
                                        swatch-b: #f3c65d;
                                        swatch-c: #192715;
                                        clicked => { root.select-theme-preset(1); }
                                    }
                                    ThemePresetCard {
                                        label: "Deep Space";
                                        selected: root.theme-preset == 2;
                                        tone: #6cc9ff;
                                        swatch-a: #6cc9ff;
                                        swatch-b: #bb8cff;
                                        swatch-c: #141c3a;
                                        clicked => { root.select-theme-preset(2); }
                                    }
                                    ThemePresetCard {
                                        label: "Retro Tech";
                                        selected: root.theme-preset == 3;
                                        tone: #5cf3a6;
                                        swatch-a: #5cf3a6;
                                        swatch-b: #ffca5c;
                                        swatch-c: #111d18;
                                        clicked => { root.select-theme-preset(3); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    ThemePresetCard {
                                        label: "Amber CRT";
                                        selected: root.theme-preset == 4;
                                        tone: #ffbe4f;
                                        swatch-a: #ffbe4f;
                                        swatch-b: #fff0b2;
                                        swatch-c: #291c0f;
                                        clicked => { root.select-theme-preset(4); }
                                    }
                                    ThemePresetCard {
                                        label: "Midnight Noir";
                                        selected: root.theme-preset == 5;
                                        tone: #90a8ff;
                                        swatch-a: #90a8ff;
                                        swatch-b: #cfd8f4;
                                        swatch-c: #151921;
                                        clicked => { root.select-theme-preset(5); }
                                    }
                                    ThemePresetCard {
                                        label: "Arctic Glass";
                                        selected: root.theme-preset == 6;
                                        tone: #5fdaf4;
                                        swatch-a: #5fdaf4;
                                        swatch-b: #c8f6ff;
                                        swatch-c: #13292f;
                                        clicked => { root.select-theme-preset(6); }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;

                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "DEVICE ROUTING"; }
                                VxButton {
                                    label: "Refresh";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.refresh-devices(); }
                                }
                            }

                            if root.input-devices.length > 0 || root.output-devices.length > 0 : HorizontalLayout {
                                spacing: 10px;
                                if root.input-devices.length > 0 : VxStatBlock {
                                    horizontal-stretch: 1;
                                    label: "Selected input";
                                    value: root.input-devices[root.selected-input];
                                    detail: "Mic route used for capture.";
                                    tone: VxTheme.accent;
                                }
                                if root.output-devices.length > 0 : VxStatBlock {
                                    horizontal-stretch: 1;
                                    label: "Selected output";
                                    value: root.output-devices[root.selected-output];
                                    detail: "Speaker route used for playback.";
                                    tone: VxTheme.success;
                                }
                            }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Input device"; }
                                if root.input-devices.length > 0 : VerticalLayout {
                                    spacing: 8px;
                                    for device[idx] in root.input-devices : VxOptionRow {
                                        label: device;
                                        detail: idx == root.selected-input ? "Current capture route" : "Tap to switch capture route";
                                        selected: idx == root.selected-input;
                                        clicked => { root.selected-input = idx; }
                                    }
                                }
                                if root.input-devices.length == 0 : VerticalLayout {
                                    spacing: 2px;
                                    Text {
                                        text: "No microphones found";
                                        color: VxTheme.danger;
                                        font-size: 10px;
                                    }
                                    Text {
                                        text: "Check connections, update drivers, or click Refresh.";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Output device"; }
                                if root.output-devices.length > 0 : VerticalLayout {
                                    spacing: 8px;
                                    for device[idx] in root.output-devices : VxOptionRow {
                                        label: device;
                                        detail: idx == root.selected-output ? "Current playback route" : "Tap to switch playback route";
                                        selected: idx == root.selected-output;
                                        clicked => { root.selected-output = idx; }
                                    }
                                }
                                if root.output-devices.length == 0 : VerticalLayout {
                                    spacing: 2px;
                                    Text {
                                        text: "No speakers found";
                                        color: VxTheme.danger;
                                        font-size: 10px;
                                    }
                                    Text {
                                        text: "Check connections, update drivers, or click Refresh.";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "LEVELS"; }

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Mic gain"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.input-volume / 2.0;
                                        changed(val) => {
                                            root.input-volume = val * 2.0;
                                            root.input-volume-changed(root.input-volume);
                                        }
                                    }
                                    Text {
                                        text: Math.round(root.input-volume * 100) + "%";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        min-width: 44px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Speaker output"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.output-volume;
                                        changed(val) => {
                                            root.output-volume = val;
                                            root.output-volume-changed(val);
                                        }
                                    }
                                    Text {
                                        text: Math.round(root.output-volume * 100) + "%";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        min-width: 44px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Noise suppression"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    Text {
                                        text: "Less";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.noise-suppression;
                                        changed(val) => {
                                            root.noise-suppression = val;
                                            root.noise-suppression-changed(val);
                                        }
                                    }
                                    Text {
                                        text: "More";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.noise-suppression < 0.2 ? "Off" :
                                          root.noise-suppression < 0.4 ? "Low" :
                                          root.noise-suppression < 0.6 ? "Medium" :
                                          root.noise-suppression < 0.8 ? "High" : "Max";
                                    color: root.noise-suppression < 0.2 ? VxTheme.text-muted : VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                            }

                            Divider {}

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "AI noise suppression";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: "Neural network removes background noise";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                VxToggle {
                                    checked: root.neural-noise-suppression;
                                    toggled => { root.toggle-neural-noise-suppression(); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "Echo cancellation";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: "Reduces speaker audio picked up by your mic";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                VxToggle {
                                    checked: root.echo-cancellation;
                                    toggled => { root.toggle-echo-cancellation(); }
                                }
                            }

                            Divider {}

                            SectionLabel { text: "PROCESSING PIPELINE"; }
                            Text {
                                text: "What Voxlink applies to your audio, in order. Read-only.";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                            }
                            // Each row: status dot + name + detail
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: VxTheme.success; }
                                Text { text: "High-pass filter"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "80 Hz cutoff"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: root.noise-suppression >= 0.2 ? VxTheme.success : VxTheme.text-muted; }
                                Text { text: "Noise gate"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: root.noise-suppression < 0.2 ? "Off" : "Threshold: " + root.audio-noise-gate-threshold; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: VxTheme.success; }
                                Text { text: "AGC"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Target: -18 dB"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: VxTheme.success; }
                                Text { text: "De-esser"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: "Active"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: root.neural-noise-suppression ? VxTheme.success : VxTheme.text-muted; }
                                Text { text: "Neural denoise"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: root.neural-noise-suppression ? "On" : "Off"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: root.echo-cancellation ? VxTheme.success : VxTheme.text-muted; }
                                Text { text: "Echo cancellation"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: root.echo-cancellation ? "On" : "Off"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Rectangle { width: 8px; height: 8px; border-radius: 4px; background: VxTheme.success; }
                                Text { text: "Opus encode"; color: VxTheme.text-primary; font-size: 10px; font-weight: 600; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: root.audio-opus-bitrate; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: root.side-column-width;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "OUTPUT CHECK"; }

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: center;

                                VxGlyphTile {
                                    glyph: "SP";
                                    tone: root.speaker-test-active ? VxTheme.success : VxTheme.accent;
                                    tile-size: 30px;
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: root.speaker-test-active
                                            ? "Playing a short tone"
                                            : "Play a local speaker test";
                                        color: VxTheme.text-primary;
                                        font-size: 15px;
                                        font-weight: 700;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: root.output-devices.length > 0 ? root.output-devices[root.selected-output] : "No output route selected";
                                        color: root.output-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            Text {
                                text: root.speaker-test-active
                                    ? "Use the sample to confirm your selected route and output level before joining a room."
                                    : "This opens playback only long enough to hear a short preview tone. It does not join a call.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.speaker-test-active ? "Playing sample" : "Ready";
                                    tone: root.speaker-test-active ? VxTheme.success : VxTheme.accent;
                                    fill: root.speaker-test-active ? VxTheme.success-dim : VxTheme.accent-subtle;
                                }
                                VxStatusPill {
                                    label: root.output-devices.length > 0 ? "Output selected" : "No output";
                                    tone: root.output-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            VxButton {
                                label: root.speaker-test-active ? "Playing sample..." : "Play sample tone";
                                accent: !root.speaker-test-active;
                                soft: root.speaker-test-active;
                                enabled: root.output-devices.length > 0 && !root.speaker-test-active;
                                horizontal-stretch: 1;
                                clicked => { root.play-speaker-test(); }
                            }

                            if root.output-devices.length == 0 : Text {
                                text: "No speaker route is currently available.";
                                color: VxTheme.danger;
                                font-size: 10px;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "MIC CHECK"; }

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: center;

                                VxGlyphTile {
                                    glyph: "MC";
                                    tone: root.mic-preview-active ? VxTheme.success : VxTheme.accent;
                                    tile-size: 30px;
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: root.mic-preview-active
                                            ? "Listening on " + (root.input-devices.length > 0 ? root.input-devices[root.selected-input] : "your selected input")
                                            : "Start a local mic check";
                                        color: VxTheme.text-primary;
                                        font-size: 15px;
                                        font-weight: 700;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: root.input-devices.length > 0 ? "Capture stays local to settings." : "No microphone route selected";
                                        color: root.input-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            Text {
                                text: !root.mic-preview-active
                                    ? "This only opens capture while the settings panel is active. No call join, no background media session."
                                    : root.mic-level > 0.20 ? "Signal is running hot. Back off a little or lower mic gain." :
                                      root.mic-level > 0.06 ? "Signal looks healthy for normal speaking." :
                                      "Speak at your normal distance to verify the meter responds.";
                                color: root.mic-preview-active && root.mic-level > 0.20 ? VxTheme.warning : VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            Rectangle {
                                height: 10px;
                                border-radius: 5px;
                                background: VxTheme.bg-soft;

                                Rectangle {
                                    width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                                    height: parent.height;
                                    border-radius: 5px;
                                    background: !root.mic-preview-active ? VxTheme.text-muted :
                                                root.mic-level > 0.20 ? VxTheme.warning :
                                                root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                    animate width { duration: 40ms; }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.mic-preview-active ? "Live preview" : "Idle";
                                    tone: root.mic-preview-active ? VxTheme.success : VxTheme.text-secondary;
                                    fill: root.mic-preview-active ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: Math.round(clamp(root.mic-level * 500.0, 0.0, 100.0)) + "%";
                                    tone: root.mic-level > 0.20 ? VxTheme.warning :
                                          root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            VxButton {
                                label: root.mic-preview-active ? "Stop mic check" : "Start mic check";
                                accent: !root.mic-preview-active;
                                soft: root.mic-preview-active;
                                enabled: root.input-devices.length > 0;
                                horizontal-stretch: 1;
                                clicked => { root.toggle-mic-preview(); }
                            }

                            if root.input-devices.length == 0 : Text {
                                text: "No microphone route is currently available.";
                                color: VxTheme.danger;
                                font-size: 10px;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "VOICE MODE"; }
                            HorizontalLayout {
                                spacing: 10px;
                                alignment: center;

                                VxGlyphTile {
                                    glyph: "VM";
                                    tone: root.is-open-mic ? VxTheme.success : VxTheme.warning;
                                    tile-size: 30px;
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    alignment: center;
                                    spacing: 2px;
                                    Text {
                                        text: root.is-open-mic ? "Open mic is active." : "Push to talk is active.";
                                        color: VxTheme.text-primary;
                                        font-size: 15px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: root.is-open-mic ? "Natural flow for quieter rooms." : "Tighter transmit control when you need it.";
                                        color: VxTheme.text-secondary;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }

                                VxStatusPill {
                                    label: root.is-open-mic ? "Live" : "PTT";
                                    tone: root.is-open-mic ? VxTheme.success : VxTheme.warning;
                                    fill: root.is-open-mic ? VxTheme.success-dim : VxTheme.warning-soft;
                                }
                            }
                            Text {
                                text: root.is-open-mic
                                    ? "Use this when the room is quiet and you want a natural flow."
                                    : "Use this when you need tighter control over when you transmit.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            VxButton {
                                label: root.is-open-mic ? "Switch to push to talk" : "Switch to open mic";
                                accent: true;
                                horizontal-stretch: 1;
                                clicked => { root.toggle-mic-mode(); }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "ALERTS"; }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Join, leave, mute, and deafen sounds";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.feedback-sound;
                                    toggled => { root.toggle-feedback-sound(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Desktop notifications for messages and joins";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                                VxToggle {
                                    checked: root.notifications-enabled;
                                    toggled => { root.toggle-notifications(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Minimize to system tray on close";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.minimize-to-tray;
                                    toggled => { root.toggle-minimize-to-tray(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Join and leave notification sounds";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.join-leave-sounds;
                                    toggled => { root.toggle-join-leave-sounds(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "OS desktop notifications";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: "Show system notifications for mentions and DMs when unfocused";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                                VxToggle {
                                    checked: root.desktop-notifications;
                                    toggled => { root.toggle-desktop-notifications(); }
                                }
                            }

                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Notification sound style";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    for item[idx] in [
                                        { label: "Default" },
                                        { label: "Subtle" },
                                        { label: "Chime" },
                                        { label: "None" },
                                    ] : Rectangle {
                                        horizontal-stretch: 1;
                                        height: 30px;
                                        border-radius: VxTheme.radius-control;
                                        background: root.notification-sound-index == idx ? VxTheme.accent.transparentize(0.85) :
                                                    ns-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                        border-color: root.notification-sound-index == idx ? VxTheme.accent.transparentize(0.5) : VxTheme.border-subtle;
                                        border-width: 1px;

                                        ns-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.set-notification-sound(idx); }
                                        }

                                        Text {
                                            text: item.label;
                                            color: root.notification-sound-index == idx ? VxTheme.accent : VxTheme.text-secondary;
                                            font-size: 10px;
                                            font-weight: root.notification-sound-index == idx ? 700 : 500;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "CHAT"; }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Compact chat density";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.compact-chat;
                                    toggled => { root.toggle-compact-chat(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Show spoiler text by default";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.show-spoilers;
                                    toggled => { root.toggle-show-spoilers(); }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            SectionLabel { text: "PRIVACY"; }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: center;
                                Text {
                                    text: "Streamer mode";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.streamer-mode;
                                    toggled => { root.toggle-streamer-mode(); }
                                }
                            }
                            Text {
                                text: "Hides server IPs, invite codes, room codes, and email from the UI.";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "STATUS"; }
                            Text {
                                text: "Set your presence so others know your availability.";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                VxButton {
                                    label: "Online";
                                    small: true;
                                    accent: root.status-preset == 0;
                                    soft: root.status-preset != 0;
                                    clicked => { root.set-status-preset(0); }
                                }
                                VxButton {
                                    label: "Idle";
                                    small: true;
                                    accent: root.status-preset == 1;
                                    soft: root.status-preset != 1;
                                    clicked => { root.set-status-preset(1); }
                                }
                                VxButton {
                                    label: "DND";
                                    small: true;
                                    accent: root.status-preset == 2;
                                    soft: root.status-preset != 2;
                                    clicked => { root.set-status-preset(2); }
                                }
                                VxButton {
                                    label: "Invisible";
                                    small: true;
                                    accent: root.status-preset == 3;
                                    soft: root.status-preset != 3;
                                    clicked => { root.set-status-preset(3); }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Auto-idle timeout";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: root.idle-timeout-mins == 0
                                        ? "Disabled — status will not change automatically."
                                        : "Switch to idle after " + root.idle-timeout-mins + " minutes of inactivity.";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    for item[idx] in [
                                        { label: "Off", mins: 0 },
                                        { label: "2m", mins: 2 },
                                        { label: "5m", mins: 5 },
                                        { label: "10m", mins: 10 },
                                        { label: "30m", mins: 30 },
                                    ] : Rectangle {
                                        horizontal-stretch: 1;
                                        height: 30px;
                                        border-radius: VxTheme.radius-control;
                                        background: root.idle-timeout-mins == item.mins ? VxTheme.accent.transparentize(0.85) :
                                                    idle-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                        border-color: root.idle-timeout-mins == item.mins ? VxTheme.accent.transparentize(0.5) : VxTheme.border-subtle;
                                        border-width: 1px;

                                        idle-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.set-idle-timeout(item.mins); }
                                        }

                                        Text {
                                            text: item.label;
                                            color: root.idle-timeout-mins == item.mins ? VxTheme.accent : VxTheme.text-secondary;
                                            font-size: 10px;
                                            font-weight: root.idle-timeout-mins == item.mins ? 700 : 500;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "KEYBINDS"; }
                            if root.listening-keybind != "" : Text {
                                text: "Press a key combination now, or click Cancel to abort.";
                                color: VxTheme.accent;
                                font-size: 10px;
                                font-weight: 600;
                            }
                            if root.listening-keybind == "" : Text {
                                text: "Click Set to assign a keybind, then press your key combo.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Push to talk"; horizontal-stretch: 1; }
                                if root.listening-keybind == "ptt" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "ptt" : KeyPill {
                                    key-text: root.ptt-key-display != "" ? root.ptt-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "ptt" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "ptt" ? "" : "ptt"; }
                                }
                                if root.ptt-key-display != "" && root.listening-keybind != "ptt" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("ptt"); }
                                }
                            }
                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Toggle mute"; horizontal-stretch: 1; }
                                if root.listening-keybind == "mute" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "mute" : KeyPill {
                                    key-text: root.mute-key-display != "" ? root.mute-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "mute" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "mute" ? "" : "mute"; }
                                }
                                if root.mute-key-display != "" && root.listening-keybind != "mute" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("mute"); }
                                }
                            }
                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Toggle deafen"; horizontal-stretch: 1; }
                                if root.listening-keybind == "deafen" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "deafen" : KeyPill {
                                    key-text: root.deafen-key-display != "" ? root.deafen-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "deafen" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "deafen" ? "" : "deafen"; }
                                }
                                if root.deafen-key-display != "" && root.listening-keybind != "deafen" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("deafen"); }
                                }
                            }

                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Quick back"; horizontal-stretch: 1; }
                                KeyPill { key-text: "Esc"; }
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 12px;

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "APPEARANCE"; }
                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                Text {
                                    text:
                                        root.theme-preset == 1 ? (root.dark-mode ? "360 party dark" : "360 party light") :
                                        root.theme-preset == 2 ? (root.dark-mode ? "Deep space dark" : "Deep space light") :
                                        root.theme-preset == 3 ? (root.dark-mode ? "Retro tech dark" : "Retro tech light") :
                                        root.theme-preset == 4 ? (root.dark-mode ? "Amber CRT dark" : "Amber CRT light") :
                                        root.theme-preset == 5 ? (root.dark-mode ? "Midnight noir dark" : "Midnight noir light") :
                                        root.theme-preset == 6 ? (root.dark-mode ? "Arctic glass dark" : "Arctic glass light") :
                                        root.dark-mode ? "Voxlink dark" : "Voxlink light";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: "Theme swaps are visual only and apply instantly.";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    wrap: word-wrap;
                                }
                            }
                            VxToggle {
                                checked: root.dark-mode;
                                toggled => { root.toggle-dark-mode(); }
                            }
                        }

                        Divider {}

                        VerticalLayout {
                            spacing: 6px;
                            HorizontalLayout {
                                spacing: 6px;
                                ThemePresetCard {
                                    label: "Voxlink";
                                    selected: root.theme-preset == 0;
                                    tone: #54d2ff;
                                    swatch-a: #54d2ff;
                                    swatch-b: #7ce5c8;
                                    swatch-c: #13202d;
                                    clicked => { root.select-theme-preset(0); }
                                }
                                ThemePresetCard {
                                    label: "360 Party";
                                    selected: root.theme-preset == 1;
                                    tone: #8be14f;
                                    swatch-a: #8be14f;
                                    swatch-b: #f3c65d;
                                    swatch-c: #192715;
                                    clicked => { root.select-theme-preset(1); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ThemePresetCard {
                                    label: "Deep Space";
                                    selected: root.theme-preset == 2;
                                    tone: #6cc9ff;
                                    swatch-a: #6cc9ff;
                                    swatch-b: #bb8cff;
                                    swatch-c: #141c3a;
                                    clicked => { root.select-theme-preset(2); }
                                }
                                ThemePresetCard {
                                    label: "Retro Tech";
                                    selected: root.theme-preset == 3;
                                    tone: #5cf3a6;
                                    swatch-a: #5cf3a6;
                                    swatch-b: #ffca5c;
                                    swatch-c: #111d18;
                                    clicked => { root.select-theme-preset(3); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ThemePresetCard {
                                    label: "Amber CRT";
                                    selected: root.theme-preset == 4;
                                    tone: #ffbe4f;
                                    swatch-a: #ffbe4f;
                                    swatch-b: #fff0b2;
                                    swatch-c: #291c0f;
                                    clicked => { root.select-theme-preset(4); }
                                }
                                ThemePresetCard {
                                    label: "Noir";
                                    selected: root.theme-preset == 5;
                                    tone: #90a8ff;
                                    swatch-a: #90a8ff;
                                    swatch-b: #cfd8f4;
                                    swatch-c: #151921;
                                    clicked => { root.select-theme-preset(5); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                ThemePresetCard {
                                    label: "Arctic Glass";
                                    selected: root.theme-preset == 6;
                                    tone: #5fdaf4;
                                    swatch-a: #5fdaf4;
                                    swatch-b: #c8f6ff;
                                    swatch-c: #13292f;
                                    clicked => { root.select-theme-preset(6); }
                                }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "DEVICE ROUTING"; }
                            VxButton {
                                label: "Refresh";
                                small: true;
                                ghost: true;
                                clicked => { root.refresh-devices(); }
                            }
                        }
                        if root.input-devices.length > 0 : VerticalLayout {
                            spacing: 8px;
                            FieldLabel { text: "Input"; }
                            for device[idx] in root.input-devices : VxOptionRow {
                                label: device;
                                detail: idx == root.selected-input ? "Current capture route" : "";
                                selected: idx == root.selected-input;
                                clicked => { root.selected-input = idx; }
                            }
                        }
                        if root.output-devices.length > 0 : VerticalLayout {
                            spacing: 8px;
                            FieldLabel { text: "Output"; }
                            for device[idx] in root.output-devices : VxOptionRow {
                                label: device;
                                detail: idx == root.selected-output ? "Current playback route" : "";
                                selected: idx == root.selected-output;
                                clicked => { root.selected-output = idx; }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "OUTPUT CHECK"; }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;
                            VxGlyphTile {
                                glyph: "SP";
                                tone: root.speaker-test-active ? VxTheme.success : VxTheme.accent;
                                tile-size: 28px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: root.speaker-test-active ? "Playing a local sample." : "Play a local speaker test.";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: root.output-devices.length > 0 ? "Confirms the selected route before a call." : "Choose an output route first.";
                                    color: root.output-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        Text {
                            text: root.output-devices.length > 0
                                ? "Confirms the selected speaker route without joining a call."
                                : "Choose an output route to test playback.";
                            color: root.output-devices.length > 0 ? VxTheme.text-muted : VxTheme.danger;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        VxButton {
                            label: root.speaker-test-active ? "Playing sample..." : "Play sample tone";
                            accent: !root.speaker-test-active;
                            soft: root.speaker-test-active;
                            enabled: root.output-devices.length > 0 && !root.speaker-test-active;
                            horizontal-stretch: 1;
                            clicked => { root.play-speaker-test(); }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "MIC CHECK"; }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;
                            VxGlyphTile {
                                glyph: "MC";
                                tone: root.mic-preview-active ? VxTheme.success : VxTheme.accent;
                                tile-size: 28px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: root.mic-preview-active ? "Mic check is live." : "Start a local mic check.";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: root.input-devices.length > 0 ? "Capture stays local to settings." : "Choose an input route first.";
                                    color: root.input-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        Rectangle {
                            height: 10px;
                            border-radius: 5px;
                            background: VxTheme.bg-soft;

                            Rectangle {
                                width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                                height: parent.height;
                                border-radius: 5px;
                                background: !root.mic-preview-active ? VxTheme.text-muted :
                                            root.mic-level > 0.20 ? VxTheme.warning :
                                            root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                animate width { duration: 40ms; }
                            }
                        }
                        VxButton {
                            label: root.mic-preview-active ? "Stop mic check" : "Start mic check";
                            accent: !root.mic-preview-active;
                            soft: root.mic-preview-active;
                            enabled: root.input-devices.length > 0;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-mic-preview(); }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "VOICE MODE"; }
                        HorizontalLayout {
                            spacing: 10px;
                            alignment: center;
                            VxGlyphTile {
                                glyph: "VM";
                                tone: root.is-open-mic ? VxTheme.success : VxTheme.warning;
                                tile-size: 28px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: root.is-open-mic ? "Open mic is active." : "Push to talk is active.";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: root.is-open-mic ? "Natural flow for quieter rooms." : "Tighter transmit control when needed.";
                                    color: VxTheme.text-secondary;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        VxButton {
                            label: root.is-open-mic ? "Switch to push to talk" : "Switch to open mic";
                            accent: true;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-mic-mode(); }
                        }
                    }
                }
            }

            // ACCOUNT
            VxCard {
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    SectionLabel { text: "ACCOUNT"; }

                    if root.is-logged-in : VerticalLayout {
                        spacing: 10px;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Rectangle {
                                width: 32px;
                                height: 32px;
                                border-radius: 16px;
                                background: VxTheme.accent;
                                Text {
                                    text: "VX";
                                    color: VxTheme.text-inverse;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: root.streamer-mode ? "****@****.***" : root.account-email;
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "Signed in";
                                    color: VxTheme.success;
                                    font-size: 10px;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxButton {
                                label: "Sign out";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.logout(); }
                            }
                            VxButton {
                                label: "Revoke all sessions";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.revoke-all-sessions(); }
                            }
                        }
                        Divider { }
                        // Change display name
                        FieldLabel { text: "Display Name"; }
                        HorizontalLayout {
                            spacing: 6px;
                            VxInput {
                                horizontal-stretch: 1;
                                text <=> root.acct-new-name;
                                placeholder: "New display name";
                            }
                            VxButton {
                                label: "Save";
                                accent: true;
                                clicked => {
                                    if root.acct-new-name != "" {
                                        root.change-display-name(root.acct-new-name);
                                        root.acct-new-name = "";
                                    }
                                }
                            }
                        }
                        // Change password
                        FieldLabel { text: "Change Password"; }
                        HorizontalLayout {
                            spacing: 6px;
                            VxInput {
                                horizontal-stretch: 1;
                                text <=> root.acct-old-pw;
                                placeholder: "Current password";
                            }
                            VxInput {
                                horizontal-stretch: 1;
                                text <=> root.acct-new-pw;
                                placeholder: "New password";
                            }
                            VxButton {
                                label: "Change";
                                accent: true;
                                clicked => {
                                    if root.acct-old-pw != "" && root.acct-new-pw != "" {
                                        root.change-password(root.acct-old-pw, root.acct-new-pw);
                                        root.acct-old-pw = "";
                                        root.acct-new-pw = "";
                                    }
                                }
                            }
                        }
                        Divider { }
                        // Delete account
                        FieldLabel { text: "Danger Zone"; }
                        Text {
                            text: "Type DELETE to confirm account deletion.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            VxInput {
                                horizontal-stretch: 1;
                                text <=> root.acct-delete-confirm;
                                placeholder: "Type DELETE";
                            }
                            VxButton {
                                label: "Delete Account";
                                soft: true;
                                enabled: root.acct-delete-confirm == "DELETE";
                                clicked => {
                                    root.delete-account();
                                    root.acct-delete-confirm = "";
                                }
                            }
                        }
                    }

                    if !root.is-logged-in : VerticalLayout {
                        spacing: 10px;
                        Text {
                            text: "Sign in or create an account to sync your identity across devices.";
                            color: VxTheme.text-muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        VxButton {
                            label: "Sign in / Register";
                            accent: true;
                            horizontal-stretch: 1;
                            clicked => { root.show-login(); }
                        }
                    }
                }
            }

            // ─── Soundboard ───
            VxCard {
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    SectionLabel { text: "SOUNDBOARD"; }

                    if root.soundboard-clips.length == 0 : Text {
                        text: "No clips loaded. Add WAV files to play into voice chat.";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        wrap: word-wrap;
                    }

                    for clip[idx] in root.soundboard-clips : Rectangle {
                        height: 36px;
                        border-radius: VxTheme.radius-control;
                        background: clip-row-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                        border-color: VxTheme.border-subtle;
                        border-width: 1px;

                        clip-row-touch := TouchArea {}

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 6px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: clip.name;
                                color: VxTheme.text-primary;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-stretch: 1;
                                overflow: elide;
                                vertical-alignment: center;
                            }

                            if clip.keybind != "" : KeyPill {
                                key-text: clip.keybind;
                            }

                            VxButton {
                                label: "Play";
                                small: true;
                                soft: true;
                                clicked => { root.play-soundboard-clip(idx); }
                            }

                            VxButton {
                                label: "X";
                                small: true;
                                danger: true;
                                clicked => { root.remove-soundboard-clip(idx); }
                            }
                        }
                    }

                    if root.soundboard-clips.length < 16 : VerticalLayout {
                        spacing: 6px;
                        Text { text: "ADD CLIP"; color: VxTheme.text-muted; font-size: 9px; font-weight: 700; }
                        HorizontalLayout {
                            spacing: 6px;
                            VxInput {
                                text <=> root.new-clip-name;
                                placeholder: "Clip name";
                                horizontal-stretch: 1;
                            }
                            VxInput {
                                text <=> root.new-clip-keybind;
                                placeholder: "Keybind (e.g. f5)";
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            VxInput {
                                text <=> root.new-clip-path;
                                placeholder: "Path to .wav file";
                                horizontal-stretch: 1;
                                accepted => {
                                    if root.new-clip-name != "" && root.new-clip-path != "" {
                                        root.add-soundboard-clip(root.new-clip-name, root.new-clip-path, root.new-clip-keybind);
                                        root.new-clip-name = "";
                                        root.new-clip-path = "";
                                        root.new-clip-keybind = "";
                                    }
                                }
                            }
                            VxButton {
                                label: "Add";
                                small: true;
                                accent: true;
                                enabled: root.new-clip-name != "" && root.new-clip-path != "";
                                clicked => {
                                    root.add-soundboard-clip(root.new-clip-name, root.new-clip-path, root.new-clip-keybind);
                                    root.new-clip-name = "";
                                    root.new-clip-path = "";
                                    root.new-clip-keybind = "";
                                }
                            }
                        }
                        Text {
                            text: "48kHz mono WAV recommended. Max 16 clips, 5s each.";
                            color: VxTheme.text-muted;
                            font-size: 9px;
                        }
                    }
                }
            }

            // ─── Privacy Dashboard ───
            VxCard {
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    SectionLabel { text: "PRIVACY DASHBOARD"; }
                    Text {
                        text: "Voxlink is transparent about what data it stores and where.";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        wrap: word-wrap;
                    }

                    // Local data
                    FieldLabel { text: "Data stored locally"; }
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Config:"; color: VxTheme.text-secondary; font-size: 10px; font-weight: 600; }
                            Text {
                                text: root.privacy-config-path != "" ? root.privacy-config-path + "/config.json" : "(unknown)";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: "Log:"; color: VxTheme.text-secondary; font-size: 10px; font-weight: 600; }
                            Text {
                                text: root.privacy-config-path != "" ? root.privacy-config-path + "/voxlink.log" : "(unknown)";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                    }

                    Divider {}

                    // Server data
                    FieldLabel { text: "Data stored on server"; }
                    VerticalLayout {
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 6px;
                            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: VxTheme.accent; }
                            Text { text: "Account: email, display name, hashed password"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: VxTheme.accent; }
                            Text { text: "Messages: text messages in spaces you belong to"; color: VxTheme.text-muted; font-size: 10px; vertical-alignment: center; }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: VxTheme.success; }
                            Text { text: "No voice data is ever recorded or stored"; color: VxTheme.success; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: VxTheme.success; }
                            Text { text: "No telemetry or analytics collected"; color: VxTheme.success; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                        }
                    }

                    Divider {}

                    // Actions
                    HorizontalLayout {
                        spacing: 8px;
                        VxButton {
                            label: "Clear Local Data";
                            soft: true;
                            horizontal-stretch: 1;
                            clicked => { root.clear-local-data(); }
                        }
                        VxButton {
                            label: "Export My Data";
                            soft: true;
                            horizontal-stretch: 1;
                            clicked => { root.export-my-data(); }
                        }
                    }
                    Text {
                        text: "Clear resets config to defaults (keeps your login). Export copies config JSON to clipboard.";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        wrap: word-wrap;
                    }
                    if root.is-logged-in : Text {
                        text: "To delete your server account, use the Delete Account option above.";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        wrap: word-wrap;
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                spacing: 8px;
                Rectangle {
                    width: 6px;
                    height: 6px;
                    border-radius: 3px;
                    background: VxTheme.success;
                }
                Text {
                    text: "Settings save automatically";
                    color: VxTheme.text-muted;
                    font-size: 10px;
                }
            }

            VxButton {
                label: "About Voxlink";
                ghost: true;
                clicked => { root.show-about(); }
            }
        }
    }
}
