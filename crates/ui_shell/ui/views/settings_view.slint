import { ScrollView } from "std-widgets.slint";
import { VxTheme } from "../theme.slint";
import { Divider, FieldLabel, KeyPill, SectionLabel, VxButton, VxCard, VxOptionRow, VxSlider, VxStatBlock, VxStatusPill, VxToggle } from "../components.slint";

component ThemePresetCard inherits Rectangle {
    in property <string> label: "";
    in property <string> detail: "";
    in property <bool> selected: false;
    in property <color> tone: VxTheme.accent;
    in property <color> swatch-a: VxTheme.accent;
    in property <color> swatch-b: VxTheme.accent-warm;
    in property <color> swatch-c: VxTheme.bg-raised;
    callback clicked();

    border-radius: VxTheme.radius-card;
    background: root.selected ? root.tone.transparentize(0.88) :
                touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
    border-color: root.selected ? root.tone.transparentize(0.42) : VxTheme.border-subtle;
    border-width: 1px;
    clip: true;

    animate background { duration: 90ms; easing: ease-out; }
    animate border-color { duration: 90ms; easing: ease-out; }

    Rectangle {
        width: parent.width;
        height: 2px;
        background: root.selected ? root.tone : VxTheme.accent-subtle;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 6px;
            Rectangle {
                width: 24px;
                height: 8px;
                border-radius: 4px;
                background: root.swatch-a;
            }
            Rectangle {
                width: 24px;
                height: 8px;
                border-radius: 4px;
                background: root.swatch-b;
            }
            Rectangle {
                width: 24px;
                height: 8px;
                border-radius: 4px;
                background: root.swatch-c;
            }
        }

        Text {
            text: root.label;
            color: root.selected ? root.tone : VxTheme.text-primary;
            font-size: 12px;
            font-weight: 700;
        }

        Text {
            text: root.detail;
            color: VxTheme.text-muted;
            font-size: 9px;
            wrap: word-wrap;
        }

        if root.selected : VxStatusPill {
            label: "Active";
            tone: root.tone;
            fill: root.tone.transparentize(0.84);
        }
    }
}

export component SettingsView inherits Rectangle {
    in property <bool> wide: false;
    in property <int> previous-view: 0;
    in property <bool> dark-mode: true;
    in property <int> theme-preset: 0;
    in property <[string]> input-devices: [];
    in property <[string]> output-devices: [];
    in-out property <int> selected-input: 0;
    in-out property <int> selected-output: 0;
    in-out property <float> input-volume: 1.0;
    in-out property <float> output-volume: 1.0;
    in property <bool> is-open-mic: true;
    in property <float> mic-level: 0.0;
    in-out property <bool> mic-preview-active: false;
    in-out property <bool> speaker-test-active: false;
    in-out property <float> noise-suppression: 0.5;
    in property <bool> feedback-sound: true;
    in property <bool> notifications-enabled: true;
    in property <bool> minimize-to-tray: true;
    in property <bool> neural-noise-suppression: false;
    in property <bool> echo-cancellation: false;
    in property <bool> join-leave-sounds: true;
    in property <bool> show-spoilers: false;
    in property <bool> compact-chat: false;
    in-out property <string> listening-keybind: "";
    in property <string> ptt-key-display: "";
    in property <string> mute-key-display: "";
    in property <string> deafen-key-display: "";
    callback navigate(int);
    callback toggle-dark-mode();
    callback select-theme-preset(int);
    callback refresh-devices();
    callback input-volume-changed(float);
    callback output-volume-changed(float);
    callback toggle-mic-preview();
    callback play-speaker-test();
    callback toggle-mic-mode();
    callback noise-suppression-changed(float);
    callback toggle-feedback-sound();
    callback toggle-notifications();
    callback toggle-minimize-to-tray();
    callback toggle-neural-noise-suppression();
    callback toggle-echo-cancellation();
    callback toggle-join-leave-sounds();
    callback toggle-show-spoilers();
    callback toggle-compact-chat();
    callback clear-keybind(string);
    // Account
    in property <bool> is-logged-in: false;
    in property <string> account-email: "";
    callback logout();
    callback show-login();
    callback revoke-all-sessions();

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: root.wide ? 16px : 12px;
            spacing: 12px;

            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "Audio and preferences";
                    color: VxTheme.text-primary;
                    font-size: 22px;
                    font-weight: 700;
                }
                if root.previous-view == 1 : VxButton {
                    label: "Back to call";
                    soft: true;
                    clicked => { root.navigate(root.previous-view); }
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 12px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "APPEARANCE"; }
                            HorizontalLayout {
                                spacing: 12px;
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text:
                                            root.theme-preset == 1 ? (root.dark-mode ? "360 party dark" : "360 party light") :
                                            root.theme-preset == 2 ? (root.dark-mode ? "Deep space dark" : "Deep space light") :
                                            root.theme-preset == 3 ? (root.dark-mode ? "Retro tech dark" : "Retro tech light") :
                                            root.theme-preset == 4 ? (root.dark-mode ? "Amber CRT dark" : "Amber CRT light") :
                                            root.theme-preset == 5 ? (root.dark-mode ? "Midnight noir dark" : "Midnight noir light") :
                                            root.theme-preset == 6 ? (root.dark-mode ? "Arctic glass dark" : "Arctic glass light") :
                                            root.dark-mode ? "Voxlink dark" : "Voxlink light";
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text:
                                            root.theme-preset == 1 ? "Retro console party energy with green glass surfaces and warm highlights." :
                                            root.theme-preset == 2 ? "A colder orbital palette with blue-black surfaces and neon trim." :
                                            root.theme-preset == 3 ? "Retro control-room styling with phosphor green and amber accents." :
                                            root.theme-preset == 4 ? "Warm amber phosphor styling with CRT-era contrast and sepia depth." :
                                            root.theme-preset == 5 ? "A stripped-back noir shell with ink-dark surfaces and cold blue trim." :
                                            root.theme-preset == 6 ? "Frosted cyan glass with brighter surfaces and cleaner contrast." :
                                            "The default premium shell. Theme changes apply instantly without touching the audio pipeline.";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                                VxToggle {
                                    checked: root.dark-mode;
                                    toggled => { root.toggle-dark-mode(); }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 10px;
                                FieldLabel { text: "Theme preset"; }

                                HorizontalLayout {
                                    spacing: 10px;
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Voxlink";
                                        detail: "Default premium broadcast shell.";
                                        selected: root.theme-preset == 0;
                                        tone: #54d2ff;
                                        swatch-a: #54d2ff;
                                        swatch-b: #7ce5c8;
                                        swatch-c: #13202d;
                                        clicked => { root.select-theme-preset(0); }
                                    }
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "360 Party";
                                        detail: "Green-room glow with retro console energy.";
                                        selected: root.theme-preset == 1;
                                        tone: #8be14f;
                                        swatch-a: #8be14f;
                                        swatch-b: #f3c65d;
                                        swatch-c: #192715;
                                        clicked => { root.select-theme-preset(1); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Deep Space";
                                        detail: "Orbital blues, violet trims, calmer contrast.";
                                        selected: root.theme-preset == 2;
                                        tone: #6cc9ff;
                                        swatch-a: #6cc9ff;
                                        swatch-b: #bb8cff;
                                        swatch-c: #141c3a;
                                        clicked => { root.select-theme-preset(2); }
                                    }
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Retro Tech";
                                        detail: "Old-school control console with phosphor edges.";
                                        selected: root.theme-preset == 3;
                                        tone: #5cf3a6;
                                        swatch-a: #5cf3a6;
                                        swatch-b: #ffca5c;
                                        swatch-c: #111d18;
                                        clicked => { root.select-theme-preset(3); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Amber CRT";
                                        detail: "Warm phosphor amber with old-school monitor depth.";
                                        selected: root.theme-preset == 4;
                                        tone: #ffbe4f;
                                        swatch-a: #ffbe4f;
                                        swatch-b: #fff0b2;
                                        swatch-c: #291c0f;
                                        clicked => { root.select-theme-preset(4); }
                                    }
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Midnight Noir";
                                        detail: "Minimal graphite shell with cool blue edge lighting.";
                                        selected: root.theme-preset == 5;
                                        tone: #90a8ff;
                                        swatch-a: #90a8ff;
                                        swatch-b: #cfd8f4;
                                        swatch-c: #151921;
                                        clicked => { root.select-theme-preset(5); }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    ThemePresetCard {
                                        horizontal-stretch: 1;
                                        label: "Arctic Glass";
                                        detail: "Frosted cyan surfaces with airy contrast and clean edges.";
                                        selected: root.theme-preset == 6;
                                        tone: #5fdaf4;
                                        swatch-a: #5fdaf4;
                                        swatch-b: #c8f6ff;
                                        swatch-c: #13292f;
                                        clicked => { root.select-theme-preset(6); }
                                    }
                                    Rectangle {
                                        horizontal-stretch: 1;
                                        background: transparent;
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;

                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "DEVICE ROUTING"; }
                                VxButton {
                                    label: "Refresh";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.refresh-devices(); }
                                }
                            }

                            if root.input-devices.length > 0 || root.output-devices.length > 0 : HorizontalLayout {
                                spacing: 10px;
                                if root.input-devices.length > 0 : VxStatBlock {
                                    horizontal-stretch: 1;
                                    label: "Selected input";
                                    value: root.input-devices[root.selected-input];
                                    detail: "Mic route used for capture.";
                                    tone: VxTheme.accent;
                                }
                                if root.output-devices.length > 0 : VxStatBlock {
                                    horizontal-stretch: 1;
                                    label: "Selected output";
                                    value: root.output-devices[root.selected-output];
                                    detail: "Speaker route used for playback.";
                                    tone: VxTheme.success;
                                }
                            }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Input device"; }
                                if root.input-devices.length > 0 : VerticalLayout {
                                    spacing: 8px;
                                    for device[idx] in root.input-devices : VxOptionRow {
                                        label: device;
                                        detail: idx == root.selected-input ? "Current capture route" : "Tap to switch capture route";
                                        selected: idx == root.selected-input;
                                        clicked => { root.selected-input = idx; }
                                    }
                                }
                                if root.input-devices.length == 0 : Text {
                                    text: "No microphones found";
                                    color: VxTheme.danger;
                                    font-size: 10px;
                                }
                            }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Output device"; }
                                if root.output-devices.length > 0 : VerticalLayout {
                                    spacing: 8px;
                                    for device[idx] in root.output-devices : VxOptionRow {
                                        label: device;
                                        detail: idx == root.selected-output ? "Current playback route" : "Tap to switch playback route";
                                        selected: idx == root.selected-output;
                                        clicked => { root.selected-output = idx; }
                                    }
                                }
                                if root.output-devices.length == 0 : Text {
                                    text: "No speakers found";
                                    color: VxTheme.danger;
                                    font-size: 10px;
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "LEVELS"; }

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Mic gain"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.input-volume / 2.0;
                                        changed(val) => {
                                            root.input-volume = val * 2.0;
                                            root.input-volume-changed(root.input-volume);
                                        }
                                    }
                                    Text {
                                        text: Math.round(root.input-volume * 100) + "%";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        min-width: 44px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Speaker output"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.output-volume;
                                        changed(val) => {
                                            root.output-volume = val;
                                            root.output-volume-changed(val);
                                        }
                                    }
                                    Text {
                                        text: Math.round(root.output-volume * 100) + "%";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        min-width: 44px;
                                        horizontal-alignment: right;
                                    }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Noise suppression"; }
                                HorizontalLayout {
                                    spacing: 10px;
                                    Text {
                                        text: "Less";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                    VxSlider {
                                        horizontal-stretch: 1;
                                        value: root.noise-suppression;
                                        changed(val) => {
                                            root.noise-suppression = val;
                                            root.noise-suppression-changed(val);
                                        }
                                    }
                                    Text {
                                        text: "More";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: root.noise-suppression < 0.2 ? "Off" :
                                          root.noise-suppression < 0.4 ? "Low" :
                                          root.noise-suppression < 0.6 ? "Medium" :
                                          root.noise-suppression < 0.8 ? "High" : "Max";
                                    color: root.noise-suppression < 0.2 ? VxTheme.text-muted : VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                            }

                            Divider {}

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "AI noise suppression";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: "Neural network removes background noise";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                VxToggle {
                                    checked: root.neural-noise-suppression;
                                    toggled => { root.toggle-neural-noise-suppression(); }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "Echo cancellation";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: "Reduces speaker audio picked up by your mic";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                VxToggle {
                                    checked: root.echo-cancellation;
                                    toggled => { root.toggle-echo-cancellation(); }
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: 320px;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "OUTPUT CHECK"; }

                            Text {
                                text: root.speaker-test-active
                                    ? "Playing a short tone on " + (root.output-devices.length > 0 ? root.output-devices[root.selected-output] : "your selected output")
                                    : "Play a local speaker test";
                                color: VxTheme.text-primary;
                                font-size: 15px;
                                font-weight: 700;
                                wrap: word-wrap;
                            }

                            Text {
                                text: root.speaker-test-active
                                    ? "Use the sample to confirm your selected route and output level before joining a room."
                                    : "This opens playback only long enough to hear a short preview tone. It does not join a call.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.speaker-test-active ? "Playing sample" : "Ready";
                                    tone: root.speaker-test-active ? VxTheme.success : VxTheme.accent;
                                    fill: root.speaker-test-active ? VxTheme.success-dim : VxTheme.accent-subtle;
                                }
                                VxStatusPill {
                                    label: root.output-devices.length > 0 ? "Output selected" : "No output";
                                    tone: root.output-devices.length > 0 ? VxTheme.text-secondary : VxTheme.danger;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            VxButton {
                                label: root.speaker-test-active ? "Playing sample..." : "Play sample tone";
                                accent: !root.speaker-test-active;
                                soft: root.speaker-test-active;
                                enabled: root.output-devices.length > 0 && !root.speaker-test-active;
                                horizontal-stretch: 1;
                                clicked => { root.play-speaker-test(); }
                            }

                            if root.output-devices.length == 0 : Text {
                                text: "No speaker route is currently available.";
                                color: VxTheme.danger;
                                font-size: 10px;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "MIC CHECK"; }

                            Text {
                                text: root.mic-preview-active
                                    ? "Listening on " + (root.input-devices.length > 0 ? root.input-devices[root.selected-input] : "your selected input")
                                    : "Start a local mic check";
                                color: VxTheme.text-primary;
                                font-size: 15px;
                                font-weight: 700;
                                wrap: word-wrap;
                            }

                            Text {
                                text: !root.mic-preview-active
                                    ? "This only opens capture while the settings panel is active. No call join, no background media session."
                                    : root.mic-level > 0.20 ? "Signal is running hot. Back off a little or lower mic gain." :
                                      root.mic-level > 0.06 ? "Signal looks healthy for normal speaking." :
                                      "Speak at your normal distance to verify the meter responds.";
                                color: root.mic-preview-active && root.mic-level > 0.20 ? VxTheme.warning : VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            Rectangle {
                                height: 10px;
                                border-radius: 5px;
                                background: VxTheme.bg-soft;

                                Rectangle {
                                    width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                                    height: parent.height;
                                    border-radius: 5px;
                                    background: !root.mic-preview-active ? VxTheme.text-muted :
                                                root.mic-level > 0.20 ? VxTheme.warning :
                                                root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                    animate width { duration: 40ms; }
                                }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: root.mic-preview-active ? "Live preview" : "Idle";
                                    tone: root.mic-preview-active ? VxTheme.success : VxTheme.text-secondary;
                                    fill: root.mic-preview-active ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                                VxStatusPill {
                                    label: Math.round(clamp(root.mic-level * 500.0, 0.0, 100.0)) + "%";
                                    tone: root.mic-level > 0.20 ? VxTheme.warning :
                                          root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            VxButton {
                                label: root.mic-preview-active ? "Stop mic check" : "Start mic check";
                                accent: !root.mic-preview-active;
                                soft: root.mic-preview-active;
                                enabled: root.input-devices.length > 0;
                                horizontal-stretch: 1;
                                clicked => { root.toggle-mic-preview(); }
                            }

                            if root.input-devices.length == 0 : Text {
                                text: "No microphone route is currently available.";
                                color: VxTheme.danger;
                                font-size: 10px;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            SectionLabel { text: "VOICE MODE"; }
                            Text {
                                text: root.is-open-mic ? "Open mic is active." : "Push to talk is active.";
                                color: VxTheme.text-primary;
                                font-size: 15px;
                                font-weight: 700;
                            }
                            Text {
                                text: root.is-open-mic
                                    ? "Use this when the room is quiet and you want a natural flow."
                                    : "Use this when you need tighter control over when you transmit.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            VxButton {
                                label: root.is-open-mic ? "Switch to push to talk" : "Switch to open mic";
                                accent: true;
                                horizontal-stretch: 1;
                                clicked => { root.toggle-mic-mode(); }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "ALERTS"; }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Join, leave, mute, and deafen sounds";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.feedback-sound;
                                    toggled => { root.toggle-feedback-sound(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Desktop notifications for messages and joins";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                                VxToggle {
                                    checked: root.notifications-enabled;
                                    toggled => { root.toggle-notifications(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Minimize to system tray on close";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.minimize-to-tray;
                                    toggled => { root.toggle-minimize-to-tray(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Join and leave notification sounds";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.join-leave-sounds;
                                    toggled => { root.toggle-join-leave-sounds(); }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "CHAT"; }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Compact chat density";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.compact-chat;
                                    toggled => { root.toggle-compact-chat(); }
                                }
                            }
                            HorizontalLayout {
                                spacing: 10px;
                                Text {
                                    text: "Show spoiler text by default";
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                }
                                VxToggle {
                                    checked: root.show-spoilers;
                                    toggled => { root.toggle-show-spoilers(); }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "KEYBINDS"; }
                            Text {
                                text: "Hold modifiers and a key to capture combinations.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Push to talk"; horizontal-stretch: 1; }
                                if root.listening-keybind == "ptt" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "ptt" : KeyPill {
                                    key-text: root.ptt-key-display != "" ? root.ptt-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "ptt" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "ptt" ? "" : "ptt"; }
                                }
                                if root.ptt-key-display != "" && root.listening-keybind != "ptt" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("ptt"); }
                                }
                            }
                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Toggle mute"; horizontal-stretch: 1; }
                                if root.listening-keybind == "mute" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "mute" : KeyPill {
                                    key-text: root.mute-key-display != "" ? root.mute-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "mute" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "mute" ? "" : "mute"; }
                                }
                                if root.mute-key-display != "" && root.listening-keybind != "mute" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("mute"); }
                                }
                            }
                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Toggle deafen"; horizontal-stretch: 1; }
                                if root.listening-keybind == "deafen" : Text {
                                    text: "Listening…";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                if root.listening-keybind != "deafen" : KeyPill {
                                    key-text: root.deafen-key-display != "" ? root.deafen-key-display : "None";
                                }
                                VxButton {
                                    label: root.listening-keybind == "deafen" ? "Cancel" : "Set";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.listening-keybind = root.listening-keybind == "deafen" ? "" : "deafen"; }
                                }
                                if root.deafen-key-display != "" && root.listening-keybind != "deafen" : VxButton {
                                    label: "Clear";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.clear-keybind("deafen"); }
                                }
                            }

                            Divider {}

                            HorizontalLayout {
                                spacing: 8px;
                                FieldLabel { text: "Quick back"; horizontal-stretch: 1; }
                                KeyPill { key-text: "Esc"; }
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 12px;

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "APPEARANCE"; }
                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                horizontal-stretch: 1;
                                Text {
                                    text:
                                        root.theme-preset == 1 ? (root.dark-mode ? "360 party dark" : "360 party light") :
                                        root.theme-preset == 2 ? (root.dark-mode ? "Deep space dark" : "Deep space light") :
                                        root.theme-preset == 3 ? (root.dark-mode ? "Retro tech dark" : "Retro tech light") :
                                        root.theme-preset == 4 ? (root.dark-mode ? "Amber CRT dark" : "Amber CRT light") :
                                        root.theme-preset == 5 ? (root.dark-mode ? "Midnight noir dark" : "Midnight noir light") :
                                        root.theme-preset == 6 ? (root.dark-mode ? "Arctic glass dark" : "Arctic glass light") :
                                        root.dark-mode ? "Voxlink dark" : "Voxlink light";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: "Theme swaps are visual only and apply instantly.";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    wrap: word-wrap;
                                }
                            }
                            VxToggle {
                                checked: root.dark-mode;
                                toggled => { root.toggle-dark-mode(); }
                            }
                        }

                        Divider {}

                        VerticalLayout {
                            spacing: 8px;
                            ThemePresetCard {
                                label: "Voxlink";
                                detail: "Default premium broadcast shell.";
                                selected: root.theme-preset == 0;
                                tone: #54d2ff;
                                swatch-a: #54d2ff;
                                swatch-b: #7ce5c8;
                                swatch-c: #13202d;
                                clicked => { root.select-theme-preset(0); }
                            }
                            ThemePresetCard {
                                label: "360 Party";
                                detail: "Green-room glow with retro console energy.";
                                selected: root.theme-preset == 1;
                                tone: #8be14f;
                                swatch-a: #8be14f;
                                swatch-b: #f3c65d;
                                swatch-c: #192715;
                                clicked => { root.select-theme-preset(1); }
                            }
                            ThemePresetCard {
                                label: "Deep Space";
                                detail: "Orbital blues, violet trims, calmer contrast.";
                                selected: root.theme-preset == 2;
                                tone: #6cc9ff;
                                swatch-a: #6cc9ff;
                                swatch-b: #bb8cff;
                                swatch-c: #141c3a;
                                clicked => { root.select-theme-preset(2); }
                            }
                            ThemePresetCard {
                                label: "Retro Tech";
                                detail: "Old-school control console with phosphor edges.";
                                selected: root.theme-preset == 3;
                                tone: #5cf3a6;
                                swatch-a: #5cf3a6;
                                swatch-b: #ffca5c;
                                swatch-c: #111d18;
                                clicked => { root.select-theme-preset(3); }
                            }
                            ThemePresetCard {
                                label: "Amber CRT";
                                detail: "Warm phosphor amber with old-school monitor depth.";
                                selected: root.theme-preset == 4;
                                tone: #ffbe4f;
                                swatch-a: #ffbe4f;
                                swatch-b: #fff0b2;
                                swatch-c: #291c0f;
                                clicked => { root.select-theme-preset(4); }
                            }
                            ThemePresetCard {
                                label: "Midnight Noir";
                                detail: "Minimal graphite shell with cool blue edge lighting.";
                                selected: root.theme-preset == 5;
                                tone: #90a8ff;
                                swatch-a: #90a8ff;
                                swatch-b: #cfd8f4;
                                swatch-c: #151921;
                                clicked => { root.select-theme-preset(5); }
                            }
                            ThemePresetCard {
                                label: "Arctic Glass";
                                detail: "Frosted cyan surfaces with airy contrast and clean edges.";
                                selected: root.theme-preset == 6;
                                tone: #5fdaf4;
                                swatch-a: #5fdaf4;
                                swatch-b: #c8f6ff;
                                swatch-c: #13292f;
                                clicked => { root.select-theme-preset(6); }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "DEVICE ROUTING"; }
                            VxButton {
                                label: "Refresh";
                                small: true;
                                ghost: true;
                                clicked => { root.refresh-devices(); }
                            }
                        }
                        if root.input-devices.length > 0 : VerticalLayout {
                            spacing: 8px;
                            FieldLabel { text: "Input"; }
                            for device[idx] in root.input-devices : VxOptionRow {
                                label: device;
                                detail: idx == root.selected-input ? "Current capture route" : "";
                                selected: idx == root.selected-input;
                                clicked => { root.selected-input = idx; }
                            }
                        }
                        if root.output-devices.length > 0 : VerticalLayout {
                            spacing: 8px;
                            FieldLabel { text: "Output"; }
                            for device[idx] in root.output-devices : VxOptionRow {
                                label: device;
                                detail: idx == root.selected-output ? "Current playback route" : "";
                                selected: idx == root.selected-output;
                                clicked => { root.selected-output = idx; }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "OUTPUT CHECK"; }
                        Text {
                            text: root.speaker-test-active ? "Playing a local sample." : "Play a local speaker test.";
                            color: VxTheme.text-primary;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.output-devices.length > 0
                                ? "Confirms the selected speaker route without joining a call."
                                : "Choose an output route to test playback.";
                            color: root.output-devices.length > 0 ? VxTheme.text-muted : VxTheme.danger;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        VxButton {
                            label: root.speaker-test-active ? "Playing sample..." : "Play sample tone";
                            accent: !root.speaker-test-active;
                            soft: root.speaker-test-active;
                            enabled: root.output-devices.length > 0 && !root.speaker-test-active;
                            horizontal-stretch: 1;
                            clicked => { root.play-speaker-test(); }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "MIC CHECK"; }
                        Text {
                            text: root.mic-preview-active ? "Mic check is live." : "Start a local mic check.";
                            color: VxTheme.text-primary;
                            font-size: 12px;
                            font-weight: 700;
                        }
                        Rectangle {
                            height: 10px;
                            border-radius: 5px;
                            background: VxTheme.bg-soft;

                            Rectangle {
                                width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                                height: parent.height;
                                border-radius: 5px;
                                background: !root.mic-preview-active ? VxTheme.text-muted :
                                            root.mic-level > 0.20 ? VxTheme.warning :
                                            root.mic-level > 0.06 ? VxTheme.success : VxTheme.accent;
                                animate width { duration: 40ms; }
                            }
                        }
                        VxButton {
                            label: root.mic-preview-active ? "Stop mic check" : "Start mic check";
                            accent: !root.mic-preview-active;
                            soft: root.mic-preview-active;
                            enabled: root.input-devices.length > 0;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-mic-preview(); }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "VOICE MODE"; }
                        VxButton {
                            label: root.is-open-mic ? "Switch to push to talk" : "Switch to open mic";
                            accent: true;
                            horizontal-stretch: 1;
                            clicked => { root.toggle-mic-mode(); }
                        }
                    }
                }
            }

            // ACCOUNT
            VxCard {
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    SectionLabel { text: "ACCOUNT"; }

                    if root.is-logged-in : VerticalLayout {
                        spacing: 10px;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            Rectangle {
                                width: 32px;
                                height: 32px;
                                border-radius: 16px;
                                background: VxTheme.accent;
                                Text {
                                    text: "VX";
                                    color: white;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: root.account-email;
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "Signed in";
                                    color: VxTheme.success;
                                    font-size: 10px;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxButton {
                                label: "Sign out";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.logout(); }
                            }
                            VxButton {
                                label: "Revoke all sessions";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.revoke-all-sessions(); }
                            }
                        }
                    }

                    if !root.is-logged-in : VerticalLayout {
                        spacing: 10px;
                        Text {
                            text: "Sign in or create an account to sync your identity across devices.";
                            color: VxTheme.text-muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                        VxButton {
                            label: "Sign in / Register";
                            accent: true;
                            horizontal-stretch: 1;
                            clicked => { root.show-login(); }
                        }
                    }
                }
            }

            Text {
                text: "Settings save automatically.";
                color: VxTheme.text-muted;
                font-size: 10px;
                horizontal-alignment: center;
            }
        }
    }
}
