import { ScrollView } from "std-widgets.slint";
import { DirectMessageThreadData, PublicSpaceData, SavedServerData, SpaceData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, SectionLabel, StatusDot, VxAvatar, VxButton, VxCard, VxInput, VxLogo, VxStatBlock, VxStatusPill } from "../components.slint";

export component HomeView inherits Rectangle {
    in property <bool> wide: false;
    in-out property <string> server-address: "";
    in-out property <string> user-name: "";
    in property <string> status-text: "";
    in property <bool> is-connected: false;
    in property <bool> first-run: false;
    in property <[SpaceData]> spaces: [];
    in-out property <string> space-name: "";
    in-out property <string> space-invite-code: "";
    in-out property <bool> show-quick-call: false;
    in-out property <string> join-code: "";
    in-out property <string> room-password: "";
    in property <[DirectMessageThreadData]> direct-message-threads: [];
    in property <int> unread-direct-messages-count: 0;
    in property <[SavedServerData]> saved-servers: [];
    in property <bool> streamer-mode: false;
    in-out property <string> activity-text: "";
    callback connect-server();
    callback disconnect-server();
    callback find-server();
    callback save-server(string);
    callback remove-server(int);
    callback select-space(string);
    callback create-space();
    callback join-space();
    callback create-room();
    callback join-room(string);
    callback open-direct-message(string);
    callback close-direct-message(string);
    callback call-user(string); // user_id — initiate DM voice call
    callback set-activity(string);
    callback dismiss-welcome();
    in property <[PublicSpaceData]> public-spaces: [];
    callback browse-public-spaces();
    callback join-public-space(string); // invite_code
    property <bool> show-explore: false;

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: (root.wide ? 16px : 12px) * VxTheme.s;
            spacing: 12px * VxTheme.s;

            VxCard {
                HorizontalLayout {
                    padding: root.wide ? 20px : 16px;
                    spacing: 12px;

                    VxLogo { logo-size: 58px; }

                    VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        horizontal-stretch: 1;

                        Text {
                            text: root.user-name != "" && root.user-name != "User"
                                ? (VxTheme.is-party ? "Welcome back, " + root.user-name + ". Ready to play?" :
                                   VxTheme.is-space ? "Captain " + root.user-name + ", on deck." :
                                   VxTheme.is-retro ? "user@voxlink:~$ hello " + root.user-name :
                                   VxTheme.is-amber ? "> WELCOME, " + root.user-name :
                                   VxTheme.is-noir  ? root.user-name + ". Good evening." :
                                   VxTheme.is-arctic ? "Welcome to the tundra, " + root.user-name :
                                   "Welcome back, " + root.user-name)
                                : (VxTheme.is-party ? "Ready up." :
                                   VxTheme.is-space ? "Awaiting crew." :
                                   VxTheme.is-retro ? "BOOT COMPLETE" :
                                   VxTheme.is-amber ? "> SYSTEM READY_" :
                                   VxTheme.is-noir  ? "The line is open." :
                                   VxTheme.is-arctic ? "Clear signal ahead." :
                                   "Voice with less drag");
                            color: VxTheme.text-primary;
                            font-size: 24px;
                            font-weight: VxTheme.is-noir ? 500 : 700;
                            wrap: word-wrap;
                        }

                        Text {
                            text:
                                VxTheme.is-party ? "Your 360-style voice party. Jump in, squad up, dominate." :
                                VxTheme.is-space ? "Deep-space comms array online. All channels nominal." :
                                VxTheme.is-retro ? "TERMINAL READY // ALL SUBSYSTEMS NOMINAL // VOICE CODEC LOADED" :
                                VxTheme.is-amber ? "PHOSPHOR DISPLAY ACTIVE. VOICE SUBSYSTEM INITIALIZED." :
                                VxTheme.is-noir  ? "A quieter kind of voice app. Understated. Reliable." :
                                VxTheme.is-arctic ? "Crystal-clear comms. Zero noise. Sub-zero latency." :
                                "A calmer, faster desktop shell for calls, spaces, and chat.";
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            StatusDot { active: root.is-connected; }
                            VxStatusPill {
                                label: root.status-text;
                                tone: root.is-connected ? VxTheme.success :
                                      root.status-text == "Connecting..." ? VxTheme.warning : VxTheme.text-secondary;
                                fill: root.is-connected ? VxTheme.success-dim :
                                      root.status-text == "Connecting..." ? VxTheme.warning-soft : VxTheme.bg-soft;
                            }
                            if root.spaces.length > 0 : VxStatusPill {
                                label: root.spaces.length + " spaces";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }
                    }
                }
            }

            // Activity status — let users set "Playing ...", "Working on ..."
            if root.is-connected : HorizontalLayout {
                spacing: 8px;
                alignment: stretch;
                VxInput {
                    horizontal-stretch: 1;
                    placeholder: "Set activity (e.g. Playing Valorant)";
                    text <=> root.activity-text;
                    accepted => {
                        root.set-activity(root.activity-text);
                    }
                }
                VxButton {
                    label: root.activity-text == "" ? "Set" : "Clear";
                    small: true;
                    soft: root.activity-text != "";
                    accent: root.activity-text == "";
                    clicked => {
                        if root.activity-text != "" {
                            root.activity-text = "";
                            root.set-activity("");
                        } else {
                            root.set-activity(root.activity-text);
                        }
                    }
                }
            }

            // First-run welcome card — shown once for new users, dismissed via "Got it!"
            if root.first-run : VxCard {
                VerticalLayout {
                    padding: 20px;
                    spacing: 16px;

                    Text {
                        text: "Welcome to Voxlink";
                        color: VxTheme.accent;
                        font-size: 20px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Voxlink is a voice-first chat app. Here's how to get started:";
                        color: VxTheme.text-secondary;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    // Step 1: Create a Space
                    HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: VxTheme.accent;
                            Text {
                                text: "1";
                                color: white;
                                font-size: 13px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "Create a Space";
                                color: VxTheme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                            }
                            Text {
                                text: "Your own server with voice and text channels.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Step 2: Invite Friends
                    HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: VxTheme.accent;
                            Text {
                                text: "2";
                                color: white;
                                font-size: 13px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "Invite Friends";
                                color: VxTheme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                            }
                            Text {
                                text: "Share your invite code to bring people in.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Step 3: Join a Voice Channel
                    HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: VxTheme.accent;
                            Text {
                                text: "3";
                                color: white;
                                font-size: 13px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "Join a Voice Channel";
                                color: VxTheme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                            }
                            Text {
                                text: "Click any voice channel to start talking.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Step 4: Chat
                    HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 14px;
                            background: VxTheme.accent;
                            Text {
                                text: "4";
                                color: white;
                                font-size: 13px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: "Chat";
                                color: VxTheme.text-primary;
                                font-size: 13px;
                                font-weight: 600;
                            }
                            Text {
                                text: "Use text channels for messages, reactions, and threads.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    VxButton {
                        label: "Got it!";
                        accent: true;
                        clicked => {
                            root.dismiss-welcome();
                        }
                    }
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 12px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;

                            SectionLabel { text: "SERVER"; }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Server address"; }
                                HorizontalLayout {
                                    spacing: 8px;
                                    VxInput {
                                        text <=> root.server-address;
                                        horizontal-stretch: 1;
                                        accepted => {
                                            if !root.is-connected {
                                                root.connect-server();
                                            }
                                        }
                                    }
                                    VxButton {
                                        label: "Save";
                                        soft: true;
                                        clicked => { root.save-server(root.server-address); }
                                    }
                                }
                            }

                            // Saved servers list
                            if root.saved-servers.length > 0 : VerticalLayout {
                                spacing: 4px;
                                FieldLabel { text: "Saved servers"; }
                                for server[idx] in root.saved-servers : Rectangle {
                                    height: 32px;
                                    border-radius: VxTheme.radius-card;
                                    background: server-touch.has-hover ? VxTheme.bg-raised : transparent;

                                    server-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.server-address = server.address;
                                        }
                                    }

                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 6px;
                                        spacing: 8px;
                                        alignment: center;

                                        if server.is-default : Rectangle {
                                            width: 6px;
                                            height: 6px;
                                            border-radius: 3px;
                                            background: VxTheme.accent;
                                        }

                                        Text {
                                            text: server.name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }

                                        Text {
                                            text: root.streamer-mode ? "ws://***:****" : server.address;
                                            color: VxTheme.text-muted;
                                            font-size: 10px;
                                            vertical-alignment: center;
                                        }

                                        remove-touch := TouchArea {
                                            width: 20px;
                                            height: 20px;
                                            mouse-cursor: pointer;
                                            clicked => { root.remove-server(idx); }
                                            Text {
                                                text: "✕";
                                                color: remove-touch.has-hover ? VxTheme.danger : VxTheme.text-muted;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                if !root.is-connected : VxButton {
                                    label: root.status-text == "Connecting..." ? "Connecting..." : "Connect";
                                    accent: true;
                                    enabled: root.status-text != "Connecting...";
                                    horizontal-stretch: 1;
                                    clicked => { root.connect-server(); }
                                }
                                if root.is-connected : VxButton {
                                    label: "Disconnect";
                                    danger: true;
                                    horizontal-stretch: 1;
                                    clicked => { root.disconnect-server(); }
                                }
                                if !root.is-connected : VxButton {
                                    label: "Find on LAN";
                                    soft: true;
                                    clicked => { root.find-server(); }
                                }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Display name"; }
                                VxInput {
                                    text <=> root.user-name;
                                    placeholder: "Enter a display name";
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "SPACES"; }
                                if root.spaces.length > 0 : Text {
                                    text: root.spaces.length + " linked";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }

                            if root.spaces.length == 0 : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 5px;
                                    Text {
                                        text: "Your workspace rail is empty.";
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: "Create a space to get channels, members, and chat in one place.";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            for space in root.spaces : Rectangle {
                                height: 60px;
                                border-radius: VxTheme.radius-card;
                                background: space-wide-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: space-wide-touch.has-hover ? VxTheme.card-hover-border : VxTheme.border-subtle;
                                border-width: 1px;

                                space-wide-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.select-space(space.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 12px;
                                    alignment: center;

                                    VxAvatar {
                                        avatar-size: 36px;
                                        initial: space.initial;
                                        color-index: space.color-index;
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: space.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px;
                                            font-weight: 700;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: space.member-count + " members  ·  " + space.channel-count + " channels";
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                            overflow: elide;
                                        }
                                    }

                                    if space.has-unread : Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: VxTheme.accent;
                                    }
                                    VxStatusPill {
                                        label: "Open";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "DIRECT MESSAGES"; }
                                if root.unread-direct-messages-count > 0 : VxStatusPill {
                                    label: root.unread-direct-messages-count + " unread";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.accent-subtle;
                                }
                            }

                            if root.direct-message-threads.length == 0 : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 5px;
                                    Text {
                                        text: "No conversations yet";
                                        color: VxTheme.text-secondary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: "Start a conversation from your friends list.";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            for thread in root.direct-message-threads : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: dm-wide-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: thread.unread-count > 0 ? VxTheme.accent-border :
                                              thread.is-in-voice ? VxTheme.speaking-border :
                                              dm-wide-touch.has-hover ? VxTheme.card-hover-border :
                                              thread.is-online ? VxTheme.border-strong : VxTheme.border-subtle;
                                border-width: 1px;

                                dm-wide-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.open-direct-message(thread.user-id); }
                                }

                                HorizontalLayout {
                                    padding: 12px;
                                    spacing: 10px;
                                    alignment: center;

                                    VxAvatar {
                                        avatar-size: 32px;
                                        initial: thread.initial;
                                        color-index: thread.color-index;
                                        show-status: true;
                                        is-online: thread.is-online;
                                        is-speaking: thread.is-in-voice;
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;

                                        HorizontalLayout {
                                            spacing: 6px;
                                            alignment: start;
                                            Text {
                                                text: thread.name;
                                                color: VxTheme.text-primary;
                                                font-size: 11px;
                                                font-weight: 700;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: thread.meta;
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                                vertical-alignment: center;
                                            }
                                        }

                                        Text {
                                            text: thread.preview;
                                            color: VxTheme.text-secondary;
                                            font-size: 10px;
                                            overflow: elide;
                                        }
                                    }

                                    if thread.unread-count > 0 : VxStatusPill {
                                        label: thread.unread-count + "";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }

                                    if dm-wide-touch.has-hover : Rectangle {
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: dm-call-wide.has-hover ? VxTheme.success.transparentize(0.8) : transparent;
                                        dm-call-wide := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.call-user(thread.user-id); }
                                        }
                                        Text {
                                            text: "Call";
                                            color: dm-call-wide.has-hover ? VxTheme.success : VxTheme.text-muted;
                                            font-size: 9px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if dm-wide-touch.has-hover : Rectangle {
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: dm-close-wide.has-hover ? VxTheme.bg-elevated : transparent;
                                        dm-close-wide := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.close-direct-message(thread.user-id); }
                                        }
                                        Text {
                                            text: "\u{00D7}";
                                            color: dm-close-wide.has-hover ? VxTheme.text-primary : VxTheme.text-muted;
                                            font-size: 14px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: 308px;
                    spacing: 12px;

                    if root.join-code != "" : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "RECENT ROOM"; }
                            VxStatBlock {
                                label: "Last call code";
                                value: root.join-code;
                                detail: "Stored locally so you can jump back in faster.";
                                tone: VxTheme.accent;
                            }
                            VxButton {
                                label: root.is-connected ? "Rejoin last call" : "Connect to rejoin";
                                accent: root.is-connected;
                                enabled: root.is-connected;
                                horizontal-stretch: 1;
                                clicked => { root.join-room(root.join-code); }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            SectionLabel { text: "SPACE BUILDER"; }

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Create a new space"; }
                                Text {
                                    text: "A space is your own group with voice and text channels.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                                VxInput {
                                    text <=> root.space-name;
                                    placeholder: "Studio, Guild, Squad";
                                    accepted => {
                                        if root.is-connected && root.space-name != "" {
                                            root.create-space();
                                        }
                                    }
                                }
                            }

                            VxButton {
                                label: "Create Space";
                                accent: true;
                                enabled: root.is-connected && root.space-name != "";
                                horizontal-stretch: 1;
                                clicked => { root.create-space(); }
                            }

                            Divider {}

                            VerticalLayout {
                                spacing: 6px;
                                FieldLabel { text: "Join by invite"; }
                                VxInput {
                                    text <=> root.space-invite-code;
                                    placeholder: "Paste invite code";
                                    accepted => {
                                        if root.is-connected && root.space-invite-code != "" {
                                            root.join-space();
                                        }
                                    }
                                }
                            }

                            VxButton {
                                label: "Join Space";
                                soft: true;
                                enabled: root.is-connected && root.space-invite-code != "";
                                horizontal-stretch: 1;
                                clicked => { root.join-space(); }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "QUICK CALL"; }
                                VxButton {
                                    label: root.show-quick-call ? "Hide" : "Show";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.show-quick-call = !root.show-quick-call; }
                                }
                            }

                            Text {
                                text: "Fast room codes for ad-hoc voice without a full space.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            if root.show-quick-call : VerticalLayout {
                                spacing: 10px;

                                VxButton {
                                    label: root.status-text == "Starting call..." ? "Starting..." :
                                           root.is-connected ? "Start Call" : "Connect first";
                                    accent: true;
                                    enabled: root.is-connected && root.status-text != "Starting call..." && root.status-text != "Joining call...";
                                    horizontal-stretch: 1;
                                    clicked => { root.create-room(); }
                                }

                                VerticalLayout {
                                    spacing: 6px;
                                    FieldLabel { text: "Join by room code"; }
                                    VxInput {
                                        text <=> root.join-code;
                                        placeholder: "Room code";
                                        accepted => {
                                            if root.is-connected && root.join-code != "" {
                                                root.join-room(root.join-code);
                                            }
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    VxButton {
                                        label: "Join";
                                        soft: true;
                                        enabled: root.is-connected && root.join-code != "";
                                        clicked => { root.join-room(root.join-code); }
                                    }
                                    VxInput {
                                        text <=> root.room-password;
                                        placeholder: "Password (optional)";
                                        input-type: InputType.password;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 12px;

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 14px;

                        SectionLabel { text: "SERVER"; }

                        VerticalLayout {
                            spacing: 6px;
                            FieldLabel { text: "Server address"; }
                            HorizontalLayout {
                                spacing: 8px;
                                VxInput {
                                    text <=> root.server-address;
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if !root.is-connected {
                                            root.connect-server();
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Save";
                                    soft: true;
                                    clicked => { root.save-server(root.server-address); }
                                }
                            }
                        }

                        // Saved servers list (narrow)
                        if root.saved-servers.length > 0 : VerticalLayout {
                            spacing: 4px;
                            FieldLabel { text: "Saved servers"; }
                            for server[idx] in root.saved-servers : Rectangle {
                                height: 32px;
                                border-radius: VxTheme.radius-card;
                                background: narrow-server-touch.has-hover ? VxTheme.bg-raised : transparent;

                                narrow-server-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.server-address = server.address;
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    alignment: center;

                                    if server.is-default : Rectangle {
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: VxTheme.accent;
                                    }

                                    Text {
                                        text: server.name;
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: root.streamer-mode ? "ws://***:****" : server.address;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }

                                    narrow-remove-touch := TouchArea {
                                        width: 20px;
                                        height: 20px;
                                        mouse-cursor: pointer;
                                        clicked => { root.remove-server(idx); }
                                        Text {
                                            text: "✕";
                                            color: narrow-remove-touch.has-hover ? VxTheme.danger : VxTheme.text-muted;
                                            font-size: 11px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            if !root.is-connected : VxButton {
                                label: root.status-text == "Connecting..." ? "Connecting..." : "Connect";
                                accent: true;
                                enabled: root.status-text != "Connecting...";
                                horizontal-stretch: 1;
                                clicked => { root.connect-server(); }
                            }
                            if root.is-connected : VxButton {
                                label: "Disconnect";
                                danger: true;
                                horizontal-stretch: 1;
                                clicked => { root.disconnect-server(); }
                            }
                            if !root.is-connected : VxButton {
                                label: "Find on LAN";
                                soft: true;
                                clicked => { root.find-server(); }
                            }
                        }

                        VerticalLayout {
                            spacing: 6px;
                            FieldLabel { text: "Display name"; }
                            VxInput {
                                text <=> root.user-name;
                                placeholder: "Enter a display name";
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "SPACE BUILDER"; }

                        VerticalLayout {
                            spacing: 6px;
                            FieldLabel { text: "Create a new space"; }
                            VxInput {
                                text <=> root.space-name;
                                placeholder: "Studio, Guild, Squad";
                                accepted => {
                                    if root.is-connected && root.space-name != "" {
                                        root.create-space();
                                    }
                                }
                            }
                        }

                        VxButton {
                            label: "Create Space";
                            accent: true;
                            enabled: root.is-connected && root.space-name != "";
                            horizontal-stretch: 1;
                            clicked => { root.create-space(); }
                        }

                        Divider {}

                        VerticalLayout {
                            spacing: 6px;
                            FieldLabel { text: "Join by invite"; }
                            VxInput {
                                text <=> root.space-invite-code;
                                placeholder: "Paste invite code";
                                accepted => {
                                    if root.is-connected && root.space-invite-code != "" {
                                        root.join-space();
                                    }
                                }
                            }
                        }

                        VxButton {
                            label: "Join Space";
                            soft: true;
                            enabled: root.is-connected && root.space-invite-code != "";
                            horizontal-stretch: 1;
                            clicked => { root.join-space(); }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        if root.join-code != "" : VxStatBlock {
                            label: "Recent room";
                            value: root.join-code;
                            detail: "Jump back in when you are ready.";
                            tone: VxTheme.accent;
                        }
                        if root.join-code != "" : VxButton {
                            label: root.is-connected ? "Rejoin last call" : "Connect to rejoin";
                            accent: root.is-connected;
                            enabled: root.is-connected;
                            horizontal-stretch: 1;
                            clicked => { root.join-room(root.join-code); }
                        }
                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "QUICK CALL"; }
                            VxButton {
                                label: root.show-quick-call ? "Hide" : "Show";
                                small: true;
                                ghost: true;
                                clicked => { root.show-quick-call = !root.show-quick-call; }
                            }
                        }

                        if root.show-quick-call : VerticalLayout {
                            spacing: 10px;
                            VxButton {
                                label: root.status-text == "Starting call..." ? "Starting..." :
                                       root.is-connected ? "Start Call" : "Connect first";
                                accent: true;
                                enabled: root.is-connected && root.status-text != "Starting call..." && root.status-text != "Joining call...";
                                horizontal-stretch: 1;
                                clicked => { root.create-room(); }
                            }
                            VxInput {
                                text <=> root.join-code;
                                placeholder: "Room code";
                                accepted => {
                                    if root.is-connected && root.join-code != "" {
                                        root.join-room(root.join-code);
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                VxButton {
                                    label: "Join";
                                    soft: true;
                                    enabled: root.is-connected && root.join-code != "";
                                    clicked => { root.join-room(root.join-code); }
                                }
                                VxInput {
                                    text <=> root.room-password;
                                    placeholder: "Password";
                                    input-type: InputType.password;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }
                }

                if root.spaces.length > 0 : VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "SPACES"; }
                        for space in root.spaces : Rectangle {
                            height: 54px;
                            border-radius: VxTheme.radius-card;
                            background: space-compact-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;

                            space-compact-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.select-space(space.id); }
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                alignment: center;

                                VxAvatar {
                                    avatar-size: 32px;
                                    initial: space.initial;
                                    color-index: space.color-index;
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: space.name;
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: space.member-count + " members";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                if space.has-unread : Rectangle {
                                    width: 8px;
                                    height: 8px;
                                    border-radius: 4px;
                                    background: VxTheme.accent;
                                }
                            }
                        }
                    }
                }

                // ─── Explore Public Spaces ───
                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "EXPLORE"; }
                            VxButton {
                                label: root.show-explore ? "Hide" : "Browse Servers";
                                small: true;
                                soft: true;
                                clicked => {
                                    root.show-explore = !root.show-explore;
                                    if root.show-explore {
                                        root.browse-public-spaces();
                                    }
                                }
                            }
                        }

                        if root.show-explore : VerticalLayout {
                            spacing: 8px;

                            if root.public-spaces.length == 0 : Text {
                                text: "No public spaces found. Ask a server admin to make their space public.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            for ps in root.public-spaces : Rectangle {
                                height: 64px;
                                border-radius: VxTheme.radius-card;
                                background: ps-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                ps-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.join-public-space(ps.invite-code); }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 10px;
                                    alignment: center;

                                    VxAvatar {
                                        avatar-size: 36px;
                                        initial: ps.initial;
                                        color-index: ps.color-index;
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: ps.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px;
                                            font-weight: 700;
                                        }
                                        if ps.description != "" : Text {
                                            text: ps.description;
                                            color: VxTheme.text-secondary;
                                            font-size: 9px;
                                            overflow: elide;
                                        }
                                        HorizontalLayout {
                                            spacing: 8px;
                                            Text {
                                                text: ps.member-count + " members";
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                            }
                                            if ps.online-count > 0 : HorizontalLayout {
                                                spacing: 3px;
                                                Rectangle {
                                                    width: 6px; height: 6px;
                                                    border-radius: 3px;
                                                    background: VxTheme.success;
                                                    y: 2px;
                                                }
                                                Text {
                                                    text: ps.online-count + " online";
                                                    color: VxTheme.success;
                                                    font-size: 9px;
                                                }
                                            }
                                        }
                                    }

                                    VxButton {
                                        label: "Join";
                                        small: true;
                                        accent: true;
                                        clicked => { root.join-public-space(ps.invite-code); }
                                    }
                                }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "DIRECT MESSAGES"; }
                            if root.unread-direct-messages-count > 0 : VxStatusPill {
                                label: root.unread-direct-messages-count + " unread";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }

                        if root.direct-message-threads.length == 0 : Text {
                            text: "Recent direct messages will appear here.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        for thread in root.direct-message-threads : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: dm-compact-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                            border-color: thread.unread-count > 0 ? VxTheme.accent-border :
                                          dm-compact-touch.has-hover ? VxTheme.card-hover-border : VxTheme.border-subtle;
                            border-width: 1px;

                            dm-compact-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-direct-message(thread.user-id); }
                            }

                            VerticalLayout {
                                padding: 12px;
                                spacing: 6px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: center;

                                    VxAvatar {
                                        avatar-size: 28px;
                                        initial: thread.initial;
                                        color-index: thread.color-index;
                                        show-status: true;
                                        is-online: thread.is-online;
                                        is-speaking: thread.is-in-voice;
                                    }

                                    Text {
                                        text: thread.name;
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: thread.meta;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }

                                    if thread.unread-count > 0 : VxStatusPill {
                                        label: thread.unread-count + "";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }

                                    if dm-compact-touch.has-hover : Rectangle {
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: dm-call-compact.has-hover ? VxTheme.success.transparentize(0.8) : transparent;
                                        dm-call-compact := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.call-user(thread.user-id); }
                                        }
                                        Text {
                                            text: "Call";
                                            color: dm-call-compact.has-hover ? VxTheme.success : VxTheme.text-muted;
                                            font-size: 9px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    if dm-compact-touch.has-hover : Rectangle {
                                        width: 22px;
                                        height: 22px;
                                        border-radius: 4px;
                                        background: dm-close-compact.has-hover ? VxTheme.bg-elevated : transparent;
                                        dm-close-compact := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.close-direct-message(thread.user-id); }
                                        }
                                        Text {
                                            text: "\u{00D7}";
                                            color: dm-close-compact.has-hover ? VxTheme.text-primary : VxTheme.text-muted;
                                            font-size: 14px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Text {
                                    text: thread.preview;
                                    color: VxTheme.text-secondary;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
