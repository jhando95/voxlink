import { ListView, ScrollView } from "std-widgets.slint";
import { ParticipantData, ShareSourceData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, SectionLabel, VxAvatar, VxButton, VxCard, VxOptionRow, VxSlider, VxStatusPill } from "../components.slint";

export component RoomView inherits Rectangle {
    in property <bool> wide: false;
    in property <string> room-code: "";
    in property <[ParticipantData]> participants: [];
    in property <bool> is-connected: false;
    in property <string> status-text: "";
    in property <string> room-status: "";
    in property <bool> is-muted: false;
    in property <bool> is-deafened: false;
    in property <bool> talking-while-muted: false;
    in property <bool> is-open-mic: true;
    in property <float> mic-level: 0.0;
    in property <string> ptt-key-display: "";
    in property <int> ping-ms: -1;
    in property <int> reconnect-attempts: 0;
    in property <int> dropped-frames: 0;
    in property <bool> in-space-channel: false;
    in property <string> current-space-name: "";
    in property <bool> has-screen-share: false;
    in property <bool> is-sharing-screen: false;
    in property <string> screen-share-owner-name: "";
    in property <image> screen-share-image;
    in property <[ShareSourceData]> screen-share-sources: [];
    in property <int> selected-screen-share-source: -1;
    in property <int> selected-screen-share-profile: 0;
    in property <string> screen-share-source-label: "";
    in property <string> screen-share-source-detail: "";
    in property <string> screen-share-quality-label: "";
    in property <string> screen-share-quality-detail: "";
    in-out property <bool> show-copied: false;
    in-out property <string> selected-peer-id: "";
    in-out property <bool> show-share-config: false;
    callback copy-room-code();
    callback leave-room();
    callback leave-channel();
    callback toggle-mute();
    callback toggle-deafen();
    callback toggle-mic-mode();
    callback toggle-screen-share();
    callback refresh-screen-share-sources();
    callback select-screen-share-source(int);
    callback select-screen-share-profile(int);
    callback volume-changed(string, float);
    callback navigate(int);

    background: transparent;

    // -- Grid layout helpers --
    property <int> cols:
        root.participants.length <= 1 ? 1 :
        root.participants.length <= 4 ? 2 :
        root.participants.length <= 9 ? 3 : 4;
    property <length> avatar-sz:
        (root.participants.length <= 2 ? 88px :
        root.participants.length <= 4 ? 76px :
        root.participants.length <= 9 ? 64px : 52px) * VxTheme.s;
    property <length> tile-w: root.avatar-sz + 24px * VxTheme.s;
    property <length> tile-h: root.avatar-sz + 32px * VxTheme.s;
    property <length> tile-gap: (root.wide ? 16px : 10px) * VxTheme.s;
    property <int> row-count: root.participants.length <= 0 ? 0 :
        (root.participants.length + root.cols - 1) / root.cols;
    property <length> grid-w: root.cols * root.tile-w + (root.cols - 1) * root.tile-gap;
    property <length> grid-h: root.row-count * root.tile-h + (root.row-count <= 1 ? 0px : (root.row-count - 1) * root.tile-gap);

    VerticalLayout {
        spacing: 0px;

        // ═══════════════════════════════════════════
        //  ZONE 1 — Header bar
        // ═══════════════════════════════════════════
        Rectangle {
            height: 48px * VxTheme.s;
            background: VxTheme.bg-card;
            border-color: VxTheme.border-subtle;
            border-width: 0px;

            // bottom border
            Rectangle {
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: VxTheme.border-subtle;
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 12px;
                alignment: center;

                // Left: channel/room info
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: root.in-space-channel ? "# " + root.room-code : root.room-code;
                            color: VxTheme.text-primary;
                            font-size: 14px;
                            font-weight: 700;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        if root.in-space-channel && root.current-space-name != "" : Text {
                            text: "· " + root.current-space-name;
                            color: VxTheme.text-muted;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Center: status
                if !root.is-connected : VxStatusPill {
                    label: "Reconnecting" + (root.reconnect-attempts > 0 ? " (" + root.reconnect-attempts + ")" : "");
                    tone: VxTheme.danger;
                    fill: VxTheme.mute-badge-bg;
                }

                if root.talking-while-muted : VxStatusPill {
                    label: "You're muted";
                    tone: VxTheme.warning;
                    fill: VxTheme.warning-soft;
                }

                // Right: participant count + ping
                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;

                    Text {
                        text: root.participants.length + "";
                        color: VxTheme.text-secondary;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    // Ping dot
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: root.ping-ms < 0 ? VxTheme.text-muted :
                                    root.ping-ms < 60 ? VxTheme.success :
                                    root.ping-ms < 150 ? VxTheme.warning : VxTheme.danger;
                    }
                    Text {
                        text: root.ping-ms >= 0 ? root.ping-ms + "ms" : "--";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        vertical-alignment: center;
                    }

                    // Copy code button
                    VxButton {
                        label: root.show-copied ? "Copied" : "Copy";
                        small: true;
                        ghost: true;
                        clicked => {
                            root.copy-room-code();
                            root.show-copied = true;
                        }
                    }
                }
            }
        }

        // ═══════════════════════════════════════════
        //  ZONE 2 — Stage area
        // ═══════════════════════════════════════════
        Rectangle {
            vertical-stretch: 1;
            background: VxTheme.bg-panel;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Screen share: when active, takes over the stage
                if root.has-screen-share : Rectangle {
                    vertical-stretch: 1;
                    border-radius: VxTheme.radius-card;
                    background: VxTheme.bg-stage;
                    border-color: VxTheme.accent-border;
                    border-width: 1px;
                    clip: true;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.screen-share-image;
                        image-fit: contain;
                    }

                    // Sharer badge overlaid top-left
                    Rectangle {
                        x: 8px;
                        y: 8px;
                        height: 24px;
                        width: share-label.preferred-width + 20px;
                        border-radius: 12px;
                        background: VxTheme.bg-panel.transparentize(0.2);
                        share-label := Text {
                            text: root.is-sharing-screen ? "You are sharing" : root.screen-share-owner-name + " is sharing";
                            color: VxTheme.success;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // When screen share is active, show participants as a compact row below
                if root.has-screen-share : HorizontalLayout {
                    height: 50px;
                    spacing: 8px;
                    alignment: center;

                    for p[idx] in root.participants : Rectangle {
                        width: 42px;
                        height: 50px;

                        VxAvatar {
                            x: (parent.width - self.width) / 2;
                            y: 0px;
                            avatar-size: 34px;
                            initial: p.initial;
                            color-index: p.color-index;
                            is-speaking: p.is-speaking;
                        }
                        Text {
                            y: 36px;
                            width: parent.width;
                            text: p.id == "self" ? "You" : p.name;
                            color: VxTheme.text-secondary;
                            font-size: 9px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                // No screen share: avatar grid is the stage
                if !root.has-screen-share : Rectangle {
                    vertical-stretch: 1;

                    // Empty state
                    if root.participants.length <= 1 : VerticalLayout {
                        alignment: center;
                        spacing: 12px;
                        padding: 24px;

                        if root.participants.length == 1 : VxAvatar {
                            x: (parent.width - self.width) / 2;
                            avatar-size: 96px;
                            initial: root.participants[0].initial;
                            color-index: root.participants[0].color-index;
                            is-speaking: root.participants[0].is-speaking;
                        }

                        Text {
                            text: root.participants.length == 1
                                ? (root.participants[0].id == "self" ? root.participants[0].name + " · You" : root.participants[0].name)
                                : "";
                            color: VxTheme.text-primary;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: root.in-space-channel
                                ? "Waiting for others to join the channel..."
                                : "Share the room code to invite others.";
                            color: VxTheme.text-muted;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }

                    // Multi-participant avatar grid (2+ people)
                    if root.participants.length > 1 : Rectangle {
                        // Center the grid
                        property <length> stage-w: self.width;
                        property <length> stage-h: self.height;
                        property <length> offset-x: (stage-w - root.grid-w) / 2;
                        property <length> offset-y: (stage-h - root.grid-h) / 2;

                        for p[idx] in root.participants : Rectangle {
                            x: parent.offset-x + Math.mod(idx, root.cols) * (root.tile-w + root.tile-gap);
                            y: parent.offset-y + Math.floor(idx / root.cols) * (root.tile-h + root.tile-gap);
                            width: root.tile-w;
                            height: root.tile-h;

                            tile-touch := TouchArea {
                                mouse-cursor: p.id != "self" ? pointer : default;
                                clicked => {
                                    if p.id != "self" {
                                        root.selected-peer-id = root.selected-peer-id == p.id ? "" : p.id;
                                    }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 6px;

                                // Avatar with badges
                                Rectangle {
                                    width: root.avatar-sz;
                                    height: root.avatar-sz;
                                    x: (parent.width - self.width) / 2;

                                    VxAvatar {
                                        avatar-size: root.avatar-sz;
                                        initial: p.initial;
                                        color-index: p.color-index;
                                        is-speaking: p.is-speaking;
                                    }

                                    // Mute badge (bottom-right corner)
                                    if p.is-muted || (p.id == "self" && root.is-muted) : Rectangle {
                                        x: parent.width - self.width - 2px;
                                        y: parent.height - self.height - 2px;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: VxTheme.danger;
                                        border-color: VxTheme.bg-panel;
                                        border-width: 2px;

                                        // Slash line for mute icon
                                        Rectangle {
                                            x: 5px;
                                            y: 7px;
                                            width: 6px;
                                            height: 2px;
                                            border-radius: 1px;
                                            background: VxTheme.text-inverse;
                                        }
                                    }

                                    // Deafen badge
                                    if p.is-deafened || (p.id == "self" && root.is-deafened) : Rectangle {
                                        x: parent.width - self.width - 2px;
                                        y: 2px;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: VxTheme.warning;
                                        border-color: VxTheme.bg-panel;
                                        border-width: 2px;

                                        Rectangle {
                                            x: 5px;
                                            y: 7px;
                                            width: 6px;
                                            height: 2px;
                                            border-radius: 1px;
                                            background: VxTheme.text-inverse;
                                        }
                                    }

                                    // Speaking "LIVE" pill (centered above avatar)
                                    if p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted) : Rectangle {
                                        x: (parent.width - self.width) / 2;
                                        y: -8px;
                                        width:
                                            VxTheme.is-party ? 52px :
                                            VxTheme.is-space ? 42px :
                                            VxTheme.is-retro ? 28px :
                                            VxTheme.is-noir  ? 36px :
                                            32px;
                                        height: 16px;
                                        border-radius:
                                            VxTheme.is-retro || VxTheme.is-amber ? 2px : 8px;
                                        background: VxTheme.success;
                                        Text {
                                            text:
                                                VxTheme.is-party ? "HOT MIC" :
                                                VxTheme.is-space ? "COMMS" :
                                                VxTheme.is-retro ? "TX" :
                                                VxTheme.is-amber ? "TX" :
                                                VxTheme.is-noir  ? "On Air" :
                                                VxTheme.is-arctic ? "LIVE" :
                                                "LIVE";
                                            color: VxTheme.text-inverse;
                                            font-size: 8px;
                                            font-weight: 800;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Name
                                Text {
                                    text: p.id == "self" ? p.name + " (You)" : p.name;
                                    color: p.is-speaking ? VxTheme.success :
                                           root.selected-peer-id == p.id ? VxTheme.accent : VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    overflow: elide;
                                    max-width: root.tile-w;
                                }
                            }

                            // Hover highlight
                            Rectangle {
                                width: parent.width;
                                height: parent.height;
                                border-radius: VxTheme.radius-card;
                                background: tile-touch.has-hover && p.id != "self" ? VxTheme.row-hover-bg : transparent;
                                border-color: root.selected-peer-id == p.id ? VxTheme.accent-border : transparent;
                                border-width: root.selected-peer-id == p.id ? 1px : 0px;
                                animate background { duration: 80ms; }
                            }
                        }
                    }
                }

                // Per-peer volume slider (shows when a peer is selected)
                if root.selected-peer-id != "" : Rectangle {
                    height: 40px;
                    border-radius: VxTheme.radius-control;
                    background: VxTheme.bg-soft;
                    border-color: VxTheme.border-subtle;
                    border-width: 1px;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 12px;
                        alignment: center;

                        Text {
                            text: "Volume";
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        VxSlider {
                            horizontal-stretch: 1;
                            // Find the selected peer's volume — iterate to match
                            // Slint doesn't support array.find(), so use first participant as fallback
                            value: 1.0;
                            changed(val) => { root.volume-changed(root.selected-peer-id, val); }
                        }

                        VxButton {
                            label: "Done";
                            small: true;
                            ghost: true;
                            clicked => { root.selected-peer-id = ""; }
                        }
                    }
                }

                // Screen share configuration (expandable)
                if root.show-share-config : VxCard {
                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "SHARE SOURCE"; }
                            HorizontalLayout {
                                spacing: 8px;
                                VxButton {
                                    label: "Refresh";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.refresh-screen-share-sources(); }
                                }
                                VxButton {
                                    label: "Close";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.show-share-config = false; }
                                }
                            }
                        }

                        Rectangle {
                            height: 120px;
                            clip: true;
                            if root.screen-share-sources.length > 0 : ListView {
                                for source[idx] in root.screen-share-sources : VxOptionRow {
                                    label: source.label;
                                    detail: source.kind-label + " · " + source.detail;
                                    selected: idx == root.selected-screen-share-source;
                                    clicked => { root.select-screen-share-source(idx); }
                                }
                            }
                            if root.screen-share-sources.length == 0 : VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "No sources — click Refresh";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        SectionLabel { text: "STREAM PROFILE"; }
                        VxOptionRow {
                            label: "Efficient";
                            detail: "Up to 540p / 8 fps";
                            selected: root.selected-screen-share-profile == 0;
                            clicked => { root.select-screen-share-profile(0); }
                        }
                        VxOptionRow {
                            label: "Balanced";
                            detail: "Up to 720p / 15 fps";
                            selected: root.selected-screen-share-profile == 1;
                            clicked => { root.select-screen-share-profile(1); }
                        }
                        VxOptionRow {
                            label: "Smooth";
                            detail: "Up to 720p / 30 fps";
                            selected: root.selected-screen-share-profile == 2;
                            clicked => { root.select-screen-share-profile(2); }
                        }
                        VxOptionRow {
                            label: "Max";
                            detail: "Up to 720p / 60 fps";
                            selected: root.selected-screen-share-profile == 3;
                            clicked => { root.select-screen-share-profile(3); }
                        }
                    }
                }
            }
        }

        // ═══════════════════════════════════════════
        //  ZONE 3 — Control bar (pinned bottom)
        // ═══════════════════════════════════════════

        // Mic level indicator strip
        Rectangle {
            height: 3px;
            background: VxTheme.bg-card;
            Rectangle {
                width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                height: parent.height;
                background: root.is-muted ? VxTheme.danger :
                            root.is-deafened ? VxTheme.text-muted :
                            root.mic-level > 0.15 ? VxTheme.warning :
                            root.mic-level > 0.05 ? VxTheme.success : VxTheme.accent;
                animate width { duration: 50ms; }
            }
        }

        Rectangle {
            height: 56px * VxTheme.s;
            background: VxTheme.bg-card;
            border-color: VxTheme.border-subtle;

            // Top border
            Rectangle {
                width: parent.width;
                height: 1px;
                background: VxTheme.border-subtle;
            }

            HorizontalLayout {
                padding-left: root.wide ? 24px : 10px;
                padding-right: root.wide ? 24px : 10px;
                spacing: root.wide ? 10px : 6px;
                alignment: center;

                // Mute
                VxButton {
                    label: root.is-muted ? "Unmute" : "Mute";
                    danger: root.is-muted;
                    soft: !root.is-muted;
                    horizontal-stretch: 1;
                    clicked => { root.toggle-mute(); }
                }

                // Deafen
                VxButton {
                    label: root.is-deafened ? "Undeafen" : "Deafen";
                    soft: true;
                    horizontal-stretch: 1;
                    clicked => { root.toggle-deafen(); }
                }

                // Mic mode
                VxButton {
                    label: root.is-open-mic ? "Open Mic" : "PTT";
                    accent: root.is-open-mic;
                    soft: !root.is-open-mic;
                    horizontal-stretch: 1;
                    clicked => { root.toggle-mic-mode(); }
                }

                // Screen share
                VxButton {
                    label: root.is-sharing-screen ? "Stop" :
                           root.has-screen-share ? "Viewing" : "Share";
                    accent: root.is-sharing-screen;
                    soft: !root.is-sharing-screen;
                    horizontal-stretch: 1;
                    clicked => {
                        if !root.has-screen-share && !root.is-sharing-screen {
                            root.show-share-config = !root.show-share-config;
                        }
                        root.toggle-screen-share();
                    }
                }

                // Settings
                VxButton {
                    label: "Settings";
                    ghost: true;
                    clicked => { root.navigate(2); }
                }

                // Disconnect
                VxButton {
                    label: root.in-space-channel ? "Leave" : "Disconnect";
                    danger: true;
                    clicked => {
                        if root.in-space-channel {
                            root.leave-channel();
                        } else {
                            root.leave-room();
                        }
                    }
                }
            }
        }
    }
}
