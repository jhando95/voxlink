import { ListView, ScrollView } from "std-widgets.slint";
import { ParticipantData, ShareSourceData, SoundboardClipData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, SectionLabel, VxAvatar, VxButton, VxCard, VxGlyphTile, VxLogoBig, VxOptionRow, VxSlider, VxStatusPill } from "../components.slint";

export component RoomView inherits Rectangle {
    in property <bool> wide: false;
    in property <string> room-code: "";
    in property <[ParticipantData]> participants: [];
    in property <bool> is-connected: false;
    in property <string> status-text: "";
    in property <string> room-status: "";
    in property <bool> is-muted: false;
    in property <bool> is-deafened: false;
    in property <bool> talking-while-muted: false;
    in property <bool> is-open-mic: true;
    in property <float> mic-level: 0.0;
    in property <string> ptt-key-display: "";
    in property <string> mute-key-display: "";
    in property <string> deafen-key-display: "";
    in property <int> ping-ms: -1;
    in property <bool> udp-active: false;
    in property <int> reconnect-attempts: 0;
    in property <int> dropped-frames: 0;
    in property <int> bandwidth-up-kbps: 0;
    in property <int> bandwidth-down-kbps: 0;
    in property <string> session-data-mb: "0.0";
    in property <string> est-data-per-hour: "";
    in property <bool> in-space-channel: false;
    in property <string> current-space-name: "";
    in property <string> channel-topic: "";
    in property <bool> has-screen-share: false;
    in property <bool> is-sharing-screen: false;
    in property <string> screen-share-owner-name: "";
    in property <image> screen-share-image;
    in property <[ShareSourceData]> screen-share-sources: [];
    in property <int> selected-screen-share-source: -1;
    in property <int> selected-screen-share-profile: 0;
    in property <string> screen-share-source-label: "";
    in property <string> screen-share-source-detail: "";
    in property <string> screen-share-quality-label: "";
    in property <string> screen-share-quality-detail: "";
    in-out property <bool> show-copied: false;
    in-out property <string> selected-peer-id: "";
    in-out property <float> selected-peer-volume: 1.0;
    // EQ slider values: 0.0 = -6dB, 0.5 = 0dB (flat), 1.0 = +6dB
    in-out property <float> selected-peer-bass: 0.5;
    in-out property <float> selected-peer-mid: 0.5;
    in-out property <float> selected-peer-treble: 0.5;
    // Pan slider value: 0.0 = full left, 0.5 = center, 1.0 = full right
    in-out property <float> selected-peer-pan: 0.5;
    in-out property <bool> show-share-config: false;
    callback copy-room-code();
    callback leave-room();
    callback leave-channel();
    callback toggle-mute();
    callback toggle-deafen();
    callback toggle-mic-mode();
    callback toggle-screen-share();
    callback refresh-screen-share-sources();
    callback select-screen-share-source(int);
    callback select-screen-share-profile(int);
    callback volume-changed(string, float);
    // EQ changed: peer_id, bass (0-1), mid (0-1), treble (0-1)
    callback eq-changed(string, float, float, float);
    // Pan changed: peer_id, pan (0-1 where 0.5=center)
    callback pan-changed(string, float);
    callback navigate(int);
    in property <[SoundboardClipData]> soundboard-clips: [];
    callback play-soundboard-clip(int);
    in-out property <bool> show-soundboard: false;
    in property <bool> recording-active: false;
    in property <string> recording-user: "";

    background: transparent;

    // -- Grid layout helpers --
    property <int> cols:
        root.participants.length <= 1 ? 1 :
        root.participants.length <= 4 ? 2 :
        root.participants.length <= 9 ? 3 : 4;
    property <length> avatar-sz:
        (root.participants.length <= 2 ? 88px :
        root.participants.length <= 4 ? 76px :
        root.participants.length <= 9 ? 64px : 52px) * VxTheme.s;
    property <length> tile-w: root.avatar-sz + 24px * VxTheme.s;
    property <length> tile-h: root.avatar-sz + 40px * VxTheme.s;
    property <length> tile-gap: (root.wide ? 16px : 10px) * VxTheme.s;
    property <int> row-count: root.participants.length <= 0 ? 0 :
        (root.participants.length + root.cols - 1) / root.cols;
    property <length> grid-w: root.cols * root.tile-w + (root.cols - 1) * root.tile-gap;
    property <length> grid-h: root.row-count * root.tile-h + (root.row-count <= 1 ? 0px : (root.row-count - 1) * root.tile-gap);

    VerticalLayout {
        spacing: 0px;

        // ═══════════════════════════════════════════
        //  ZONE 1 — Header bar
        // ═══════════════════════════════════════════
        Rectangle {
            height: 52px * VxTheme.s;
            background: @linear-gradient(180deg,
                VxTheme.bg-card.brighter(VxTheme.dark-mode ? 0.03 : 0.01) 0%,
                VxTheme.bg-card 78%,
                VxTheme.bg-soft.transparentize(VxTheme.dark-mode ? 0.72 : 0.52) 100%);
            border-color: VxTheme.border-subtle;
            border-width: 0px;

            Rectangle {
                x: -parent.width * 0.05;
                width: parent.width * 0.34;
                height: parent.height;
                background: @linear-gradient(125deg, VxTheme.accent-glow 0%, transparent 76%);
                opacity: VxTheme.dark-mode ? 0.9 : 0.62;
            }

            // bottom border
            Rectangle {
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: VxTheme.border-subtle;
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 12px;
                alignment: center;

                // Left: channel/room info
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 1px;
                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;
                        Text {
                            text: root.in-space-channel ? "# " + root.room-code : root.room-code;
                            color: VxTheme.text-primary;
                            font-size: 14px;
                            font-weight: 700;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                        if root.in-space-channel && root.current-space-name != "" : Text {
                            text: "· " + root.current-space-name;
                            color: VxTheme.text-muted;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    if root.channel-topic != "" : Text {
                        text: root.channel-topic;
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        overflow: elide;
                    }
                }

                // Center: status
                if !root.is-connected : VxStatusPill {
                    label: "Reconnecting" + (root.reconnect-attempts > 0 ? " (" + root.reconnect-attempts + ")" : "");
                    tone: VxTheme.danger;
                    fill: VxTheme.mute-badge-bg;
                }

                if root.talking-while-muted : VxStatusPill {
                    label: "You're muted";
                    tone: VxTheme.warning;
                    fill: VxTheme.warning-soft;
                }

                // Recording indicator — pulsing red pill
                if root.recording-active : Rectangle {
                    height: 24px;
                    border-radius: VxTheme.radius-pill;
                    background: VxTheme.danger.transparentize(VxTheme.dark-mode ? 0.9 : 0.92);
                    border-color: VxTheme.danger.transparentize(0.45);
                    border-width: 1px;
                    width: rec-layout.preferred-width;

                    rec-layout := HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;

                        // Pulsing red dot
                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: VxTheme.danger;
                            opacity: 0.5 + 0.5 * Math.sin(animation-tick() / 600ms * 360deg);
                        }
                        Text {
                            text: "REC";
                            color: VxTheme.danger;
                            font-size: 10px;
                            font-weight: 800;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.recording-user;
                            color: VxTheme.text-secondary;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }

                // PTT state indicator — shows when push-to-talk is active
                if !root.is-open-mic && !root.is-muted && !root.is-deafened : VxStatusPill {
                    label: "Transmitting  " + root.ptt-key-display;
                    tone: VxTheme.success;
                    fill: VxTheme.success-dim;
                }
                if !root.is-open-mic && root.is-muted && !root.talking-while-muted : VxStatusPill {
                    label: "PTT  " + root.ptt-key-display;
                    tone: VxTheme.text-muted;
                    fill: VxTheme.bg-soft;
                }

                // Right: participant count + copy button
                HorizontalLayout {
                    spacing: 10px;
                    alignment: center;

                    Text {
                        text: root.participants.length + "";
                        color: VxTheme.text-secondary;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }

                    // Copy code button
                    VxButton {
                        label: root.show-copied ? "Copied" : "Copy";
                        small: true;
                        ghost: true;
                        clicked => {
                            root.copy-room-code();
                            root.show-copied = true;
                        }
                    }
                }
            }
        }

        // ═══════════════════════════════════════════
        //  ZONE 2 — Stage area
        // ═══════════════════════════════════════════
        Rectangle {
            vertical-stretch: 1;
            background: @linear-gradient(180deg,
                VxTheme.bg-stage.brighter(VxTheme.dark-mode ? 0.02 : 0.00) 0%,
                VxTheme.bg-stage 62%,
                VxTheme.bg-panel 100%);

            Rectangle {
                x: -parent.width * 0.08;
                y: 0px;
                width: parent.width * 0.48;
                height: parent.height * 0.28;
                background: @linear-gradient(135deg, VxTheme.accent-glow 0%, transparent 74%);
                opacity: VxTheme.dark-mode ? 0.65 : 0.42;
            }

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Screen share: when active, takes over the stage
                if root.has-screen-share && !root.is-sharing-screen : Rectangle {
                    vertical-stretch: 1;
                    border-radius: VxTheme.radius-card;
                    background: VxTheme.bg-stage;
                    border-color: VxTheme.accent-border;
                    border-width: 1px;
                    clip: true;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.screen-share-image;
                        image-fit: contain;
                    }

                    // Sharer badge overlaid top-left
                    Rectangle {
                        x: 8px;
                        y: 8px;
                        height: 24px;
                        width: share-label.preferred-width + 20px;
                        border-radius: 12px;
                        background: VxTheme.bg-panel.transparentize(0.2);
                        share-label := Text {
                            text: root.screen-share-owner-name + " is sharing";
                            color: VxTheme.success;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                            max-width: 120px;
                        }
                    }
                }

                // Self-stream preview: when YOU are sharing, show a preview of your stream
                if root.is-sharing-screen : Rectangle {
                    vertical-stretch: 1;
                    border-radius: VxTheme.radius-card;
                    background: VxTheme.bg-stage;
                    border-color: VxTheme.success.transparentize(0.5);
                    border-width: 2px;
                    clip: true;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.screen-share-image;
                        image-fit: contain;
                    }

                    // "You are sharing" badge top-left
                    Rectangle {
                        x: 8px;
                        y: 8px;
                        height: 26px;
                        width: self-share-row.preferred-width + 20px;
                        border-radius: 13px;
                        background: VxTheme.success.transparentize(0.15);

                        self-share-row := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: white;
                                animate opacity { duration: 800ms; }
                                opacity: mod(animation-tick() / 800ms, 2) < 1 ? 1.0 : 0.3;
                            }
                            Text {
                                text: "LIVE — Your screen";
                                color: white;
                                font-size: 10px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Source info bottom-left
                    if root.screen-share-source-label != "" : Rectangle {
                        x: 8px;
                        y: parent.height - self.height - 8px;
                        height: 22px;
                        width: source-info-text.preferred-width + 16px;
                        border-radius: 11px;
                        background: VxTheme.bg-panel.transparentize(0.2);
                        source-info-text := Text {
                            text: root.screen-share-source-label;
                            color: VxTheme.text-secondary;
                            font-size: 9px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                            max-width: 200px;
                        }
                    }

                    // Stop button bottom-right
                    Rectangle {
                        x: parent.width - self.width - 8px;
                        y: parent.height - self.height - 8px;
                        width: stop-share-text.preferred-width + 24px;
                        height: 28px;
                        border-radius: 14px;
                        background: stop-touch.has-hover ? VxTheme.danger : VxTheme.danger.transparentize(0.15);
                        stop-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.toggle-screen-share(); }
                        }
                        stop-share-text := Text {
                            text: "Stop Sharing";
                            color: white;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // When screen share is active, show participants as a compact row below
                if root.has-screen-share : VxCard {
                    VerticalLayout {
                        padding: 10px;
                        spacing: 8px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "LIVE PARTICIPANTS"; }
                            VxStatusPill {
                                label: root.participants.length + " connected";
                                tone: VxTheme.success;
                                fill: VxTheme.success-dim;
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;

                            for p[idx] in root.participants : Rectangle {
                                width: 46px;
                                height: 52px;

                                VxAvatar {
                                    x: (parent.width - self.width) / 2;
                                    y: 0px;
                                    avatar-size: 34px;
                                    initial: p.initial;
                                    color-index: p.color-index;
                                    is-speaking: p.is-speaking;
                                }
                                Text {
                                    y: 36px;
                                    width: parent.width;
                                    text: p.id == "self" ? "You" : p.name;
                                    color: p.is-speaking ? VxTheme.success : VxTheme.text-secondary;
                                    font-size: 9px;
                                    font-weight: p.is-speaking ? 800 : 600;
                                    horizontal-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }

                // No screen share: avatar grid is the stage
                if !root.has-screen-share : Rectangle {
                    vertical-stretch: 1;

                    // Empty state
                    if root.participants.length <= 1 : VerticalLayout {
                        alignment: center;
                        spacing: 14px;
                        padding: 24px;

                        VxCard {
                            width: clamp(root.width * 0.50, 300px, 460px);

                            VerticalLayout {
                                padding: 22px;
                                spacing: 14px;
                                alignment: center;

                                if root.participants.length == 1 : VxAvatar {
                                    avatar-size: 84px;
                                    initial: root.participants[0].initial;
                                    color-index: root.participants[0].color-index;
                                    is-speaking: root.participants[0].is-speaking;
                                }
                                if root.participants.length == 0 : VxLogoBig {
                                    width: 64px;
                                    height: 64px;
                                }

                                Text {
                                    text: root.participants.length == 1
                                        ? (root.participants[0].id == "self" ? root.participants[0].name + " · You" : root.participants[0].name)
                                        : "Voice stage ready";
                                    color: VxTheme.text-primary;
                                    font-size: 15px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                // Audio level meter for solo view
                                if root.participants.length == 1 : Rectangle {
                                    height: 4px;
                                    width: 160px;
                                    x: (parent.width - self.width) / 2;
                                    border-radius: 2px;
                                    background: VxTheme.bg-raised;

                                    Rectangle {
                                        width: parent.width * clamp(root.participants[0].audio-level / 100.0, 0.0, 1.0);
                                        height: parent.height;
                                        border-radius: 2px;
                                        background: root.participants[0].audio-level > 80 ? VxTheme.danger :
                                                    root.participants[0].audio-level > 60 ? VxTheme.warning :
                                                    VxTheme.success;
                                        animate width { duration: 60ms; }
                                        animate background { duration: 200ms; }
                                    }
                                }

                                Text {
                                    text: root.in-space-channel
                                        ? "You’re live in the channel. The stage will fill as people join."
                                        : "Your room is ready. Copy the code or wait for others to drop in.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: center;

                                    if root.room-code != "" : VxStatusPill {
                                        label: root.in-space-channel ? "# " + root.room-code : "Room " + root.room-code;
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }
                                    VxStatusPill {
                                        label: root.is-open-mic ? "Open mic" : "Push to talk";
                                        tone: root.is-open-mic ? VxTheme.success : VxTheme.warning;
                                        fill: root.is-open-mic ? VxTheme.success-dim : VxTheme.warning-soft;
                                    }
                                }

                                if !root.in-space-channel && root.room-code != "" : VxButton {
                                    label: root.show-copied ? "Copied room code" : "Copy room code";
                                    accent: true;
                                    clicked => {
                                        root.copy-room-code();
                                        root.show-copied = true;
                                    }
                                }
                            }
                        }
                    }

                    // Multi-participant avatar grid (2+ people)
                    if root.participants.length > 1 : Rectangle {
                        // Center the grid
                        property <length> stage-w: self.width;
                        property <length> stage-h: self.height;
                        property <length> offset-x: (stage-w - root.grid-w) / 2;
                        property <length> offset-y: (stage-h - root.grid-h) / 2;

                        for p[idx] in root.participants : Rectangle {
                            x: parent.offset-x + Math.mod(idx, root.cols) * (root.tile-w + root.tile-gap);
                            y: parent.offset-y + Math.floor(idx / root.cols) * (root.tile-h + root.tile-gap);
                            width: root.tile-w;
                            height: root.tile-h;

                            tile-touch := TouchArea {
                                mouse-cursor: p.id != "self" ? pointer : default;
                                clicked => {
                                    if p.id != "self" {
                                        if root.selected-peer-id == p.id {
                                            root.selected-peer-id = "";
                                        } else {
                                            root.selected-peer-id = p.id;
                                            root.selected-peer-volume = p.volume;
                                            root.selected-peer-bass = p.eq-bass;
                                            root.selected-peer-mid = p.eq-mid;
                                            root.selected-peer-treble = p.eq-treble;
                                            root.selected-peer-pan = p.pan;
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 6px;

                                // Avatar with badges
                                Rectangle {
                                    width: root.avatar-sz;
                                    height: root.avatar-sz;
                                    x: (parent.width - self.width) / 2;

                                    // Speaking glow ring (behind avatar)
                                    if p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted) : Rectangle {
                                        x: -4px;
                                        y: -4px;
                                        width: root.avatar-sz + 8px;
                                        height: root.avatar-sz + 8px;
                                        border-radius: (root.avatar-sz + 8px) * VxTheme.avatar-roundness;
                                        background: transparent;
                                        border-color: VxTheme.success.transparentize(0.45);
                                        border-width: 2px;
                                        animate border-color { duration: 200ms; }
                                    }

                                    VxAvatar {
                                        avatar-size: root.avatar-sz;
                                        initial: p.initial;
                                        color-index: p.color-index;
                                        is-speaking: p.is-speaking;
                                    }

                                    // Mute badge (bottom-right corner)
                                    if p.is-muted || (p.id == "self" && root.is-muted) : Rectangle {
                                        x: parent.width - self.width - 2px;
                                        y: parent.height - self.height - 2px;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: VxTheme.danger;
                                        border-color: VxTheme.bg-panel;
                                        border-width: 2px;

                                        // Slash line for mute icon
                                        Rectangle {
                                            x: 5px;
                                            y: 7px;
                                            width: 6px;
                                            height: 2px;
                                            border-radius: 1px;
                                            background: VxTheme.text-inverse;
                                        }
                                    }

                                    // Deafen badge
                                    if p.is-deafened || (p.id == "self" && root.is-deafened) : Rectangle {
                                        x: parent.width - self.width - 2px;
                                        y: 2px;
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 10px;
                                        background: VxTheme.warning;
                                        border-color: VxTheme.bg-panel;
                                        border-width: 2px;

                                        Rectangle {
                                            x: 5px;
                                            y: 7px;
                                            width: 6px;
                                            height: 2px;
                                            border-radius: 1px;
                                            background: VxTheme.text-inverse;
                                        }
                                    }

                                    // Speaking "LIVE" pill (centered above avatar)
                                    if p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted) : Rectangle {
                                        x: (parent.width - self.width) / 2;
                                        y: -8px;
                                        width:
                                            VxTheme.is-party ? 52px :
                                            VxTheme.is-space ? 42px :
                                            VxTheme.is-retro ? 28px :
                                            VxTheme.is-noir  ? 36px :
                                            32px;
                                        height: 16px;
                                        border-radius:
                                            VxTheme.is-retro || VxTheme.is-amber ? 2px : 8px;
                                        background: VxTheme.success;
                                        Text {
                                            text:
                                                VxTheme.is-party ? "HOT MIC" :
                                                VxTheme.is-space ? "COMMS" :
                                                VxTheme.is-retro ? "TX" :
                                                VxTheme.is-amber ? "TX" :
                                                VxTheme.is-noir  ? "On Air" :
                                                VxTheme.is-arctic ? "LIVE" :
                                                "LIVE";
                                            color: VxTheme.text-inverse;
                                            font-size: 8px;
                                            font-weight: 800;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Name
                                Text {
                                    text: p.id == "self"
                                        ? (p.is-priority-speaker ? p.name + " (You) \u{2605}" : p.name + " (You)")
                                        : (p.is-priority-speaker ? p.name + " \u{2605}" : p.name);
                                    color: p.is-priority-speaker ? VxTheme.warning :
                                           p.is-speaking ? VxTheme.success :
                                           root.selected-peer-id == p.id ? VxTheme.accent : VxTheme.text-primary;
                                    font-size: p.is-speaking ? 12px : 11px;
                                    font-weight: p.is-speaking ? 800 : 600;
                                    horizontal-alignment: center;
                                    overflow: elide;
                                    max-width: root.tile-w;
                                }

                                // Audio level meter
                                Rectangle {
                                    height: 3px;
                                    width: root.tile-w - 8px;
                                    x: (parent.width - self.width) / 2;
                                    border-radius: 1.5px;
                                    background: VxTheme.bg-raised;

                                    Rectangle {
                                        width: parent.width * clamp(p.audio-level / 100.0, 0.0, 1.0);
                                        height: parent.height;
                                        border-radius: 1.5px;
                                        background: p.audio-level > 80 ? VxTheme.danger :
                                                    p.audio-level > 60 ? VxTheme.warning :
                                                    VxTheme.success;
                                        animate width { duration: 60ms; }
                                        animate background { duration: 200ms; }
                                    }
                                }
                            }

                            // Hover / speaking highlight
                            Rectangle {
                                width: parent.width;
                                height: parent.height;
                                border-radius: VxTheme.radius-card;
                                background: p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted)
                                    ? VxTheme.success.transparentize(0.92)
                                    : tile-touch.has-hover && p.id != "self" ? VxTheme.row-hover-bg : transparent;
                                border-color: p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted)
                                    ? VxTheme.success.transparentize(0.55)
                                    : root.selected-peer-id == p.id ? VxTheme.accent-border : transparent;
                                border-width: p.is-speaking && !p.is-muted && !(p.id == "self" && root.is-muted)
                                    ? 1px
                                    : root.selected-peer-id == p.id ? 1px : 0px;
                                animate background { duration: 120ms; }
                                animate border-color { duration: 120ms; }
                            }
                        }
                    }
                }

                // Per-peer audio controls (shows when a peer is selected)
                if root.selected-peer-id != "" : VxCard {

                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "PEER MIX"; }
                            HorizontalLayout {
                                spacing: 6px;
                                VxGlyphTile { glyph: "MX"; tone: VxTheme.accent; tile-size: 20px; }
                                VxButton {
                                    label: "Done";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.selected-peer-id = ""; }
                                }
                            }
                        }

                        // Volume row
                        HorizontalLayout {
                            height: 24px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Vol";
                                color: VxTheme.text-secondary;
                                font-size: 10px;
                                font-weight: 600;
                                min-width: 32px;
                                vertical-alignment: center;
                            }

                            VxSlider {
                                horizontal-stretch: 1;
                                value <=> root.selected-peer-volume;
                                changed(val) => {
                                    root.selected-peer-volume = val;
                                    root.volume-changed(root.selected-peer-id, val);
                                }
                            }

                            Text {
                                text: Math.round(root.selected-peer-volume * 100) + "%";
                                color: VxTheme.text-primary;
                                font-size: 10px;
                                font-weight: 700;
                                min-width: 32px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }

                        // Bass EQ row
                        HorizontalLayout {
                            height: 20px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Bass";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                vertical-alignment: center;
                            }

                            VxSlider {
                                horizontal-stretch: 1;
                                value <=> root.selected-peer-bass;
                                changed(val) => {
                                    root.selected-peer-bass = val;
                                    root.eq-changed(root.selected-peer-id, root.selected-peer-bass, root.selected-peer-mid, root.selected-peer-treble);
                                }
                            }

                            Text {
                                text: (Math.round((root.selected-peer-bass - 0.5) * 12) >= 0 ? "+" + Math.round((root.selected-peer-bass - 0.5) * 12) : Math.round((root.selected-peer-bass - 0.5) * 12)) + "dB";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }

                        // Mid EQ row
                        HorizontalLayout {
                            height: 20px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Mid";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                vertical-alignment: center;
                            }

                            VxSlider {
                                horizontal-stretch: 1;
                                value <=> root.selected-peer-mid;
                                changed(val) => {
                                    root.selected-peer-mid = val;
                                    root.eq-changed(root.selected-peer-id, root.selected-peer-bass, root.selected-peer-mid, root.selected-peer-treble);
                                }
                            }

                            Text {
                                text: (Math.round((root.selected-peer-mid - 0.5) * 12) >= 0 ? "+" + Math.round((root.selected-peer-mid - 0.5) * 12) : Math.round((root.selected-peer-mid - 0.5) * 12)) + "dB";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }

                        // Treble EQ row
                        HorizontalLayout {
                            height: 20px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Treble";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                vertical-alignment: center;
                            }

                            VxSlider {
                                horizontal-stretch: 1;
                                value <=> root.selected-peer-treble;
                                changed(val) => {
                                    root.selected-peer-treble = val;
                                    root.eq-changed(root.selected-peer-id, root.selected-peer-bass, root.selected-peer-mid, root.selected-peer-treble);
                                }
                            }

                            Text {
                                text: (Math.round((root.selected-peer-treble - 0.5) * 12) >= 0 ? "+" + Math.round((root.selected-peer-treble - 0.5) * 12) : Math.round((root.selected-peer-treble - 0.5) * 12)) + "dB";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }

                        // Pan row
                        HorizontalLayout {
                            height: 20px;
                            spacing: 8px;
                            alignment: center;

                            Text {
                                text: "Pan";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                vertical-alignment: center;
                            }

                            VxSlider {
                                horizontal-stretch: 1;
                                value <=> root.selected-peer-pan;
                                changed(val) => {
                                    root.selected-peer-pan = val;
                                    root.pan-changed(root.selected-peer-id, val);
                                }
                            }

                            Text {
                                text: {
                                    Math.round((root.selected-peer-pan - 0.5) * 200) == 0 ? "C" :
                                    Math.round((root.selected-peer-pan - 0.5) * 200) < 0 ?
                                        "L" + Math.round((0.5 - root.selected-peer-pan) * 200) :
                                        "R" + Math.round((root.selected-peer-pan - 0.5) * 200);
                                }
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 600;
                                min-width: 32px;
                                horizontal-alignment: right;
                                vertical-alignment: center;
                            }
                        }

                    }
                }

                // Screen share configuration (expandable)
                if root.show-share-config : VxCard {
                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "SHARE SOURCE"; }
                            HorizontalLayout {
                                spacing: 8px;
                                VxButton {
                                    label: "Refresh";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.refresh-screen-share-sources(); }
                                }
                                VxButton {
                                    label: "Close";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.show-share-config = false; }
                                }
                            }
                        }

                        Rectangle {
                            height: 120px;
                            clip: true;
                            if root.screen-share-sources.length > 0 : ListView {
                                for source[idx] in root.screen-share-sources : VxOptionRow {
                                    label: source.label;
                                    detail: source.kind-label + " · " + source.detail;
                                    selected: idx == root.selected-screen-share-source;
                                    clicked => { root.select-screen-share-source(idx); }
                                }
                            }
                            if root.screen-share-sources.length == 0 : VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "No sources — click Refresh";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        SectionLabel { text: "STREAM PROFILE"; }
                        VxOptionRow {
                            label: "Efficient";
                            detail: "Up to 540p / 8 fps";
                            selected: root.selected-screen-share-profile == 0;
                            clicked => { root.select-screen-share-profile(0); }
                        }
                        VxOptionRow {
                            label: "Balanced";
                            detail: "Up to 720p / 15 fps";
                            selected: root.selected-screen-share-profile == 1;
                            clicked => { root.select-screen-share-profile(1); }
                        }
                        VxOptionRow {
                            label: "Smooth";
                            detail: "Up to 720p / 30 fps";
                            selected: root.selected-screen-share-profile == 2;
                            clicked => { root.select-screen-share-profile(2); }
                        }
                        VxOptionRow {
                            label: "Max";
                            detail: "Up to 720p / 60 fps";
                            selected: root.selected-screen-share-profile == 3;
                            clicked => { root.select-screen-share-profile(3); }
                        }
                    }
                }
            }
        }

        // ═══════════════════════════════════════════
        //  CONNECTION STATUS BAR
        // ═══════════════════════════════════════════
        Rectangle {
            height: 28px * VxTheme.s;
            background: VxTheme.bg-card;
            border-color: VxTheme.border-subtle;
            border-width: 0px;

            // Top border
            Rectangle {
                y: 0px;
                width: parent.width;
                height: 1px;
                background: VxTheme.border-subtle;
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 10px;
                alignment: center;

                // Connection quality dot
                Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: !root.is-connected ? VxTheme.danger :
                                root.reconnect-attempts > 0 ? VxTheme.danger :
                                root.ping-ms < 0 ? VxTheme.text-muted :
                                root.ping-ms < 100 ? VxTheme.success :
                                root.ping-ms < 200 ? VxTheme.warning : VxTheme.danger;
                    opacity: !root.is-connected || root.reconnect-attempts > 0
                        ? 0.4 + 0.6 * Math.abs(Math.sin(animation-tick() / 800ms * 360deg))
                        : 1.0;
                }

                // Connection label
                Text {
                    text: !root.is-connected
                        ? "Reconnecting" + (root.reconnect-attempts > 0 ? " (" + root.reconnect-attempts + ")" : "...")
                        : root.ping-ms < 0 ? "Connecting..."
                        : root.ping-ms < 100 ? "Connected"
                        : root.ping-ms < 200 ? "Unstable"
                        : "Poor connection";
                    color: !root.is-connected || root.reconnect-attempts > 0 ? VxTheme.danger :
                           root.ping-ms < 0 ? VxTheme.text-muted :
                           root.ping-ms < 100 ? VxTheme.success :
                           root.ping-ms < 200 ? VxTheme.warning : VxTheme.danger;
                    font-size: 10px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                // Ping value
                if root.ping-ms >= 0 : Text {
                    text: root.ping-ms + "ms";
                    color: root.ping-ms < 100 ? VxTheme.text-muted :
                           root.ping-ms < 200 ? VxTheme.warning : VxTheme.danger;
                    font-size: 10px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                // Separator
                if root.ping-ms >= 0 : Rectangle {
                    width: 1px;
                    height: 12px;
                    background: VxTheme.border-subtle;
                }

                // Protocol badge
                Rectangle {
                    width: proto-text.preferred-width + 10px;
                    height: 16px;
                    border-radius: 3px;
                    background: root.udp-active
                        ? VxTheme.success.transparentize(0.85)
                        : VxTheme.text-muted.transparentize(0.85);
                    border-color: root.udp-active
                        ? VxTheme.success.transparentize(0.6)
                        : VxTheme.border-subtle;
                    border-width: 1px;

                    proto-text := Text {
                        text: root.udp-active ? "UDP" : "WS";
                        color: root.udp-active ? VxTheme.success : VxTheme.text-muted;
                        font-size: 9px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Dropped frames (only show if > 0)
                if root.dropped-frames > 0 : HorizontalLayout {
                    spacing: 4px;
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 12px;
                        background: VxTheme.border-subtle;
                    }
                    Text {
                        text: root.dropped-frames + " dropped";
                        color: VxTheme.warning;
                        font-size: 9px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Bandwidth display — separator + up/down kbps
                if root.bandwidth-up-kbps > 0 || root.bandwidth-down-kbps > 0 : HorizontalLayout {
                    spacing: 4px;
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 12px;
                        background: VxTheme.border-subtle;
                    }
                    Text {
                        text: "\u{2191}" + root.bandwidth-up-kbps + "  \u{2193}" + root.bandwidth-down-kbps + " kbps";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                // Session total + estimated per hour
                if root.session-data-mb != "0.0" : HorizontalLayout {
                    spacing: 4px;
                    alignment: center;
                    Rectangle {
                        width: 1px;
                        height: 12px;
                        background: VxTheme.border-subtle;
                    }
                    Text {
                        text: root.session-data-mb + " MB" + (root.est-data-per-hour != "" ? "  \u{b7}  " + root.est-data-per-hour : "");
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ═══════════════════════════════════════════
        //  ZONE 3 — Control bar (pinned bottom)
        // ═══════════════════════════════════════════

        // Mic level indicator strip
        Rectangle {
            height: 3px;
            background: VxTheme.bg-card;
            Rectangle {
                width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                height: parent.height;
                background: root.is-muted ? VxTheme.danger :
                            root.is-deafened ? VxTheme.text-muted :
                            root.mic-level > 0.15 ? VxTheme.warning :
                            root.mic-level > 0.05 ? VxTheme.success : VxTheme.accent;
                animate width { duration: 50ms; }
            }
        }

        Rectangle {
            height: 56px * VxTheme.s;
            background: VxTheme.bg-card;
            border-color: VxTheme.border-subtle;

            // Soundboard quick-panel
            if root.show-soundboard && root.soundboard-clips.length > 0 : Rectangle {
                background: VxTheme.bg-panel;
                border-color: VxTheme.border-subtle;
                border-width: 1px;
                height: 44px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 6px;
                    alignment: center;
                    Text {
                        text: "SFX";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    for clip[idx] in root.soundboard-clips : VxButton {
                        label: clip.name;
                        small: true;
                        soft: true;
                        clicked => { root.play-soundboard-clip(idx); }
                    }
                }
            }

            // Top border
            Rectangle {
                width: parent.width;
                height: 1px;
                background: VxTheme.border-subtle;
            }

            HorizontalLayout {
                padding-left: root.wide ? 24px : 10px;
                padding-right: root.wide ? 24px : 10px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 0px;
                alignment: center;

                // ── Group 1: Audio controls ──
                HorizontalLayout {
                    spacing: root.wide ? 6px : 4px;
                    horizontal-stretch: 3;

                    VxButton {
                        label: root.wide && root.mute-key-display != ""
                            ? (root.is-muted ? "Unmute" : "Mute") + "  [" + root.mute-key-display + "]"
                            : (root.is-muted ? "Unmute" : "Mute");
                        danger: root.is-muted;
                        soft: !root.is-muted;
                        horizontal-stretch: 1;
                        clicked => { root.toggle-mute(); }
                    }
                    VxButton {
                        label: root.wide && root.deafen-key-display != ""
                            ? (root.is-deafened ? "Undeafen" : "Deafen") + "  [" + root.deafen-key-display + "]"
                            : (root.is-deafened ? "Undeafen" : "Deafen");
                        soft: true;
                        horizontal-stretch: 1;
                        clicked => { root.toggle-deafen(); }
                    }
                    VxButton {
                        label: root.is-open-mic ? "Open Mic" : "PTT";
                        accent: root.is-open-mic;
                        soft: !root.is-open-mic;
                        horizontal-stretch: 1;
                        clicked => { root.toggle-mic-mode(); }
                    }
                }

                // Separator
                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: VxTheme.border-subtle;
                }

                // ── Group 2: Media & extras ──
                HorizontalLayout {
                    padding-left: root.wide ? 8px : 4px;
                    padding-right: root.wide ? 8px : 4px;
                    spacing: root.wide ? 6px : 4px;
                    horizontal-stretch: 2;

                    VxButton {
                        label: root.is-sharing-screen ? "Stop" :
                               root.has-screen-share ? "Viewing" : "Share";
                        accent: root.is-sharing-screen;
                        soft: !root.is-sharing-screen;
                        horizontal-stretch: 1;
                        clicked => {
                            if !root.has-screen-share && !root.is-sharing-screen {
                                root.show-share-config = !root.show-share-config;
                            }
                            root.toggle-screen-share();
                        }
                    }
                    if root.soundboard-clips.length > 0 : VxButton {
                        label: "SFX";
                        accent: root.show-soundboard;
                        soft: !root.show-soundboard;
                        horizontal-stretch: 1;
                        clicked => { root.show-soundboard = !root.show-soundboard; }
                    }
                }

                // Separator
                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: VxTheme.border-subtle;
                }

                // ── Group 3: Navigation ──
                HorizontalLayout {
                    padding-left: root.wide ? 8px : 4px;
                    spacing: root.wide ? 6px : 4px;

                    VxButton {
                        label: "Settings";
                        ghost: true;
                        clicked => { root.navigate(2); }
                    }
                    VxButton {
                        label: root.in-space-channel ? "Leave" : "Disconnect";
                        danger: true;
                        clicked => {
                            if root.in-space-channel {
                                root.leave-channel();
                            } else {
                                root.leave-room();
                            }
                        }
                    }
                }
            }
        }
    }
}
