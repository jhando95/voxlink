import { ScrollView } from "std-widgets.slint";
import { ChatMessage, VxTheme } from "../theme.slint";
import { Divider, SectionLabel, VxAvatar, VxButton, VxCard, VxGlyphTile, VxInput, VxLogoBig, VxStatusPill } from "../components.slint";

export component ChatView inherits Rectangle {
    in property <bool> wide: false;
    in property <bool> compact-mode: false;
    in property <string> current-space-name: "";
    in property <string> chat-channel-name: "";
    in property <bool> chat-is-direct-message: false;
    in property <string> chat-context-subtitle: "";
    in property <int> chat-back-view: 4;
    in property <[ChatMessage]> chat-messages: [];
    in property <[ChatMessage]> chat-pinned-messages: [];
    in-out property <string> chat-input: "";
    in property <string> chat-typing-text: "";
    in-out property <string> editing-message-id: "";
    in-out property <string> editing-original-content: "";
    in-out property <string> reply-target-message-id: "";
    in-out property <string> reply-target-sender-name: "";
    in-out property <string> reply-target-preview: "";
    in property <[ChatMessage]> chat-search-results: [];
    in-out property <string> chat-search-query: "";
    callback search-messages(string);
    in property <[string]> recent-reactions: [];
    in property <int> typing-dot-phase: 0;

    // Thread panel
    in property <[ChatMessage]> thread-messages: [];
    in-out property <bool> thread-panel-visible: false;
    in property <string> thread-parent-sender: "";
    in property <string> thread-parent-content: "";
    in property <string> thread-parent-timestamp: "";
    callback open-thread(string, string);
    callback close-thread();

    // Slow mode countdown
    in property <int> slow-mode-secs: 0;
    in-out property <int> slow-mode-remaining: 0;

    // Mention autocomplete
    in property <bool> mention-popup-visible: false;
    in property <[string]> mention-suggestions: [];
    in-out property <int> mention-selected-index: 0;
    callback mention-input-changed(string);
    callback mention-selected(int);

    property <bool> show-pinned-panel: true;
    property <bool> show-search-panel: false;
    property <bool> show-emoji-picker: false;
    property <string> emoji-picker-target-message-id: "";
    property <int> emoji-tab: 0; // 0=Recent 1=Smileys 2=People 3=Nature 4=Food 5=Objects 6=Symbols
    property <string> emoji-search-text: "";
    property <bool> typing-active: false;
    property <length> side-panel-width: clamp(root.width * 0.28, 280px, 336px);
    property <length> emoji-picker-width: clamp(root.width * 0.34, 300px, 360px);
    property <length> emoji-picker-height: clamp(root.height * 0.52, 320px, 400px);
    property <bool> show-chat-meta: root.wide && !root.compact-mode;
    changed chat-input => {
        let next = root.chat-input != "";
        if next != root.typing-active {
            root.typing-active = next;
            root.chat-typing-activity(next);
        }
        // Notify Rust side for mention autocomplete detection
        root.mention-input-changed(root.chat-input);
    }
    callback navigate(int);
    callback chat-typing-activity(bool);
    callback send-text-message();
    callback edit-text-message(string, string);
    callback delete-text-message(string);
    callback react-to-message(string, string);
    callback toggle-pin-message(string, bool);
    callback forward-message(string); // message_id
    callback copy-message-text(string); // message content
    callback show-profile(string); // user_id

    background: transparent;

    HorizontalLayout {
    VerticalLayout {
        horizontal-stretch: 1;
        spacing: 4px;
        padding: root.wide ? 10px : 8px;
        padding-bottom: root.wide ? 8px : 6px;

        HorizontalLayout {
            alignment: space-between;
            spacing: 8px;

            HorizontalLayout {
                min-width: 0px;
                horizontal-stretch: 1;
                alignment: start;
                spacing: 8px;
                VxGlyphTile {
                    tile-size: 30px;
                    glyph: root.chat-is-direct-message ? "DM" : "TX";
                    tone: root.chat-is-direct-message ? VxTheme.warning : VxTheme.accent;
                }
                Text {
                    text: root.chat-channel-name;
                    color: VxTheme.text-primary;
                    font-size: 16px;
                    font-weight: 700;
                    overflow: elide;
                    horizontal-stretch: 1;
                    min-width: 0px;
                    max-width: root.wide ? 360px : 220px;
                    vertical-alignment: center;
                }
                if root.show-chat-meta && (root.chat-context-subtitle != "" || !root.chat-is-direct-message) : Text {
                    text: root.chat-context-subtitle != ""
                        ? root.chat-context-subtitle
                        : (root.current-space-name != "" ? root.current-space-name : "Text chat");
                    color: VxTheme.text-muted;
                    font-size: 10px;
                    vertical-alignment: center;
                }
                if root.show-chat-meta : VxStatusPill {
                    label: root.chat-messages.length + " messages";
                    tone: VxTheme.accent;
                    fill: VxTheme.accent-subtle;
                }
            }

            HorizontalLayout {
                spacing: 6px;
                VxButton {
                    label: "Back";
                    glyph: "BK";
                    small: true;
                    soft: true;
                    clicked => { root.navigate(root.chat-back-view); }
                }
                if !root.chat-is-direct-message : VxButton {
                    label: root.show-search-panel ? "Close" : "Search";
                    glyph: root.show-search-panel ? "CL" : "SR";
                    small: true;
                    soft: true;
                    clicked => {
                        root.show-search-panel = !root.show-search-panel;
                        if !root.show-search-panel {
                            root.chat-search-query = "";
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 6px;
            padding-left: 2px;

            if !root.chat-is-direct-message && root.chat-pinned-messages.length > 0 : Rectangle {
                height: 22px;
                pinned-toggle-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.show-pinned-panel = !root.show-pinned-panel; }
                }
                VxStatusPill {
                    label: (root.show-pinned-panel ? "Hide " : "") + root.chat-pinned-messages.length + " pinned";
                    tone: VxTheme.warning;
                    fill: pinned-toggle-touch.has-hover
                        ? VxTheme.card-hover-bg
                        : VxTheme.warning-soft;
                }
            }
            if root.reply-target-message-id != "" : VxStatusPill {
                label: "Replying to " + root.reply-target-sender-name;
                tone: VxTheme.accent;
                fill: VxTheme.accent-subtle;
            }
            if root.chat-typing-text != "" : VxStatusPill {
                label: root.chat-typing-text;
                tone: VxTheme.success;
                fill: VxTheme.success-dim;
            }
        }

        VxCard {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 0px;
                vertical-stretch: 1;

                if root.editing-message-id != "" : Rectangle {
                    background: VxTheme.accent-subtle;
                    border-color: VxTheme.accent-border;
                    border-width: 0px;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 10px;
                        padding-bottom: 10px;
                        spacing: 10px;
                        Text {
                            text: "Editing message";
                            color: VxTheme.accent;
                            font-size: 10px;
                            font-weight: 700;
                            horizontal-stretch: 1;
                        }
                        VxButton {
                            label: "Cancel";
                            glyph: "CN";
                            small: true;
                            ghost: true;
                            clicked => {
                                root.editing-message-id = "";
                                root.editing-original-content = "";
                                root.chat-input = "";
                            }
                        }
                    }
                }

                Divider {}

                if !root.chat-is-direct-message && root.chat-pinned-messages.length > 0 && root.show-pinned-panel : Rectangle {
                    background: VxTheme.bg-soft;
                    max-height: 120px;
                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 8px;

                        HorizontalLayout {
                            spacing: 8px;
                            SectionLabel { text: "PINNED"; }
                            VxStatusPill {
                                label: root.chat-pinned-messages.length + " saved";
                                tone: VxTheme.warning;
                                fill: VxTheme.warning-soft;
                            }
                        }

                        for pinned in root.chat-pinned-messages : Rectangle {
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.bg-panel;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: pinned.sender-name;
                                    color: VxTheme.text-primary;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: pinned.content;
                                    color: VxTheme.text-secondary;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                    max-height: 28px;
                                }
                            }
                        }
                    }
                }

                if root.show-search-panel : Rectangle {
                    background: VxTheme.bg-soft;
                    VerticalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 8px;

                        HorizontalLayout {
                            spacing: 8px;
                            SectionLabel { text: "SEARCH"; }
                            VxStatusPill {
                                label: root.chat-search-results.length + " results";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            search-input := VxInput {
                                placeholder: "Search messages...";
                                text <=> root.chat-search-query;
                                horizontal-stretch: 1;
                                accepted => {
                                    if root.chat-search-query != "" {
                                        root.search-messages(root.chat-search-query);
                                    }
                                }
                            }
                            VxButton {
                                label: "Go";
                                glyph: "GO";
                                small: true;
                                clicked => {
                                    if root.chat-search-query != "" {
                                        root.search-messages(root.chat-search-query);
                                    }
                                }
                            }
                        }

                        for result in root.chat-search-results : Rectangle {
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.bg-panel;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;

                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                HorizontalLayout {
                                    spacing: 6px;
                                    if result.channel-name != "" : Rectangle {
                                        background: VxTheme.accent-subtle;
                                        border-radius: VxTheme.radius-pill;
                                        height: 16px;
                                        width: ch-badge-txt.preferred-width + 12px;

                                        ch-badge-txt := Text {
                                            text: "#" + result.channel-name;
                                            color: VxTheme.accent;
                                            font-size: 8px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: result.sender-name;
                                        color: VxTheme.text-primary;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: result.timestamp;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                                Text {
                                    text: result.content;
                                    color: VxTheme.text-secondary;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                    max-height: 42px;
                                }
                            }
                        }
                    }
                }

                Divider {}

                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: root.wide ? 14px : (root.compact-mode ? 6px : 10px);
                        spacing: root.compact-mode ? 2px : 5px;

                        if root.chat-messages.length == 0 : VerticalLayout {
                            alignment: center;
                            vertical-stretch: 1;
                            spacing: 10px;
                            padding: 24px;
                            VxCard {
                                width: clamp(root.width * 0.50, 280px, 420px);

                                VerticalLayout {
                                    padding: 22px;
                                    spacing: 14px;
                                    alignment: center;

                                    VxLogoBig {
                                        width: 58px;
                                        height: 58px;
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        alignment: center;

                                        Text {
                                            text: root.chat-is-direct-message
                                                ? "Start the conversation"
                                                : "This channel is ready";
                                            color: VxTheme.text-primary;
                                            font-size: 15px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                        }
                                        Text {
                                            text: root.chat-is-direct-message
                                                ? "Drop the first message and this thread becomes a real conversation."
                                                : "Say hello, drop context, or pin the first thing people should see.";
                                            color: VxTheme.text-muted;
                                            font-size: 10px;
                                            wrap: word-wrap;
                                            horizontal-alignment: center;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: center;

                                        VxStatusPill {
                                            label: root.chat-is-direct-message ? "Direct message" : "Channel chat";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                        if root.chat-channel-name != "" : VxStatusPill {
                                            label: root.chat-is-direct-message ? root.chat-channel-name : "# " + root.chat-channel-name;
                                            tone: VxTheme.text-secondary;
                                            fill: VxTheme.bg-soft;
                                        }
                                    }
                                }
                            }
                        }

                        for msg in root.chat-messages : VerticalLayout {
                            // ─── Date separator ───
                            if msg.date-separator != "" : HorizontalLayout {
                                padding-top: 8px;
                                padding-bottom: 4px;
                                alignment: center;
                                spacing: 10px;
                                Rectangle { height: 1px; background: VxTheme.border-subtle; horizontal-stretch: 1; }
                                Text {
                                    text: msg.date-separator;
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    font-weight: 600;
                                }
                                Rectangle { height: 1px; background: VxTheme.border-subtle; horizontal-stretch: 1; }
                            }

                            // ─── NEW messages separator ───
                            if msg.is-new-separator && msg.date-separator == "" : HorizontalLayout {
                                padding-top: 6px;
                                padding-bottom: 4px;
                                alignment: center;
                                spacing: 10px;
                                Rectangle { height: 1px; background: VxTheme.accent; horizontal-stretch: 1; }
                                Text {
                                    text: "NEW";
                                    color: VxTheme.accent;
                                    font-size: 10px;
                                    font-weight: 700;
                                }
                                Rectangle { height: 1px; background: VxTheme.accent; horizontal-stretch: 1; }
                            }

                            // ─── Message bubble ───
                            if msg.date-separator == "" : Rectangle {
                            border-radius: msg.show-header ? VxTheme.radius-card : VxTheme.radius-control;
                            background: msg-hover.has-hover
                                ? (msg.is-self ? VxTheme.msg-self-bg.darker(0.03) : VxTheme.msg-other-bg.darker(0.03))
                                : (msg.mentions-self && !msg.is-self ? VxTheme.accent-subtle :
                                   msg.is-self ? VxTheme.msg-self-bg : VxTheme.msg-other-bg);
                            border-color: root.editing-message-id == msg.message-id || (msg.mentions-self && !msg.is-self)
                                ? VxTheme.accent-border
                                : msg-hover.has-hover ? VxTheme.border-subtle.darker(0.1) : VxTheme.border-subtle;
                            border-width: msg.show-header ? 1px : 0px;

                            msg-hover := TouchArea {}

                            HorizontalLayout {
                                padding-left: root.compact-mode ? 6px : 10px;
                                padding-right: root.compact-mode ? 6px : 10px;
                                padding-top: msg.show-header ? (root.compact-mode ? 4px : 8px) : 1px;
                                padding-bottom: msg.show-header ? (root.compact-mode ? 4px : 8px) : 1px;
                                spacing: root.compact-mode ? 6px : 10px;

                                if !root.compact-mode && msg.show-header : VxAvatar {
                                    avatar-size: 30px;
                                    initial: msg.sender-initial;
                                    color-index: msg.color-index;
                                }
                                // Spacer — shows timestamp on hover (like Discord)
                                if !root.compact-mode && !msg.show-header : Rectangle {
                                    width: 30px;
                                    Text {
                                        text: msg.timestamp;
                                        color: VxTheme.text-muted;
                                        font-size: 8px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        visible: msg-hover.has-hover;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: root.compact-mode ? 2px : (msg.show-header ? 6px : 2px);

                                    // Sender header — hidden for grouped messages
                                    if msg.show-header : HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle {
                                            width: sender-name-text.preferred-width;
                                            height: sender-name-text.preferred-height;
                                            sender-name-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.show-profile(msg.sender-id); }
                                            }
                                            sender-name-text := Text {
                                                text: msg.sender-name;
                                                color: sender-name-touch.has-hover
                                                    ? VxTheme.accent-hover
                                                    : (msg.is-self ? VxTheme.accent : VxTheme.text-primary);
                                                font-size: 11px;
                                                font-weight: 700;
                                                overflow: elide;
                                                max-width: root.wide ? 260px : 180px;
                                            }
                                        }
                                        Text {
                                            text: msg.timestamp;
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                        }
                                        if msg.is-pinned : VxStatusPill {
                                            label: "Pinned";
                                            tone: VxTheme.warning;
                                            fill: VxTheme.warning-soft;
                                        }
                                        if msg.mentions-self && !msg.is-self : VxStatusPill {
                                            label: "Mentions you";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                        if msg.edited : Text {
                                            text: "(edited)";
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                            font-weight: 500;
                                            font-italic: true;
                                        }
                                    }
                                    // Hover actions row
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle { horizontal-stretch: 1; }

                                        // Compact hover toolbar (Discord-style)
                                        if msg-hover.has-hover : Rectangle {
                                            height: 32px;
                                            border-radius: VxTheme.radius-pill;
                                            background: VxTheme.bg-raised;
                                            border-color: VxTheme.border-subtle;
                                            border-width: 1px;

                                            HorizontalLayout {
                                                padding-left: 3px;
                                                padding-right: 3px;
                                                spacing: 3px;
                                                alignment: center;

                                                // Quick reactions
                                                for emoji in ["\u{1F44D}", "\u{2764}", "\u{1F602}"] : Rectangle {
                                                    width: 26px;
                                                    height: 22px;
                                                    border-radius: VxTheme.radius-pill;
                                                    background: react-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                                                    react-touch := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => { root.react-to-message(msg.message-id, emoji); }
                                                    }
                                                    Text {
                                                        text: emoji;
                                                        font-size: 12px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                                Rectangle {
                                                    width: 26px;
                                                    height: 22px;
                                                    border-radius: VxTheme.radius-pill;
                                                    background: more-emoji-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                                                    more-emoji-touch := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.emoji-picker-target-message-id = msg.message-id;
                                                            root.show-emoji-picker = true;
                                                        }
                                                    }
                                                    Text {
                                                        text: "+";
                                                        font-size: 12px;
                                                        color: VxTheme.text-muted;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }

                                                // Separator
                                                Rectangle { width: 1px; height: 16px; background: VxTheme.border-subtle; }

                                                VxButton {
                                                    label: "Reply";
                                                    glyph: "RP";
                                                    small: true;
                                                    ghost: true;
                                                    clicked => {
                                                        root.editing-message-id = "";
                                                        root.editing-original-content = "";
                                                        root.reply-target-message-id = msg.message-id;
                                                        root.reply-target-sender-name = msg.sender-name;
                                                        root.reply-target-preview = msg.content;
                                                    }
                                                }

                                                VxButton {
                                                    label: "Copy";
                                                    glyph: "CP";
                                                    small: true;
                                                    ghost: true;
                                                    clicked => { root.copy-message-text(msg.content); }
                                                }

                                                if msg.reply-count > 0 : VxButton {
                                                    label: msg.reply-count + " replies";
                                                    glyph: "TH";
                                                    small: true;
                                                    soft: true;
                                                    clicked => { root.open-thread(msg.message-id, msg.channel-name); }
                                                }

                                                if !root.chat-is-direct-message : VxButton {
                                                    label: "Forward";
                                                    glyph: "FW";
                                                    small: true;
                                                    ghost: true;
                                                    clicked => { root.forward-message(msg.message-id); }
                                                }

                                                if !root.chat-is-direct-message : VxButton {
                                                    label: msg.is-pinned ? "Unpin" : "Pin";
                                                    glyph: msg.is-pinned ? "UP" : "PN";
                                                    small: true;
                                                    soft: msg.is-pinned;
                                                    ghost: !msg.is-pinned;
                                                    clicked => { root.toggle-pin-message(msg.message-id, !msg.is-pinned); }
                                                }

                                                if msg.is-self : Rectangle {
                                                    width: 1px; height: 16px; background: VxTheme.border-subtle;
                                                }

                                                if msg.is-self : VxButton {
                                                    label: "Edit";
                                                    glyph: "ED";
                                                    small: true;
                                                    ghost: true;
                                                    clicked => {
                                                        root.editing-message-id = msg.message-id;
                                                        root.editing-original-content = msg.content;
                                                        root.chat-input = msg.content;
                                                    }
                                                }

                                                if msg.is-self : VxButton {
                                                    label: "Delete";
                                                    glyph: "DL";
                                                    small: true;
                                                    soft: true;
                                                    clicked => { root.delete-text-message(msg.message-id); }
                                                }
                                            }
                                        }
                                    }

                                    if msg.forwarded-from != "" : Rectangle {
                                        background: VxTheme.bg-panel;
                                        border-radius: VxTheme.radius-control;
                                        height: 28px;

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            alignment: start;
                                            spacing: 6px;
                                            VxGlyphTile {
                                                tile-size: 18px;
                                                glyph: "FW";
                                                tone: VxTheme.text-secondary;
                                            }
                                            Text {
                                                text: "Forwarded from";
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                                font-weight: 500;
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: msg.forwarded-from;
                                                color: VxTheme.accent;
                                                font-size: 9px;
                                                font-weight: 700;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    if msg.reply-sender-name != "" : Rectangle {
                                        border-radius: VxTheme.radius-control;
                                        background: reply-quote-touch.has-hover ? VxTheme.bg-raised : VxTheme.bg-panel;
                                        border-width: 0px;
                                        height: reply-col.preferred-height + 16px;

                                        reply-quote-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.open-thread(msg.message-id, msg.channel-name); }
                                        }

                                        // Left accent bar
                                        Rectangle {
                                            x: 0px;
                                            y: 2px;
                                            width: 3px;
                                            height: parent.height - 4px;
                                            border-radius: 1.5px;
                                            background: VxTheme.accent;
                                        }

                                        reply-col := VerticalLayout {
                                            padding-top: 8px;
                                            padding-bottom: 8px;
                                            padding-left: 14px;
                                            padding-right: 10px;
                                            spacing: 2px;
                                            Text {
                                                text: msg.reply-sender-name;
                                                color: VxTheme.accent;
                                                font-size: 9px;
                                                font-weight: 700;
                                            }
                                            Text {
                                                text: msg.reply-preview;
                                                color: VxTheme.text-secondary;
                                                font-size: 9px;
                                                wrap: word-wrap;
                                                max-height: 28px;
                                                overflow: elide;
                                            }
                                        }
                                    }

                                    if !msg.is-code-block : Text {
                                        text: msg.content;
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                    }
                                    if msg.is-code-block : Rectangle {
                                        border-radius: VxTheme.radius-control;
                                        background: VxTheme.bg-panel;
                                        border-color: VxTheme.border-subtle;
                                        border-width: 1px;
                                        height: code-text.preferred-height + 16px;
                                        code-text := Text {
                                            x: 8px;
                                            y: 8px;
                                            width: parent.width - 16px;
                                            text: msg.content;
                                            color: VxTheme.text-secondary;
                                            font-size: 11px;
                                            font-family: "monospace";
                                            wrap: word-wrap;
                                        }
                                    }

                                    // Attachment card
                                    if msg.attachment-name != "" : Rectangle {
                                        background: VxTheme.bg-panel;
                                        border-radius: VxTheme.radius-control;
                                        border-width: 1px;
                                        border-color: VxTheme.border-subtle;
                                        height: 52px;

                                        HorizontalLayout {
                                            padding: 10px;
                                            spacing: 10px;

                                            VxGlyphTile { glyph: "FI"; tone: VxTheme.accent; tile-size: 30px; }

                                            VerticalLayout {
                                                spacing: 2px;
                                                alignment: center;

                                                Text {
                                                    text: "Attachment";
                                                    color: VxTheme.text-muted;
                                                    font-size: 8px;
                                                    font-weight: 700;
                                                    letter-spacing: 0.8px;
                                                }
                                                Text {
                                                    text: msg.attachment-name;
                                                    color: VxTheme.accent;
                                                    font-size: 10px;
                                                    font-weight: 600;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: msg.attachment-size;
                                                    color: VxTheme.text-muted;
                                                    font-size: 9px;
                                                }
                                            }
                                        }
                                    }

                                    // Link preview card
                                    if msg.link-url != "" : Rectangle {
                                        background: VxTheme.bg-panel;
                                        border-radius: VxTheme.radius-control;
                                        border-width: 1px;
                                        border-color: VxTheme.accent-border;
                                        height: 44px;

                                        HorizontalLayout {
                                            padding: 8px;
                                            spacing: 8px;

                                            VxGlyphTile { glyph: "LN"; tone: VxTheme.accent; tile-size: 26px; }

                                            VerticalLayout {
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: "Link preview";
                                                    color: VxTheme.text-muted;
                                                    font-size: 8px;
                                                    font-weight: 700;
                                                    letter-spacing: 0.8px;
                                                }
                                                Text {
                                                    text: msg.link-url;
                                                    color: VxTheme.accent;
                                                    font-size: 10px;
                                                    font-weight: 600;
                                                    overflow: elide;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    if msg.reactions != "" : HorizontalLayout {
                                        spacing: 4px;
                                        padding-top: 2px;
                                        // Each reaction pill
                                        Rectangle {
                                            height: 24px;
                                            width: reaction-txt.preferred-width + 14px;
                                            border-radius: VxTheme.radius-pill;
                                            background: rxn-touch.has-hover ? VxTheme.accent-subtle : VxTheme.bg-raised;
                                            border-color: rxn-touch.has-hover ? VxTheme.accent-border : VxTheme.border-subtle;
                                            border-width: 1px;
                                            rxn-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.emoji-picker-target-message-id = msg.message-id;
                                                    root.show-emoji-picker = true;
                                                }
                                            }
                                            reaction-txt := Text {
                                                text: msg.reactions;
                                                color: VxTheme.text-primary;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                        // + add reaction button
                                        Rectangle {
                                            width: 24px; height: 24px;
                                            border-radius: VxTheme.radius-pill;
                                            background: add-rxn.has-hover ? VxTheme.card-hover-bg : transparent;
                                            border-color: add-rxn.has-hover ? VxTheme.border-subtle : transparent;
                                            border-width: 1px;
                                            add-rxn := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.emoji-picker-target-message-id = msg.message-id;
                                                    root.show-emoji-picker = true;
                                                }
                                            }
                                            Text {
                                                text: "+";
                                                color: VxTheme.text-muted;
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        } // end if msg.date-separator == "" Rectangle
                        } // end for msg VerticalLayout
                    }
                }

                Divider {}

                if root.chat-typing-text != "" : Rectangle {
                    background: VxTheme.accent-subtle;
                    height: 28px;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        alignment: start;
                        spacing: 4px;

                        Text {
                            text: root.chat-typing-text;
                            color: VxTheme.accent;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        // Bouncing dot 1
                        Rectangle {
                            width: 5px;
                            height: 5px;
                            y: root.typing-dot-phase == 0 ? 8px : 12px;
                            border-radius: 2.5px;
                            background: VxTheme.accent;
                            opacity: root.typing-dot-phase == 0 ? 1.0 : 0.4;
                            animate y { duration: 200ms; easing: ease-out; }
                            animate opacity { duration: 200ms; }
                        }
                        // Bouncing dot 2
                        Rectangle {
                            width: 5px;
                            height: 5px;
                            y: root.typing-dot-phase == 1 ? 8px : 12px;
                            border-radius: 2.5px;
                            background: VxTheme.accent;
                            opacity: root.typing-dot-phase == 1 ? 1.0 : 0.4;
                            animate y { duration: 200ms; easing: ease-out; }
                            animate opacity { duration: 200ms; }
                        }
                        // Bouncing dot 3
                        Rectangle {
                            width: 5px;
                            height: 5px;
                            y: root.typing-dot-phase == 2 ? 8px : 12px;
                            border-radius: 2.5px;
                            background: VxTheme.accent;
                            opacity: root.typing-dot-phase == 2 ? 1.0 : 0.4;
                            animate y { duration: 200ms; easing: ease-out; }
                            animate opacity { duration: 200ms; }
                        }
                    }
                }

                Rectangle {
                    background: VxTheme.bg-panel;
                    VerticalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 6px;

                        if root.reply-target-message-id != "" : Rectangle {
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.accent-subtle;
                            border-color: VxTheme.accent-border;
                            border-width: 1px;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                padding-top: 10px;
                                padding-bottom: 10px;
                                spacing: 10px;
                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 2px;
                                    Text {
                                        text: "Replying to " + root.reply-target-sender-name;
                                        color: VxTheme.accent;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    Text {
                                        text: root.reply-target-preview;
                                        color: VxTheme.text-secondary;
                                        font-size: 9px;
                                        wrap: word-wrap;
                                        max-height: 24px;
                                    }
                                }
                                VxButton {
                                    label: "Cancel";
                                    glyph: "CN";
                                    small: true;
                                    ghost: true;
                                    clicked => {
                                        root.reply-target-message-id = "";
                                        root.reply-target-sender-name = "";
                                        root.reply-target-preview = "";
                                    }
                                }
                            }
                        }

                        // Slash command hints
                        if root.chat-input == "/" || (root.chat-input != "" && root.chat-input.character-count > 0 && root.chat-input.to-float() != root.chat-input.to-float()) : Rectangle {
                        }
                        if root.chat-input == "/" : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: VxTheme.bg-raised;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                Text { text: "COMMANDS"; color: VxTheme.text-muted; font-size: 8px; font-weight: 700; }
                                for cmd in [
                                    { slash: "/nick", desc: "Set server nickname" },
                                    { slash: "/status", desc: "Set status (online/idle/dnd/invisible)" },
                                    { slash: "/activity", desc: "Set activity text" },
                                    { slash: "/mute", desc: "Toggle mute" },
                                    { slash: "/deafen", desc: "Toggle deafen" },
                                    { slash: "/shrug", desc: "Append \u{00AF}\\_(\u{30C4})_/\u{00AF}" },
                                    { slash: "/tableflip", desc: "Append (\u{256F}\u{00B0}\u{25A1}\u{00B0})\u{256F}\u{FE35} \u{253B}\u{2501}\u{253B}" },
                                    { slash: "/unflip", desc: "Append \u{252C}\u{2500}\u{252C} \u{30CE}( \u{309C}-\u{309C}\u{30CE})" },
                                ] : Rectangle {
                                    height: 26px;
                                    border-radius: VxTheme.radius-control;
                                    background: cmd-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                                    cmd-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.chat-input = cmd.slash + " "; }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 10px;
                                        alignment: center;
                                        Text {
                                            text: cmd.slash;
                                            color: VxTheme.accent;
                                            font-size: 11px;
                                            font-weight: 700;
                                            width: 80px;
                                        }
                                        Text {
                                            text: cmd.desc;
                                            color: VxTheme.text-secondary;
                                            font-size: 10px;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }

                        // Mention autocomplete popup
                        if root.mention-popup-visible && root.mention-suggestions.length > 0 : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: VxTheme.bg-raised;
                            border-color: VxTheme.accent-border;
                            border-width: 1px;
                            VerticalLayout {
                                padding: 6px;
                                spacing: 2px;
                                Text {
                                    text: "MEMBERS";
                                    color: VxTheme.text-muted;
                                    font-size: 8px;
                                    font-weight: 700;
                                    horizontal-alignment: left;
                                }
                                for suggestion[idx] in root.mention-suggestions : Rectangle {
                                    height: idx < 8 ? 28px : 0px;
                                    visible: idx < 8;
                                    border-radius: VxTheme.radius-control;
                                    background: idx == root.mention-selected-index
                                        ? VxTheme.surface-active
                                        : mention-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                                    border-color: idx == root.mention-selected-index ? VxTheme.accent-border : transparent;
                                    border-width: 1px;
                                    animate background { duration: 60ms; easing: ease-out; }
                                    mention-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.mention-selected(idx);
                                        }
                                    }
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 8px;
                                        alignment: center;
                                        VxGlyphTile {
                                            tile-size: 18px;
                                            glyph: "AT";
                                            tone: VxTheme.accent;
                                        }
                                        Text {
                                            text: suggestion;
                                            color: idx == root.mention-selected-index ? VxTheme.accent : VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: 600;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            Rectangle {
                                horizontal-stretch: 1;
                                VxInput {
                                    width: parent.width;
                                    height: parent.height;
                                    text <=> root.chat-input;
                                    placeholder: root.slow-mode-remaining > 0
                                        ? "Slowmode: " + root.slow-mode-remaining + "s"
                                        : root.editing-message-id != "" ? "Edit message" :
                                                 root.reply-target-message-id != "" ? (root.chat-is-direct-message ? "Reply to " + root.chat-channel-name : "Reply in #" + root.chat-channel-name) :
                                                 (root.chat-is-direct-message ? "Message " + root.chat-channel-name : "Message #" + root.chat-channel-name);
                                    accepted => {
                                        if root.chat-input != "" {
                                            if root.editing-message-id != "" {
                                                root.edit-text-message(root.editing-message-id, root.chat-input);
                                                root.editing-message-id = "";
                                                root.editing-original-content = "";
                                                root.chat-input = "";
                                            } else if root.slow-mode-remaining <= 0 {
                                                root.send-text-message();
                                                root.reply-target-message-id = "";
                                                root.reply-target-sender-name = "";
                                                root.reply-target-preview = "";
                                                if root.slow-mode-secs > 0 {
                                                    root.slow-mode-remaining = root.slow-mode-secs;
                                                }
                                            }
                                        }
                                    }
                                }
                                // Character counter — visible when approaching the 2000 char limit
                                if root.chat-input.character-count > 1800 : Rectangle {
                                    x: parent.width - self.width - 6px;
                                    y: parent.height - self.height - 4px;
                                    width: char-counter-text.preferred-width + 10px;
                                    height: 18px;
                                    border-radius: VxTheme.radius-pill;
                                    background: VxTheme.bg-panel.transparentize(0.15);
                                    char-counter-text := Text {
                                        text: root.chat-input.character-count + "/2000";
                                        color: root.chat-input.character-count > 1950 ? VxTheme.danger :
                                               root.chat-input.character-count > 1800 ? VxTheme.warning : VxTheme.text-muted;
                                        font-size: 9px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                width: 38px;
                                height: 36px;
                                border-radius: VxTheme.radius-control;
                                background: emoji-toggle-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                                border-color: root.show-emoji-picker ? VxTheme.accent-border : transparent;
                                border-width: root.show-emoji-picker ? 1px : 0px;
                                emoji-toggle-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.emoji-picker-target-message-id = "";
                                        root.show-emoji-picker = !root.show-emoji-picker;
                                    }
                                }
                                VxGlyphTile {
                                    x: 4px;
                                    y: 3px;
                                    tile-size: 30px;
                                    glyph: "EM";
                                    tone: root.show-emoji-picker ? VxTheme.accent : VxTheme.text-secondary;
                                }
                            }
                            if root.slow-mode-remaining > 0 : VxStatusPill {
                                label: root.slow-mode-remaining + "s";
                                tone: VxTheme.warning;
                                fill: VxTheme.warning-soft;
                            }
                            VxButton {
                                label: root.editing-message-id != "" ? "Save" :
                                       root.reply-target-message-id != "" ? "Reply" : "Send";
                                glyph: root.editing-message-id != "" ? "SV" :
                                       root.reply-target-message-id != "" ? "RP" : "SD";
                                accent: true;
                                enabled: root.chat-input != "" && (root.slow-mode-remaining <= 0 || root.editing-message-id != "");
                                clicked => {
                                    if root.editing-message-id != "" {
                                        root.edit-text-message(root.editing-message-id, root.chat-input);
                                        root.editing-message-id = "";
                                        root.editing-original-content = "";
                                        root.chat-input = "";
                                    } else if root.slow-mode-remaining <= 0 {
                                        root.send-text-message();
                                        root.reply-target-message-id = "";
                                        root.reply-target-sender-name = "";
                                        root.reply-target-preview = "";
                                        if root.slow-mode-secs > 0 {
                                            root.slow-mode-remaining = root.slow-mode-secs;
                                        }
                                    }
                                }
                            }
                        }

                        if !root.chat-is-direct-message : Text {
                            text: root.slow-mode-remaining > 0
                                ? "Slowmode active — " + root.slow-mode-remaining + "s remaining"
                                : "Enter sends · @name mentions · **bold** · *italic*";
                            color: root.slow-mode-remaining > 0 ? VxTheme.warning : VxTheme.text-muted;
                            font-size: 9px;
                        }
                    }
                }
            }
        }
    } // end main VerticalLayout

        // Thread side panel
        if root.thread-panel-visible : Rectangle {
            width: root.side-panel-width;
            background: VxTheme.bg-surface;
            border-color: VxTheme.border-subtle;
            border-width: 1px;

            VerticalLayout {
                spacing: 0px;

                // Thread panel header
                Rectangle {
                    background: VxTheme.bg-panel;
                    height: 48px;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 12px;
                        alignment: space-between;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Thread";
                                color: VxTheme.text-primary;
                                font-size: 14px;
                                font-weight: 700;
                            }
                        }
                        VxButton {
                            label: "Close";
                            glyph: "CL";
                            small: true;
                            ghost: true;
                            clicked => {
                                root.thread-panel-visible = false;
                                root.close-thread();
                            }
                        }
                    }
                }

                Divider {}

                // Parent message
                Rectangle {
                    background: VxTheme.bg-soft;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 4px;
                        HorizontalLayout {
                            spacing: 8px;
                            Text {
                                text: root.thread-parent-sender;
                                color: VxTheme.accent;
                                font-size: 11px;
                                font-weight: 700;
                                overflow: elide;
                                max-width: 160px;
                            }
                            Text {
                                text: root.thread-parent-timestamp;
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: root.thread-parent-content;
                            color: VxTheme.text-primary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }

                Divider {}

                // Thread replies
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        alignment: start;
                        spacing: 2px;
                        padding: 8px;
                        for reply in root.thread-messages : Rectangle {
                            border-radius: VxTheme.radius-control;
                            background: reply.is-self ? VxTheme.accent-subtle : transparent;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 2px;
                                HorizontalLayout {
                                    spacing: 6px;
                                    Text {
                                        text: reply.sender-name;
                                        color: VxTheme.accent;
                                        font-size: 10px;
                                        font-weight: 700;
                                        overflow: elide;
                                        max-width: 160px;
                                    }
                                    Text {
                                        text: reply.timestamp;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: reply.content;
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }

                // Reply count
                Rectangle {
                    height: 28px;
                    background: VxTheme.bg-panel;
                    HorizontalLayout {
                        padding-left: 16px;
                        alignment: start;
                        Text {
                            text: root.thread-messages.length + " replies";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ─── Full emoji picker overlay ───
    if root.show-emoji-picker : Rectangle {
        x: root.wide ? root.width - root.emoji-picker-width - 24px : root.width / 2 - root.emoji-picker-width / 2;
        y: root.height - root.emoji-picker-height - 24px;
        width: root.emoji-picker-width;
        height: root.emoji-picker-height;
        background: VxTheme.bg-surface;
        border-color: VxTheme.border-subtle;
        border-width: 1px;
        border-radius: VxTheme.radius-card;

        VerticalLayout {
            padding: 8px;
            spacing: 4px;

            // Header + close
            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "Emoji";
                    color: VxTheme.text-primary;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                VxButton {
                    label: "";
                    glyph: "CL";
                    small: true;
                    ghost: true;
                    clicked => { root.show-emoji-picker = false; root.emoji-search-text = ""; }
                }
            }

            // Category tabs
            HorizontalLayout {
                spacing: 2px;
                for tab-info[idx] in [
                    {emoji: "\u{1F552}", label: "Recent"},
                    {emoji: "\u{1F600}", label: "Smileys"},
                    {emoji: "\u{1F44B}", label: "People"},
                    {emoji: "\u{1F431}", label: "Nature"},
                    {emoji: "\u{1F354}", label: "Food"},
                    {emoji: "\u{1F3B5}", label: "Objects"},
                    {emoji: "\u{2764}", label: "Symbols"}
                ] : Rectangle {
                    width: 34px; height: 28px;
                    border-radius: VxTheme.radius-control;
                    background: root.emoji-tab == idx ? VxTheme.accent-subtle : (tab-hover.has-hover ? VxTheme.card-hover-bg : transparent);
                    border-color: root.emoji-tab == idx ? VxTheme.accent-border : transparent;
                    border-width: root.emoji-tab == idx ? 1px : 0px;
                    tab-hover := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.emoji-tab = idx; }
                    }
                    Text {
                        text: tab-info.emoji;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle { height: 1px; background: VxTheme.border-subtle; }

            // ── Recent reactions quick-access ──
            if root.recent-reactions.length > 0 : HorizontalLayout {
                spacing: 4px;
                padding-left: 2px;
                padding-right: 2px;
                Text {
                    text: "Recent";
                    color: VxTheme.text-muted;
                    font-size: 8px;
                    font-weight: 700;
                    vertical-alignment: center;
                    width: 36px;
                }
                for rr-emoji in root.recent-reactions : Rectangle {
                    width: 30px;
                    height: 28px;
                    border-radius: 6px;
                    background: rr-touch.has-hover ? VxTheme.card-hover-bg : transparent;
                    border-color: rr-touch.has-hover ? VxTheme.border-subtle : transparent;
                    border-width: 1px;
                    rr-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if root.emoji-picker-target-message-id != "" {
                                root.react-to-message(root.emoji-picker-target-message-id, rr-emoji);
                            } else {
                                root.chat-input = root.chat-input + rr-emoji;
