import { ScrollView } from "std-widgets.slint";
import { AuditEntryData, ChannelData, MemberData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, SectionLabel, VxAvatar, VxButton, VxCard, VxInput, VxStatusPill } from "../components.slint";

export component SpaceView inherits Rectangle {
    in property <bool> wide: false;
    in property <string> current-space-name: "";
    in property <string> current-space-invite: "";
    in property <bool> is-space-owner: false;
    in property <string> space-role-label: "Member";
    in property <bool> can-manage-space-channels: false;
    in property <bool> can-manage-space-members: false;
    in property <bool> can-manage-space-roles: false;
    in property <bool> can-view-space-audit: false;
    in property <[ChannelData]> channels: [];
    in property <[MemberData]> members: [];
    in property <[AuditEntryData]> audit-entries: [];
    in-out property <string> search-query: "";
    in property <int> visible-text-channels: 0;
    in property <int> visible-voice-channels: 0;
    in property <int> visible-members: 0;
    in-out property <string> new-channel-name: "";
    in-out property <bool> new-channel-is-voice: true;
    in-out property <int> new-channel-voice-quality: 2;
    in-out property <bool> confirm-delete-visible: false;
    in-out property <string> confirm-delete-channel-id: "";
    changed search-query => { root.search-changed(root.search-query); }
    callback navigate(int);
    callback copy-invite-code();
    callback copy-share-message();
    callback search-changed(string);
    callback select-text-channel(string);
    callback join-channel(string);
    callback create-channel();
    callback delete-channel(string);
    callback leave-space();
    callback delete-space();
    callback kick-member(string);
    callback ban-member(string);
    callback server-mute-member(string, bool);
    callback set-member-role(string, int);
    callback set-user-status(string);
    callback set-channel-topic(string, string);
    callback set-profile(string);
    callback timeout-member(string, int);
    callback set-channel-user-limit(string, int);
    callback set-channel-slow-mode(string, int);
    callback set-channel-category(string, string);
    callback set-channel-status(string, string);
    callback save-user-note(string, string);
    in-out property <string> user-status-input: "";
    in-out property <string> user-bio-input: "";
    in-out property <string> topic-edit-channel-id: "";
    in-out property <string> topic-edit-value: "";
    callback send-friend-request(string);
    callback accept-friend-request(string);
    callback decline-friend-request(string);
    callback cancel-friend-request(string);
    callback remove-friend(string);
    callback open-direct-message(string);

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: (root.wide ? 22px : 14px) * VxTheme.s;
            spacing: 18px * VxTheme.s;

            HorizontalLayout {
                alignment: space-between;
                spacing: 12px;

                VerticalLayout {
                    alignment: center;
                    spacing: 4px;
                    Text {
                        text: root.current-space-name;
                        color: VxTheme.text-primary;
                        font-size: 24px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Channels, members, and chat in one focused workspace.";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                    }
                    VxStatusPill {
                        label: root.space-role-label + " access";
                        tone: VxTheme.accent;
                        fill: VxTheme.accent-subtle;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        VxInput {
                            text <=> root.user-status-input;
                            placeholder: "Set your status";
                            horizontal-stretch: 1;
                            accepted => {
                                if root.user-status-input != "" {
                                    root.set-user-status(root.user-status-input);
                                    root.user-status-input = "";
                                }
                            }
                        }
                        VxButton {
                            label: "Set";
                            small: true;
                            soft: true;
                            enabled: root.user-status-input != "";
                            clicked => {
                                if root.user-status-input != "" {
                                    root.set-user-status(root.user-status-input);
                                    root.user-status-input = "";
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        VxInput {
                            text <=> root.user-bio-input;
                            placeholder: "Set your bio";
                            horizontal-stretch: 1;
                            accepted => {
                                if root.user-bio-input != "" {
                                    root.set-profile(root.user-bio-input);
                                    root.user-bio-input = "";
                                }
                            }
                        }
                        VxButton {
                            label: "Save";
                            small: true;
                            soft: true;
                            enabled: root.user-bio-input != "";
                            clicked => {
                                if root.user-bio-input != "" {
                                    root.set-profile(root.user-bio-input);
                                    root.user-bio-input = "";
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 10px;
                    VxButton {
                        label: "Back";
                        soft: true;
                        clicked => { root.navigate(0); }
                    }
                    VxButton {
                        label: "Copy invite";
                        accent: true;
                        clicked => { root.copy-invite-code(); }
                    }
                }
            }

            VxCard {
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;
                    SectionLabel { text: "DISCOVER"; }

                    VxInput {
                        text <=> root.search-query;
                        placeholder: "Filter channels or members";
                        horizontal-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        VxStatusPill {
                            label: root.visible-text-channels + " text";
                            tone: VxTheme.accent;
                            fill: VxTheme.accent-subtle;
                        }
                        VxStatusPill {
                            label: root.visible-voice-channels + " voice";
                            tone: VxTheme.success;
                            fill: VxTheme.success-dim;
                        }
                        VxStatusPill {
                            label: root.visible-members + " members";
                            tone: VxTheme.warning;
                            fill: VxTheme.warning-soft;
                        }
                    }

                    Text {
                        text: root.search-query == ""
                            ? "Use filters to jump straight to the right channel or teammate."
                            : "Results update instantly without reloading the space.";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        wrap: word-wrap;
                    }
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 18px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 18px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "TEXT CHANNELS"; }

                            if root.visible-text-channels == 0 : Text {
                                text: root.search-query == ""
                                    ? "Create the first text channel to shape the space."
                                    : "No text channels match this filter.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            for channel in root.channels : Rectangle {
                                height: channel.is-category-header ? 28px :
                                    channel.is-voice ? 0px :
                                    (root.topic-edit-channel-id == channel.id ? 100px : 58px);
                                visible: channel.is-category-header ? true : !channel.is-voice;
                                border-radius: channel.is-category-header ? 0px : VxTheme.radius-card;
                                background: channel.is-category-header ? transparent :
                                            channel.is-active ? VxTheme.tab-active-bg :
                                            channel.unread-count > 0 ? VxTheme.accent-subtle :
                                            text-channel-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: channel.is-category-header ? transparent :
                                    channel.is-active || channel.unread-count > 0
                                    ? VxTheme.accent-border
                                    : VxTheme.border-subtle;
                                border-width: channel.is-category-header ? 0px : 1px;

                                if channel.is-category-header : HorizontalLayout {
                                    padding-left: 4px;
                                    alignment: start;
                                    Text {
                                        text: channel.name;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        font-weight: 800;
                                        letter-spacing: 0.5px;
                                    }
                                }

                                text-channel-touch := TouchArea {
                                    mouse-cursor: channel.is-category-header ? default : pointer;
                                    clicked => { if !channel.is-category-header { root.select-text-channel(channel.id); } }
                                }

                                if !channel.is-category-header : VerticalLayout {
                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        height: 58px;
                                        spacing: 12px;
                                        alignment: center;

                                        Rectangle {
                                            width: 36px;
                                            height: 36px;
                                            border-radius: 10px;
                                            background: channel.is-active || channel.unread-count > 0
                                                ? VxTheme.accent-subtle
                                                : VxTheme.bg-panel;
                                            border-color: channel.is-active || channel.unread-count > 0
                                                ? VxTheme.accent-border
                                                : VxTheme.border-subtle;
                                            border-width: 1px;
                                            Text {
                                                text: "TXT";
                                                color: channel.is-active || channel.unread-count > 0
                                                    ? VxTheme.accent
                                                    : VxTheme.text-secondary;
                                                font-size: 10px;
                                                font-weight: 800;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            Text {
                                                text: channel.name;
                                                color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                                font-size: 12px;
                                                font-weight: 700;
                                            }
                                            Text {
                                                text: channel.topic != ""
                                                    ? channel.topic
                                                    : channel.unread-count > 0
                                                        ? channel.unread-count + " new messages"
                                                        : channel.is-active ? "Recent conversation" : "Persistent text channel";
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                                overflow: elide;
                                            }
                                        }

                                        if channel.mention-count > 0 : VxStatusPill {
                                            label: "@" + channel.mention-count;
                                            tone: VxTheme.danger;
                                            fill: VxTheme.danger.transparentize(0.85);
                                        }
                                        if channel.unread-count > 0 : VxStatusPill {
                                            label: channel.unread-count > 99 ? "99+" : channel.unread-count + " new";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                        if channel.unread-count == 0 && channel.mention-count == 0 : VxStatusPill {
                                            label: channel.is-active ? "Recent" : "Open";
                                            tone: channel.is-active ? VxTheme.success : VxTheme.accent;
                                            fill: channel.is-active ? VxTheme.success-dim : VxTheme.accent-subtle;
                                        }
                                        if root.can-manage-space-channels : VxButton {
                                            label: root.topic-edit-channel-id == channel.id ? "Save" : "Topic";
                                            small: true;
                                            soft: root.topic-edit-channel-id != channel.id;
                                            accent: root.topic-edit-channel-id == channel.id;
                                            clicked => {
                                                if root.topic-edit-channel-id == channel.id {
                                                    root.set-channel-topic(channel.id, root.topic-edit-value);
                                                    root.topic-edit-channel-id = "";
                                                    root.topic-edit-value = "";
                                                } else {
                                                    root.topic-edit-channel-id = channel.id;
                                                    root.topic-edit-value = channel.topic;
                                                }
                                            }
                                        }
                                        if root.can-manage-space-channels : VxButton {
                                            label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                            small: true;
                                            danger: root.confirm-delete-channel-id == channel.id;
                                            soft: root.confirm-delete-channel-id != channel.id;
                                            clicked => {
                                                if root.confirm-delete-channel-id == channel.id {
                                                    root.confirm-delete-channel-id = "";
                                                    root.delete-channel(channel.id);
                                                } else {
                                                    root.confirm-delete-channel-id = channel.id;
                                                }
                                            }
                                        }
                                    }

                                    if root.topic-edit-channel-id == channel.id : HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        padding-bottom: 10px;
                                        spacing: 8px;
                                        VxInput {
                                            text <=> root.topic-edit-value;
                                            placeholder: "Channel topic";
                                            horizontal-stretch: 1;
                                            accepted => {
                                                root.set-channel-topic(channel.id, root.topic-edit-value);
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            }
                                        }
                                        VxButton {
                                            label: "Cancel";
                                            small: true;
                                            ghost: true;
                                            clicked => {
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.can-view-space-audit : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "ACTIVITY"; }
                                Text {
                                    text: root.audit-entries.length + " events";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }

                            if root.audit-entries.length == 0 : Text {
                                text: "Role changes, moderation, and channel changes appear here.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            for entry in root.audit-entries : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 4px;
                                    HorizontalLayout {
                                        alignment: space-between;
                                        Text {
                                            text: entry.actor-name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: 700;
                                        }
                                        VxStatusPill {
                                            label: entry.action;
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                    }
                                    if entry.target-name != "" : Text {
                                        text: entry.target-name;
                                        color: VxTheme.text-secondary;
                                        font-size: 10px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: entry.detail;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: entry.timestamp;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "VOICE CHANNELS"; }

                            if root.visible-voice-channels == 0 : Text {
                                text: root.search-query == ""
                                    ? "Voice channels appear here as soon as you add them."
                                    : "No voice channels match this filter.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            for channel in root.channels : Rectangle {
                                height: channel.is-voice ? 62px : 0px;
                                visible: channel.is-voice;
                                border-radius: VxTheme.radius-card;
                                background: channel.is-active ? VxTheme.tab-active-bg :
                                            channel.peer-count > 0 ? VxTheme.speaking-row-bg :
                                            voice-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: channel.is-active ? VxTheme.accent-border :
                                              channel.peer-count > 0 ? VxTheme.speaking-border : VxTheme.border-subtle;
                                border-width: 1px;

                                voice-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.join-channel(channel.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 12px;
                                    alignment: center;

                                    Rectangle {
                                        width: 36px;
                                        height: 36px;
                                        border-radius: 10px;
                                        background: channel.is-active || channel.peer-count > 0
                                            ? VxTheme.accent-subtle
                                            : VxTheme.bg-panel;
                                        border-color: channel.is-active || channel.peer-count > 0
                                            ? VxTheme.accent-border
                                            : VxTheme.border-subtle;
                                        border-width: 1px;
                                        Text {
                                            text: "VC";
                                            color: channel.is-active || channel.peer-count > 0
                                                ? VxTheme.accent
                                                : VxTheme.text-secondary;
                                            font-size: 10px;
                                            font-weight: 800;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: channel.name;
                                            color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                            font-size: 12px;
                                            font-weight: 700;
                                        }
                                        Text {
                                            text: channel.status != "" ? channel.status
                                                : channel.topic != ""
                                                ? channel.topic
                                                : channel.is-active ? "Connected right now" :
                                                  channel.peer-count > 0 ? channel.peer-count + " currently inside" : "Instant voice channel";
                                            color: channel.status != "" ? VxTheme.accent : VxTheme.text-muted;
                                            font-size: 9px;
                                            overflow: elide;
                                        }
                                    }

                                    if channel.user-limit > 0 : VxStatusPill {
                                        label: channel.peer-count + "/" + channel.user-limit;
                                        tone: channel.peer-count >= channel.user-limit ? VxTheme.danger : VxTheme.text-secondary;
                                        fill: VxTheme.bg-soft;
                                    }
                                    if channel.slow-mode-secs > 0 : VxStatusPill {
                                        label: "Slow";
                                        tone: VxTheme.warning;
                                        fill: VxTheme.bg-soft;
                                    }
                                    VxStatusPill {
                                        label: channel.voice-quality == 0 ? "Low"
                                             : channel.voice-quality == 1 ? "Std"
                                             : channel.voice-quality == 3 ? "Ultra"
                                             : "High";
                                        tone: channel.voice-quality == 3 ? VxTheme.warning
                                            : channel.voice-quality == 0 ? VxTheme.text-muted
                                            : VxTheme.text-secondary;
                                        fill: VxTheme.bg-soft;
                                    }
                                    if channel.is-active : VxStatusPill {
                                        label: "Connected";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }
                                    if channel.peer-count > 0 : VxStatusPill {
                                        label: channel.peer-count + " live";
                                        tone: VxTheme.success;
                                        fill: VxTheme.success-dim;
                                    }
                                    if root.can-manage-space-channels : VxButton {
                                        label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                        small: true;
                                        danger: root.confirm-delete-channel-id == channel.id;
                                        soft: root.confirm-delete-channel-id != channel.id;
                                        clicked => {
                                            if root.confirm-delete-channel-id == channel.id {
                                                root.confirm-delete-channel-id = "";
                                                root.delete-channel(channel.id);
                                            } else {
                                                root.confirm-delete-channel-id = channel.id;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.can-manage-space-channels : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "NEW CHANNEL"; }

                            HorizontalLayout {
                                spacing: 10px;
                                FieldLabel {
                                    text: root.new-channel-is-voice ? "Voice channel" : "Text channel";
                                    horizontal-stretch: 1;
                                }
                                VxButton {
                                    label: root.new-channel-is-voice ? "Switch to text" : "Switch to voice";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.new-channel-is-voice = !root.new-channel-is-voice; }
                                }
                            }

                            if root.new-channel-is-voice : HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                FieldLabel { text: "Quality:"; vertical-alignment: center; }
                                VxButton {
                                    label: "Low";
                                    small: true;
                                    ghost: root.new-channel-voice-quality != 0;
                                    accent: root.new-channel-voice-quality == 0;
                                    clicked => { root.new-channel-voice-quality = 0; }
                                }
                                VxButton {
                                    label: "Standard";
                                    small: true;
                                    ghost: root.new-channel-voice-quality != 1;
                                    accent: root.new-channel-voice-quality == 1;
                                    clicked => { root.new-channel-voice-quality = 1; }
                                }
                                VxButton {
                                    label: "High";
                                    small: true;
                                    ghost: root.new-channel-voice-quality != 2;
                                    accent: root.new-channel-voice-quality == 2;
                                    clicked => { root.new-channel-voice-quality = 2; }
                                }
                                VxButton {
                                    label: "Ultra";
                                    small: true;
                                    ghost: root.new-channel-voice-quality != 3;
                                    accent: root.new-channel-voice-quality == 3;
                                    clicked => { root.new-channel-voice-quality = 3; }
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                VxInput {
                                    text <=> root.new-channel-name;
                                    placeholder: "channel-name";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.new-channel-name != "" {
                                            root.create-channel();
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Create";
                                    accent: true;
                                    enabled: root.new-channel-name != "";
                                    clicked => { root.create-channel(); }
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: 304px;
                    spacing: 18px;

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "SPACE INVITE"; }
                            Text {
                                text: root.current-space-invite;
                                color: VxTheme.text-primary;
                                font-size: 18px;
                                font-weight: 700;
                                letter-spacing: 1.5px;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                VxStatusPill {
                                    label: "Paste to join";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.accent-subtle;
                                }
                                VxStatusPill {
                                    label: "No account wall";
                                    tone: VxTheme.success;
                                    fill: VxTheme.success-dim;
                                }
                            }
                            Text {
                                text: "Share this invite to grow the room without making anyone create an account.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 4px;
                                    Text {
                                        text: "Join " + (root.current-space-name != "" ? root.current-space-name : "this space") + " on Voxlink";
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 700;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: "Invite code: " + root.current-space-invite;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: "Open Voxlink and paste the invite code to jump straight in.";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                VxButton {
                                    label: "Copy invite";
                                    accent: true;
                                    horizontal-stretch: 1;
                                    clicked => { root.copy-invite-code(); }
                                }
                                VxButton {
                                    label: "Copy share";
                                    soft: true;
                                    horizontal-stretch: 1;
                                    clicked => { root.copy-share-message(); }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "MEMBERS"; }
                                Text {
                                    text: root.visible-members + " visible";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }

                            if root.visible-members == 0 : Text {
                                text: root.search-query == ""
                                    ? "Members show up here as soon as they join the space."
                                    : "No members match this filter.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            for member in root.members : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: member-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                member-touch := TouchArea { }

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: center;

                                        VxAvatar {
                                            avatar-size: 30px;
                                            initial: member.initial;
                                            color-index: member.color-index;
                                            show-status: true;
                                            is-online: member.is-online;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            Text {
                                                text: member.name;
                                                color: VxTheme.text-primary;
                                                font-size: 11px;
                                                font-weight: 700;
                                            }
                                            Text {
                                                text: member.status != ""
                                                    ? member.status
                                                    : member.is-in-voice ? member.channel-name : "Not in voice";
                                                color: member.status != "" ? VxTheme.text-secondary : VxTheme.text-muted;
                                                font-size: 9px;
                                                overflow: elide;
                                            }
                                        }

                                        if member.is-server-muted : VxStatusPill {
                                            label: "Muted";
                                            tone: VxTheme.danger;
                                            fill: VxTheme.mute-badge-bg;
                                        }
                                        if member.is-self : VxStatusPill {
                                            label: "You";
                                            tone: VxTheme.text-secondary;
                                            fill: VxTheme.bg-panel;
                                        }
                                        if member.is-friend : VxStatusPill {
                                            label: "Friend";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                        if !member.is-friend && member.has-incoming-request : VxStatusPill {
                                            label: "Incoming";
                                            tone: VxTheme.warning;
                                            fill: VxTheme.warning-soft;
                                        }
                                        if !member.is-friend && !member.has-incoming-request && member.has-outgoing-request : VxStatusPill {
                                            label: "Pending";
                                            tone: VxTheme.text-secondary;
                                            fill: VxTheme.bg-panel;
                                        }
                                        VxStatusPill {
                                            label: member.role-label;
                                            tone: member.role-tier >= 2 ? VxTheme.warning :
                                                member.role-tier == 1 ? VxTheme.success :
                                                VxTheme.text-secondary;
                                            fill: member.role-tier >= 2 ? VxTheme.warning-soft :
                                                member.role-tier == 1 ? VxTheme.success-dim :
                                                VxTheme.bg-panel;
                                        }
                                    }

                                    if !member.is-self : HorizontalLayout {
                                        spacing: 8px;
                                        if member.is-friend : VxButton {
                                            label: "Message";
                                            small: true;
                                            accent: true;
                                            clicked => { root.open-direct-message(member.user-id); }
                                        }
                                        if member.has-incoming-request : VxButton {
                                            label: "Accept";
                                            small: true;
                                            accent: true;
                                            clicked => { root.accept-friend-request(member.user-id); }
                                        }
                                        if member.has-incoming-request : VxButton {
                                            label: "Decline";
                                            small: true;
                                            soft: true;
                                            clicked => { root.decline-friend-request(member.user-id); }
                                        }
                                        if !member.has-incoming-request && member.has-outgoing-request : VxButton {
                                            label: "Cancel request";
                                            small: true;
                                            soft: true;
                                            clicked => { root.cancel-friend-request(member.user-id); }
                                        }
                                        if !member.has-incoming-request && !member.has-outgoing-request && member.is-friend : VxButton {
                                            label: "Remove friend";
                                            small: true;
                                            soft: true;
                                            clicked => { root.remove-friend(member.user-id); }
                                        }
                                        if !member.has-incoming-request && !member.has-outgoing-request && !member.is-friend : VxButton {
                                            label: "Add friend";
                                            small: true;
                                            accent: true;
                                            clicked => { root.send-friend-request(member.user-id); }
                                        }
                                    }

                                    if root.can-manage-space-roles && !member.is-self && member.role-tier < 3 : HorizontalLayout {
                                        spacing: 8px;
                                        if member.role-tier == 0 : VxButton {
                                            label: "Promote mod";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 1); }
                                        }
                                        if member.role-tier == 1 : VxButton {
                                            label: "Demote";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 0); }
                                        }
                                        if root.is-space-owner && member.role-tier < 2 : VxButton {
                                            label: "Promote admin";
                                            small: true;
                                            accent: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 2); }
                                        }
                                        if root.is-space-owner && member.role-tier == 2 : VxButton {
                                            label: "Demote admin";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 0); }
                                        }
                                    }

                                    if root.can-manage-space-members && !member.is-self : HorizontalLayout {
                                        spacing: 8px;
                                        VxButton {
                                            label: member.is-server-muted ? "Unmute" : "Server mute";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.server-mute-member(member.id, !member.is-server-muted); }
                                        }
                                        VxButton {
                                            label: "Timeout 5m";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.timeout-member(member.id, 300); }
                                        }
                                        VxButton {
                                            label: "Kick";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.kick-member(member.id); }
                                        }
                                        VxButton {
                                            label: "Ban";
                                            small: true;
                                            danger: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.ban-member(member.id); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "SPACE ACTIONS"; }
                            VxButton {
                                label: "Leave space";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.leave-space(); }
                            }
                            if root.is-space-owner : VxButton {
                                label: root.confirm-delete-visible ? "Confirm delete" : "Delete space";
                                danger: true;
                                horizontal-stretch: 1;
                                clicked => {
                                    if root.confirm-delete-visible {
                                        root.confirm-delete-visible = false;
                                        root.delete-space();
                                    } else {
                                        root.confirm-delete-visible = true;
                                    }
                                }
                            }
                            if root.is-space-owner && root.confirm-delete-visible : Text {
                                text: "Delete removes the space for everyone.";
                                color: VxTheme.danger;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            if !root.is-space-owner : Text {
                                text: "Admins can manage channels. Moderators can manage members. Only the creator can delete the space.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 18px;

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "SPACE INVITE"; }
                        Text {
                            text: root.current-space-invite;
                            color: VxTheme.text-primary;
                            font-size: 18px;
                            font-weight: 700;
                            letter-spacing: 1.5px;
                        }
                        Text {
                            text: "Share the code directly or copy a ready-to-send invite note.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            VxButton {
                                label: "Copy invite";
                                accent: true;
                                horizontal-stretch: 1;
                                clicked => { root.copy-invite-code(); }
                            }
                            VxButton {
                                label: "Copy share";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.copy-share-message(); }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "CHANNELS"; }
                        if root.channels.length == 0 : Text {
                            text: root.search-query == ""
                                ? "Channels appear here when the space has activity."
                                : "No channels match this filter.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                        }
                        for channel in root.channels : Rectangle {
                            height: !channel.is-voice && root.topic-edit-channel-id == channel.id ? 96px : 56px;
                            border-radius: VxTheme.radius-card;
                            background: channel.is-active ? VxTheme.tab-active-bg :
                                        channel.unread-count > 0 ? VxTheme.accent-subtle :
                                        compact-channel-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                            border-color: channel.is-active || channel.unread-count > 0
                                ? VxTheme.accent-border
                                : VxTheme.border-subtle;
                            border-width: 1px;

                            compact-channel-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if channel.is-voice {
                                        root.join-channel(channel.id);
                                    } else {
                                        root.select-text-channel(channel.id);
                                    }
                                }
                            }

                            VerticalLayout {
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    height: 56px;
                                    spacing: 10px;
                                    alignment: center;
                                    Text {
                                        text: channel.is-voice ? "VC" : "TXT";
                                        color: channel.is-active || channel.is-voice ? VxTheme.accent : VxTheme.text-secondary;
                                        font-size: 10px;
                                        font-weight: 800;
                                    }
                                    Text {
                                        text: channel.name;
                                        color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-stretch: 1;
                                    }
                                    if channel.unread-count > 0 : Text {
                                        text: channel.unread-count > 99 ? "99+" : channel.unread-count + "";
                                        color: VxTheme.accent;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    if channel.peer-count > 0 : Text {
                                        text: channel.peer-count + "";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    if root.can-manage-space-channels && !channel.is-voice : VxButton {
                                        label: root.topic-edit-channel-id == channel.id ? "Save" : "Topic";
                                        small: true;
                                        soft: root.topic-edit-channel-id != channel.id;
                                        accent: root.topic-edit-channel-id == channel.id;
                                        clicked => {
                                            if root.topic-edit-channel-id == channel.id {
                                                root.set-channel-topic(channel.id, root.topic-edit-value);
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            } else {
                                                root.topic-edit-channel-id = channel.id;
                                                root.topic-edit-value = channel.topic;
                                            }
                                        }
                                    }
                                    if root.can-manage-space-channels : VxButton {
                                        label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                        small: true;
                                        danger: root.confirm-delete-channel-id == channel.id;
                                        soft: root.confirm-delete-channel-id != channel.id;
                                        clicked => {
                                            if root.confirm-delete-channel-id == channel.id {
                                                root.confirm-delete-channel-id = "";
                                                root.delete-channel(channel.id);
                                            } else {
                                                root.confirm-delete-channel-id = channel.id;
                                            }
                                        }
                                    }
                                }

                                if root.topic-edit-channel-id == channel.id && !channel.is-voice : HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    padding-bottom: 10px;
                                    spacing: 8px;
                                    VxInput {
                                        text <=> root.topic-edit-value;
                                        placeholder: "Channel topic";
                                        horizontal-stretch: 1;
                                        accepted => {
                                            root.set-channel-topic(channel.id, root.topic-edit-value);
                                            root.topic-edit-channel-id = "";
                                            root.topic-edit-value = "";
                                        }
                                    }
                                    VxButton {
                                        label: "Cancel";
                                        small: true;
                                        ghost: true;
                                        clicked => {
                                            root.topic-edit-channel-id = "";
                                            root.topic-edit-value = "";
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.can-view-space-audit : VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "ACTIVITY"; }
                        if root.audit-entries.length == 0 : Text {
                            text: "Role changes and moderation actions show up here.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        for entry in root.audit-entries : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: VxTheme.bg-soft;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;
                                Text {
                                    text: entry.actor-name + " • " + entry.action;
                                    color: VxTheme.text-primary;
                                    font-size: 10px;
                                    font-weight: 700;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: entry.detail;
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: entry.timestamp;
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                }
                            }
                        }
                    }
                }

                // Space actions (leave / delete)
                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "SPACE ACTIONS"; }
                        VxButton {
                            label: "Leave space";
                            soft: true;
                            horizontal-stretch: 1;
                            clicked => { root.leave-space(); }
                        }
                        if root.is-space-owner : VxButton {
                            label: root.confirm-delete-visible ? "Confirm delete" : "Delete space";
                            danger: true;
                            horizontal-stretch: 1;
                            clicked => {
                                if root.confirm-delete-visible {
                                    root.confirm-delete-visible = false;
                                    root.delete-space();
                                } else {
                                    root.confirm-delete-visible = true;
                                }
                            }
                        }
                        if root.is-space-owner && root.confirm-delete-visible : Text {
                            text: "Delete removes the space for everyone.";
                            color: VxTheme.danger;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        if !root.is-space-owner : Text {
                            text: "Only the creator can delete the space.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
