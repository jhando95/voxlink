import { ScrollView } from "std-widgets.slint";
import { AuditEntryData, AutomodWordData, ChannelData, MemberData, ScheduledEventData, VxTheme } from "../theme.slint";
import { Divider, FieldLabel, SectionLabel, VxAvatar, VxButton, VxCard, VxGlyphTile, VxInput, VxStatusPill } from "../components.slint";

export component SpaceView inherits Rectangle {
    in property <bool> wide: false;
    in property <string> current-space-name: "";
    in property <string> current-space-invite: "";
    in property <bool> is-space-owner: false;
    in property <string> space-role-label: "Member";
    in property <bool> can-manage-space-channels: false;
    in property <bool> can-manage-space-members: false;
    in property <bool> can-manage-space-roles: false;
    in property <bool> can-view-space-audit: false;
    in property <[ChannelData]> channels: [];
    in property <[MemberData]> members: [];
    in property <[AuditEntryData]> audit-entries: [];
    in-out property <string> search-query: "";
    in property <int> visible-text-channels: 0;
    in property <int> visible-voice-channels: 0;
    in property <int> visible-favorite-channels: 0;
    in property <int> visible-members: 0;
    in-out property <string> new-channel-name: "";
    in-out property <bool> new-channel-is-voice: true;
    in-out property <int> new-channel-voice-quality: 2;
    in-out property <bool> confirm-delete-visible: false;
    in-out property <bool> invite-copied: false;
    in-out property <string> confirm-delete-channel-id: "";
    changed search-query => { root.search-changed(root.search-query); }
    callback navigate(int);
    callback copy-invite-code();
    callback copy-share-message();
    callback search-changed(string);
    callback select-text-channel(string);
    callback join-channel(string);
    callback create-channel();
    callback delete-channel(string);
    callback move-channel-up(string);
    callback move-channel-down(string);
    callback leave-space();
    callback delete-space();
    callback rename-space(string);
    callback set-space-description(string);
    in property <string> space-description: "";
    callback kick-member(string);
    callback ban-member(string);
    callback server-mute-member(string, bool);
    callback set-member-role(string, int);
    callback set-user-status(string);
    callback set-channel-topic(string, string);
    callback set-profile(string);
    callback timeout-member(string, int);
    callback set-channel-user-limit(string, int);
    callback set-channel-slow-mode(string, int);
    callback set-channel-auto-delete(string, int);
    callback set-channel-category(string, string);
    callback set-channel-status(string, string);
    callback save-user-note(string, string);
    in-out property <string> user-status-input: "";
    in-out property <string> user-bio-input: "";
    in-out property <string> topic-edit-channel-id: "";
    in-out property <string> topic-edit-value: "";
    callback send-friend-request(string);
    callback accept-friend-request(string);
    callback decline-friend-request(string);
    callback cancel-friend-request(string);
    callback remove-friend(string);
    callback open-direct-message(string);
    callback toggle-category-collapse(string);
    callback toggle-favorite-channel(string);
    callback set-channel-notification(/* channel_id */ string, /* setting: "all"/"mentions"/"none" */ string);
    in-out property <string> notification-popup-channel-id: "";
    in-out property <string> settings-channel-id: "";
    in property <bool> unread-pulse: false;
    in property <bool> streamer-mode: false;
    in-out property <string> expanded-member-id: "";
    in property <int> focused-channel-index: -1;
    // Scheduled events
    in property <[ScheduledEventData]> scheduled-events: [];
    callback create-event(string, string, int);
    callback delete-event(string);
    callback toggle-event-interest(string);
    callback list-events();
    in-out property <bool> show-events-panel: false;
    // Auto-moderation word filter
    in property <[AutomodWordData]> automod-words: [];
    callback add-automod-word(string, string);
    callback remove-automod-word(string);
    callback list-automod-words();
    in-out property <string> automod-word-input: "";
    in-out property <int> automod-action-index: 0; // 0=delete, 1=warn
    in property <bool> is-space-public: false;
    callback set-space-public(bool);
    property <length> side-column-width: clamp(root.width * 0.25, 248px, 292px);
    property <length> channel-name-max-width: root.wide ? 300px : 200px;
    property <length> rail-row-height: 52px * VxTheme.s;
    property <length> rail-favorite-row-height: 44px * VxTheme.s;

    background: transparent;

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            padding: (root.wide ? 16px : 12px) * VxTheme.s;
            spacing: 12px * VxTheme.s;

            HorizontalLayout {
                alignment: space-between;
                spacing: 12px;

                VerticalLayout {
                    alignment: center;
                    spacing: 4px;
                    Text {
                        text: root.current-space-name;
                        color: VxTheme.text-primary;
                        font-size: 24px;
                        font-weight: 700;
                    }
                    Text {
                        text: root.space-description != ""
                            ? root.space-description
                            : "Channels, members, and moderation in one focused space.";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        VxStatusPill {
                            label: root.space-role-label;
                            tone: VxTheme.accent;
                            fill: VxTheme.accent-subtle;
                        }
                        VxStatusPill {
                            label: root.visible-members + " online";
                            tone: VxTheme.success;
                            fill: VxTheme.success-dim;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 10px;
                    VxButton {
                        label: "Back";
                        glyph: "BK";
                        soft: true;
                        clicked => { root.navigate(0); }
                    }
                    VxButton {
                        label: root.invite-copied ? "Copied!" : "Copy invite";
                        glyph: root.invite-copied ? "OK" : "CP";
                        accent: true;
                        clicked => {
                            root.copy-invite-code();
                            root.invite-copied = true;
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                VxInput {
                    prominent: true;
                    text <=> root.search-query;
                    placeholder: "Search channels and members...";
                    horizontal-stretch: 1;
                }
                VxStatusPill {
                    label: root.visible-text-channels + " text";
                    tone: VxTheme.accent;
                    fill: VxTheme.accent-subtle;
                }
                VxStatusPill {
                    label: root.visible-voice-channels + " voice";
                    tone: VxTheme.success;
                    fill: VxTheme.success-dim;
                }
            }

            if root.wide : HorizontalLayout {
                spacing: 12px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 12px;

                    // ── Favorite channels (wide) ──
                    if root.visible-favorite-channels > 0 : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "FAVORITES"; }
                                VxStatusPill {
                                    label: root.visible-favorite-channels + "";
                                    tone: VxTheme.warning;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            for channel in root.channels : Rectangle {
                                visible: channel.is-favorite && !channel.is-category-header;
                                height: channel.is-favorite && !channel.is-category-header ? root.rail-favorite-row-height : 0px;
                                border-radius: 12px;
                                background: channel.is-active ? VxTheme.tab-active-bg :
                                            fav-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                                border-color: channel.is-active ? VxTheme.accent-border : transparent;
                                border-width: channel.is-active ? 1px : 0px;
                                clip: true;

                                fav-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if channel.is-voice {
                                            root.join-channel(channel.id);
                                        } else {
                                            root.select-text-channel(channel.id);
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    height: root.rail-favorite-row-height;
                                    spacing: 8px;
                                    alignment: center;

                                    if channel.is-active || channel.unread-count > 0 : Rectangle {
                                        width: 3px;
                                        height: 22px;
                                        border-radius: 1.5px;
                                        background: channel.is-active ? VxTheme.accent : VxTheme.warning;
                                    }

                                    VxGlyphTile {
                                        tile-size: 24px;
                                        glyph: channel.is-voice ? "VC" : "TX";
                                        tone: channel.is-active || channel.unread-count > 0 ? VxTheme.accent : VxTheme.text-secondary;
                                    }
                                    Text {
                                        text: channel.name;
                                        color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    if channel.unread-count > 0 : VxStatusPill {
                                        label: channel.unread-count > 99 ? "99+" : channel.unread-count + "";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }
                                    if channel.is-voice && channel.peer-count > 0 : VxStatusPill {
                                        label: channel.peer-count + " live";
                                        tone: VxTheme.success;
                                        fill: VxTheme.success-dim;
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "TEXT CHANNELS"; }
                                VxStatusPill {
                                    label: root.visible-text-channels + "";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            if root.visible-text-channels == 0 : VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: root.search-query == ""
                                        ? "No text channels yet"
                                        : "No text channels match this filter.";
                                    color: VxTheme.text-secondary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                if root.search-query == "" : Text {
                                    text: "Create a channel to get started.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                }
                            }

                            for channel[idx] in root.channels : Rectangle {
                                property <bool> is-focused: idx == root.focused-channel-index;
                                height: channel.is-category-header ? 24px :
                                    channel.is-voice ? 0px :
                                    channel.category-collapsed ? 0px :
                                    (root.topic-edit-channel-id == channel.id ? 94px :
                                     root.can-manage-space-channels && root.settings-channel-id == channel.id ? 150px : root.rail-row-height);
                                visible: channel.is-category-header ? true :
                                    channel.category-collapsed ? false : !channel.is-voice;
                                border-radius: channel.is-category-header ? 0px : 12px;
                                background: channel.is-category-header ? transparent :
                                            channel.is-active ? VxTheme.tab-active-bg :
                                            is-focused ? VxTheme.surface-active :
                                            text-channel-touch.has-hover ? VxTheme.row-hover-bg :
                                            channel.mention-count > 0 ? VxTheme.warning-soft.transparentize(0.08) :
                                            channel.unread-count > 0 ? VxTheme.bg-soft : transparent;
                                border-color: channel.is-category-header ? transparent :
                                    is-focused || channel.is-active
                                    ? VxTheme.accent-border
                                    : transparent;
                                border-width: channel.is-category-header ? 0px : (is-focused || channel.is-active ? 1px : 0px);
                                clip: true;

                                if channel.is-category-header : HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 4px;
                                    alignment: start;
                                    spacing: 6px;
                                    Text {
                                        text: channel.category-collapsed ? "▶" : "▼";
                                        color: VxTheme.text-muted;
                                        font-size: 8px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: channel.name;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        font-weight: 800;
                                        letter-spacing: 0.5px;
                                        overflow: elide;
                                    }
                                    Rectangle {
                                        height: 1px;
                                        horizontal-stretch: 1;
                                        background: VxTheme.border-subtle.transparentize(0.35);
                                    }
                                }

                                text-channel-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if channel.is-category-header {
                                            root.toggle-category-collapse(channel.category);
                                        } else {
                                            root.select-text-channel(channel.id);
                                        }
                                    }
                                }

                                if !channel.is-category-header && (channel.is-active || channel.unread-count > 0 || channel.mention-count > 0) : Rectangle {
                                    x: 0px;
                                    y: 8px;
                                    width: 3px;
                                    height: root.rail-row-height - 16px;
                                    border-radius: 1.5px;
                                    background: channel.mention-count > 0 ? VxTheme.warning :
                                        channel.is-active ? VxTheme.accent : VxTheme.text-secondary;
                                }

                                if !channel.is-category-header : VerticalLayout {
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 14px;
                                        height: root.rail-row-height;
                                        spacing: 8px;
                                        alignment: center;

                                        TouchArea {
                                            width: 20px;
                                            mouse-cursor: pointer;
                                            clicked => { root.toggle-favorite-channel(channel.id); }
                                            VxGlyphTile {
                                                x: 1px;
                                                y: 9px;
                                                tile-size: 18px;
                                                glyph: "FV";
                                                tone: channel.is-favorite ? VxTheme.warning : VxTheme.text-muted;
                                            }
                                        }

                                        VxGlyphTile {
                                            tile-size: 30px;
                                            glyph: "TX";
                                            tone: channel.is-active || channel.unread-count > 0
                                                ? VxTheme.accent
                                                : VxTheme.text-secondary;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            HorizontalLayout {
                                                spacing: 4px;
                                                alignment: start;
                                                Text {
                                                    text: channel.name;
                                                    color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                    max-width: root.channel-name-max-width;
                                                }
                                                // Notification override indicator
                                                if channel.notification-setting == "none" : Text {
                                                    text: "\u{00D7}";
                                                    color: VxTheme.text-muted;
                                                    font-size: 10px;
                                                    vertical-alignment: center;
                                                }
                                                if channel.notification-setting == "mentions" : Text {
                                                    text: "@";
                                                    color: VxTheme.text-muted;
                                                    font-size: 9px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                }
                                            }
                                            Text {
                                                text: channel.topic != ""
                                                    ? channel.topic
                                                    : channel.unread-count > 0
                                                        ? channel.unread-count + " unread"
                                                        : "";
                                                color: VxTheme.text-muted;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }

                                        if channel.mention-count > 0 : VxStatusPill {
                                            label: "@" + channel.mention-count;
                                            tone: VxTheme.danger;
                                            fill: VxTheme.danger.transparentize(0.85);
                                        }
                                        if channel.unread-count > 0 : VxStatusPill {
                                            label: channel.unread-count > 99 ? "99+" : channel.unread-count + "";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                            opacity: root.unread-pulse ? 0.6 : 1.0;
                                            animate opacity { duration: 600ms; easing: ease-in-out; }
                                        }
                                        if channel.auto-delete-hours > 0 : VxStatusPill {
                                            label: channel.auto-delete-hours + "h";
                                            tone: VxTheme.warning;
                                            fill: VxTheme.bg-soft;
                                        }

                                        // ── Notification bell ──
                                        if text-channel-touch.has-hover || root.notification-popup-channel-id == channel.id || channel.notification-setting == "none" || channel.notification-setting == "mentions" : Rectangle {
                                            width: 22px;
                                            height: 22px;
                                            border-radius: 6px;
                                            background: notif-bell-touch.has-hover ? VxTheme.btn-hover-bg : transparent;
                                            notif-bell-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    if root.notification-popup-channel-id == channel.id {
                                                        root.notification-popup-channel-id = "";
                                                    } else {
                                                        root.notification-popup-channel-id = channel.id;
                                                    }
                                                }
                                            }
                                            Text {
                                                text: channel.notification-setting == "none" ? "\u{1F6AB}"
                                                    : channel.notification-setting == "mentions" ? "\u{1F515}"
                                                    : "\u{1F514}";
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                color: channel.notification-setting == "none" ? VxTheme.text-muted
                                                     : channel.notification-setting == "mentions" ? VxTheme.warning
                                                     : VxTheme.text-secondary;
                                            }
                                        }
                                        // Notification setting popup
                                        if root.notification-popup-channel-id == channel.id : Rectangle {
                                            width: 130px;
                                            height: 84px;
                                            border-radius: VxTheme.radius-card;
                                            background: VxTheme.bg-card;
                                            border-color: VxTheme.border-strong;
                                            border-width: 1px;
                                            VerticalLayout {
                                                padding: 4px;
                                                spacing: 2px;
                                                // All
                                                Rectangle {
                                                    height: 24px;
                                                    border-radius: 4px;
                                                    background: (channel.notification-setting == "" || channel.notification-setting == "all")
                                                        ? VxTheme.accent-subtle : notif-all-ta.has-hover ? VxTheme.row-hover-bg : transparent;
                                                    notif-all-ta := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.set-channel-notification(channel.id, "all");
                                                            root.notification-popup-channel-id = "";
                                                        }
                                                    }
                                                    HorizontalLayout {
                                                        padding-left: 8px;
                                                        spacing: 6px;
                                                        alignment: start;
                                                        Text { text: "\u{1F514}"; font-size: 11px; vertical-alignment: center; }
                                                        Text {
                                                            text: "All";
                                                            color: (channel.notification-setting == "" || channel.notification-setting == "all")
                                                                ? VxTheme.accent : VxTheme.text-primary;
                                                            font-size: 11px;
                                                            font-weight: 600;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }
                                                // Mentions only
                                                Rectangle {
                                                    height: 24px;
                                                    border-radius: 4px;
                                                    background: channel.notification-setting == "mentions"
                                                        ? VxTheme.accent-subtle : notif-mentions-ta.has-hover ? VxTheme.row-hover-bg : transparent;
                                                    notif-mentions-ta := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.set-channel-notification(channel.id, "mentions");
                                                            root.notification-popup-channel-id = "";
                                                        }
                                                    }
                                                    HorizontalLayout {
                                                        padding-left: 8px;
                                                        spacing: 6px;
                                                        alignment: start;
                                                        Text { text: "\u{1F515}"; font-size: 11px; vertical-alignment: center; }
                                                        Text {
                                                            text: "Mentions only";
                                                            color: channel.notification-setting == "mentions"
                                                                ? VxTheme.accent : VxTheme.text-primary;
                                                            font-size: 11px;
                                                            font-weight: 600;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }
                                                // None
                                                Rectangle {
                                                    height: 24px;
                                                    border-radius: 4px;
                                                    background: channel.notification-setting == "none"
                                                        ? VxTheme.accent-subtle : notif-none-ta.has-hover ? VxTheme.row-hover-bg : transparent;
                                                    notif-none-ta := TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.set-channel-notification(channel.id, "none");
                                                            root.notification-popup-channel-id = "";
                                                        }
                                                    }
                                                    HorizontalLayout {
                                                        padding-left: 8px;
                                                        spacing: 6px;
                                                        alignment: start;
                                                        Text { text: "\u{1F6AB}"; font-size: 11px; vertical-alignment: center; }
                                                        Text {
                                                            text: "None";
                                                            color: channel.notification-setting == "none"
                                                                ? VxTheme.accent : VxTheme.text-primary;
                                                            font-size: 11px;
                                                            font-weight: 600;
                                                            vertical-alignment: center;
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        if root.can-manage-space-channels && (text-channel-touch.has-hover || root.topic-edit-channel-id == channel.id || root.settings-channel-id == channel.id) : VxButton {
                                            label: root.topic-edit-channel-id == channel.id ? "Save" : "Topic";
                                            glyph: root.topic-edit-channel-id == channel.id ? "SV" : "TP";
                                            small: true;
                                            soft: root.topic-edit-channel-id != channel.id;
                                            accent: root.topic-edit-channel-id == channel.id;
                                            clicked => {
                                                if root.topic-edit-channel-id == channel.id {
                                                    root.set-channel-topic(channel.id, root.topic-edit-value);
                                                    root.topic-edit-channel-id = "";
                                                    root.topic-edit-value = "";
                                                } else {
                                                    root.topic-edit-channel-id = channel.id;
                                                    root.topic-edit-value = channel.topic;
                                                }
                                            }
                                        }
                                        if root.can-manage-space-channels && (text-channel-touch.has-hover || root.settings-channel-id == channel.id) : VxButton {
                                            label: root.settings-channel-id == channel.id ? "Close" : "Manage";
                                            glyph: root.settings-channel-id == channel.id ? "CL" : "MG";
                                            small: true;
                                            ghost: true;
                                            clicked => {
                                                if root.settings-channel-id == channel.id {
                                                    root.settings-channel-id = "";
                                                } else {
                                                    root.settings-channel-id = channel.id;
                                                    root.topic-edit-channel-id = "";
                                                }
                                            }
                                        }
                                        if root.can-manage-space-channels && (text-channel-touch.has-hover || root.confirm-delete-channel-id == channel.id) : VxButton {
                                            label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                            glyph: root.confirm-delete-channel-id == channel.id ? "OK" : "DL";
                                            small: true;
                                            danger: root.confirm-delete-channel-id == channel.id;
                                            soft: root.confirm-delete-channel-id != channel.id;
                                            clicked => {
                                                if root.confirm-delete-channel-id == channel.id {
                                                    root.confirm-delete-channel-id = "";
                                                    root.delete-channel(channel.id);
                                                } else {
                                                    root.confirm-delete-channel-id = channel.id;
                                                }
                                            }
                                        }
                                    }

                                    if root.topic-edit-channel-id == channel.id : HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        padding-bottom: 10px;
                                        spacing: 8px;
                                        VxInput {
                                            text <=> root.topic-edit-value;
                                            placeholder: "Channel topic";
                                            horizontal-stretch: 1;
                                            accepted => {
                                                root.set-channel-topic(channel.id, root.topic-edit-value);
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            }
                                        }
                                        VxButton {
                                            label: "Cancel";
                                            glyph: "CN";
                                            small: true;
                                            ghost: true;
                                            clicked => {
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            }
                                        }
                                    }

                                    // ── Text channel management controls ──
                                    if root.can-manage-space-channels && root.settings-channel-id == channel.id : VerticalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        padding-bottom: 8px;
                                        spacing: 4px;

                                        // User limit row
                                        HorizontalLayout {
                                            spacing: 4px;
                                            alignment: start;
                                            Text {
                                                text: "Limit";
                                                color: VxTheme.text-muted;
                                                font-size: 10px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                                width: 36px;
                                            }
                                            VxButton { label: channel.user-limit == 0 ? "[None]" : "None"; small: true; ghost: channel.user-limit != 0; accent: channel.user-limit == 0; clicked => { root.set-channel-user-limit(channel.id, 0); } }
                                            VxButton { label: "5"; small: true; ghost: channel.user-limit != 5; accent: channel.user-limit == 5; clicked => { root.set-channel-user-limit(channel.id, 5); } }
                                            VxButton { label: "10"; small: true; ghost: channel.user-limit != 10; accent: channel.user-limit == 10; clicked => { root.set-channel-user-limit(channel.id, 10); } }
                                            VxButton { label: "25"; small: true; ghost: channel.user-limit != 25; accent: channel.user-limit == 25; clicked => { root.set-channel-user-limit(channel.id, 25); } }
                                        }

                                        // Slow mode row
                                        HorizontalLayout {
                                            spacing: 4px;
                                            alignment: start;
                                            Text {
                                                text: "Slow";
                                                color: VxTheme.text-muted;
                                                font-size: 10px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                                width: 36px;
                                            }
                                            VxButton { label: channel.slow-mode-secs == 0 ? "[Off]" : "Off"; small: true; ghost: channel.slow-mode-secs != 0; accent: channel.slow-mode-secs == 0; clicked => { root.set-channel-slow-mode(channel.id, 0); } }
                                            VxButton { label: "5s"; small: true; ghost: channel.slow-mode-secs != 5; accent: channel.slow-mode-secs == 5; clicked => { root.set-channel-slow-mode(channel.id, 5); } }
                                            VxButton { label: "15s"; small: true; ghost: channel.slow-mode-secs != 15; accent: channel.slow-mode-secs == 15; clicked => { root.set-channel-slow-mode(channel.id, 15); } }
                                            VxButton { label: "30s"; small: true; ghost: channel.slow-mode-secs != 30; accent: channel.slow-mode-secs == 30; clicked => { root.set-channel-slow-mode(channel.id, 30); } }
                                            VxButton { label: "60s"; small: true; ghost: channel.slow-mode-secs != 60; accent: channel.slow-mode-secs == 60; clicked => { root.set-channel-slow-mode(channel.id, 60); } }
                                        }

                                        // Auto-delete row
                                        HorizontalLayout {
                                            spacing: 4px;
                                            alignment: start;
                                            Text {
                                                text: "Expire";
                                                color: VxTheme.text-muted;
                                                font-size: 10px;
                                                font-weight: 600;
                                                vertical-alignment: center;
                                                width: 36px;
                                            }
                                            VxButton { label: channel.auto-delete-hours == 0 ? "[Off]" : "Off"; small: true; ghost: channel.auto-delete-hours != 0; accent: channel.auto-delete-hours == 0; clicked => { root.set-channel-auto-delete(channel.id, 0); } }
                                            VxButton { label: "1h"; small: true; ghost: channel.auto-delete-hours != 1; accent: channel.auto-delete-hours == 1; clicked => { root.set-channel-auto-delete(channel.id, 1); } }
                                            VxButton { label: "6h"; small: true; ghost: channel.auto-delete-hours != 6; accent: channel.auto-delete-hours == 6; clicked => { root.set-channel-auto-delete(channel.id, 6); } }
                                            VxButton { label: "24h"; small: true; ghost: channel.auto-delete-hours != 24; accent: channel.auto-delete-hours == 24; clicked => { root.set-channel-auto-delete(channel.id, 24); } }
                                            VxButton { label: "72h"; small: true; ghost: channel.auto-delete-hours != 72; accent: channel.auto-delete-hours == 72; clicked => { root.set-channel-auto-delete(channel.id, 72); } }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.can-view-space-audit : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "ACTIVITY"; }
                                Text {
                                    text: root.audit-entries.length + " events";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }

                            if root.audit-entries.length == 0 : Text {
                                text: "Role changes, moderation, and channel changes appear here.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            for entry in root.audit-entries : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 4px;
                                    HorizontalLayout {
                                        alignment: space-between;
                                        Text {
                                            text: entry.actor-name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px;
                                            font-weight: 700;
                                        }
                                        VxStatusPill {
                                            label: entry.action;
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                    }
                                    if entry.target-name != "" : Text {
                                        text: entry.target-name;
                                        color: VxTheme.text-secondary;
                                        font-size: 10px;
                                        font-weight: 600;
                                    }
                                    Text {
                                        text: entry.detail;
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                    Text {
                                        text: entry.timestamp;
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                    }
                                }
                            }
                        }
                    }

                    // ── Scheduled Events ──
                    if root.scheduled-events.length > 0 || root.can-manage-space-channels : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 8px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "EVENTS"; }
                                Text {
                                    text: root.scheduled-events.length > 0 ? root.scheduled-events.length + " upcoming" : "";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }
                            for evt in root.scheduled-events : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: evt.is-interested ? VxTheme.accent-border : VxTheme.border-subtle;
                                border-width: 1px;
                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 4px;
                                    HorizontalLayout {
                                        alignment: space-between;
                                        Text {
                                            text: evt.title;
                                            color: VxTheme.text-primary;
                                            font-size: 12px;
                                            font-weight: 700;
                                        }
                                        VxStatusPill {
                                            label: evt.start-time;
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                    }
                                    if evt.description != "" : Text {
                                        text: evt.description;
                                        color: VxTheme.text-secondary;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: start;
                                        Text {
                                            text: "by " + evt.creator-name;
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                        }
                                        evt-interest-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            width: 80px;
                                            clicked => { root.toggle-event-interest(evt.id); }
                                            VxStatusPill {
                                                label: (evt.is-interested ? "★ " : "☆ ") + evt.interested-count;
                                                tone: evt.is-interested ? VxTheme.accent : VxTheme.text-muted;
                                                fill: evt.is-interested ? VxTheme.accent-subtle : VxTheme.bg-soft;
                                            }
                                        }
                                        if root.can-manage-space-channels : TouchArea {
                                            mouse-cursor: pointer;
                                            width: 30px;
                                            clicked => { root.delete-event(evt.id); }
                                            Text {
                                                text: "✕";
                                                color: VxTheme.danger;
                                                font-size: 10px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                            if root.scheduled-events.length == 0 : Text {
                                text: "No upcoming events.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "VOICE CHANNELS"; }
                                VxStatusPill {
                                    label: root.visible-voice-channels + "";
                                    tone: VxTheme.success;
                                    fill: VxTheme.bg-soft;
                                }
                            }

                            if root.visible-voice-channels == 0 : VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: root.search-query == ""
                                        ? "No voice channels yet"
                                        : "No voice channels match this filter.";
                                    color: VxTheme.text-secondary;
                                    font-size: 11px;
                                    font-weight: 600;
                                }
                                if root.search-query == "" : Text {
                                    text: "Add a voice channel and hop in.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                }
                            }

                            for channel[idx] in root.channels : Rectangle {
                                property <bool> is-focused: idx == root.focused-channel-index;
                                property <bool> show-settings: root.can-manage-space-channels && root.settings-channel-id == channel.id;
                                height: channel.is-voice ? (show-settings ? 154px : 58px * VxTheme.s) : 0px;
                                visible: channel.is-voice;
                                border-radius: 12px;
                                background: channel.is-active ? VxTheme.tab-active-bg :
                                            is-focused ? VxTheme.surface-active :
                                            voice-touch.has-hover ? VxTheme.row-hover-bg :
                                            channel.peer-count > 0 ? VxTheme.speaking-row-bg.transparentize(0.12) : transparent;
                                border-color: is-focused || channel.is-active ? VxTheme.accent-border :
                                              channel.peer-count > 0 ? VxTheme.speaking-border.transparentize(0.35) : transparent;
                                border-width: is-focused || channel.is-active || channel.peer-count > 0 ? 1px : 0px;
                                clip: true;

                                voice-touch := TouchArea {
                                    height: 58px * VxTheme.s;
                                    mouse-cursor: pointer;
                                    clicked => { root.join-channel(channel.id); }
                                }

                                if channel.is-active || channel.peer-count > 0 : Rectangle {
                                    x: 0px;
                                    y: 10px;
                                    width: 3px;
                                    height: 38px * VxTheme.s;
                                    border-radius: 1.5px;
                                    background: channel.is-active ? VxTheme.accent : VxTheme.success;
                                }

                                // Favorite star overlay (top-left of voice channel row)
                                TouchArea {
                                    x: 4px;
                                    y: (58px * VxTheme.s - 18px) / 2;
                                    width: 18px;
                                    height: 18px;
                                    mouse-cursor: pointer;
                                    clicked => { root.toggle-favorite-channel(channel.id); }
                                    Text {
                                        text: channel.is-favorite ? "\u{2605}" : "\u{2606}";
                                        color: channel.is-favorite ? VxTheme.warning : VxTheme.text-muted;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                HorizontalLayout {
                                    height: 58px * VxTheme.s;
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 10px;
                                    alignment: center;

                                    VxGlyphTile {
                                        tile-size: 30px;
                                        glyph: "VC";
                                        tone: channel.is-active || channel.peer-count > 0
                                            ? VxTheme.accent
                                            : VxTheme.text-secondary;
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 2px;
                                        Text {
                                            text: channel.name;
                                            color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                            font-size: 12px;
                                            font-weight: 700;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: channel.status != "" ? channel.status
                                                : channel.topic != ""
                                                ? channel.topic
                                                : channel.is-active ? "Connected right now" :
                                                  channel.peer-count > 0 ? channel.peer-count + " currently inside" : "Instant voice channel";
                                            color: channel.status != "" ? VxTheme.accent : VxTheme.text-muted;
                                            font-size: 10px;
                                            overflow: elide;
                                        }
                                    }

                                    if channel.user-limit > 0 : VxStatusPill {
                                        label: channel.peer-count + "/" + channel.user-limit;
                                        tone: channel.peer-count >= channel.user-limit ? VxTheme.danger
                                            : channel.peer-count * 100 >= channel.user-limit * 80 ? VxTheme.warning
                                            : VxTheme.text-secondary;
                                        fill: channel.peer-count >= channel.user-limit ? VxTheme.danger.transparentize(0.85)
                                            : channel.peer-count * 100 >= channel.user-limit * 80 ? VxTheme.warning-soft
                                            : VxTheme.bg-soft;
                                    }
                                    if channel.slow-mode-secs > 0 : VxStatusPill {
                                        label: "Slow";
                                        tone: VxTheme.warning;
                                        fill: VxTheme.bg-soft;
                                    }
                                    VxStatusPill {
                                        label: channel.voice-quality == 0 ? "Eco 16k"
                                             : channel.voice-quality == 1 ? "Std 32k"
                                             : channel.voice-quality == 3 ? "Studio 128k"
                                             : "High 64k";
                                        tone: channel.voice-quality == 3 ? VxTheme.warning
                                            : channel.voice-quality == 2 ? VxTheme.success
                                            : channel.voice-quality == 0 ? VxTheme.text-muted
                                            : VxTheme.text-secondary;
                                        fill: channel.voice-quality == 3 ? VxTheme.warning.transparentize(0.88)
                                            : channel.voice-quality == 2 ? VxTheme.success-dim
                                            : VxTheme.bg-soft;
                                    }
                                    if channel.is-active : VxStatusPill {
                                        label: "Connected";
                                        tone: VxTheme.accent;
                                        fill: VxTheme.accent-subtle;
                                    }
                                    if channel.peer-count > 0 : VxStatusPill {
                                        label: channel.peer-count + "";
                                        tone: VxTheme.success;
                                        fill: VxTheme.success-dim;
                                    }
                                    if root.can-manage-space-channels && (voice-touch.has-hover || show-settings) : VxButton {
                                        label: root.settings-channel-id == channel.id ? "Close" : "Manage";
                                        glyph: root.settings-channel-id == channel.id ? "CL" : "MG";
                                        small: true;
                                        ghost: true;
                                        clicked => {
                                            if root.settings-channel-id == channel.id {
                                                root.settings-channel-id = "";
                                            } else {
                                                root.settings-channel-id = channel.id;
                                            }
                                        }
                                    }
                                    if root.can-manage-space-channels && (voice-touch.has-hover || root.confirm-delete-channel-id == channel.id) : VxButton {
                                        label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                        glyph: root.confirm-delete-channel-id == channel.id ? "OK" : "DL";
                                        small: true;
                                        danger: root.confirm-delete-channel-id == channel.id;
                                        soft: root.confirm-delete-channel-id != channel.id;
                                        clicked => {
                                            if root.confirm-delete-channel-id == channel.id {
                                                root.confirm-delete-channel-id = "";
                                                root.delete-channel(channel.id);
                                            } else {
                                                root.confirm-delete-channel-id = channel.id;
                                            }
                                        }
                                    }
                                }

                                // ── Channel management controls ──
                                if show-settings : VerticalLayout {
                                    y: 58px * VxTheme.s;
                                    height: 96px;
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    padding-bottom: 8px;
                                    spacing: 4px;

                                    // User limit row
                                    HorizontalLayout {
                                        spacing: 4px;
                                        alignment: start;
                                        Text {
                                            text: "Limit";
                                            color: VxTheme.text-muted;
                                            font-size: 10px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            width: 36px;
                                        }
                                        VxButton { label: channel.user-limit == 0 ? "[None]" : "None"; small: true; ghost: channel.user-limit != 0; accent: channel.user-limit == 0; clicked => { root.set-channel-user-limit(channel.id, 0); } }
                                        VxButton { label: "5"; small: true; ghost: channel.user-limit != 5; accent: channel.user-limit == 5; clicked => { root.set-channel-user-limit(channel.id, 5); } }
                                        VxButton { label: "10"; small: true; ghost: channel.user-limit != 10; accent: channel.user-limit == 10; clicked => { root.set-channel-user-limit(channel.id, 10); } }
                                        VxButton { label: "25"; small: true; ghost: channel.user-limit != 25; accent: channel.user-limit == 25; clicked => { root.set-channel-user-limit(channel.id, 25); } }
                                    }

                                    // Slow mode row
                                    HorizontalLayout {
                                        spacing: 4px;
                                        alignment: start;
                                        Text {
                                            text: "Slow";
                                            color: VxTheme.text-muted;
                                            font-size: 10px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            width: 36px;
                                        }
                                        VxButton { label: channel.slow-mode-secs == 0 ? "[Off]" : "Off"; small: true; ghost: channel.slow-mode-secs != 0; accent: channel.slow-mode-secs == 0; clicked => { root.set-channel-slow-mode(channel.id, 0); } }
                                        VxButton { label: "5s"; small: true; ghost: channel.slow-mode-secs != 5; accent: channel.slow-mode-secs == 5; clicked => { root.set-channel-slow-mode(channel.id, 5); } }
                                        VxButton { label: "15s"; small: true; ghost: channel.slow-mode-secs != 15; accent: channel.slow-mode-secs == 15; clicked => { root.set-channel-slow-mode(channel.id, 15); } }
                                        VxButton { label: "30s"; small: true; ghost: channel.slow-mode-secs != 30; accent: channel.slow-mode-secs == 30; clicked => { root.set-channel-slow-mode(channel.id, 30); } }
                                        VxButton { label: "60s"; small: true; ghost: channel.slow-mode-secs != 60; accent: channel.slow-mode-secs == 60; clicked => { root.set-channel-slow-mode(channel.id, 60); } }
                                    }

                                    // Auto-delete row
                                    HorizontalLayout {
                                        spacing: 4px;
                                        alignment: start;
                                        Text {
                                            text: "Expire";
                                            color: VxTheme.text-muted;
                                            font-size: 10px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            width: 36px;
                                        }
                                        VxButton { label: channel.auto-delete-hours == 0 ? "[Off]" : "Off"; small: true; ghost: channel.auto-delete-hours != 0; accent: channel.auto-delete-hours == 0; clicked => { root.set-channel-auto-delete(channel.id, 0); } }
                                        VxButton { label: "1h"; small: true; ghost: channel.auto-delete-hours != 1; accent: channel.auto-delete-hours == 1; clicked => { root.set-channel-auto-delete(channel.id, 1); } }
                                        VxButton { label: "6h"; small: true; ghost: channel.auto-delete-hours != 6; accent: channel.auto-delete-hours == 6; clicked => { root.set-channel-auto-delete(channel.id, 6); } }
                                        VxButton { label: "24h"; small: true; ghost: channel.auto-delete-hours != 24; accent: channel.auto-delete-hours == 24; clicked => { root.set-channel-auto-delete(channel.id, 24); } }
                                        VxButton { label: "72h"; small: true; ghost: channel.auto-delete-hours != 72; accent: channel.auto-delete-hours == 72; clicked => { root.set-channel-auto-delete(channel.id, 72); } }
                                    }
                                }
                            }
                        }
                    }

                    if root.can-manage-space-channels : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            // Empty-space guidance — prominent when no channels exist yet
                            if root.channels.length == 0 && root.is-space-owner : VerticalLayout {
                                spacing: 8px;
                                padding-bottom: 4px;
                                Text {
                                    text: "Your space is empty!";
                                    color: VxTheme.accent;
                                    font-size: 14px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: "Create your first channel to get started. Voice channels are great for talking, text channels for chat.";
                                    color: VxTheme.text-secondary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                                Divider {}
                            }
                            SectionLabel { text: "NEW CHANNEL"; }

                            Text {
                                text: root.new-channel-is-voice
                                    ? "Voice channels let members join and talk in real time."
                                    : "Text channels are for messages, reactions, and threads.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                FieldLabel {
                                    text: root.new-channel-is-voice ? "Voice channel" : "Text channel";
                                    horizontal-stretch: 1;
                                }
                                VxButton {
                                    label: root.new-channel-is-voice ? "Switch to text" : "Switch to voice";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.new-channel-is-voice = !root.new-channel-is-voice; }
                                }
                            }

                            if root.new-channel-is-voice : VerticalLayout {
                                spacing: 6px;
                                SectionLabel { text: "VOICE QUALITY PRESET"; }
                                Text {
                                    text: root.new-channel-voice-quality == 0 ? "Economy \u{2014} 16 kbps per user. Great for slow connections, minimal data."
                                        : root.new-channel-voice-quality == 1 ? "Standard \u{2014} 32 kbps per user. Balanced quality and bandwidth."
                                        : root.new-channel-voice-quality == 3 ? "Studio \u{2014} 128 kbps per user. Maximum quality for podcasts/music."
                                        : "High \u{2014} 64 kbps per user. Clear voice, recommended.";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                                HorizontalLayout {
                                    spacing: 6px;
                                    alignment: start;
                                    VxButton {
                                        label: "Economy";
                                        small: true;
                                        ghost: root.new-channel-voice-quality != 0;
                                        accent: root.new-channel-voice-quality == 0;
                                        clicked => { root.new-channel-voice-quality = 0; }
                                    }
                                    VxButton {
                                        label: "Standard";
                                        small: true;
                                        ghost: root.new-channel-voice-quality != 1;
                                        accent: root.new-channel-voice-quality == 1;
                                        clicked => { root.new-channel-voice-quality = 1; }
                                    }
                                    VxButton {
                                        label: "High";
                                        small: true;
                                        ghost: root.new-channel-voice-quality != 2;
                                        accent: root.new-channel-voice-quality == 2;
                                        clicked => { root.new-channel-voice-quality = 2; }
                                    }
                                    VxButton {
                                        label: "Studio";
                                        small: true;
                                        ghost: root.new-channel-voice-quality != 3;
                                        accent: root.new-channel-voice-quality == 3;
                                        clicked => { root.new-channel-voice-quality = 3; }
                                    }
                                }
                            }

                            VerticalLayout {
                                spacing: 8px;
                                VxInput {
                                    prominent: true;
                                    text <=> root.new-channel-name;
                                    placeholder: "channel-name";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.new-channel-name != "" {
                                            root.create-channel();
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Create";
                                    accent: true;
                                    horizontal-stretch: 1;
                                    enabled: root.new-channel-name != "";
                                    clicked => { root.create-channel(); }
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    width: root.side-column-width;
                    spacing: 12px;

                    // Compact profile card — status + bio
                    VxCard {
                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;
                            SectionLabel { text: "YOUR PROFILE"; }
                            VerticalLayout {
                                spacing: 8px;
                                VxInput {
                                    prominent: true;
                                    text <=> root.user-status-input;
                                    placeholder: "Set status";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.user-status-input != "" {
                                            root.set-user-status(root.user-status-input);
                                            root.user-status-input = "";
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Set";
                                    glyph: "ST";
                                    soft: true;
                                    horizontal-stretch: 1;
                                    enabled: root.user-status-input != "";
                                    clicked => {
                                        if root.user-status-input != "" {
                                            root.set-user-status(root.user-status-input);
                                            root.user-status-input = "";
                                        }
                                    }
                                }
                            }
                            VerticalLayout {
                                spacing: 8px;
                                VxInput {
                                    prominent: true;
                                    text <=> root.user-bio-input;
                                    placeholder: "Set bio";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.user-bio-input != "" {
                                            root.set-profile(root.user-bio-input);
                                            root.user-bio-input = "";
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Save";
                                    glyph: "SV";
                                    soft: true;
                                    horizontal-stretch: 1;
                                    enabled: root.user-bio-input != "";
                                    clicked => {
                                        if root.user-bio-input != "" {
                                            root.set-profile(root.user-bio-input);
                                            root.user-bio-input = "";
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;
                            SectionLabel { text: "INVITE"; }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: center;
                                Text {
                                    text: root.streamer-mode ? "********" : root.current-space-invite;
                                    color: VxTheme.text-primary;
                                    font-size: 16px;
                                    font-weight: 700;
                                    letter-spacing: 1.5px;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                VxButton {
                                    label: "Copy";
                                    glyph: "CP";
                                    small: true;
                                    accent: true;
                                    clicked => { root.copy-invite-code(); }
                                }
                                VxButton {
                                    label: "Share";
                                    glyph: "SH";
                                    small: true;
                                    soft: true;
                                    clicked => { root.copy-share-message(); }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "MEMBERS"; }
                                Text {
                                    text: root.visible-members + " visible";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }

                            if root.visible-members == 0 : Text {
                                text: root.search-query == ""
                                    ? "Members show up here as soon as they join the space."
                                    : "No members match this filter.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }

                            for member in root.members : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: root.expanded-member-id == member.id ? VxTheme.tab-active-bg :
                                            member-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                                border-color: root.expanded-member-id == member.id ? VxTheme.accent-border : VxTheme.border-subtle;
                                border-width: 1px;

                                member-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        if root.expanded-member-id == member.id {
                                            root.expanded-member-id = "";
                                        } else {
                                            root.expanded-member-id = member.id;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: center;

                                        VxAvatar {
                                            avatar-size: 30px;
                                            initial: member.initial;
                                            color-index: member.color-index;
                                            show-status: true;
                                            is-online: member.is-online;
                                            status-level: member.status-level;
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            Text {
                                                text: member.name;
                                                color: member.role-color-index > 0
                                                    ? VxTheme.role-color(member.role-color-index)
                                                    : VxTheme.text-primary;
                                                font-size: 11px;
                                                font-weight: 700;
                                                overflow: elide;
                                            }
                                            if member.activity != "" : Text {
                                                text: member.activity;
                                                color: VxTheme.accent;
                                                font-size: 9px;
                                                overflow: elide;
                                                font-weight: 500;
                                            }
                                            Text {
                                                text: member.status != ""
                                                    ? member.status
                                                    : member.is-in-voice ? member.channel-name : "Not in voice";
                                                color: member.status != "" ? VxTheme.text-secondary : VxTheme.text-muted;
                                                font-size: 9px;
                                                overflow: elide;
                                            }
                                        }

                                        if member.is-server-muted : VxStatusPill {
                                            label: "Muted";
                                            tone: VxTheme.danger;
                                            fill: VxTheme.mute-badge-bg;
                                        }
                                        if member.is-self : VxStatusPill {
                                            label: "You";
                                            tone: VxTheme.text-secondary;
                                            fill: VxTheme.bg-panel;
                                        }
                                        if member.is-friend : VxStatusPill {
                                            label: "Friend";
                                            tone: VxTheme.accent;
                                            fill: VxTheme.accent-subtle;
                                        }
                                        if !member.is-friend && member.has-incoming-request : VxStatusPill {
                                            label: "Incoming";
                                            tone: VxTheme.warning;
                                            fill: VxTheme.warning-soft;
                                        }
                                        if !member.is-friend && !member.has-incoming-request && member.has-outgoing-request : VxStatusPill {
                                            label: "Pending";
                                            tone: VxTheme.text-secondary;
                                            fill: VxTheme.bg-panel;
                                        }
                                        VxStatusPill {
                                            label: member.role-label;
                                            tone: member.role-tier >= 2 ? VxTheme.warning :
                                                member.role-tier == 1 ? VxTheme.success :
                                                VxTheme.text-secondary;
                                            fill: member.role-tier >= 2 ? VxTheme.warning-soft :
                                                member.role-tier == 1 ? VxTheme.success-dim :
                                                VxTheme.bg-panel;
                                        }
                                    }

                                    // Expanded details — click member row to toggle
                                    if root.expanded-member-id == member.id && member.nickname != "" : Text {
                                        text: "aka \"" + member.nickname + "\"";
                                        color: VxTheme.text-secondary;
                                        font-size: 9px;
                                    }
                                    if root.expanded-member-id == member.id && member.bio != "" : Rectangle {
                                        border-radius: VxTheme.radius-card;
                                        background: VxTheme.bg-panel;
                                        border-color: VxTheme.border-subtle;
                                        border-width: 1px;
                                        VerticalLayout {
                                            padding: 6px;
                                            Text {
                                                text: member.bio;
                                                color: VxTheme.text-secondary;
                                                font-size: 9px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    if root.expanded-member-id == member.id && !member.is-self : HorizontalLayout {
                                        spacing: 6px;
                                        if member.is-friend : VxButton {
                                            label: "Message";
                                            glyph: "DM";
                                            small: true;
                                            accent: true;
                                            clicked => { root.open-direct-message(member.user-id); }
                                        }
                                        if member.has-incoming-request : VxButton {
                                            label: "Accept";
                                            glyph: "OK";
                                            small: true;
                                            accent: true;
                                            clicked => { root.accept-friend-request(member.user-id); }
                                        }
                                        if member.has-incoming-request : VxButton {
                                            label: "Decline";
                                            glyph: "NO";
                                            small: true;
                                            soft: true;
                                            clicked => { root.decline-friend-request(member.user-id); }
                                        }
                                        if !member.has-incoming-request && member.has-outgoing-request : VxButton {
                                            label: "Cancel";
                                            glyph: "CN";
                                            small: true;
                                            soft: true;
                                            clicked => { root.cancel-friend-request(member.user-id); }
                                        }
                                        if !member.has-incoming-request && !member.has-outgoing-request && member.is-friend : VxButton {
                                            label: "Unfriend";
                                            glyph: "RM";
                                            small: true;
                                            soft: true;
                                            clicked => { root.remove-friend(member.user-id); }
                                        }
                                        if !member.has-incoming-request && !member.has-outgoing-request && !member.is-friend : VxButton {
                                            label: "Add friend";
                                            glyph: "FR";
                                            small: true;
                                            accent: true;
                                            clicked => { root.send-friend-request(member.user-id); }
                                        }
                                    }

                                    if root.expanded-member-id == member.id && !member.is-self : VxInput {
                                        prominent: true;
                                        placeholder: "Private note...";
                                        text: member.user-note;
                                        accepted => {
                                            root.save-user-note(member.user-id, self.text);
                                        }
                                    }

                                    if root.expanded-member-id == member.id && root.can-manage-space-roles && !member.is-self && member.role-tier < 3 : HorizontalLayout {
                                        spacing: 6px;
                                        if member.role-tier == 0 : VxButton {
                                            label: "Mod";
                                            glyph: "MD";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 1); }
                                        }
                                        if member.role-tier == 1 : VxButton {
                                            label: "Demote";
                                            glyph: "DN";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 0); }
                                        }
                                        if root.is-space-owner && member.role-tier < 2 : VxButton {
                                            label: "Admin";
                                            glyph: "AD";
                                            small: true;
                                            accent: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 2); }
                                        }
                                        if root.is-space-owner && member.role-tier == 2 : VxButton {
                                            label: "Remove admin";
                                            glyph: "RM";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.set-member-role(member.user-id, 0); }
                                        }
                                    }

                                    if root.expanded-member-id == member.id && root.can-manage-space-members && !member.is-self : HorizontalLayout {
                                        spacing: 6px;
                                        VxButton {
                                            label: member.is-server-muted ? "Unmute" : "Mute";
                                            glyph: member.is-server-muted ? "AU" : "MU";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.server-mute-member(member.id, !member.is-server-muted); }
                                        }
                                        VxButton {
                                            label: "Timeout";
                                            glyph: "TM";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.timeout-member(member.id, 300); }
                                        }
                                        VxButton {
                                            label: "Kick";
                                            glyph: "KK";
                                            small: true;
                                            soft: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.kick-member(member.id); }
                                        }
                                        VxButton {
                                            label: "Ban";
                                            glyph: "BN";
                                            small: true;
                                            danger: true;
                                            horizontal-stretch: 1;
                                            clicked => { root.ban-member(member.id); }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionLabel { text: "SPACE ACTIONS"; }
                            VxButton {
                                label: "Leave space";
                                glyph: "LV";
                                soft: true;
                                horizontal-stretch: 1;
                                clicked => { root.leave-space(); }
                            }
                            if root.is-space-owner : VxButton {
                                label: root.confirm-delete-visible ? "Confirm delete" : "Delete space";
                                glyph: root.confirm-delete-visible ? "OK" : "DL";
                                danger: true;
                                horizontal-stretch: 1;
                                clicked => {
                                    if root.confirm-delete-visible {
                                        root.confirm-delete-visible = false;
                                        root.delete-space();
                                    } else {
                                        root.confirm-delete-visible = true;
                                    }
                                }
                            }
                            if root.is-space-owner && root.confirm-delete-visible : Text {
                                text: "Delete removes the space for everyone.";
                                color: VxTheme.danger;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            if !root.is-space-owner : Text {
                                text: "Admins can manage channels. Moderators can manage members. Only the creator can delete the space.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    if root.can-manage-space-channels : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "SPACE SETTINGS"; }
                            HorizontalLayout {
                                spacing: 8px;
                                rename-input := VxInput {
                                    prominent: true;
                                    placeholder: "New space name";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if self.text != "" {
                                            root.rename-space(self.text);
                                            self.text = "";
                                        }
                                    }
                                }
                                VxButton {
                                    label: "Rename";
                                    glyph: "RN";
                                    small: true;
                                    accent: true;
                                    clicked => {
                                        if rename-input.text != "" {
                                            root.rename-space(rename-input.text);
                                            rename-input.text = "";
                                        }
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                desc-input := VxInput {
                                    prominent: true;
                                    placeholder: "Space description (optional)";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        root.set-space-description(self.text);
                                        self.text = "";
                                    }
                                }
                                VxButton {
                                    label: "Save";
                                    glyph: "SV";
                                    small: true;
                                    soft: true;
                                    clicked => {
                                        root.set-space-description(desc-input.text);
                                        desc-input.text = "";
                                    }
                                }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                alignment: space-between;
                                Text {
                                    text: "Make Public";
                                    color: VxTheme.text-primary;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                }
                                VxButton {
                                    label: root.is-space-public ? "Public" : "Private";
                                    glyph: root.is-space-public ? "PB" : "PR";
                                    small: true;
                                    accent: root.is-space-public;
                                    soft: !root.is-space-public;
                                    clicked => {
                                        root.set-space-public(!root.is-space-public);
                                    }
                                }
                            }
                        }
                    }

                    if root.can-manage-space-channels : VxCard {
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionLabel { text: "AUTO-MODERATION"; }
                            Text {
                                text: "Filtered words are automatically removed or trigger a warning.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                wide-automod-word-input := VxInput {
                                    text <=> root.automod-word-input;
                                    placeholder: "Word or phrase";
                                    horizontal-stretch: 1;
                                    accepted => {
                                        if root.automod-word-input != "" {
                                            root.add-automod-word(
                                                root.automod-word-input,
                                                root.automod-action-index == 0 ? "delete" : "warn",
                                            );
                                            root.automod-word-input = "";
                                        }
                                    }
                                }
                                VxButton {
                                    label: root.automod-action-index == 0 ? "Delete" : "Warn";
                                    small: true;
                                    soft: true;
                                    clicked => {
                                        root.automod-action-index = root.automod-action-index == 0 ? 1 : 0;
                                    }
                                }
                                VxButton {
                                    label: "Add";
                                    small: true;
                                    accent: true;
                                    enabled: root.automod-word-input != "";
                                    clicked => {
                                        if root.automod-word-input != "" {
                                            root.add-automod-word(
                                                root.automod-word-input,
                                                root.automod-action-index == 0 ? "delete" : "warn",
                                            );
                                            root.automod-word-input = "";
                                        }
                                    }
                                }
                            }
                            if root.automod-words.length == 0 : Text {
                                text: "No filtered words yet.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                            }
                            for entry in root.automod-words : Rectangle {
                                border-radius: VxTheme.radius-card;
                                background: VxTheme.bg-soft;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                HorizontalLayout {
                                    padding: 10px;
                                    spacing: 8px;
                                    alignment: center;
                                    Text {
                                        text: entry.word;
                                        color: VxTheme.text-primary;
                                        font-size: 11px;
                                        font-weight: 600;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                    VxStatusPill {
                                        label: entry.action == "delete" ? "Delete" : "Warn";
                                        tone: entry.action == "delete" ? VxTheme.danger : VxTheme.warning;
                                        fill: entry.action == "delete" ? VxTheme.danger.transparentize(0.85) : VxTheme.warning.transparentize(0.85);
                                    }
                                    VxButton {
                                        label: "Remove";
                                        glyph: "RM";
                                        small: true;
                                        ghost: true;
                                        clicked => { root.remove-automod-word(entry.word); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !root.wide : VerticalLayout {
                spacing: 12px;

                // Profile + invite in one compact row
                HorizontalLayout {
                    spacing: 6px;
                    VxInput {
                        text <=> root.user-status-input;
                        placeholder: "Status";
                        horizontal-stretch: 1;
                        accepted => {
                            if root.user-status-input != "" {
                                root.set-user-status(root.user-status-input);
                                root.user-status-input = "";
                            }
                        }
                    }
                    VxButton {
                        label: "Set";
                        glyph: "ST";
                        small: true;
                        soft: true;
                        enabled: root.user-status-input != "";
                        clicked => {
                            if root.user-status-input != "" {
                                root.set-user-status(root.user-status-input);
                                root.user-status-input = "";
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: center;
                            Text {
                                text: root.streamer-mode ? "Invite: ********" : "Invite: " + root.current-space-invite;
                                color: VxTheme.text-primary;
                                font-size: 13px;
                                font-weight: 700;
                                letter-spacing: 1px;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                            VxButton {
                                label: "Copy";
                                glyph: "CP";
                                small: true;
                                accent: true;
                                clicked => { root.copy-invite-code(); }
                            }
                            VxButton {
                                label: "Share";
                                glyph: "SH";
                                small: true;
                                soft: true;
                                clicked => { root.copy-share-message(); }
                            }
                        }
                    }
                }

                // ── Favorite channels (compact) ──
                if root.visible-favorite-channels > 0 : VxCard {
                    VerticalLayout {
                        padding: 14px;
                        spacing: 8px;
                        HorizontalLayout {
                            alignment: space-between;
                            SectionLabel { text: "FAVORITES"; }
                            VxStatusPill {
                                label: root.visible-favorite-channels + "";
                                tone: VxTheme.warning;
                                fill: VxTheme.bg-soft;
                            }
                        }

                        for channel in root.channels : Rectangle {
                            visible: channel.is-favorite && !channel.is-category-header;
                            height: channel.is-favorite && !channel.is-category-header ? 42px * VxTheme.s : 0px;
                            border-radius: 12px;
                            background: channel.is-active ? VxTheme.tab-active-bg :
                                        compact-fav-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                            border-color: channel.is-active ? VxTheme.accent-border : transparent;
                            border-width: channel.is-active ? 1px : 0px;
                            clip: true;

                            compact-fav-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if channel.is-voice {
                                        root.join-channel(channel.id);
                                    } else {
                                        root.select-text-channel(channel.id);
                                    }
                                }
                            }

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                height: 42px * VxTheme.s;
                                spacing: 8px;
                                alignment: center;
                                if channel.is-active || channel.unread-count > 0 : Rectangle {
                                    width: 3px;
                                    height: 22px;
                                    border-radius: 1.5px;
                                    background: channel.is-active ? VxTheme.accent : VxTheme.warning;
                                }
                                VxGlyphTile {
                                    tile-size: 24px;
                                    glyph: channel.is-voice ? "VC" : "TX";
                                    tone: channel.is-active || channel.unread-count > 0 ? VxTheme.accent : VxTheme.text-secondary;
                                }
                                Text {
                                    text: channel.name;
                                    color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                if channel.unread-count > 0 : Text {
                                    text: channel.unread-count > 99 ? "99+" : channel.unread-count + "";
                                    color: VxTheme.accent;
                                    font-size: 11px;
                                    font-weight: 700;
                                }
                                if channel.is-voice && channel.peer-count > 0 : Text {
                                    text: channel.peer-count + " live";
                                    color: VxTheme.success;
                                    font-size: 10px;
                                    font-weight: 600;
                                }
                            }
                        }
                    }
                }

                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                            HorizontalLayout {
                                alignment: space-between;
                                SectionLabel { text: "CHANNELS"; }
                                VxStatusPill {
                                    label: (root.visible-text-channels + root.visible-voice-channels) + "";
                                    tone: VxTheme.accent;
                                    fill: VxTheme.bg-soft;
                                }
                            }
                        if root.channels.length == 0 : VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: root.search-query == ""
                                    ? (root.is-space-owner ? "Your space is empty!" : "No channels yet")
                                    : "No channels match this filter.";
                                color: root.search-query == "" && root.is-space-owner ? VxTheme.accent : VxTheme.text-secondary;
                                font-size: root.is-space-owner && root.search-query == "" ? 14px : 11px;
                                font-weight: root.is-space-owner && root.search-query == "" ? 700 : 600;
                            }
                            if root.search-query == "" : Text {
                                text: root.is-space-owner
                                    ? "Create your first channel to get started. Voice channels are great for talking, text channels for chat."
                                    : "The space owner hasn't created any channels yet.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                        for channel in root.channels : Rectangle {
                            height: !channel.is-voice && root.topic-edit-channel-id == channel.id ? 94px : 52px * VxTheme.s;
                            border-radius: 12px;
                            background: channel.is-active ? VxTheme.tab-active-bg :
                                        compact-channel-touch.has-hover ? VxTheme.row-hover-bg :
                                        channel.mention-count > 0 ? VxTheme.warning-soft.transparentize(0.08) :
                                        channel.unread-count > 0 ? VxTheme.bg-soft : transparent;
                            border-color: channel.is-active
                                ? VxTheme.accent-border
                                : transparent;
                            border-width: channel.is-active ? 1px : 0px;
                            clip: true;

                            compact-channel-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if channel.is-voice {
                                        root.join-channel(channel.id);
                                    } else {
                                        root.select-text-channel(channel.id);
                                    }
                                }
                            }

                            if channel.is-active || channel.unread-count > 0 || channel.mention-count > 0 : Rectangle {
                                x: 0px;
                                y: 9px;
                                width: 3px;
                                height: 34px * VxTheme.s;
                                border-radius: 1.5px;
                                background: channel.mention-count > 0 ? VxTheme.warning :
                                    channel.is-active ? VxTheme.accent : VxTheme.text-secondary;
                            }

                            VerticalLayout {
                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 12px;
                                    height: 52px * VxTheme.s;
                                    spacing: 6px;
                                    alignment: center;
                                    TouchArea {
                                        width: 18px;
                                        mouse-cursor: pointer;
                                        clicked => { root.toggle-favorite-channel(channel.id); }
                                        Text {
                                            text: channel.is-favorite ? "\u{2605}" : "\u{2606}";
                                            color: channel.is-favorite ? VxTheme.warning : VxTheme.text-muted;
                                            font-size: 13px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                    VxGlyphTile {
                                        tile-size: 26px;
                                        glyph: channel.is-voice ? "VC" : "TX";
                                        tone: channel.is-active || channel.is-voice ? VxTheme.accent : VxTheme.text-secondary;
                                    }
                                    Text {
                                        text: channel.name;
                                        color: channel.is-active ? VxTheme.accent : VxTheme.text-primary;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                    // Notification override indicator (compact)
                                    if channel.notification-setting == "none" : Text {
                                        text: "\u{00D7}";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                    }
                                    if channel.notification-setting == "mentions" : Text {
                                        text: "@";
                                        color: VxTheme.text-muted;
                                        font-size: 9px;
                                        font-weight: 700;
                                    }
                                    if channel.unread-count > 0 : Text {
                                        text: channel.unread-count > 99 ? "99+" : channel.unread-count + "";
                                        color: VxTheme.accent;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }
                                    if channel.is-voice && channel.user-limit > 0 : Text {
                                        text: channel.peer-count + "/" + channel.user-limit;
                                        color: channel.peer-count >= channel.user-limit ? VxTheme.danger
                                            : channel.peer-count * 100 >= channel.user-limit * 80 ? VxTheme.warning
                                            : VxTheme.text-muted;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    if channel.peer-count > 0 && (!channel.is-voice || channel.user-limit <= 0) : Text {
                                        text: channel.peer-count + "";
                                        color: VxTheme.text-muted;
                                        font-size: 10px;
                                        font-weight: 700;
                                    }
                                    // Compact notification bell (text channels only)
                                    if !channel.is-voice && (compact-channel-touch.has-hover || channel.notification-setting == "none" || channel.notification-setting == "mentions") : Rectangle {
                                        width: 20px;
                                        height: 20px;
                                        border-radius: 5px;
                                        background: compact-notif-ta.has-hover ? VxTheme.btn-hover-bg : transparent;
                                        compact-notif-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                // Cycle: all -> mentions -> none -> all
                                                if channel.notification-setting == "mentions" {
                                                    root.set-channel-notification(channel.id, "none");
                                                } else if channel.notification-setting == "none" {
                                                    root.set-channel-notification(channel.id, "all");
                                                } else {
                                                    root.set-channel-notification(channel.id, "mentions");
                                                }
                                            }
                                        }
                                        Text {
                                            text: channel.notification-setting == "none" ? "\u{1F6AB}"
                                                : channel.notification-setting == "mentions" ? "\u{1F515}"
                                                : "\u{1F514}";
                                            font-size: 11px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            color: channel.notification-setting == "none" ? VxTheme.text-muted
                                                 : channel.notification-setting == "mentions" ? VxTheme.warning
                                                 : VxTheme.text-secondary;
                                        }
                                    }
                                    if root.can-manage-space-channels && !channel.is-voice && (compact-channel-touch.has-hover || root.topic-edit-channel-id == channel.id) : VxButton {
                                        label: root.topic-edit-channel-id == channel.id ? "Save" : "Topic";
                                        glyph: root.topic-edit-channel-id == channel.id ? "SV" : "TP";
                                        small: true;
                                        soft: root.topic-edit-channel-id != channel.id;
                                        accent: root.topic-edit-channel-id == channel.id;
                                        clicked => {
                                            if root.topic-edit-channel-id == channel.id {
                                                root.set-channel-topic(channel.id, root.topic-edit-value);
                                                root.topic-edit-channel-id = "";
                                                root.topic-edit-value = "";
                                            } else {
                                                root.topic-edit-channel-id = channel.id;
                                                root.topic-edit-value = channel.topic;
                                            }
                                        }
                                    }
                                    if root.can-manage-space-channels && compact-channel-touch.has-hover : VxButton {
                                        label: "\u{25B2}";
                                        small: true;
                                        ghost: true;
                                        clicked => { root.move-channel-up(channel.id); }
                                    }
                                    if root.can-manage-space-channels && compact-channel-touch.has-hover : VxButton {
                                        label: "\u{25BC}";
                                        small: true;
                                        ghost: true;
                                        clicked => { root.move-channel-down(channel.id); }
                                    }
                                    if root.can-manage-space-channels && (compact-channel-touch.has-hover || root.confirm-delete-channel-id == channel.id) : VxButton {
                                        label: root.confirm-delete-channel-id == channel.id ? "Confirm" : "Delete";
                                        glyph: root.confirm-delete-channel-id == channel.id ? "OK" : "DL";
                                        small: true;
                                        danger: root.confirm-delete-channel-id == channel.id;
                                        soft: root.confirm-delete-channel-id != channel.id;
                                        clicked => {
                                            if root.confirm-delete-channel-id == channel.id {
                                                root.confirm-delete-channel-id = "";
                                                root.delete-channel(channel.id);
                                            } else {
                                                root.confirm-delete-channel-id = channel.id;
                                            }
                                        }
                                    }
                                }

                                if root.topic-edit-channel-id == channel.id && !channel.is-voice : HorizontalLayout {
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    padding-bottom: 10px;
                                    spacing: 8px;
                                    VxInput {
                                        text <=> root.topic-edit-value;
                                        placeholder: "Channel topic";
                                        horizontal-stretch: 1;
                                        accepted => {
                                            root.set-channel-topic(channel.id, root.topic-edit-value);
                                            root.topic-edit-channel-id = "";
                                            root.topic-edit-value = "";
                                        }
                                    }
                                    VxButton {
                                        label: "Cancel";
                                        glyph: "CN";
                                        small: true;
                                        ghost: true;
                                        clicked => {
                                            root.topic-edit-channel-id = "";
                                            root.topic-edit-value = "";
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.can-view-space-audit : VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "ACTIVITY"; }
                        if root.audit-entries.length == 0 : Text {
                            text: "Role changes and moderation actions show up here.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        for entry in root.audit-entries : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: VxTheme.bg-soft;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            VerticalLayout {
                                padding: 12px;
                                spacing: 4px;
                                Text {
                                    text: entry.actor-name + " • " + entry.action;
                                    color: VxTheme.text-primary;
                                    font-size: 10px;
                                    font-weight: 700;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: entry.detail;
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: entry.timestamp;
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                }
                            }
                        }
                    }
                }

                if root.can-manage-space-channels : VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        SectionLabel { text: "AUTO-MODERATION"; }
                        Text {
                            text: "Filtered words are automatically removed or trigger a warning.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            compact-automod-word-input := VxInput {
                                text <=> root.automod-word-input;
                                placeholder: "Word or phrase";
                                horizontal-stretch: 1;
                                accepted => {
                                    if root.automod-word-input != "" {
                                        root.add-automod-word(
                                            root.automod-word-input,
                                            root.automod-action-index == 0 ? "delete" : "warn",
                                        );
                                        root.automod-word-input = "";
                                    }
                                }
                            }
                            VxButton {
                                label: root.automod-action-index == 0 ? "Delete" : "Warn";
                                small: true;
                                soft: true;
                                clicked => {
                                    root.automod-action-index = root.automod-action-index == 0 ? 1 : 0;
                                }
                            }
                            VxButton {
                                label: "Add";
                                small: true;
                                accent: true;
                                enabled: root.automod-word-input != "";
                                clicked => {
                                    if root.automod-word-input != "" {
                                        root.add-automod-word(
                                            root.automod-word-input,
                                            root.automod-action-index == 0 ? "delete" : "warn",
                                        );
                                        root.automod-word-input = "";
                                    }
                                }
                            }
                        }
                        if root.automod-words.length == 0 : Text {
                            text: "No filtered words yet.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                        }
                        for entry in root.automod-words : Rectangle {
                            border-radius: VxTheme.radius-card;
                            background: VxTheme.bg-soft;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            HorizontalLayout {
                                padding: 10px;
                                spacing: 8px;
                                alignment: center;
                                Text {
                                    text: entry.word;
                                    color: VxTheme.text-primary;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                VxStatusPill {
                                    label: entry.action == "delete" ? "Delete" : "Warn";
                                    tone: entry.action == "delete" ? VxTheme.danger : VxTheme.warning;
                                    fill: entry.action == "delete" ? VxTheme.danger.transparentize(0.85) : VxTheme.warning.transparentize(0.85);
                                }
                                VxButton {
                                    label: "Remove";
                                    glyph: "RM";
                                    small: true;
                                    ghost: true;
                                    clicked => { root.remove-automod-word(entry.word); }
                                }
                            }
                        }
                    }
                }

                // Space actions (leave / delete)
                VxCard {
                    VerticalLayout {
                        padding: 18px;
                        spacing: 12px;
                        SectionLabel { text: "SPACE ACTIONS"; }
                        VxButton {
                            label: "Leave space";
                            glyph: "LV";
                            soft: true;
                            horizontal-stretch: 1;
                            clicked => { root.leave-space(); }
                        }
                        if root.is-space-owner : VxButton {
                            label: root.confirm-delete-visible ? "Confirm delete" : "Delete space";
                            glyph: root.confirm-delete-visible ? "OK" : "DL";
                            danger: true;
                            horizontal-stretch: 1;
                            clicked => {
                                if root.confirm-delete-visible {
                                    root.confirm-delete-visible = false;
                                    root.delete-space();
                                } else {
                                    root.confirm-delete-visible = true;
                                }
                            }
                        }
                        if root.is-space-owner && root.confirm-delete-visible : Text {
                            text: "Delete removes the space for everyone.";
                            color: VxTheme.danger;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                        if !root.is-space-owner : Text {
                            text: "Only the creator can delete the space.";
                            color: VxTheme.text-muted;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
