import { ScrollView } from "std-widgets.slint";
import { SpaceData, MemberData, VxTheme } from "theme.slint";
import { AccentBar, Divider, SectionLabel, StatusDot, VxAvatar, VxButton, VxGlyphTile, VxLogo, VxStatusPill } from "components.slint";

export component TopBar inherits Rectangle {
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <bool> compact: false;
    in property <bool> is-connected: false;
    in property <int> ping-ms: -1;
    in property <string> room-code: "";
    in property <int> unread-direct-messages-count: 0;
    in property <bool> show-nav-button: false;
    in property <bool> in-call: false;
    in property <bool> is-muted: false;
    in property <bool> is-deafened: false;
    in property <bool> update-available: false;
    in property <string> update-version: "";
    callback nav-toggle();

    height: (root.compact ? 52px : 58px) * VxTheme.s;
    background: @linear-gradient(180deg,
        VxTheme.bg-panel.brighter(VxTheme.dark-mode ? 0.04 : 0.02) 0%,
        VxTheme.bg-panel 72%,
        VxTheme.bg-soft.transparentize(VxTheme.dark-mode ? 0.78 : 0.60) 100%);

    Rectangle {
        x: -parent.width * 0.04;
        y: 0px;
        width: parent.width * 0.38;
        height: parent.height;
        background: @linear-gradient(135deg, VxTheme.accent-glow 0%, transparent 74%);
        opacity: VxTheme.dark-mode ? 0.9 : 0.58;
    }

    Rectangle {
        x: parent.width * 0.68;
        y: 0px;
        width: parent.width * 0.22;
        height: parent.height;
        background: @linear-gradient(180deg, VxTheme.header-accent-right.transparentize(0.92) 0%, transparent 100%);
        opacity: VxTheme.dark-mode ? 0.72 : 0.44;
    }

    AccentBar {
        y: parent.height - 2px;
        opacity: 0.65;
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: space-between;
        spacing: root.compact ? 8px : 10px;

        HorizontalLayout {
            spacing: root.compact ? 8px : 12px;
            alignment: center;

            if root.show-nav-button : Rectangle {
                width: root.compact ? 36px : 40px;
                height: root.compact ? 36px : 40px;
                border-radius: VxTheme.radius-control;
                background: nav-button-touch.has-hover ? VxTheme.tab-active-bg : VxTheme.bg-soft;
                border-color: nav-button-touch.has-hover ? VxTheme.accent-border : VxTheme.border-subtle;
                border-width: 1px;
                clip: true;

                accessible-role: button;
                accessible-label: "Toggle sidebar navigation";

                nav-button-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.nav-toggle(); }
                }

                VerticalLayout {
                    alignment: center;
                    spacing: 4px;
                    Rectangle {
                        width: parent.width;
                        height: 2px;
                        background: nav-button-touch.has-hover ? VxTheme.accent : #ffffff18;
                    }
                    for row in [0, 1, 2] : Rectangle {
                        width: 18px;
                        height: 2px;
                        border-radius: 1px;
                        background: row == 1 ? VxTheme.accent : VxTheme.text-secondary;
                    }
                }
            }

            VerticalLayout {
                alignment: center;
                spacing: root.subtitle != "" ? 2px : 0px;
                Text {
                    text: root.title;
                    color: VxTheme.text-primary;
                    font-size: root.compact ? 16px : 19px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                if root.subtitle != "" : Text {
                    text: root.subtitle;
                    color: VxTheme.text-muted;
                    font-size: 10px;
                    font-weight: 600;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        HorizontalLayout {
            spacing: root.compact ? 6px : 8px;
            alignment: center;

            if root.room-code != "" : VxStatusPill {
                label: "Room " + root.room-code;
                tone: root.in-call ? VxTheme.success : VxTheme.accent;
                fill: root.in-call ? VxTheme.success-dim : VxTheme.accent-subtle;
            }

            if root.unread-direct-messages-count > 0 : VxStatusPill {
                label: "Inbox " + root.unread-direct-messages-count;
                tone: VxTheme.accent;
                fill: VxTheme.accent-subtle;
            }

            if root.update-available : VxStatusPill {
                label: "Update " + root.update-version;
                tone: VxTheme.accent;
                fill: VxTheme.accent-subtle;
            }

            if root.in-call && root.is-muted : VxStatusPill {
                label: "Muted";
                tone: VxTheme.danger;
                fill: VxTheme.mute-badge-bg;
            }

            if root.in-call && root.is-deafened : VxStatusPill {
                label: "Deafened";
                tone: VxTheme.warning;
                fill: VxTheme.deafen-badge-bg;
            }

            Rectangle {
                height: 32px;
                border-radius: VxTheme.radius-pill;
                background: VxTheme.bg-soft;
                border-color: VxTheme.border-subtle;
                border-width: 1px;
                clip: true;

                Rectangle {
                    width: parent.width;
                    height: 1px;
                    background: VxTheme.dark-mode ? #ffffff0a : #ffffffc4;
                    opacity: 0.78;
                }

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    spacing: 8px;
                    alignment: center;

                    StatusDot { active: root.is-connected; }

                    Text {
                        text: root.is-connected ? "Connected" : "Offline";
                        color: root.is-connected ? VxTheme.text-primary : VxTheme.text-muted;
                        font-size: 10px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }

                    if root.ping-ms >= 0 : Rectangle {
                        width: 1px;
                        height: 14px;
                        background: VxTheme.border-subtle;
                    }

                    if root.ping-ms >= 0 : Text {
                        text: root.ping-ms + " ms";
                        color: root.ping-ms < 60 ? VxTheme.success :
                               root.ping-ms < 150 ? VxTheme.warning : VxTheme.danger;
                        font-size: 10px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

export component WorkspaceRail inherits Rectangle {
    in property <int> current-view: 0;
    in property <bool> compact: false;
    in property <[SpaceData]> spaces: [];
    in property <string> current-space-id: "";
    in property <[MemberData]> members: [];
    in property <bool> show-members: false;
    in property <string> room-code: "";
    in property <int> unread-direct-messages-count: 0;
    in property <int> favorite-friends-count: 0;
    in property <int> online-friends-count: 0;
    in property <string> user-name: "";
    in property <string> user-status: "";
    in property <bool> is-muted: false;
    in property <bool> is-deafened: false;
    callback navigate(int);
    callback select-space(string);
    callback show-shortcuts();

    width: root.compact ? 212px : 240px;
    background: VxTheme.bg-rail;

    Rectangle {
        x: -parent.width * 0.18;
        y: 0px;
        width: parent.width * 0.92;
        height: 220px;
        background: @linear-gradient(150deg, VxTheme.accent-glow.transparentize(0.28) 0%, transparent 72%);
        opacity: VxTheme.dark-mode ? 0.42 : 0.28;
    }

    Rectangle {
        x: parent.width - 1px;
        width: 1px;
        height: parent.height;
        background: VxTheme.border-subtle;
    }

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: root.compact ? 58px : 66px;
            background: transparent;

            HorizontalLayout {
                padding-left: root.compact ? 14px : 16px;
                padding-right: root.compact ? 14px : 16px;
                spacing: root.compact ? 10px : 12px;
                alignment: center;

                VxLogo { logo-size: root.compact ? 32px : 36px; }

                VerticalLayout {
                    alignment: center;
                    spacing: 2px;

                    Text {
                        text:
                            VxTheme.is-retro ? "VOXLINK//" :
                            VxTheme.is-amber ? "VOX>LINK_" :
                            "VOXLINK";
                        color: VxTheme.text-primary;
                        font-size: root.compact ? 12px : 13px;
                        font-weight:
                            VxTheme.is-noir ? 500 : 800;
                        letter-spacing:
                            VxTheme.is-noir ? 0.6px :
                            VxTheme.is-retro || VxTheme.is-amber ? 2.0px :
                            1.4px;
                    }
                    Text {
                        text: root.compact ? "Voice-first" : "Fast voice, spaces, and chat";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        font-weight:
                            VxTheme.is-retro || VxTheme.is-amber ? 700 : 500;
                        letter-spacing:
                            VxTheme.is-retro || VxTheme.is-amber ? 1.0px : 0px;
                    }
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-bottom: 14px;
                spacing: root.compact ? 10px : 12px;

                Rectangle {
                    border-radius: VxTheme.radius-card;
                    background: root.room-code != ""
                        ? @linear-gradient(140deg, VxTheme.accent-subtle 0%, VxTheme.bg-soft 72%, transparent 100%)
                        : @linear-gradient(140deg, VxTheme.bg-soft.brighter(0.03) 0%, VxTheme.bg-soft 78%, transparent 100%);
                    border-color: root.room-code != ""
                        ? VxTheme.accent-border
                        : session-touch.has-hover ? VxTheme.accent-border : VxTheme.border-subtle;
                    border-width: 1px;
                    clip: true;

                    session-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.navigate(root.room-code != "" ? 1 : 3);
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 8px;
                        width: 3px;
                        height: parent.height - 16px;
                        border-radius: 2px;
                        background: root.room-code != "" ? VxTheme.accent : VxTheme.border-subtle;
                    }

                    HorizontalLayout {
                        padding: 12px;
                        spacing: 10px;
                        alignment: center;

                        VxGlyphTile {
                            tile-size: root.compact ? 34px : 36px;
                            glyph: root.room-code != "" ? "VC" : "SY";
                            tone: root.room-code != "" ? VxTheme.accent : VxTheme.text-secondary;
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 4px;

                            HorizontalLayout {
                                alignment: space-between;
                                spacing: 6px;

                                SectionLabel {
                                    text: root.room-code != "" ? "ACTIVE ROOM" : "SESSION";
                                }

                                VxStatusPill {
                                    label: root.room-code != ""
                                        ? "Live"
                                        : root.unread-direct-messages-count > 0 ? "Inbox" : "Ready";
                                    tone: root.room-code != "" ? VxTheme.success :
                                        root.unread-direct-messages-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                    fill: root.room-code != "" ? VxTheme.success-dim :
                                        root.unread-direct-messages-count > 0 ? VxTheme.accent-subtle : VxTheme.bg-soft;
                                }
                            }

                            Text {
                                text: root.room-code != ""
                                    ? "Room " + root.room-code
                                    : "Keep voice, inbox, and friends close";
                                color: VxTheme.text-primary;
                                font-size: 12px;
                                font-weight: 800;
                                wrap: word-wrap;
                            }

                            Text {
                                text: root.room-code != ""
                                    ? (root.compact
                                        ? "Resume without leaving the rail."
                                        : "Jump back into the live room without leaving the shell.")
                                    : (root.compact
                                        ? "Unread messages and favorites stay one tap away."
                                        : "Unread direct messages, favorite friends, and your current room stay one step away.");
                                color: VxTheme.text-secondary;
                                font-size: 9px;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                spacing: 6px;

                                VxStatusPill {
                                    label: root.unread-direct-messages-count > 0
                                        ? root.unread-direct-messages-count + " unread"
                                        : "Inbox clear";
                                    tone: root.unread-direct-messages-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                    fill: root.unread-direct-messages-count > 0 ? VxTheme.accent-subtle : VxTheme.bg-soft;
                                }

                                VxStatusPill {
                                    label: root.favorite-friends-count > 0
                                        ? root.online-friends-count + " online"
                                        : "No favorites";
                                    tone: root.online-friends-count > 0 ? VxTheme.success : VxTheme.text-muted;
                                    fill: root.online-friends-count > 0 ? VxTheme.success-dim : VxTheme.bg-soft;
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: 6px;
                    HorizontalLayout {
                        alignment: space-between;
                        spacing: 6px;
                        SectionLabel {
                            text: "NAVIGATION";
                        }
                        VxStatusPill {
                            label: "3";
                            tone: VxTheme.text-muted;
                            fill: VxTheme.bg-soft;
                        }
                    }

                    Rectangle {
                        height: 44px;
                        border-radius: VxTheme.radius-control;
                        background: root.current-view == 0 ? VxTheme.tab-active-bg :
                                    home-rail-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                        border-color: root.current-view == 0 ? VxTheme.accent-border :
                            home-rail-touch.has-hover ? VxTheme.border-subtle : transparent;
                        border-width: 1px;
                        clip: true;

                        accessible-role: button;
                        accessible-label: "Home — Dashboard and spaces";

                        home-rail-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.navigate(0); }
                        }

                        Rectangle {
                            x: 0px;
                            y: 7px;
                            width: 3px;
                            height: parent.height - 14px;
                            border-radius: 2px;
                            background: root.current-view == 0 ? VxTheme.accent : transparent;
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;

                            VxGlyphTile {
                                tile-size: 30px;
                                glyph: "HM";
                                tone: root.current-view == 0 ? VxTheme.accent : VxTheme.text-secondary;
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: "Home";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: "Calls, spaces, and chat";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    visible: !root.compact;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 44px;
                        border-radius: VxTheme.radius-control;
                        background: root.current-view == 2 ? VxTheme.tab-active-bg :
                                    settings-rail-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                        border-color: root.current-view == 2 ? VxTheme.accent-border :
                            settings-rail-touch.has-hover ? VxTheme.border-subtle : transparent;
                        border-width: 1px;
                        clip: true;

                        accessible-role: button;
                        accessible-label: "Settings — Audio, devices, keybinds";

                        settings-rail-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.navigate(2); }
                        }

                        Rectangle {
                            x: 0px;
                            y: 7px;
                            width: 3px;
                            height: parent.height - 14px;
                            border-radius: 2px;
                            background: root.current-view == 2 ? VxTheme.accent : transparent;
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;

                            VxGlyphTile {
                                tile-size: 30px;
                                glyph: "IO";
                                tone: root.current-view == 2 ? VxTheme.accent : VxTheme.text-secondary;
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: "Settings";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: "Audio, devices, shortcuts";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    visible: !root.compact;
                                }
                            }
                        }
                    }

                    Rectangle {
                        height: 44px;
                        border-radius: VxTheme.radius-control;
                        background: root.current-view == 3 ? VxTheme.tab-active-bg :
                                    system-rail-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                        border-color: root.current-view == 3 ? VxTheme.accent-border :
                            system-rail-touch.has-hover ? VxTheme.border-subtle : transparent;
                        border-width: 1px;
                        clip: true;

                        accessible-role: button;
                        accessible-label: "System — Performance, friends, session";

                        system-rail-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.navigate(3); }
                        }

                        Rectangle {
                            x: 0px;
                            y: 7px;
                            width: 3px;
                            height: parent.height - 14px;
                            border-radius: 2px;
                            background: root.current-view == 3 ? VxTheme.accent : transparent;
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;

                            VxGlyphTile {
                                tile-size: 30px;
                                glyph: "SY";
                                tone: root.current-view == 3 ? VxTheme.accent : VxTheme.text-secondary;
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 1px;
                                Text {
                                    text: "System";
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }
                                Text {
                                    text: "Health, friends, runtime";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    visible: !root.compact;
                                }
                            }

                            Rectangle { horizontal-stretch: 1; }

                            if root.unread-direct-messages-count > 0 : VxStatusPill {
                                label: root.unread-direct-messages-count + "";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }
                    }
                }

                Divider {}

                Flickable {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 6px;

                    HorizontalLayout {
                        alignment: space-between;
                        spacing: 6px;
                        SectionLabel { text: "SPACES"; }
                        if root.spaces.length > 0 : VxStatusPill {
                            label: root.spaces.length + "";
                            tone: VxTheme.text-muted;
                            fill: VxTheme.bg-soft;
                        }
                    }

                    if root.spaces.length == 0 : Rectangle {
                        border-radius: VxTheme.radius-card;
                        background: VxTheme.bg-soft;
                        border-color: VxTheme.border-subtle;
                        border-width: 1px;
                        VerticalLayout {
                            padding: 14px;
                            spacing: 4px;
                            Text {
                                text: "No spaces yet";
                                color: VxTheme.text-primary;
                                font-size: 12px;
                                font-weight: 700;
                            }
                            Text {
                                text: "Create one from Home to unlock the workspace rail.";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    for space in root.spaces : Rectangle {
                        height: 52px;
                        border-radius: VxTheme.radius-control;
                        background: root.current-space-id == space.id &&
                                    (root.current-view == 1 || root.current-view == 4 || root.current-view == 5)
                                    ? VxTheme.tab-active-bg
                                    : space-rail-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                        border-color: root.current-space-id == space.id &&
                                      (root.current-view == 1 || root.current-view == 4 || root.current-view == 5)
                                      ? VxTheme.accent-border :
                                      space-rail-touch.has-hover ? VxTheme.border-subtle : transparent;
                        border-width: 1px;
                        clip: true;

                        space-rail-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.select-space(space.id); }
                        }

                        Rectangle {
                            x: 0px;
                            y: 7px;
                            width: 3px;
                            height: parent.height - 14px;
                            border-radius: 2px;
                            background: root.current-space-id == space.id &&
                                (root.current-view == 1 || root.current-view == 4 || root.current-view == 5)
                                ? VxTheme.accent : transparent;
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;

                            VxAvatar {
                                avatar-size: 34px;
                                initial: space.initial;
                                color-index: space.color-index;
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                spacing: 2px;
                                Text {
                                    text: space.name;
                                    color: VxTheme.text-primary;
                                    font-size: 12px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                Text {
                                    text: space.member-count + " members  ·  " + space.channel-count + " channels";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    overflow: elide;
                                }
                            }

                            if root.current-space-id == space.id &&
                                (root.current-view == 1 || root.current-view == 4 || root.current-view == 5) : VxStatusPill {
                                label: "Open";
                                tone: VxTheme.accent;
                                fill: VxTheme.accent-subtle;
                            }
                        }
                    }

                if root.show-members && root.members.length > 0 : Divider {}

                if root.show-members && root.members.length > 0 : VerticalLayout {
                    spacing: 6px;
                    HorizontalLayout {
                        alignment: space-between;
                        spacing: 6px;
                        SectionLabel { text: "ONLINE"; }
                        VxStatusPill {
                            label: root.members.length + "";
                            tone: VxTheme.success;
                            fill: VxTheme.success-dim;
                        }
                    }

                    for member in root.members : Rectangle {
                        height: 40px;
                        border-radius: VxTheme.radius-control;
                        background: member-rail-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                        border-color: member-rail-touch.has-hover ? VxTheme.border-subtle : transparent;
                        border-width: 1px;

                        member-rail-touch := TouchArea { }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 10px;
                            alignment: center;

                            VxAvatar {
                                avatar-size: 24px;
                                initial: member.initial;
                                color-index: member.color-index;
                                show-status: true;
                                is-online: member.is-online;
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                spacing: 1px;
                                Text {
                                    text: member.name;
                                    color: member.is-server-muted ? VxTheme.text-muted : VxTheme.text-primary;
                                    font-size: 10px;
                                    font-weight: 600;
                                    overflow: elide;
                                }
                                Text {
                                    text: member.is-in-voice ? member.channel-name : "Idle";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    overflow: elide;
                                }
                            }

                            if member.is-server-muted : VxStatusPill {
                                label: "Muted";
                                tone: VxTheme.danger;
                                fill: VxTheme.mute-badge-bg;
                            }
                        }
                    }
                }
                } // close Flickable VerticalLayout
                } // close Flickable

            }
        }

        // User identity footer (Discord-style)
        Rectangle {
            height: 1px;
            background: VxTheme.border-subtle;
        }

        Rectangle {
            height: 52px;
            background: @linear-gradient(180deg, VxTheme.bg-panel.brighter(0.02) 0%, VxTheme.bg-panel 100%);
            clip: true;

            user-footer-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.navigate(2); }
            }

            Rectangle {
                width: parent.width;
                height: 1px;
                background: VxTheme.dark-mode ? #ffffff0a : #ffffffc4;
                opacity: 0.78;
            }

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 10px;
                alignment: center;

                VxAvatar {
                    avatar-size: 28px;
                    initial: root.user-name != "" ? root.user-name : "?";
                    color-index: 0;
                    show-status: true;
                    is-online: true;
                }

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 1px;
                    Text {
                        text: root.user-name != "" ? root.user-name : "Not signed in";
                        color: VxTheme.text-primary;
                        font-size: 11px;
                        font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: root.user-status != "" ? root.user-status : "Online";
                        color: VxTheme.text-muted;
                        font-size: 9px;
                        overflow: elide;
                    }
                }

                if root.is-muted : VxStatusPill {
                    label: "M";
                    tone: VxTheme.danger;
                    fill: VxTheme.mute-badge-bg;
                }
                if root.is-deafened : VxStatusPill {
                    label: "D";
                    tone: VxTheme.warning;
                    fill: VxTheme.deafen-badge-bg;
                }

                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 14px;
                    background: help-touch.has-hover ? VxTheme.tab-active-bg : transparent;
                    border-color: help-touch.has-hover ? VxTheme.accent-border : transparent;
                    border-width: 1px;
                    animate background { duration: 80ms; }

                    help-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.show-shortcuts(); }
                    }
                    Text {
                        text: "?";
                        color: help-touch.has-hover ? VxTheme.accent : VxTheme.text-muted;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

    }
}

export component BottomNav inherits Rectangle {
    in property <int> current-view: 0;
    in property <int> unread-direct-messages-count: 0;
    callback navigate(int);

    height: 48px;
    background: VxTheme.bg-panel;

    AccentBar { y: 0px; opacity: 0.3; }

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 6px;

        Rectangle {
            horizontal-stretch: 1;
            border-radius: VxTheme.radius-control;
            background: root.current-view == 0 ? VxTheme.tab-active-bg :
                        home-tab-touch.has-hover ? VxTheme.row-hover-bg : transparent;
            home-tab-touch := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(0); } }
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                VxGlyphTile {
                    tile-size: 24px;
                    glyph: "HM";
                    tone: root.current-view == 0 ? VxTheme.accent : VxTheme.text-secondary;
                }
                Text {
                    text: VxTheme.is-party ? "GUIDE" :
                          VxTheme.is-retro ? "MAIN" :
                          VxTheme.is-space ? "BRIDGE" :
                          "HOME";
                    color: root.current-view == 0 ? VxTheme.accent : VxTheme.text-secondary;
                    font-size: 10px;
                    font-weight: 800;
                }
                Text {
                    text: VxTheme.is-party ? "Dashboard" :
                          VxTheme.is-noir ? "Lobby" :
                          "Overview";
                    color: VxTheme.text-muted;
                    font-size: 9px;
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            border-radius: VxTheme.radius-control;
            background: root.current-view == 2 ? VxTheme.tab-active-bg :
                        settings-tab-touch.has-hover ? VxTheme.row-hover-bg : transparent;
            settings-tab-touch := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(2); } }
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                VxGlyphTile {
                    tile-size: 24px;
                    glyph: "IO";
                    tone: root.current-view == 2 ? VxTheme.accent : VxTheme.text-secondary;
                }
                Text {
                    text: VxTheme.is-party ? "PREF" :
                          VxTheme.is-retro ? "CONF" :
                          VxTheme.is-space ? "CTRL" :
                          "SET";
                    color: root.current-view == 2 ? VxTheme.accent : VxTheme.text-secondary;
                    font-size: 10px;
                    font-weight: 800;
                }
                Text {
                    text: VxTheme.is-party ? "Audio" :
                          VxTheme.is-noir ? "Dials" :
                          VxTheme.is-space ? "Array" :
                          "Devices";
                    color: VxTheme.text-muted;
                    font-size: 9px;
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            border-radius: VxTheme.radius-control;
            background: root.current-view == 3 ? VxTheme.tab-active-bg :
                        system-tab-touch.has-hover ? VxTheme.row-hover-bg : transparent;
            system-tab-touch := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(3); } }
            VerticalLayout {
                alignment: center;
                spacing: 3px;
                VxGlyphTile {
                    tile-size: 24px;
                    glyph: "SY";
                    tone: root.current-view == 3 ? VxTheme.accent : VxTheme.text-secondary;
                }
                Text {
                    text: VxTheme.is-party ? "STATS" :
                          VxTheme.is-retro ? "MON" :
                          VxTheme.is-space ? "TEL" :
                          "SYS";
                    color: root.current-view == 3 ? VxTheme.accent : VxTheme.text-secondary;
                    font-size: 10px;
                    font-weight: 800;
                }
                Text {
                    text: VxTheme.is-party ? "Score" :
                          VxTheme.is-noir ? "Pulse" :
                          VxTheme.is-space ? "Sensors" :
                          "Health";
                    color: VxTheme.text-muted;
                    font-size: 9px;
                }
            }

            if root.unread-direct-messages-count > 0 : Rectangle {
                x: parent.width - (root.unread-direct-messages-count > 9 ? 30px : 24px);
                y: 6px;
                width: root.unread-direct-messages-count > 9 ? 24px : 18px;
                height: 18px;
                border-radius: 9px;
                background: VxTheme.accent;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                Text {
                    text: root.unread-direct-messages-count + "";
                    color: VxTheme.text-inverse;
                    font-size: 9px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// ─── Voice Call Bar ───
// Shown at the bottom when in a voice call but not viewing the room.
// Like Discord's green connection bar — shows channel info, mute/deafen, and return/disconnect buttons.
export component VoiceCallBar inherits Rectangle {
    in property <string> room-code: "";
    in property <string> space-name: "";
    in property <bool> in-space-channel: false;
    in property <bool> is-muted: false;
    in property <bool> is-deafened: false;
    in property <float> mic-level: 0.0;
    in property <int> ping-ms: -1;
    callback navigate(int);
    callback leave-room();
    callback leave-channel();
    callback toggle-mute();
    callback toggle-deafen();

    height: 44px * VxTheme.s;
    background: VxTheme.success.transparentize(0.88);

    // Top accent line
    Rectangle {
        y: 0px;
        width: parent.width;
        height: 1px;
        background: VxTheme.success.transparentize(0.5);
    }

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 12px;
        spacing: 10px;
        alignment: space-between;

        // Left: voice status + channel info
        HorizontalLayout {
            spacing: 8px;
            alignment: center;

            // Pulsing voice indicator
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: VxTheme.success;
                opacity: 0.6 + root.mic-level * 0.4;
            }

            VerticalLayout {
                alignment: center;
                spacing: 1px;

                Text {
                    text: "Voice Connected";
                    color: VxTheme.success;
                    font-size: 11px;
                    font-weight: 700;
                }
                Text {
                    text: root.in-space-channel && root.space-name != ""
                        ? root.space-name + " / " + root.room-code
                        : "Room " + root.room-code;
                    color: VxTheme.text-muted;
                    font-size: 9px;
                    overflow: elide;
                    max-width: 200px;
                }
            }
        }

        // Center: mute/deafen status pills
        HorizontalLayout {
            spacing: 6px;
            alignment: center;

            // Mute toggle
            Rectangle {
                width: mute-row.preferred-width + 14px;
                height: 26px;
                border-radius: VxTheme.radius-pill;
                background: root.is-muted
                    ? VxTheme.mute-badge-bg
                    : mute-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                border-color: root.is-muted ? VxTheme.warning.transparentize(0.6) : VxTheme.border-subtle;
                border-width: 1px;

                mute-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toggle-mute(); }
                }

                mute-row := HorizontalLayout {
                    padding-left: 7px;
                    padding-right: 7px;
                    spacing: 4px;
                    alignment: center;
                    Text {
                        text: root.is-muted ? "Muted" : "Mic";
                        color: root.is-muted ? VxTheme.warning : VxTheme.text-secondary;
                        font-size: 10px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }

            // Deafen toggle
            Rectangle {
                width: deafen-row.preferred-width + 14px;
                height: 26px;
                border-radius: VxTheme.radius-pill;
                background: root.is-deafened
                    ? VxTheme.mute-badge-bg
                    : deafen-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                border-color: root.is-deafened ? VxTheme.warning.transparentize(0.6) : VxTheme.border-subtle;
                border-width: 1px;

                deafen-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.toggle-deafen(); }
                }

                deafen-row := HorizontalLayout {
                    padding-left: 7px;
                    padding-right: 7px;
                    spacing: 4px;
                    alignment: center;
                    Text {
                        text: root.is-deafened ? "Deafened" : "Sound";
                        color: root.is-deafened ? VxTheme.warning : VxTheme.text-secondary;
                        font-size: 10px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
            }

            // Ping
            if root.ping-ms >= 0 : Text {
                text: root.ping-ms + "ms";
                color: root.ping-ms < 80 ? VxTheme.success :
                       root.ping-ms < 200 ? VxTheme.warning : VxTheme.danger;
                font-size: 9px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }

        // Right: return + disconnect buttons
        HorizontalLayout {
            spacing: 6px;
            alignment: center;

            // Return to call
            Rectangle {
                width: return-text.preferred-width + 18px;
                height: 28px;
                border-radius: VxTheme.radius-control;
                background: return-touch.has-hover ? VxTheme.success.transparentize(0.7) : VxTheme.success.transparentize(0.8);
                border-color: VxTheme.success.transparentize(0.5);
                border-width: 1px;

                return-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.navigate(1); }
                }

                return-text := Text {
                    text: "Return";
                    color: VxTheme.success;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // Disconnect
            Rectangle {
                width: disc-text.preferred-width + 18px;
                height: 28px;
                border-radius: VxTheme.radius-control;
                background: disc-touch.has-hover ? VxTheme.danger.transparentize(0.7) : VxTheme.danger.transparentize(0.85);
                border-color: VxTheme.danger.transparentize(0.5);
                border-width: 1px;

                disc-touch := TouchArea {
                    mouse-cursor: pointer;
                    clicked => {
                        if root.in-space-channel { root.leave-channel(); }
                        else { root.leave-room(); }
                    }
                }

                disc-text := Text {
                    text: "Disconnect";
                    color: VxTheme.danger;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

export component NavBreadcrumb inherits Rectangle {
    in property <int> current-view: 0;
    in property <int> previous-view: 0;
    in property <string> space-name: "";
    in property <string> channel-name: "";
    in property <string> room-code: "";
    in property <bool> in-space-channel: false;
    in property <bool> chat-is-dm: false;
    in property <int> chat-back-view: 4;
    callback navigate(int);

    height: 36px;
    background: @linear-gradient(180deg,
        VxTheme.bg-panel.brighter(VxTheme.dark-mode ? 0.02 : 0.01) 0%,
        VxTheme.bg-panel 100%);

    // Bottom border
    Rectangle {
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: VxTheme.border-subtle;
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 12px;
        spacing: 6px;
        alignment: center;

        if root.current-view != 0 : Rectangle {
            width: 28px;
            height: 28px;
            border-radius: VxTheme.radius-control;
            background: back-touch.has-hover ? VxTheme.tab-active-bg : transparent;
            border-color: back-touch.has-hover ? VxTheme.accent-border : transparent;
            border-width: 1px;

            back-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    if root.current-view == 5 {
                        root.navigate(root.chat-back-view);
                    } else if root.current-view == 1 && root.in-space-channel {
                        root.navigate(4);
                    } else {
                        root.navigate(root.previous-view == root.current-view ? 0 : root.previous-view);
                    }
                }
            }

            Text {
                text: "<";
                color: back-touch.has-hover ? VxTheme.accent : VxTheme.text-secondary;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 24px;
            width: home-crumb-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: root.current-view == 0 ? VxTheme.tab-active-bg :
                home-crumb-touch.has-hover ? VxTheme.bg-soft : transparent;
            border-color: root.current-view == 0 ? VxTheme.accent-border :
                home-crumb-touch.has-hover ? VxTheme.border-subtle : transparent;
            border-width: root.current-view == 0 || home-crumb-touch.has-hover ? 1px : 0px;

            home-crumb-touch := TouchArea {
                mouse-cursor: root.current-view != 0 ? pointer : default;
                clicked => { if root.current-view != 0 { root.navigate(0); } }
            }

            home-crumb-text := Text {
                text: "Home";
                color: root.current-view == 0 ? VxTheme.text-primary :
                       home-crumb-touch.has-hover ? VxTheme.accent : VxTheme.text-muted;
                font-size: 10px;
                font-weight: root.current-view == 0 ? 700 : 500;
                vertical-alignment: center;
            }
        }

        if (root.current-view == 4 || root.current-view == 5 || (root.current-view == 1 && root.in-space-channel)) && root.space-name != "" : Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: VxTheme.text-muted.transparentize(0.15);
        }

        if (root.current-view == 4 || root.current-view == 5 || (root.current-view == 1 && root.in-space-channel)) && root.space-name != "" : Rectangle {
            height: 24px;
            width: space-crumb-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: root.current-view == 4 ? VxTheme.tab-active-bg :
                space-crumb-touch.has-hover ? VxTheme.bg-soft : transparent;
            border-color: root.current-view == 4 ? VxTheme.accent-border :
                space-crumb-touch.has-hover ? VxTheme.border-subtle : transparent;
            border-width: root.current-view == 4 || space-crumb-touch.has-hover ? 1px : 0px;

            space-crumb-touch := TouchArea {
                mouse-cursor: root.current-view != 4 ? pointer : default;
                clicked => { if root.current-view != 4 { root.navigate(4); } }
            }

            space-crumb-text := Text {
                text: root.space-name;
                color: root.current-view == 4 ? VxTheme.text-primary :
                       space-crumb-touch.has-hover ? VxTheme.accent : VxTheme.text-muted;
                font-size: 10px;
                font-weight: root.current-view == 4 ? 700 : 500;
                vertical-alignment: center;
                overflow: elide;
                max-width: 120px;
            }
        }

        if (root.current-view == 5 && root.channel-name != "") || (root.current-view == 1 && root.in-space-channel) : Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: VxTheme.text-muted.transparentize(0.15);
        }

        if root.current-view == 5 && root.channel-name != "" : Rectangle {
            height: 24px;
            width: channel-crumb-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: VxTheme.tab-active-bg;
            border-color: VxTheme.accent-border;
            border-width: 1px;

            channel-crumb-text := Text {
                text: root.chat-is-dm ? root.channel-name : "# " + root.channel-name;
                color: VxTheme.text-primary;
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
                overflow: elide;
                max-width: 140px;
            }
        }

        if root.current-view == 1 && root.in-space-channel : Rectangle {
            height: 24px;
            width: room-crumb-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: VxTheme.tab-active-bg;
            border-color: VxTheme.accent-border;
            border-width: 1px;

            room-crumb-text := Text {
                text: "# " + root.room-code;
                color: VxTheme.text-primary;
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
                overflow: elide;
                max-width: 140px;
            }
        }

        if root.current-view == 1 && !root.in-space-channel : Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: VxTheme.text-muted.transparentize(0.15);
        }

        if root.current-view == 1 && !root.in-space-channel : Rectangle {
            height: 24px;
            width: room-leaf-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: VxTheme.tab-active-bg;
            border-color: VxTheme.accent-border;
            border-width: 1px;

            room-leaf-text := Text {
                text: "Room " + root.room-code;
                color: VxTheme.text-primary;
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        if root.current-view == 2 : Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: VxTheme.text-muted.transparentize(0.15);
        }

        if root.current-view == 2 : Rectangle {
            height: 24px;
            width: settings-leaf-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: VxTheme.tab-active-bg;
            border-color: VxTheme.accent-border;
            border-width: 1px;

            settings-leaf-text := Text {
                text: "Settings";
                color: VxTheme.text-primary;
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        if root.current-view == 3 : Rectangle {
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: VxTheme.text-muted.transparentize(0.15);
        }

        if root.current-view == 3 : Rectangle {
            height: 24px;
            width: system-leaf-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: VxTheme.tab-active-bg;
            border-color: VxTheme.accent-border;
            border-width: 1px;

            system-leaf-text := Text {
                text: "System";
                color: VxTheme.text-primary;
                font-size: 10px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        Rectangle { horizontal-stretch: 1; }

        if root.current-view == 1 && root.in-space-channel : Rectangle {
            height: 24px;
            width: space-pill-text.preferred-width + 16px;
            border-radius: VxTheme.radius-pill;
            background: space-pill-touch.has-hover ? VxTheme.tab-active-bg : VxTheme.bg-soft;
            border-color: space-pill-touch.has-hover ? VxTheme.accent-border : VxTheme.border-subtle;
            border-width: 1px;

            space-pill-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.navigate(4); }
            }

            space-pill-text := Text {
                text: "Space";
                color: space-pill-touch.has-hover ? VxTheme.accent : VxTheme.text-secondary;
                font-size: 9px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // "In call" pill removed — VoiceCallBar at the bottom now handles this
    }
}
