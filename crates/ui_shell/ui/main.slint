import { AuditEntryData, AutomodWordData, ChatMessage, ChannelData, DirectMessageThreadData, FriendData, FriendRequestData, MemberData, ParticipantData, PerfData, PublicSpaceData, SavedServerData, ScheduledEventData, ShareSourceData, SoundboardClipData, SpaceData, VxTheme } from "theme.slint";
import { VxButton, VxCard, VxInput } from "components.slint";
import { BottomNav, NavBreadcrumb, TopBar, VoiceCallBar, WorkspaceRail } from "shell.slint";
import { ChatView } from "views/chat_view.slint";
import { HomeView } from "views/home_view.slint";
import { RoomView } from "views/room_view.slint";
import { SettingsView } from "views/settings_view.slint";
import { SpaceView } from "views/space_view.slint";
import { SystemView } from "views/system_view.slint";

import "../../../assets/fonts/Inter-Regular.ttf";
import "../../../assets/fonts/Inter-SemiBold.ttf";
import "../../../assets/fonts/Inter-Bold.ttf";

export { MemberWidgetWindow } from "member_widget.slint";

export component MainWindow inherits Window {
    in-out property <string> window-title: "Voxlink";
    title: root.window-title;
    icon: @image-url("../../../assets/icon.png");
    default-font-family: "Inter";
    default-font-size: 13px * VxTheme.s;
    min-width: 440px;
    min-height: 520px;
    preferred-width: 1080px;
    preferred-height: 720px;
    background: VxTheme.bg-canvas;

    // State
    in-out property <int> current-view: 0;
    in-out property <string> room-code: "";
    in-out property <string> join-code: "";
    in-out property <string> room-password: "";
    in-out property <string> server-address: "ws://127.0.0.1:9090";
    in-out property <bool> is-muted: false;
    in-out property <bool> is-deafened: false;
    in-out property <bool> talking-while-muted: false;
    in-out property <bool> is-open-mic: true;
    in-out property <bool> is-connected: false;
    in-out property <bool> first-run: false;
    callback dismiss-welcome();
    in-out property <float> mic-level: 0.0;
    in-out property <string> status-text: "Disconnected";
    in-out property <string> room-status: "";
    in-out property <[ParticipantData]> participants: [];
    in-out property <PerfData> perf: { cpu-percent: 0, memory-mb: 0, uptime-secs: 0, audio-active: false, network-connected: false };
    in-out property <[string]> input-devices: ["Default Microphone"];
    in-out property <[string]> output-devices: ["Default Speaker"];
    in-out property <int> selected-input: 0;
    in-out property <int> selected-output: 0;
    in-out property <string> user-name: "User";
    in-out property <bool> show-saved: false;
    in-out property <int> previous-view: 0;
    in-out property <bool> show-copied: false;
    in-out property <string> version-text: "0.10.1";
    in-out property <string> uptime-text: "0s";
    in-out property <string> listening-keybind: "";
    in-out property <string> ptt-key-display: "Space";
    in-out property <string> mute-key-display: "M";
    in-out property <string> deafen-key-display: "D";
    in-out property <int> theme-preset: 0;
    changed theme-preset => { VxTheme.theme-preset = self.theme-preset; }
    in-out property <bool> dark-mode: true;
    changed dark-mode => { VxTheme.dark-mode = self.dark-mode; }
    in-out property <bool> feedback-sound: true;
    in-out property <float> noise-suppression: 0.5;
    in-out property <float> input-volume: 1.0;
    in-out property <float> output-volume: 1.0;
    in-out property <int> ping-ms: -1;
    in-out property <bool> udp-active: false;
    in-out property <bool> mic-preview-active: false;
    in-out property <bool> speaker-test-active: false;
    in-out property <int> reconnect-attempts: 0;
    in-out property <int> dropped-frames: 0;
    in-out property <int> dropped-frames-total: 0;
    in-out property <int> dropped-frames-baseline: 0;
    // Bandwidth tracking
    in-out property <int> bandwidth-up-kbps: 0;
    in-out property <int> bandwidth-down-kbps: 0;
    in-out property <string> session-data-mb: "0.0";
    in-out property <string> est-data-per-hour: "";
    in-out property <bool> has-screen-share: false;
    in-out property <bool> is-sharing-screen: false;
    in-out property <string> screen-share-owner-name: "";
    in-out property <string> screen-share-owner-id: "";
    in-out property <image> screen-share-image;
    in-out property <[ShareSourceData]> screen-share-sources: [];
    in-out property <int> selected-screen-share-source: -1;
    in-out property <int> selected-screen-share-profile: 0;
    in-out property <string> screen-share-source-label: "";
    in-out property <string> screen-share-source-detail: "";
    in-out property <string> screen-share-quality-label: "Efficient";
    in-out property <string> screen-share-quality-detail: "";
    in-out property <bool> member-widget-visible: false;
    in-out property <int> favorite-friends-count: 0;
    in-out property <int> online-friends-count: 0;
    in-out property <int> live-friends-count: 0;
    in-out property <[FriendData]> favorite-friends: [];
    in-out property <[FriendRequestData]> incoming-friend-requests: [];
    in-out property <[FriendRequestData]> outgoing-friend-requests: [];
    in-out property <[DirectMessageThreadData]> direct-message-threads: [];
    in-out property <int> unread-direct-messages-count: 0;

    // Space state
    in-out property <[SpaceData]> spaces: [];
    in-out property <string> space-name: "";
    in-out property <string> space-invite-code: "";
    in-out property <string> current-space-id: "";
    in-out property <string> current-space-name: "";
    in-out property <string> current-space-invite: "";
    in-out property <string> space-description: "";
    in-out property <bool> is-space-public: false;
    in-out property <bool> is-space-owner: false;
    in-out property <string> space-role-label: "Member";
    in-out property <bool> can-manage-space-channels: false;
    in-out property <bool> can-manage-space-members: false;
    in-out property <bool> can-manage-space-roles: false;
    in-out property <bool> can-view-space-audit: false;
    in-out property <[ChannelData]> channels: [];
    in-out property <[MemberData]> members: [];
    in-out property <[AuditEntryData]> space-audit-entries: [];
    in-out property <string> new-channel-name: "";
    in-out property <bool> in-space-channel: false;
    in-out property <string> active-channel-id: "";
    in-out property <string> channel-topic: "";
    in-out property <bool> show-quick-call: false;
    in-out property <bool> new-channel-is-voice: true;
    in-out property <int> new-channel-voice-quality: 2;
    in-out property <string> confirm-delete-channel-id: "";
    in-out property <string> space-search-query: "";
    in-out property <int> visible-text-channels: 0;
    in-out property <int> visible-voice-channels: 0;
    in-out property <int> visible-favorite-channels: 0;
    in-out property <int> visible-members: 0;

    // Text chat
    in-out property <[ChatMessage]> chat-messages: [];
    in-out property <[ChatMessage]> chat-pinned-messages: [];
    in-out property <string> chat-channel-id: "";
    in-out property <string> chat-channel-name: "";
    in-out property <bool> chat-is-direct-message: false;
    in-out property <string> chat-context-subtitle: "";
    in-out property <int> chat-back-view: 4;
    in-out property <string> chat-input: "";
    in-out property <string> chat-typing-text: "";
    in-out property <string> editing-message-id: "";
    in-out property <string> editing-original-content: "";
    in-out property <string> reply-target-message-id: "";
    in-out property <string> reply-target-sender-name: "";
    in-out property <string> reply-target-preview: "";
    in property <int> typing-dot-phase: 0;
    in property <bool> unread-pulse: false;
    in-out property <[ChatMessage]> chat-search-results: [];
    in-out property <string> chat-search-query: "";
    // Recent reaction emojis (up to 5, most recent first)
    in-out property <[string]> recent-reactions: [];

    // Mention autocomplete
    in-out property <bool> mention-popup-visible: false;
    in-out property <[string]> mention-suggestions: [];
    in-out property <int> mention-selected-index: 0;
    callback mention-input-changed(string);
    callback mention-selected(int);

    // Slow mode countdown
    in-out property <int> slow-mode-secs: 0;
    in-out property <int> slow-mode-remaining: 0;

    // Thread panel
    in-out property <[ChatMessage]> thread-messages: [];
    in-out property <bool> thread-panel-visible: false;
    in-out property <string> thread-parent-sender: "";
    in-out property <string> thread-parent-content: "";
    in-out property <string> thread-parent-timestamp: "";
    callback open-thread(string, string);
    callback close-thread();

    // Profile popup
    in-out property <bool> profile-popup-visible: false;
    in-out property <string> profile-popup-user-id: "";
    in-out property <string> profile-popup-name: "";
    in-out property <string> profile-popup-bio: "";
    in-out property <string> profile-popup-status: "";
    in-out property <string> profile-popup-role: "";
    in-out property <string> profile-popup-role-color: "";
    in-out property <string> profile-popup-activity: "";
    in-out property <string> profile-popup-initial: "";
    in-out property <int> profile-popup-color-index: 0;
    in-out property <int> profile-popup-role-color-index: 0;
    callback show-profile(string);  // user_id

    // Notifications
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> minimize-to-tray: true;
    in-out property <bool> neural-noise-suppression: false;
    in-out property <bool> echo-cancellation: false;
    in-out property <bool> join-leave-sounds: true;
    in-out property <bool> show-spoilers: false;
    in-out property <bool> compact-chat: false;
    in-out property <bool> streamer-mode: false;
    in-out property <bool> desktop-notifications: true;
    in-out property <int> notification-sound-index: 0; // 0=Default, 1=Subtle, 2=Chime, 3=None
    callback set-notification-sound(int);
    in-out property <int> status-preset: 0; // 0=Online, 1=Idle, 2=DND, 3=Invisible
    callback set-status-preset(int);
    in-out property <int> idle-timeout-mins: 5;
    callback set-idle-timeout(int);
    callback toggle-notifications();
    callback toggle-minimize-to-tray();
    callback toggle-neural-noise-suppression();
    callback toggle-echo-cancellation();
    callback toggle-join-leave-sounds();
    callback toggle-show-spoilers();
    callback toggle-compact-chat();
    callback toggle-streamer-mode();
    callback toggle-desktop-notifications();
    callback toggle-member-widget();
    // Soundboard
    in property <[SoundboardClipData]> soundboard-clips: [];
    callback play-soundboard-clip(int);
    callback remove-soundboard-clip(int);
    callback add-soundboard-clip(string, string, string);
    callback send-friend-request(string);
    callback send-friend-request-by-name(string);
    callback accept-friend-request(string);
    callback decline-friend-request(string);
    callback cancel-friend-request(string);
    callback remove-friend(string);
    callback open-direct-message(string);
    callback close-direct-message(string);

    // DM Voice Calls
    callback call-user(string);  // user_id
    in-out property <bool> incoming-call-visible: false;
    in-out property <string> incoming-call-name: "";
    in-out property <string> incoming-call-room: "";
    in-out property <string> incoming-call-caller-id: "";
    callback accept-call();
    callback decline-call();

    // Toast notification
    in-out property <string> toast-message: "";
    in-out property <bool> toast-visible: false;
    in-out property <int> toast-type: 0; // 0=info, 1=success, 2=warning, 3=error

    // Keyboard shortcuts overlay
    in-out property <bool> shortcuts-visible: false;

    // About dialog
    in-out property <bool> about-visible: false;

    // Update banner
    in-out property <bool> update-available: false;
    in-out property <string> update-version: "";

    // Delete confirmation
    in-out property <bool> confirm-delete-visible: false;

    // Navigation drawer
    in-out property <bool> sidebar-expanded: false;

    // Layout state
    property <bool> desktop-layout: true;
    property <bool> shell-compact: true;
    property <bool> rail-open: desktop-layout || sidebar-expanded;
    changed width => {
        root.desktop-layout = self.width >= 1180px;
        root.shell-compact = self.width < 1460px;
        if root.desktop-layout {
            root.sidebar-expanded = false;
        }
        // Keep the shell readable as the window narrows instead of over-compressing it.
        VxTheme.ui-scale = clamp(self.width / 1120px, 0.72, 1.0);
    }
    property <string> context-title:
        current-view == 0 ? "Home" :
        current-view == 1 ? (in-space-channel && current-space-name != "" ? current-space-name : "Live call") :
        current-view == 2 ? "Settings" :
        current-view == 3 ? "System" :
        current-view == 4 ? current-space-name :
        chat-channel-name != "" ? (chat-is-direct-message ? chat-channel-name : "# " + chat-channel-name) : "Chat";
    property <string> context-subtitle:
        current-view == 0 ? "Calls, spaces, and direct chat." :
        current-view == 1 ? (room-code != "" ? "Room " + room-code : status-text) :
        current-view == 2 ? "Audio, devices, keybinds, and appearance." :
        current-view == 3 ? "Performance, friends, and session health." :
        current-view == 4 ? "Channels, members, and moderation in one space." :
        chat-context-subtitle != "" ? chat-context-subtitle :
        current-space-name != "" ? current-space-name : "Persistent conversation.";

    // Callbacks
    callback create-room();
    callback join-room(string);
    callback leave-room();
    callback toggle-mute();
    callback toggle-deafen();
    callback toggle-mic-mode();
    callback toggle-screen-share();
    callback refresh-screen-share-sources();
    callback select-screen-share-source(int);
    callback select-screen-share-profile(int);
    callback navigate(int);
    callback refresh-devices();
    callback connect-server();
    callback save-settings();
    callback find-server();
    callback save-server(string);
    callback remove-server(int);
    callback volume-changed(string, float);
    // Per-peer 3-band EQ: (peer_id, bass 0-1, mid 0-1, treble 0-1) where 0.5 = flat
    callback eq-changed(string, float, float, float);
    // Per-peer stereo pan: (peer_id, pan 0-1) where 0.5 = center
    callback pan-changed(string, float);
    callback disconnect-server();
    in-out property <[SavedServerData]> saved-servers: [];
    callback copy-room-code();
    callback clear-keybind(string);
    callback toggle-dark-mode();
    callback select-theme-preset(int);
    callback create-space();
    callback join-space();
    callback select-space(string);
    callback leave-space();
    callback create-channel();
    callback delete-channel(string);
    callback move-channel-up(string);
    callback move-channel-down(string);
    callback join-channel(string);
    callback leave-channel();
    callback copy-invite-code();
    callback copy-share-message();
    callback space-search-changed(string);
    callback delete-space();
    callback rename-space(string);
    callback set-space-description(string);
    callback set-space-public(bool);
    callback toggle-feedback-sound();
    callback noise-suppression-changed(float);
    callback input-volume-changed(float);
    callback output-volume-changed(float);
    callback toggle-mic-preview();
    callback play-speaker-test();
    callback select-text-channel(string);
    callback chat-typing-activity(bool);
    callback send-text-message();
    callback edit-text-message(string, string);
    callback delete-text-message(string);
    callback react-to-message(string, string);
    callback toggle-pin-message(string, bool);
    callback forward-message(string);
    callback copy-message-text(string);
    callback kick-member(string);
    callback ban-member(string);
    callback server-mute-member(string, bool);
    callback set-member-role(string, int);
    callback set-user-status(string);
    callback set-channel-topic(string, string);
    callback search-messages(string);
    callback set-profile(string);
    // v0.7 feature callbacks
    callback set-channel-user-limit(/* channel_id */ string, /* limit */ int);
    callback set-channel-slow-mode(/* channel_id */ string, /* secs */ int);
    callback set-channel-auto-delete(/* channel_id */ string, /* hours */ int);
    callback set-channel-category(/* channel_id */ string, /* category */ string);
    callback set-channel-status(/* channel_id */ string, /* status */ string);
    callback toggle-category-collapse(/* category */ string);
    callback toggle-favorite-channel(/* channel_id */ string);
    callback set-channel-notification(/* channel_id */ string, /* setting: "all"/"mentions"/"none" */ string);
    callback timeout-member(/* member_id */ string, /* duration_secs */ int);
    callback set-priority-speaker(/* peer_id */ string, /* enabled */ bool);
    callback whisper-to(/* comma-separated peer IDs */ string);
    callback stop-whisper();
    callback save-user-note(/* user_id */ string, /* note */ string);
    // v0.10.0: Role colors and activity
    callback set-role-color(/* role_tier: 0=member,1=mod,2=admin,3=owner */ int, /* color */ string);
    callback set-activity(/* activity text */ string);
    in-out property <string> activity-text: "";

    // Account system
    in-out property <bool> show-login-view: false;
    in-out property <bool> login-mode: true; // true=login, false=register
    in-out property <string> auth-email: "";
    in-out property <string> auth-password: "";
    in-out property <string> auth-display-name: "";
    in-out property <string> auth-error: "";
    in-out property <bool> is-logged-in: false;
    in-out property <string> account-email: "";
    callback login();
    callback create-account();
    callback logout();
    callback change-password(string, string);
    callback change-display-name(string);
    callback delete-account();
    callback revoke-all-sessions();
    // Scheduled events
    in property <[ScheduledEventData]> scheduled-events: [];
    callback create-event(string, string, int);
    callback delete-event(string);
    callback toggle-event-interest(string);
    callback list-events();

    // Server discovery / explore
    in property <[PublicSpaceData]> public-spaces: [];
    callback browse-public-spaces();
    callback join-public-space(string); // invite_code

    // Recording indicator
    in-out property <bool> recording-active: false;
    in-out property <string> recording-user: "";

    // Auto-moderation word filter
    in-out property <[AutomodWordData]> automod-words: [];
    callback add-automod-word(string, string);
    callback remove-automod-word(string);
    callback list-automod-words();

    // Quick switcher
    in-out property <bool> quick-switcher-visible: false;
    in-out property <string> quick-switcher-query: "";
    in-out property <[ChannelData]> quick-switcher-items: [];
    in-out property <int> quick-switcher-index: 0;
    callback quick-switcher-select(string);
    callback quick-switcher-filter(string);
    changed quick-switcher-query => { root.quick-switcher-filter(root.quick-switcher-query); }
    changed quick-switcher-visible => {
        if root.quick-switcher-visible {
            root.quick-switcher-query = "";
            root.quick-switcher-index = 0;
            root.quick-switcher-filter("");
        }
    }

    // Keyboard channel navigation (space view)
    in-out property <int> focused-channel-index: -1;

    // Welcome screen overlay
    in-out property <bool> show-welcome-overlay: false;
    in-out property <string> welcome-message: "";

    // Privacy dashboard
    in-out property <string> privacy-config-path: "";
    in-out property <string> privacy-log-path: "";
    callback clear-local-data();
    callback export-my-data();

    // Audio processing transparency
    in-out property <string> audio-noise-gate-threshold: "-42 dB";
    in-out property <string> audio-opus-bitrate: "64 kbps";

    Rectangle {
        background: VxTheme.bg-canvas;

        Rectangle {
            x: -parent.width * 0.08;
            y: -parent.height * 0.02;
            width: parent.width * 0.56;
            height: parent.height * 0.34;
            background: @linear-gradient(135deg, VxTheme.accent-glow 0%, transparent 72%);
            opacity: VxTheme.dark-mode ? 0.95 : 0.72;
        }

        Rectangle {
            x: parent.width * 0.62;
            y: 0px;
            width: parent.width * 0.30;
            height: parent.height * 0.24;
            background: @linear-gradient(180deg, VxTheme.header-accent-right.transparentize(0.92) 0%, transparent 86%);
            opacity: VxTheme.dark-mode ? 0.78 : 0.52;
        }

        Rectangle {
            y: parent.height * 0.68;
            width: parent.width;
            height: parent.height * 0.32;
            background: @linear-gradient(180deg, transparent 0%, VxTheme.bg-rail.transparentize(VxTheme.dark-mode ? 0.35 : 0.50) 100%);
            opacity: 0.7;
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: @linear-gradient(180deg, VxTheme.accent-subtle 0%, transparent 18%);
        }

        HorizontalLayout {
            spacing: 0px;

            if root.rail-open : WorkspaceRail {
                width: root.desktop-layout ? (root.shell-compact ? 224px : 252px) : 236px;
                compact: root.shell-compact;
                current-view: root.current-view;
                spaces: root.spaces;
                current-space-id: root.current-space-id;
                members: root.members;
                show-members: root.current-view == 4 || root.current-view == 5;
                room-code: root.room-code;
                unread-direct-messages-count: root.unread-direct-messages-count;
                favorite-friends-count: root.favorite-friends-count;
                online-friends-count: root.online-friends-count;
                user-name: root.user-name;
                user-status: root.status-text;
                is-muted: root.is-muted;
                is-deafened: root.is-deafened;
                navigate(view-index) => {
                    root.navigate(view-index);
                    if !root.desktop-layout {
                        root.sidebar-expanded = false;
                    }
                }
                show-shortcuts => { root.shortcuts-visible = true; }
                select-space(space-id) => {
                    root.select-space(space-id);
                    if !root.desktop-layout {
                        root.sidebar-expanded = false;
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: VxTheme.bg-app;

                VerticalLayout {
                    spacing: 0px;

                    TopBar {
                        compact: root.shell-compact;
                        title: root.context-title;
                        subtitle: root.context-subtitle;
                        is-connected: root.is-connected;
                        ping-ms: root.ping-ms;
                        room-code: root.room-code;
                        unread-direct-messages-count: root.unread-direct-messages-count;
                        show-nav-button: !root.desktop-layout;
                        in-call: root.current-view == 1;
                        is-muted: root.is-muted;
                        is-deafened: root.is-deafened;
                        update-available: root.update-available;
                        update-version: root.update-version;
                        nav-toggle => { root.sidebar-expanded = !root.sidebar-expanded; }
                    }

                    if !root.is-connected && root.current-view != 0 : Rectangle {
                        height: 28px;
                        background: VxTheme.danger.transparentize(0.85);
                        border-color: VxTheme.danger.transparentize(0.6);
                        border-width: 1px;
                        HorizontalLayout {
                            padding-left: 16px;
                            padding-right: 16px;
                            alignment: center;
                            spacing: 8px;
                            Text {
                                text: "Connection lost — attempting to reconnect...";
                                color: VxTheme.danger;
                                font-size: 10px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }

                    NavBreadcrumb {
                        current-view: root.current-view;
                        previous-view: root.previous-view;
                        space-name: root.current-space-name;
                        channel-name: root.chat-channel-name;
                        room-code: root.room-code;
                        in-space-channel: root.in-space-channel;
                        chat-is-dm: root.chat-is-direct-message;
                        chat-back-view: root.chat-back-view;
                        navigate(view-index) => { root.navigate(view-index); }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: transparent;

                        if root.current-view == 0 : HomeView {
                            wide: root.desktop-layout;
                            first-run: root.first-run;
                            streamer-mode: root.streamer-mode;
                            server-address <=> root.server-address;
                            saved-servers: root.saved-servers;
                            user-name <=> root.user-name;
                            status-text: root.status-text;
                            is-connected: root.is-connected;
                            spaces: root.spaces;
                            space-name <=> root.space-name;
                            space-invite-code <=> root.space-invite-code;
