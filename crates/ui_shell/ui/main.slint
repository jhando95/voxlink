        // Quick Switcher overlay (Ctrl+K)
        // Account login/register overlay
        if root.show-login-view : Rectangle {
            background: VxTheme.bg-canvas.transparentize(0.15);
            TouchArea { clicked => {} } // block clicks

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    VxCard {
                        width: 360px;
                        VerticalLayout {
                            padding: 28px;
                            spacing: 16px;

                            // Brand header
                            HorizontalLayout {
                                alignment: center;
                                spacing: 8px;
                                Text {
                                    text: "VX";
                                    color: VxTheme.accent;
                                    font-size: 22px;
                                    font-weight: 900;
                                }
                                Text {
                                    text: root.login-mode ? "Sign In" : "Create Account";
                                    color: VxTheme.text-primary;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                            }

                            // Error display
                            if root.auth-error != "" : Rectangle {
                                background: VxTheme.danger.transparentize(0.85);
                                border-radius: 6px;
                                height: auth-err-text.preferred-height + 12px;
                                auth-err-text := Text {
                                    text: root.auth-error;
                                    color: VxTheme.danger;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }
                            }

                            // Email field
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Email";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: "you@example.com";
                                    text <=> root.auth-email;
                                }
                            }

                            // Password field
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Password";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: root.login-mode ? "Enter password" : "Min 6 characters";
                                    text <=> root.auth-password;
                                    input-type: InputType.password;
                                }
                            }

                            // Display name (register only)
                            if !root.login-mode : VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Display Name";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: "How others will see you";
                                    text <=> root.auth-display-name;
                                }
                            }

                            // Submit button
                            Rectangle {
                                height: 36px;
                                border-radius: VxTheme.radius-control;
                                background: login-submit-touch.has-hover ? VxTheme.accent.darker(0.15) : VxTheme.accent;
                                login-submit-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.auth-error = "";
                                        if root.login-mode {
                                            root.login();
                                        } else {
                                            root.create-account();
                                        }
                                    }
                                }
                                Text {
                                    text: root.login-mode ? "Sign In" : "Create Account";
                                    color: VxTheme.text-inverse;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Toggle login/register
                            HorizontalLayout {
                                alignment: center;
                                spacing: 4px;
                                Text {
                                    text: root.login-mode ? "Don't have an account?" : "Already have an account?";
                                    color: VxTheme.text-muted;
                                    font-size: 11px;
                                }
                                Text {
                                    text: root.login-mode ? "Register" : "Sign In";
                                    color: VxTheme.accent;
                                    font-size: 11px;
                                    font-weight: 700;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.login-mode = !root.login-mode;
                                            root.auth-error = "";
                                        }
                                    }
                                }
                            }

                            // Skip / continue without account
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "Continue without account";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.show-login-view = false; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.quick-switcher-visible : Rectangle {
            background: VxTheme.bg-overlay;
            TouchArea {
                clicked => { root.quick-switcher-visible = false; root.quick-switcher-query = ""; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: parent.height * 0.18;
                width: min(500px, parent.width - 40px);
                border-radius: VxTheme.radius-card;
                background: VxTheme.bg-raised;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Quick Switcher";
                            color: VxTheme.text-primary;
                            font-size: 13px;
                            font-weight: 700;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: "Esc to close · Up/Down to navigate";
                            color: VxTheme.text-muted;
                            font-size: 9px;
                        }
                    }

                    VxInput {
                        text <=> root.quick-switcher-query;
                        placeholder: "Search channels, DMs, spaces...";
                        horizontal-stretch: 1;
                        accepted => {
                            if root.quick-switcher-items.length > 0 {
                                root.quick-switcher-select(root.quick-switcher-items[clamp(root.quick-switcher-index, 0, root.quick-switcher-items.length - 1)].id);
                                root.quick-switcher-visible = false;
                                root.quick-switcher-query = "";
                            }
                        }
                    }

                    if root.quick-switcher-items.length == 0 && root.quick-switcher-query != "" : Text {
                        text: "No matches found";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                    }

                    for item[idx] in root.quick-switcher-items : Rectangle {
                        height: idx < 8 ? 40px : 0px;
                        visible: idx < 8;
                        border-radius: VxTheme.radius-control;
                        background: idx == root.quick-switcher-index ? VxTheme.surface-active :
                                    qs-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                        border-color: idx == root.quick-switcher-index ? VxTheme.accent-border : VxTheme.border-subtle;
                        border-width: 1px;

                        animate background { duration: 60ms; easing: ease-out; }
                        animate border-color { duration: 60ms; easing: ease-out; }

                        qs-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.quick-switcher-select(item.id);
                                root.quick-switcher-visible = false;
                                root.quick-switcher-query = "";
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;
                            Rectangle {
                                width: 32px;
                                height: 24px;
                                border-radius: 6px;
                                background: item.is-voice ? VxTheme.accent-subtle :
                                            item.status == "dm" ? VxTheme.warning-soft : VxTheme.bg-panel;
                                border-color: item.is-voice ? VxTheme.accent-border :
                                              item.status == "dm" ? VxTheme.warning.transparentize(0.6) : VxTheme.border-subtle;
                                border-width: 1px;
                                Text {
                                    text: item.is-voice ? "VC" : item.status == "dm" ? "DM" : "#";
                                    color: item.is-voice ? VxTheme.accent :
                                           item.status == "dm" ? VxTheme.warning : VxTheme.text-muted;
                                    font-size: 9px;
                                    font-weight: 800;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: item.name;
                                color: idx == root.quick-switcher-index ? VxTheme.accent : VxTheme.text-primary;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                            if item.category != "" : Text {
                                text: item.category;
                                color: VxTheme.text-muted;
                                font-size: 9px;
                            }
                        }
                    }
                }
            }
        }

        // ─── Incoming Call Overlay ───
        if root.incoming-call-visible : Rectangle {
            background: VxTheme.bg-canvas.transparentize(0.25);
            TouchArea { clicked => {} } // block clicks

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    VxCard {
                        width: clamp(root.width * 0.36, 300px, 364px);
                        VerticalLayout {
                            padding: 24px;
                            spacing: 16px;

                            Text {
                                text: "Incoming Call";
                                color: VxTheme.text-primary;
                                font-size: 16px;
                                font-weight: 700;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: root.incoming-call-name + " is calling you";
                                color: VxTheme.text-secondary;
                                font-size: 12px;
                                horizontal-alignment: center;
                                overflow: elide;
                                max-width: 280px;
                            }

                            HorizontalLayout {
                                spacing: 12px;
                                alignment: center;

                                Rectangle {
                                    width: 110px;
                                    height: 36px;
                                    border-radius: VxTheme.radius-control;
                                    background: call-accept-touch.has-hover ? VxTheme.success.darker(0.1) : VxTheme.success;
                                    call-accept-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.incoming-call-visible = false;
                                            root.accept-call();
                                        }
                                    }
                                    Text {
                                        text: "Accept";
                                        color: VxTheme.text-inverse;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    width: 110px;
                                    height: 36px;
                                    border-radius: VxTheme.radius-control;
                                    background: call-decline-touch.has-hover ? VxTheme.danger.darker(0.1) : VxTheme.danger;
                                    call-decline-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.incoming-call-visible = false;
                                            root.decline-call();
                                        }
                                    }
                                    Text {
                                        text: "Decline";
                                        color: VxTheme.text-inverse;
                                        font-size: 12px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ─── Toast Notification ───
        if root.toast-visible : Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.height - 80px;
            width: min(360px, parent.width - 40px);
            height: 40px;
            border-radius: VxTheme.radius-control;
            background: root.toast-type == 3 ? VxTheme.danger :
                        root.toast-type == 2 ? VxTheme.warning :
                        root.toast-type == 1 ? VxTheme.success :
                        VxTheme.bg-raised;
            border-color: root.toast-type == 3 ? VxTheme.danger :
                          root.toast-type == 2 ? VxTheme.warning :
                          root.toast-type == 1 ? VxTheme.success :
                          VxTheme.accent-border;
            border-width: 1px;
            opacity: 0.95;
            animate opacity { duration: 200ms; }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: center;
                spacing: 8px;
                Text {
                    text: root.toast-type == 3 ? "✕" :
                          root.toast-type == 2 ? "⚠" :
                          root.toast-type == 1 ? "✓" : "ℹ";
                    color: root.toast-type >= 1 ? #fff : VxTheme.accent;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Text {
                    text: root.toast-message;
                    color: root.toast-type >= 1 ? #fff : VxTheme.text-primary;
                    font-size: 11px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                TouchArea {
                    width: 20px;
                    clicked => { root.toast-visible = false; }
                    Text {
                        text: "×";
                        color: root.toast-type >= 1 ? #fff : VxTheme.text-muted;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ─── Profile Popup Overlay ───
        if root.profile-popup-visible : Rectangle {
            background: VxTheme.bg-overlay;
            TouchArea {
                clicked => { root.profile-popup-visible = false; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: parent.height * 0.22;
                width: min(340px, parent.width - 40px);
                border-radius: VxTheme.radius-card;
                background: VxTheme.bg-raised;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                // Block clicks from reaching the backdrop
                TouchArea {}

                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    // Avatar + name row
                    HorizontalLayout {
                        spacing: 14px;
                        alignment: start;

                        // Avatar circle
                        Rectangle {
                            width: 52px;
                            height: 52px;
                            border-radius: 26px * VxTheme.avatar-roundness * 2;
                            background: VxTheme.avatar-color(root.profile-popup-color-index);

                            Text {
                                text: root.profile-popup-initial;
                                color: VxTheme.text-inverse;
                                font-size: 20px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;

                            Text {
                                text: root.profile-popup-name;
                                color: VxTheme.text-primary;
                                font-size: 16px;
                                font-weight: 700;
                            }

                            if root.profile-popup-role != "" : Rectangle {
                                height: 20px;
                                width: profile-role-txt.preferred-width + 14px;
                                border-radius: VxTheme.radius-pill;
                                background: root.profile-popup-role-color-index > 0
                                    ? VxTheme.role-color(root.profile-popup-role-color-index).transparentize(0.82)
                                    : VxTheme.accent-subtle;
                                border-color: root.profile-popup-role-color-index > 0
                                    ? VxTheme.role-color(root.profile-popup-role-color-index).transparentize(0.5)
                                    : VxTheme.accent-border;
                                border-width: 1px;

                                profile-role-txt := Text {
                                    text: root.profile-popup-role;
                                    color: root.profile-popup-role-color-index > 0
                                        ? VxTheme.role-color(root.profile-popup-role-color-index)
                                        : VxTheme.accent;
                                    font-size: 9px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Status
                    if root.profile-popup-status != "" : HorizontalLayout {
                        spacing: 6px;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            y: 4px;
                            border-radius: 4px;
                            background: root.profile-popup-status == "Online" ? VxTheme.success :
                                        root.profile-popup-status == "Idle" ? VxTheme.warning :
                                        root.profile-popup-status == "Do Not Disturb" ? VxTheme.danger :
                                        VxTheme.text-muted;
                        }
                        Text {
                            text: root.profile-popup-status;
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                        }
                    }

                    // Activity
                    if root.profile-popup-activity != "" : Rectangle {
                        background: VxTheme.bg-soft;
                        border-radius: VxTheme.radius-control;
                        height: profile-activity-txt.preferred-height + 14px;

                        profile-activity-txt := Text {
                            x: 10px;
                            y: 7px;
                            width: parent.width - 20px;
                            text: root.profile-popup-activity;
                            color: VxTheme.text-secondary;
                            font-size: 10px;
                            font-weight: 600;
                            wrap: word-wrap;
                        }
                    }

                    // Bio
                    if root.profile-popup-bio != "" : VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "ABOUT";
                            color: VxTheme.text-muted;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 0.8px;
                        }
                        Text {
                            text: root.profile-popup-bio;
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    // Message button
                    Rectangle {
                        height: 32px;
                        border-radius: VxTheme.radius-control;
                        background: profile-msg-touch.has-hover ? VxTheme.accent-hover : VxTheme.accent;

                        profile-msg-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.profile-popup-visible = false;
                                root.open-direct-message(root.profile-popup-user-id);
                            }
                        }

                        Text {
                            text: "Message";
                            color: VxTheme.text-inverse;
                            font-size: 11px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ─── Welcome Screen Overlay ───
        if root.show-welcome-overlay : Rectangle {
            background: VxTheme.bg-canvas.transparentize(0.15);
            TouchArea { clicked => {} } // block clicks

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    VxCard {
                        width: min(400px, root.width - 60px);
                        VerticalLayout {
                            padding: 28px;
                            spacing: 18px;

                            // Accent bar
                            Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: VxTheme.accent;
                            }

                            // Space name
                            Text {
                                text: root.current-space-name;
                                color: VxTheme.text-primary;
                                font-size: 18px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                overflow: elide;
                            }

                            // Welcome label
                            Text {
                                text: "WELCOME";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 700;
                                letter-spacing: 1.2px;
                                horizontal-alignment: center;
                            }

                            // Message body
                            Text {
                                text: root.welcome-message;
                                color: VxTheme.text-secondary;
                                font-size: 13px;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }

                            // Dismiss button
                            Rectangle {
                                height: 36px;
                                border-radius: VxTheme.radius-control;
                                background: welcome-dismiss-touch.has-hover ? VxTheme.accent.darker(0.15) : VxTheme.accent;

                                welcome-dismiss-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.show-welcome-overlay = false;
                                        root.welcome-message = "";
                                    }
                                }

                                Text {
                                    text: "Got it!";
                                    color: VxTheme.text-inverse;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        // ─── Keyboard Shortcuts Overlay (Ctrl+/) ───
        if root.shortcuts-visible : Rectangle {
            background: VxTheme.bg-overlay;
            TouchArea {
                clicked => { root.shortcuts-visible = false; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: parent.height * 0.12;
                width: min(420px, parent.width - 40px);
                border-radius: VxTheme.radius-card;
                background: VxTheme.bg-raised;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                VerticalLayout {
                    padding: 20px;
                    spacing: 12px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Keyboard Shortcuts";
                            color: VxTheme.text-primary;
                            font-size: 14px;
                            font-weight: 700;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: "Esc to close";
                            color: VxTheme.text-muted;
                            font-size: 9px;
                        }
                    }

                    // Navigation
                    Text { text: "NAVIGATION"; color: VxTheme.text-muted; font-size: 9px; font-weight: 700; }
                    for shortcut in [
                        { key: "Ctrl/Cmd+K", desc: "Quick switcher" },
                        { key: "Ctrl+/", desc: "Keyboard shortcuts" },
                        { key: "Up/Down", desc: "Navigate channels (space view)" },
                        { key: "Enter", desc: "Open focused channel" },
                        { key: "Alt+Up/Down", desc: "Switch text channels" },
                        { key: "Escape", desc: "Back / close overlay" },
                    ] : HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 100px;
                            height: 22px;
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.bg-panel;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            Text {
                                text: shortcut.key;
                                color: VxTheme.accent;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: shortcut.desc;
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }

                    // Voice
                    Text { text: "VOICE"; color: VxTheme.text-muted; font-size: 9px; font-weight: 700; }
                    for shortcut in [
                        { key: root.mute-key-display, desc: "Toggle mute" },
                        { key: root.deafen-key-display, desc: "Toggle deafen" },
                        { key: root.ptt-key-display, desc: "Push to talk (hold)" },
                    ] : HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 100px;
                            height: 22px;
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.bg-panel;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            Text {
                                text: shortcut.key;
                                color: VxTheme.accent;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: shortcut.desc;
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }

                    // Chat
                    Text { text: "CHAT"; color: VxTheme.text-muted; font-size: 9px; font-weight: 700; }
                    for shortcut in [
                        { key: "Enter", desc: "Send message" },
                        { key: "Shift+Enter", desc: "New line" },
                        { key: "Ctrl+E", desc: "Edit last message" },
                        { key: "Up", desc: "Edit last message (empty input)" },
                    ] : HorizontalLayout {
                        spacing: 12px;
                        Rectangle {
                            width: 100px;
                            height: 22px;
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.bg-panel;
                            border-color: VxTheme.border-subtle;
                            border-width: 1px;
                            Text {
                                text: shortcut.key;
                                color: VxTheme.accent;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: shortcut.desc;
                            color: VxTheme.text-secondary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ─── About Dialog Overlay ───
        if root.about-visible : Rectangle {
            background: VxTheme.bg-overlay;
            TouchArea {
                clicked => { root.about-visible = false; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: parent.height * 0.22;
                width: min(360px, parent.width - 40px);
                border-radius: VxTheme.radius-card;
                background: VxTheme.bg-raised;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                // Block clicks from reaching the backdrop
                TouchArea {}

                VerticalLayout {
                    padding: 28px;
                    spacing: 16px;
                    alignment: center;

                    // App name badge
                    HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        Rectangle {
                            width: 36px;
                            height: 24px;
                            border-radius: VxTheme.radius-control;
                            background: VxTheme.accent;
                            Text {
                                text: "VX";
                                color: VxTheme.text-inverse;
                                font-size: 12px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        Text {
                            text: "VOXLINK";
                            color: VxTheme.text-primary;
                            font-size: 22px;
                            font-weight: 800;
                            letter-spacing: 1px;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "Version " + root.version-text;
                        color: VxTheme.text-secondary;
                        font-size: 11px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Voice without limits";
                        color: VxTheme.text-muted;
                        font-size: 12px;
                        font-italic: true;
                        horizontal-alignment: center;
                    }

                    // Divider
                    Rectangle {
                        height: 1px;
                        background: VxTheme.border-subtle;
                    }

                    // Report a Bug
                    VerticalLayout {
                        spacing: 6px;
                        alignment: center;
                        Text {
                            text: "Report a Bug";
                            color: VxTheme.text-primary;
                            font-size: 11px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "github.com/jhando95/voxlink";
                            color: VxTheme.accent;
                            font-size: 11px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                    }

                    // Divider
                    Rectangle {
                        height: 1px;
                        background: VxTheme.border-subtle;
                    }

                    Text {
                        text: "Made with Rust + Slint";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                        horizontal-alignment: center;
                    }

                    VxButton {
                        label: "Close";
                        soft: true;
                        clicked => { root.about-visible = false; }
                    }
                }
            }
        }
    }
}
