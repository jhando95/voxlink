import { AuditEntryData, ChatMessage, ChannelData, DirectMessageThreadData, FriendData, FriendRequestData, MemberData, ParticipantData, PerfData, SavedServerData, ShareSourceData, SpaceData, VxTheme } from "theme.slint";
import { VxCard, VxInput } from "components.slint";
import { BottomNav, NavBreadcrumb, TopBar, VoiceCallBar, WorkspaceRail } from "shell.slint";
import { ChatView } from "views/chat_view.slint";
import { HomeView } from "views/home_view.slint";
import { RoomView } from "views/room_view.slint";
import { SettingsView } from "views/settings_view.slint";
import { SpaceView } from "views/space_view.slint";
import { SystemView } from "views/system_view.slint";

import "../../../assets/fonts/Inter-Regular.ttf";
import "../../../assets/fonts/Inter-SemiBold.ttf";
import "../../../assets/fonts/Inter-Bold.ttf";

export { MemberWidgetWindow } from "member_widget.slint";

export component MainWindow inherits Window {
    in-out property <string> window-title: "Voxlink";
    title: root.window-title;
    icon: @image-url("../../../assets/icon.png");
    default-font-family: "Inter";
    default-font-size: 13px * VxTheme.s;
    min-width: 440px;
    min-height: 520px;
    preferred-width: 1080px;
    preferred-height: 720px;
    background: VxTheme.bg-canvas;

    // State
    in-out property <int> current-view: 0;
    in-out property <string> room-code: "";
    in-out property <string> join-code: "";
    in-out property <string> room-password: "";
    in-out property <string> server-address: "ws://127.0.0.1:9090";
    in-out property <bool> is-muted: false;
    in-out property <bool> is-deafened: false;
    in-out property <bool> talking-while-muted: false;
    in-out property <bool> is-open-mic: true;
    in-out property <bool> is-connected: false;
    in-out property <bool> first-run: false;
    in-out property <float> mic-level: 0.0;
    in-out property <string> status-text: "Disconnected";
    in-out property <string> room-status: "";
    in-out property <[ParticipantData]> participants: [];
    in-out property <PerfData> perf: { cpu-percent: 0, memory-mb: 0, uptime-secs: 0, audio-active: false, network-connected: false };
    in-out property <[string]> input-devices: ["Default Microphone"];
    in-out property <[string]> output-devices: ["Default Speaker"];
    in-out property <int> selected-input: 0;
    in-out property <int> selected-output: 0;
    in-out property <string> user-name: "User";
    in-out property <bool> show-saved: false;
    in-out property <int> previous-view: 0;
    in-out property <bool> show-copied: false;
    in-out property <string> version-text: "0.8.0";
    in-out property <string> uptime-text: "0s";
    in-out property <string> listening-keybind: "";
    in-out property <string> ptt-key-display: "Space";
    in-out property <string> mute-key-display: "M";
    in-out property <string> deafen-key-display: "D";
    in-out property <int> theme-preset: 0;
    changed theme-preset => { VxTheme.theme-preset = self.theme-preset; }
    in-out property <bool> dark-mode: true;
    changed dark-mode => { VxTheme.dark-mode = self.dark-mode; }
    in-out property <bool> feedback-sound: true;
    in-out property <float> noise-suppression: 0.5;
    in-out property <float> input-volume: 1.0;
    in-out property <float> output-volume: 1.0;
    in-out property <int> ping-ms: -1;
    in-out property <bool> udp-active: false;
    in-out property <bool> mic-preview-active: false;
    in-out property <bool> speaker-test-active: false;
    in-out property <int> reconnect-attempts: 0;
    in-out property <int> dropped-frames: 0;
    in-out property <int> dropped-frames-total: 0;
    in-out property <int> dropped-frames-baseline: 0;
    in-out property <bool> has-screen-share: false;
    in-out property <bool> is-sharing-screen: false;
    in-out property <string> screen-share-owner-name: "";
    in-out property <string> screen-share-owner-id: "";
    in-out property <image> screen-share-image;
    in-out property <[ShareSourceData]> screen-share-sources: [];
    in-out property <int> selected-screen-share-source: -1;
    in-out property <int> selected-screen-share-profile: 0;
    in-out property <string> screen-share-source-label: "";
    in-out property <string> screen-share-source-detail: "";
    in-out property <string> screen-share-quality-label: "Efficient";
    in-out property <string> screen-share-quality-detail: "";
    in-out property <bool> member-widget-visible: false;
    in-out property <int> favorite-friends-count: 0;
    in-out property <int> online-friends-count: 0;
    in-out property <int> live-friends-count: 0;
    in-out property <[FriendData]> favorite-friends: [];
    in-out property <[FriendRequestData]> incoming-friend-requests: [];
    in-out property <[FriendRequestData]> outgoing-friend-requests: [];
    in-out property <[DirectMessageThreadData]> direct-message-threads: [];
    in-out property <int> unread-direct-messages-count: 0;

    // Space state
    in-out property <[SpaceData]> spaces: [];
    in-out property <string> space-name: "";
    in-out property <string> space-invite-code: "";
    in-out property <string> current-space-id: "";
    in-out property <string> current-space-name: "";
    in-out property <string> current-space-invite: "";
    in-out property <bool> is-space-owner: false;
    in-out property <string> space-role-label: "Member";
    in-out property <bool> can-manage-space-channels: false;
    in-out property <bool> can-manage-space-members: false;
    in-out property <bool> can-manage-space-roles: false;
    in-out property <bool> can-view-space-audit: false;
    in-out property <[ChannelData]> channels: [];
    in-out property <[MemberData]> members: [];
    in-out property <[AuditEntryData]> space-audit-entries: [];
    in-out property <string> new-channel-name: "";
    in-out property <bool> in-space-channel: false;
    in-out property <string> active-channel-id: "";
    in-out property <bool> show-quick-call: false;
    in-out property <bool> new-channel-is-voice: true;
    in-out property <int> new-channel-voice-quality: 2;
    in-out property <string> confirm-delete-channel-id: "";
    in-out property <string> space-search-query: "";
    in-out property <int> visible-text-channels: 0;
    in-out property <int> visible-voice-channels: 0;
    in-out property <int> visible-members: 0;

    // Text chat
    in-out property <[ChatMessage]> chat-messages: [];
    in-out property <[ChatMessage]> chat-pinned-messages: [];
    in-out property <string> chat-channel-id: "";
    in-out property <string> chat-channel-name: "";
    in-out property <bool> chat-is-direct-message: false;
    in-out property <string> chat-context-subtitle: "";
    in-out property <int> chat-back-view: 4;
    in-out property <string> chat-input: "";
    in-out property <string> chat-typing-text: "";
    in-out property <string> editing-message-id: "";
    in-out property <string> editing-original-content: "";
    in-out property <string> reply-target-message-id: "";
    in-out property <string> reply-target-sender-name: "";
    in-out property <string> reply-target-preview: "";
    in-out property <[ChatMessage]> chat-search-results: [];
    in-out property <string> chat-search-query: "";

    // Notifications
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> minimize-to-tray: true;
    in-out property <bool> neural-noise-suppression: false;
    in-out property <bool> echo-cancellation: false;
    in-out property <bool> join-leave-sounds: true;
    in-out property <bool> show-spoilers: false;
    in-out property <bool> compact-chat: false;
    callback toggle-notifications();
    callback toggle-minimize-to-tray();
    callback toggle-neural-noise-suppression();
    callback toggle-echo-cancellation();
    callback toggle-join-leave-sounds();
    callback toggle-show-spoilers();
    callback toggle-compact-chat();
    callback toggle-member-widget();
    callback send-friend-request(string);
    callback accept-friend-request(string);
    callback decline-friend-request(string);
    callback cancel-friend-request(string);
    callback remove-friend(string);
    callback open-direct-message(string);

    // Update banner
    in-out property <bool> update-available: false;
    in-out property <string> update-version: "";

    // Delete confirmation
    in-out property <bool> confirm-delete-visible: false;

    // Navigation drawer
    in-out property <bool> sidebar-expanded: false;

    // Layout state
    property <bool> desktop-layout: true;
    property <bool> shell-compact: true;
    property <bool> rail-open: desktop-layout || sidebar-expanded;
    changed width => {
        root.desktop-layout = self.width >= 1040px;
        root.shell-compact = self.width < 1320px;
        if root.desktop-layout {
            root.sidebar-expanded = false;
        }
        // Continuous UI scaling: 1.0 at 1180px (preferred), shrinks proportionally
        // Clamp between 0.65 (very small) and 1.0 (full size)
        VxTheme.ui-scale = clamp(self.width / 1080px, 0.65, 1.0);
    }
    property <string> context-title:
        current-view == 0 ? "Home base" :
        current-view == 1 ? (in-space-channel && current-space-name != "" ? current-space-name : "Live call") :
        current-view == 2 ? "Settings" :
        current-view == 3 ? "System" :
        current-view == 4 ? current-space-name :
        chat-channel-name != "" ? (chat-is-direct-message ? chat-channel-name : "# " + chat-channel-name) : "Text chat";
    property <string> context-subtitle:
        current-view == 0 ? "Connect fast, build spaces, or jump into a room." :
        current-view == 1 ? (room-code != "" ? "Room " + room-code : status-text) :
        current-view == 2 ? "Devices, keybinds, sound, and capture mode." :
        current-view == 3 ? "Performance, session health, and runtime posture." :
        current-view == 4 ? "Channels and members in one workspace." :
        chat-context-subtitle != "" ? chat-context-subtitle :
        current-space-name != "" ? current-space-name : "Persistent channel chat.";

    // Callbacks
    callback create-room();
    callback join-room(string);
    callback leave-room();
    callback toggle-mute();
    callback toggle-deafen();
    callback toggle-mic-mode();
    callback toggle-screen-share();
    callback refresh-screen-share-sources();
    callback select-screen-share-source(int);
    callback select-screen-share-profile(int);
    callback navigate(int);
    callback refresh-devices();
    callback connect-server();
    callback save-settings();
    callback find-server();
    callback save-server(string);
    callback remove-server(int);
    callback volume-changed(string, float);
    callback disconnect-server();
    in-out property <[SavedServerData]> saved-servers: [];
    callback copy-room-code();
    callback clear-keybind(string);
    callback toggle-dark-mode();
    callback select-theme-preset(int);
    callback create-space();
    callback join-space();
    callback select-space(string);
    callback leave-space();
    callback create-channel();
    callback delete-channel(string);
    callback join-channel(string);
    callback leave-channel();
    callback copy-invite-code();
    callback copy-share-message();
    callback space-search-changed(string);
    callback delete-space();
    callback toggle-feedback-sound();
    callback noise-suppression-changed(float);
    callback input-volume-changed(float);
    callback output-volume-changed(float);
    callback toggle-mic-preview();
    callback play-speaker-test();
    callback select-text-channel(string);
    callback chat-typing-activity(bool);
    callback send-text-message();
    callback edit-text-message(string, string);
    callback delete-text-message(string);
    callback react-to-message(string, string);
    callback toggle-pin-message(string, bool);
    callback kick-member(string);
    callback ban-member(string);
    callback server-mute-member(string, bool);
    callback set-member-role(string, int);
    callback set-user-status(string);
    callback set-channel-topic(string, string);
    callback search-messages(string);
    callback set-profile(string);
    // v0.7 feature callbacks
    callback set-channel-user-limit(/* channel_id */ string, /* limit */ int);
    callback set-channel-slow-mode(/* channel_id */ string, /* secs */ int);
    callback set-channel-category(/* channel_id */ string, /* category */ string);
    callback set-channel-status(/* channel_id */ string, /* status */ string);
    callback timeout-member(/* member_id */ string, /* duration_secs */ int);
    callback set-priority-speaker(/* peer_id */ string, /* enabled */ bool);
    callback whisper-to(/* comma-separated peer IDs */ string);
    callback stop-whisper();
    callback save-user-note(/* user_id */ string, /* note */ string);

    // Account system
    in-out property <bool> show-login-view: false;
    in-out property <bool> login-mode: true; // true=login, false=register
    in-out property <string> auth-email: "";
    in-out property <string> auth-password: "";
    in-out property <string> auth-display-name: "";
    in-out property <string> auth-error: "";
    in-out property <bool> is-logged-in: false;
    in-out property <string> account-email: "";
    callback login();
    callback create-account();
    callback logout();
    callback change-password(string, string);
    callback revoke-all-sessions();

    // Quick switcher
    in-out property <bool> quick-switcher-visible: false;
    in-out property <string> quick-switcher-query: "";
    in-out property <[ChannelData]> quick-switcher-items: [];
    callback quick-switcher-select(string);

    Rectangle {
        background: VxTheme.bg-canvas;

        Rectangle {
            width: parent.width;
            height: parent.height;
            background: @linear-gradient(180deg, VxTheme.accent-subtle 0%, transparent 14%);
        }

        HorizontalLayout {
            spacing: 0px;

            if root.rail-open : WorkspaceRail {
                width: root.desktop-layout ? (root.shell-compact ? 236px : 272px) : 248px;
                compact: root.shell-compact;
                current-view: root.current-view;
                spaces: root.spaces;
                current-space-id: root.current-space-id;
                members: root.members;
                show-members: root.current-view == 4 || root.current-view == 5;
                room-code: root.room-code;
                unread-direct-messages-count: root.unread-direct-messages-count;
                favorite-friends-count: root.favorite-friends-count;
                online-friends-count: root.online-friends-count;
                navigate(view-index) => {
                    root.navigate(view-index);
                    if !root.desktop-layout {
                        root.sidebar-expanded = false;
                    }
                }
                select-space(space-id) => {
                    root.select-space(space-id);
                    if !root.desktop-layout {
                        root.sidebar-expanded = false;
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: VxTheme.bg-app;

                VerticalLayout {
                    spacing: 0px;

                    TopBar {
                        compact: root.shell-compact;
                        title: root.context-title;
                        subtitle: root.context-subtitle;
                        is-connected: root.is-connected;
                        ping-ms: root.ping-ms;
                        room-code: root.room-code;
                        unread-direct-messages-count: root.unread-direct-messages-count;
                        show-nav-button: !root.desktop-layout;
                        in-call: root.current-view == 1;
                        is-muted: root.is-muted;
                        is-deafened: root.is-deafened;
                        update-available: root.update-available;
                        update-version: root.update-version;
                        nav-toggle => { root.sidebar-expanded = !root.sidebar-expanded; }
                    }

                    NavBreadcrumb {
                        current-view: root.current-view;
                        previous-view: root.previous-view;
                        space-name: root.current-space-name;
                        channel-name: root.chat-channel-name;
                        room-code: root.room-code;
                        in-space-channel: root.in-space-channel;
                        chat-is-dm: root.chat-is-direct-message;
                        chat-back-view: root.chat-back-view;
                        navigate(view-index) => { root.navigate(view-index); }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        background: transparent;

                        if root.current-view == 0 : HomeView {
                            wide: root.desktop-layout;
                            first-run: root.first-run;
                            server-address <=> root.server-address;
                            saved-servers: root.saved-servers;
                            user-name <=> root.user-name;
                            status-text: root.status-text;
                            is-connected: root.is-connected;
                            spaces: root.spaces;
                            space-name <=> root.space-name;
                            space-invite-code <=> root.space-invite-code;
                            show-quick-call <=> root.show-quick-call;
                            join-code <=> root.join-code;
                            room-password <=> root.room-password;
                            direct-message-threads: root.direct-message-threads;
                            unread-direct-messages-count: root.unread-direct-messages-count;
                            connect-server => { root.connect-server(); }
                            disconnect-server => { root.disconnect-server(); }
                            find-server => { root.find-server(); }
                            save-server(name) => { root.save-server(name); }
                            remove-server(idx) => { root.remove-server(idx); }
                            select-space(space-id) => { root.select-space(space-id); }
                            create-space => { root.create-space(); }
                            join-space => { root.join-space(); }
                            create-room => { root.create-room(); }
                            join-room(code) => { root.join-room(code); }
                            open-direct-message(user-id) => { root.open-direct-message(user-id); }
                        }

                        if root.current-view == 1 : RoomView {
                            wide: root.desktop-layout;
                            room-code: root.room-code;
                            participants: root.participants;
                            is-connected: root.is-connected;
                            status-text: root.status-text;
                            room-status: root.room-status;
                            is-muted: root.is-muted;
                            is-deafened: root.is-deafened;
                            talking-while-muted: root.talking-while-muted;
                            is-open-mic: root.is-open-mic;
                            mic-level: root.mic-level;
                            ptt-key-display: root.ptt-key-display;
                            mute-key-display: root.mute-key-display;
                            deafen-key-display: root.deafen-key-display;
                            ping-ms: root.ping-ms;
                            udp-active: root.udp-active;
                            reconnect-attempts: root.reconnect-attempts;
                            dropped-frames: root.dropped-frames;
                            in-space-channel: root.in-space-channel;
                            current-space-name: root.current-space-name;
                            has-screen-share: root.has-screen-share;
                            is-sharing-screen: root.is-sharing-screen;
                            screen-share-owner-name: root.screen-share-owner-name;
                            screen-share-image: root.screen-share-image;
                            screen-share-sources: root.screen-share-sources;
                            selected-screen-share-source: root.selected-screen-share-source;
                            selected-screen-share-profile: root.selected-screen-share-profile;
                            screen-share-source-label: root.screen-share-source-label;
                            screen-share-source-detail: root.screen-share-source-detail;
                            screen-share-quality-label: root.screen-share-quality-label;
                            screen-share-quality-detail: root.screen-share-quality-detail;
                            show-copied <=> root.show-copied;
                            copy-room-code => { root.copy-room-code(); }
                            leave-room => { root.leave-room(); }
                            leave-channel => { root.leave-channel(); }
                            toggle-mute => { root.toggle-mute(); }
                            toggle-deafen => { root.toggle-deafen(); }
                            toggle-mic-mode => { root.toggle-mic-mode(); }
                            toggle-screen-share => { root.toggle-screen-share(); }
                            refresh-screen-share-sources => { root.refresh-screen-share-sources(); }
                            select-screen-share-source(source-index) => { root.select-screen-share-source(source-index); }
                            select-screen-share-profile(profile-index) => { root.select-screen-share-profile(profile-index); }
                            volume-changed(peer-id, level) => { root.volume-changed(peer-id, level); }
                            navigate(view-index) => { root.navigate(view-index); }
                        }

                        if root.current-view == 2 : SettingsView {
                            wide: root.desktop-layout;
                            previous-view: root.previous-view;
                            dark-mode: root.dark-mode;
                            theme-preset: root.theme-preset;
                            input-devices: root.input-devices;
                            output-devices: root.output-devices;
                            selected-input <=> root.selected-input;
                            selected-output <=> root.selected-output;
                            input-volume <=> root.input-volume;
                            output-volume <=> root.output-volume;
                            is-open-mic: root.is-open-mic;
                            mic-level: root.mic-level;
                            mic-preview-active <=> root.mic-preview-active;
                            speaker-test-active <=> root.speaker-test-active;
                            noise-suppression <=> root.noise-suppression;
                            feedback-sound: root.feedback-sound;
                            notifications-enabled: root.notifications-enabled;
                            minimize-to-tray: root.minimize-to-tray;
                            neural-noise-suppression: root.neural-noise-suppression;
                            echo-cancellation: root.echo-cancellation;
                            listening-keybind <=> root.listening-keybind;
                            ptt-key-display: root.ptt-key-display;
                            mute-key-display: root.mute-key-display;
                            deafen-key-display: root.deafen-key-display;
                            navigate(view-index) => { root.navigate(view-index); }
                            toggle-dark-mode => { root.toggle-dark-mode(); }
                            select-theme-preset(preset) => { root.select-theme-preset(preset); }
                            refresh-devices => { root.refresh-devices(); }
                            input-volume-changed(level) => { root.input-volume-changed(level); }
                            output-volume-changed(level) => { root.output-volume-changed(level); }
                            toggle-mic-preview => { root.toggle-mic-preview(); }
                            play-speaker-test => { root.play-speaker-test(); }
                            toggle-mic-mode => { root.toggle-mic-mode(); }
                            noise-suppression-changed(level) => { root.noise-suppression-changed(level); }
                            toggle-feedback-sound => { root.toggle-feedback-sound(); }
                            toggle-notifications => { root.toggle-notifications(); }
                            toggle-minimize-to-tray => { root.toggle-minimize-to-tray(); }
                            toggle-neural-noise-suppression => { root.toggle-neural-noise-suppression(); }
                            toggle-echo-cancellation => { root.toggle-echo-cancellation(); }
                            join-leave-sounds: root.join-leave-sounds;
                            show-spoilers: root.show-spoilers;
                            compact-chat: root.compact-chat;
                            toggle-join-leave-sounds => { root.toggle-join-leave-sounds(); }
                            toggle-show-spoilers => { root.toggle-show-spoilers(); }
                            toggle-compact-chat => { root.toggle-compact-chat(); }
                            clear-keybind(binding) => { root.clear-keybind(binding); }
                            is-logged-in: root.is-logged-in;
                            account-email: root.account-email;
                            logout => { root.logout(); }
                            show-login => { root.show-login-view = true; root.login-mode = true; root.auth-error = ""; }
                            revoke-all-sessions => { root.revoke-all-sessions(); }
                        }

                        if root.current-view == 4 : SpaceView {
                            wide: root.desktop-layout;
                            current-space-name: root.current-space-name;
                            current-space-invite: root.current-space-invite;
                            is-space-owner: root.is-space-owner;
                            space-role-label: root.space-role-label;
                            can-manage-space-channels: root.can-manage-space-channels;
                            can-manage-space-members: root.can-manage-space-members;
                            can-manage-space-roles: root.can-manage-space-roles;
                            can-view-space-audit: root.can-view-space-audit;
                            channels: root.channels;
                            members: root.members;
                            audit-entries: root.space-audit-entries;
                            search-query <=> root.space-search-query;
                            visible-text-channels: root.visible-text-channels;
                            visible-voice-channels: root.visible-voice-channels;
                            visible-members: root.visible-members;
                            new-channel-name <=> root.new-channel-name;
                            new-channel-is-voice <=> root.new-channel-is-voice;
                            new-channel-voice-quality <=> root.new-channel-voice-quality;
                            confirm-delete-channel-id <=> root.confirm-delete-channel-id;
                            confirm-delete-visible <=> root.confirm-delete-visible;
                            navigate(view-index) => { root.navigate(view-index); }
                            copy-invite-code => { root.copy-invite-code(); }
                            copy-share-message => { root.copy-share-message(); }
                            search-changed(query) => { root.space-search-changed(query); }
                            select-text-channel(channel-id) => { root.select-text-channel(channel-id); }
                            join-channel(channel-id) => { root.join-channel(channel-id); }
                            create-channel => { root.create-channel(); }
                            delete-channel(channel-id) => { root.delete-channel(channel-id); }
                            leave-space => { root.leave-space(); }
                            delete-space => { root.delete-space(); }
                            kick-member(member-id) => { root.kick-member(member-id); }
                            ban-member(member-id) => { root.ban-member(member-id); }
                            server-mute-member(member-id, muted) => { root.server-mute-member(member-id, muted); }
                            set-member-role(user-id, role-index) => { root.set-member-role(user-id, role-index); }
                            set-user-status(status) => { root.set-user-status(status); }
                            set-channel-topic(channel-id, topic) => { root.set-channel-topic(channel-id, topic); }
                            set-profile(bio) => { root.set-profile(bio); }
                            timeout-member(member-id, duration) => { root.timeout-member(member-id, duration); }
                            set-channel-user-limit(channel-id, limit) => { root.set-channel-user-limit(channel-id, limit); }
                            set-channel-slow-mode(channel-id, secs) => { root.set-channel-slow-mode(channel-id, secs); }
                            set-channel-category(channel-id, cat) => { root.set-channel-category(channel-id, cat); }
                            set-channel-status(channel-id, status) => { root.set-channel-status(channel-id, status); }
                            save-user-note(user-id, note) => { root.save-user-note(user-id, note); }
                            send-friend-request(user-id) => { root.send-friend-request(user-id); }
                            accept-friend-request(user-id) => { root.accept-friend-request(user-id); }
                            decline-friend-request(user-id) => { root.decline-friend-request(user-id); }
                            cancel-friend-request(user-id) => { root.cancel-friend-request(user-id); }
                            remove-friend(user-id) => { root.remove-friend(user-id); }
                            open-direct-message(user-id) => { root.open-direct-message(user-id); }
                        }

                        if root.current-view == 5 : ChatView {
                            wide: root.desktop-layout;
                            compact-mode: root.compact-chat;
                            current-space-name: root.current-space-name;
                            chat-channel-name: root.chat-channel-name;
                            chat-is-direct-message: root.chat-is-direct-message;
                            chat-context-subtitle: root.chat-context-subtitle;
                            chat-back-view: root.chat-back-view;
                            chat-messages: root.chat-messages;
                            chat-pinned-messages: root.chat-pinned-messages;
                            chat-input <=> root.chat-input;
                            chat-typing-text: root.chat-typing-text;
                            editing-message-id <=> root.editing-message-id;
                            editing-original-content <=> root.editing-original-content;
                            reply-target-message-id <=> root.reply-target-message-id;
                            reply-target-sender-name <=> root.reply-target-sender-name;
                            reply-target-preview <=> root.reply-target-preview;
                            navigate(view-index) => { root.navigate(view-index); }
                            chat-typing-activity(is-typing) => { root.chat-typing-activity(is-typing); }
                            send-text-message => { root.send-text-message(); }
                            edit-text-message(message-id, content) => { root.edit-text-message(message-id, content); }
                            delete-text-message(message-id) => { root.delete-text-message(message-id); }
                            react-to-message(message-id, emoji) => { root.react-to-message(message-id, emoji); }
                            toggle-pin-message(message-id, pinned) => { root.toggle-pin-message(message-id, pinned); }
                            chat-search-results: root.chat-search-results;
                            chat-search-query <=> root.chat-search-query;
                            search-messages(query) => { root.search-messages(query); }
                        }

                        if root.current-view == 3 : SystemView {
                            wide: root.desktop-layout;
                            perf: root.perf;
                            uptime-text: root.uptime-text;
                            version-text: root.version-text;
                            room-code: root.room-code;
                            participants: root.participants;
                            is-open-mic: root.is-open-mic;
                            ping-ms: root.ping-ms;
                            current-space-name: root.current-space-name;
                            member-widget-visible: root.member-widget-visible;
                            favorite-friends-count: root.favorite-friends-count;
                            online-friends-count: root.online-friends-count;
                            live-friends-count: root.live-friends-count;
                            favorite-friends: root.favorite-friends;
                            incoming-friend-requests: root.incoming-friend-requests;
                            outgoing-friend-requests: root.outgoing-friend-requests;
                            direct-message-threads: root.direct-message-threads;
                            unread-direct-messages-count: root.unread-direct-messages-count;
                            navigate(view-index) => { root.navigate(view-index); }
                            toggle-member-widget => { root.toggle-member-widget(); }
                            accept-friend-request(user-id) => { root.accept-friend-request(user-id); }
                            decline-friend-request(user-id) => { root.decline-friend-request(user-id); }
                            cancel-friend-request(user-id) => { root.cancel-friend-request(user-id); }
                            remove-friend(user-id) => { root.remove-friend(user-id); }
                            open-direct-message(user-id) => { root.open-direct-message(user-id); }
                        }
                    }

                    // Voice call bar: shown when in a call but not viewing the room (like Discord)
                    if root.current-view != 1 && root.room-code != "" && root.is-connected : VoiceCallBar {
                        room-code: root.room-code;
                        space-name: root.current-space-name;
                        in-space-channel: root.in-space-channel;
                        is-muted: root.is-muted;
                        is-deafened: root.is-deafened;
                        mic-level: root.mic-level;
                        ping-ms: root.ping-ms;
                        navigate(view-index) => { root.navigate(view-index); }
                        leave-room => { root.leave-room(); }
                        leave-channel => { root.leave-channel(); }
                        toggle-mute => { root.toggle-mute(); }
                        toggle-deafen => { root.toggle-deafen(); }
                    }

                    if !root.desktop-layout && root.current-view != 1 && root.current-view != 4 && root.current-view != 5 : BottomNav {
                        current-view: root.current-view;
                        unread-direct-messages-count: root.unread-direct-messages-count;
                        navigate(view-index) => { root.navigate(view-index); }
                    }
                }
            }
        }

        // Quick Switcher overlay (Ctrl+K)
        // Account login/register overlay
        if root.show-login-view : Rectangle {
            background: VxTheme.bg-canvas.transparentize(0.15);
            TouchArea { clicked => {} } // block clicks

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    VxCard {
                        width: 360px;
                        VerticalLayout {
                            padding: 28px;
                            spacing: 16px;

                            // Brand header
                            HorizontalLayout {
                                alignment: center;
                                spacing: 8px;
                                Text {
                                    text: "VX";
                                    color: VxTheme.accent;
                                    font-size: 22px;
                                    font-weight: 900;
                                }
                                Text {
                                    text: root.login-mode ? "Sign In" : "Create Account";
                                    color: VxTheme.text-primary;
                                    font-size: 18px;
                                    font-weight: 700;
                                }
                            }

                            // Error display
                            if root.auth-error != "" : Rectangle {
                                background: VxTheme.danger.transparentize(0.85);
                                border-radius: 6px;
                                height: auth-err-text.preferred-height + 12px;
                                auth-err-text := Text {
                                    text: root.auth-error;
                                    color: VxTheme.danger;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }
                            }

                            // Email field
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Email";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: "you@example.com";
                                    text <=> root.auth-email;
                                }
                            }

                            // Password field
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Password";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: root.login-mode ? "Enter password" : "Min 6 characters";
                                    text <=> root.auth-password;
                                    input-type: InputType.password;
                                }
                            }

                            // Display name (register only)
                            if !root.login-mode : VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "Display Name";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    font-weight: 700;
                                    letter-spacing: 0.5px;
                                }
                                VxInput {
                                    placeholder: "How others will see you";
                                    text <=> root.auth-display-name;
                                }
                            }

                            // Submit button
                            Rectangle {
                                height: 36px;
                                border-radius: 8px;
                                background: login-submit-touch.has-hover ? VxTheme.accent.darker(0.15) : VxTheme.accent;
                                login-submit-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.auth-error = "";
                                        if root.login-mode {
                                            root.login();
                                        } else {
                                            root.create-account();
                                        }
                                    }
                                }
                                Text {
                                    text: root.login-mode ? "Sign In" : "Create Account";
                                    color: white;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Toggle login/register
                            HorizontalLayout {
                                alignment: center;
                                spacing: 4px;
                                Text {
                                    text: root.login-mode ? "Don't have an account?" : "Already have an account?";
                                    color: VxTheme.text-muted;
                                    font-size: 11px;
                                }
                                Text {
                                    text: root.login-mode ? "Register" : "Sign In";
                                    color: VxTheme.accent;
                                    font-size: 11px;
                                    font-weight: 700;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => {
                                            root.login-mode = !root.login-mode;
                                            root.auth-error = "";
                                        }
                                    }
                                }
                            }

                            // Skip / continue without account
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "Continue without account";
                                    color: VxTheme.text-muted;
                                    font-size: 10px;
                                    TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.show-login-view = false; }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        if root.quick-switcher-visible : Rectangle {
            background: #00000080;
            TouchArea {
                clicked => { root.quick-switcher-visible = false; root.quick-switcher-query = ""; }
            }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: parent.height * 0.18;
                width: min(500px, parent.width - 40px);
                border-radius: VxTheme.radius-card;
                background: VxTheme.bg-raised;
                border-color: VxTheme.accent-border;
                border-width: 1px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;

                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Quick Switcher";
                            color: VxTheme.text-primary;
                            font-size: 13px;
                            font-weight: 700;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: "Esc to close";
                            color: VxTheme.text-muted;
                            font-size: 9px;
                        }
                    }

                    VxInput {
                        text <=> root.quick-switcher-query;
                        placeholder: "Search channels, DMs, spaces...";
                        horizontal-stretch: 1;
                        accepted => {
                            if root.quick-switcher-items.length > 0 {
                                root.quick-switcher-select(root.quick-switcher-items[0].id);
                                root.quick-switcher-visible = false;
                                root.quick-switcher-query = "";
                            }
                        }
                    }

                    if root.quick-switcher-items.length == 0 && root.quick-switcher-query != "" : Text {
                        text: "No matches found";
                        color: VxTheme.text-muted;
                        font-size: 10px;
                    }

                    for item[idx] in root.quick-switcher-items : Rectangle {
                        height: idx < 8 ? 40px : 0px;
                        visible: idx < 8;
                        border-radius: VxTheme.radius-control;
                        background: qs-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-soft;
                        border-color: VxTheme.border-subtle;
                        border-width: 1px;

                        qs-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.quick-switcher-select(item.id);
                                root.quick-switcher-visible = false;
                                root.quick-switcher-query = "";
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;
                            alignment: center;
                            Text {
                                text: item.is-voice ? "VC" : "TXT";
                                color: VxTheme.text-muted;
                                font-size: 9px;
                                font-weight: 800;
                                width: 28px;
                            }
                            Text {
                                text: item.name;
                                color: VxTheme.text-primary;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-stretch: 1;
                            }
                            if item.status != "" : Text {
                                text: item.status;
                                color: VxTheme.text-muted;
                                font-size: 9px;
                            }
                        }
                    }
                }
            }
        }
    }
}
