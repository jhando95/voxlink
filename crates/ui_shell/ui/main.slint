import { ListView, ComboBox, ScrollView } from "std-widgets.slint";
import { ParticipantData, PerfData, SpaceData, ChannelData, MemberData, ChatMessage, VxTheme } from "theme.slint";
import { VxButton, VxCard, VxInput, SectionLabel, FieldLabel, KeyPill, StatusDot, MetricRow, VxSlider, Divider, AccentBar } from "components.slint";

// ─── Main Window ───

export component MainWindow inherits Window {
    in-out property <string> window-title: "Voxlink";
    title: root.window-title;
    icon: @image-url("../../../assets/icon.png");
    min-width: 400px;
    min-height: 480px;
    preferred-width: 680px;
    preferred-height: 620px;
    background: VxTheme.bg-deep;

    // State
    in-out property <int> current-view: 0;
    in-out property <string> room-code: "";
    in-out property <string> join-code: "";
    in-out property <string> room-password: "";
    in-out property <string> server-address: "ws://127.0.0.1:9090";
    in-out property <bool> is-muted: false;
    in-out property <bool> is-deafened: false;
    in-out property <bool> is-open-mic: true;
    in-out property <bool> is-connected: false;
    in-out property <float> mic-level: 0.0;
    in-out property <string> status-text: "Disconnected";
    in-out property <string> room-status: "";
    in-out property <[ParticipantData]> participants: [];
    in-out property <PerfData> perf: { cpu-percent: 0, memory-mb: 0, uptime-secs: 0, audio-active: false, network-connected: false };
    in-out property <[string]> input-devices: ["Default Microphone"];
    in-out property <[string]> output-devices: ["Default Speaker"];
    in-out property <int> selected-input: 0;
    in-out property <int> selected-output: 0;
    in-out property <string> user-name: "User";
    in-out property <bool> show-saved: false;
    in-out property <int> previous-view: 0;
    in-out property <bool> show-copied: false;
    in-out property <string> version-text: "0.1.0";
    in-out property <string> uptime-text: "0s";
    in-out property <string> listening-keybind: "";
    in-out property <string> ptt-key-display: "Space";
    in-out property <string> mute-key-display: "M";
    in-out property <string> deafen-key-display: "D";
    in-out property <bool> dark-mode: true;
    changed dark-mode => { VxTheme.dark-mode = self.dark-mode; }
    in-out property <bool> feedback-sound: true;
    in-out property <float> noise-suppression: 0.5;

    // Space state
    in-out property <[SpaceData]> spaces: [];
    in-out property <string> space-name: "";
    in-out property <string> space-invite-code: "";
    in-out property <string> current-space-id: "";
    in-out property <string> current-space-name: "";
    in-out property <string> current-space-invite: "";
    in-out property <[ChannelData]> channels: [];
    in-out property <[MemberData]> members: [];
    in-out property <string> new-channel-name: "";
    in-out property <bool> in-space-channel: false;
    in-out property <bool> show-quick-call: false;
    in-out property <bool> new-channel-is-voice: true;
    // Text chat
    in-out property <[ChatMessage]> chat-messages: [];
    in-out property <string> chat-channel-id: "";
    in-out property <string> chat-channel-name: "";
    in-out property <string> chat-input: "";

    // Delete confirmation
    in-out property <bool> confirm-delete-visible: false;

    // Sidebar — only for spaces & friends
    in-out property <bool> sidebar-expanded: false;
    property <length> sidebar-w: sidebar-expanded ? 180px : 0px;

    // Callbacks
    callback create-room();
    callback join-room(string);
    callback leave-room();
    callback toggle-mute();
    callback toggle-deafen();
    callback toggle-mic-mode();
    callback navigate(int);
    callback refresh-devices();
    callback connect-server();
    callback save-settings();
    callback find-server();
    callback volume-changed(string, float);
    callback disconnect-server();
    callback copy-room-code();
    callback clear-keybind(string);
    callback toggle-dark-mode();
    callback create-space();
    callback join-space();
    callback select-space(string);
    callback leave-space();
    callback create-channel();
    callback join-channel(string);
    callback leave-channel();
    callback copy-invite-code();
    callback delete-space();
    callback toggle-feedback-sound();
    callback noise-suppression-changed(float);
    callback select-text-channel(string);
    callback send-text-message();

    VerticalLayout {
        spacing: 0px;

        // ─── Header Bar ───
        Rectangle {
            height: 44px;
            background: VxTheme.bg-surface;
            AccentBar { y: parent.height - 2px; }

            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                alignment: space-between;

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    // Sidebar toggle — Spaces panel
                    if root.spaces.length > 0 : Rectangle {
                        height: 30px;
                        border-radius: 7px;
                        background: root.sidebar-expanded ? VxTheme.accent-glow :
                                    sb-toggle.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                        border-color: root.sidebar-expanded ? VxTheme.accent : VxTheme.border-subtle;
                        border-width: 1px;
                        animate background { duration: 80ms; }
                        animate border-color { duration: 80ms; }

                        sb-toggle := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.sidebar-expanded = !root.sidebar-expanded; }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 10px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: root.sidebar-expanded ? "\u{2715}" : "\u{2630}";
                                color: root.sidebar-expanded ? VxTheme.accent : VxTheme.text-secondary;
                                font-size: root.sidebar-expanded ? 11px : 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.sidebar-expanded ? "Close" : "Spaces";
                                color: root.sidebar-expanded ? VxTheme.accent : VxTheme.text-secondary;
                                font-size: 10px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle {
                        width: 24px; height: 24px; border-radius: 7px;
                        background: VxTheme.accent;
                        Text {
                            text: "VX";
                            color: #f0f0f8;
                            font-size: 9px; font-weight: 800; letter-spacing: 0.3px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    Text {
                        text: "VOX";
                        color: VxTheme.accent;
                        font-size: 12px; font-weight: 800; letter-spacing: 1.8px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "LINK";
                        color: VxTheme.text-primary;
                        font-size: 12px; font-weight: 600; letter-spacing: 1.8px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 5px;
                    alignment: center;

                    if current-view == 1 && root.is-muted : Rectangle {
                        width: 18px; height: 18px; border-radius: 9px;
                        background: VxTheme.mute-badge-bg;
                        border-color: VxTheme.danger;
                        border-width: 1px;
                        Text { text: "\u{1F507}"; font-size: 9px;
                               horizontal-alignment: center; vertical-alignment: center; }
                    }
                    if current-view == 1 && root.is-deafened : Rectangle {
                        width: 18px; height: 18px; border-radius: 9px;
                        background: VxTheme.deafen-badge-bg;
                        border-color: VxTheme.warning;
                        border-width: 1px;
                        Text { text: "\u{1F515}"; font-size: 9px;
                               horizontal-alignment: center; vertical-alignment: center; }
                    }

                    StatusDot { active: root.is-connected; }

                    Text {
                        text: current-view == 1 && root.room-code != "" ? root.room-code :
                              root.is-connected ? "ONLINE" : "OFFLINE";
                        color: root.is-connected ? VxTheme.text-secondary : VxTheme.text-muted;
                        font-size: 9px; font-weight: 600; letter-spacing: 0.8px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ─── Main body: sidebar + content ───
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // ═══════════════════════════════
            //  LEFT SIDEBAR — Spaces & Members
            // ═══════════════════════════════
            if root.sidebar-expanded : Rectangle {
                width: root.sidebar-w;
                background: VxTheme.sidebar-bg;
                animate width { duration: 150ms; easing: ease-out; }

                // Right border
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: parent.height;
                    background: VxTheme.sidebar-divider;
                }

                VerticalLayout {
                    spacing: 0px;

                    // Section label
                    Rectangle {
                        height: 30px;
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: space-between;
                            SectionLabel {
                                text: "SPACES";
                                vertical-alignment: center;
                            }
                            // Close sidebar
                            Rectangle {
                                width: 20px; height: 20px; border-radius: 4px;
                                background: close-sb.has-hover ? VxTheme.sidebar-item-hover : transparent;
                                close-sb := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.sidebar-expanded = false; }
                                }
                                Text {
                                    text: "\u{00D7}";
                                    color: VxTheme.text-muted;
                                    font-size: 14px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Space list
                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            spacing: 2px;
                            padding: 6px;
                            alignment: start;

                            for space in root.spaces : Rectangle {
                                height: 44px;
                                border-radius: 8px;
                                background: (current-view == 4 || current-view == 5 || (current-view == 1 && root.in-space-channel))
                                            && root.current-space-id == space.id ? VxTheme.sidebar-item-active :
                                            sp-sb.has-hover ? VxTheme.sidebar-item-hover : transparent;
                                animate background { duration: 80ms; }

                                sp-sb := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.select-space(space.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 10px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 30px; height: 30px; border-radius: 15px;
                                            background: VxTheme.avatar-color(space.color-index);
                                            Text {
                                                text: space.initial;
                                                color: #f0f0f8;
                                                font-size: 12px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        spacing: 1px;
                                        Text {
                                            text: space.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px; font-weight: 600;
                                            overflow: elide;
                                        }
                                        Text {
                                            text: space.member-count + " members";
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                        }
                                    }
                                }
                            }

                            // Empty state
                            if root.spaces.length == 0 : VerticalLayout {
                                padding: 12px;
                                spacing: 4px;
                                Text {
                                    text: "No spaces yet";
                                    color: VxTheme.text-muted;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Create or join one from Home";
                                    color: VxTheme.text-muted;
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                }
                            }

                            // Divider before members (if inside a space)
                            if (current-view == 4 || current-view == 5) && root.members.length > 0 : Rectangle {
                                height: 1px;
                                background: VxTheme.sidebar-divider;
                            }

                            // Members list (when viewing a space)
                            if (current-view == 4 || current-view == 5) && root.members.length > 0 : VerticalLayout {
                                spacing: 0px;
                                padding-top: 4px;

                                Rectangle {
                                    height: 24px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        SectionLabel {
                                            text: "ONLINE \u{2014} " + root.members.length;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                for member in root.members : Rectangle {
                                    height: 32px;
                                    border-radius: 6px;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;

                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 22px; height: 22px; border-radius: 11px;
                                                background: VxTheme.avatar-color(member.color-index);
                                                Text {
                                                    text: member.initial;
                                                    color: #f0f0f8;
                                                    font-size: 8px; font-weight: 700;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: member.name;
                                                color: VxTheme.text-primary;
                                                font-size: 11px; font-weight: 500;
                                                overflow: elide;
                                            }
                                        }

                                        if member.is-in-voice : VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 6px; height: 6px; border-radius: 3px;
                                                background: VxTheme.success;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // ═══════════════════════════════
            //  CONTENT AREA
            // ═══════════════════════════════
            Rectangle {
                background: VxTheme.bg-deep;
                horizontal-stretch: 1;
                vertical-stretch: 1;

                // ═══════════════════════════════
                //  HOME VIEW
                // ═══════════════════════════════
                if current-view == 0 : VerticalLayout {

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 14px;
                            alignment: start;

                            // Welcome hero
                            Rectangle {
                                height: 94px;
                                border-radius: 14px;
                                background: VxTheme.bg-card;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;

                                // Accent top edge
                                Rectangle {
                                    y: 0px;
                                    height: 3px;
                                    border-radius: 14px;
                                    clip: true;
                                    Rectangle {
                                        x: 0px;
                                        width: parent.width * 0.33;
                                        height: parent.height;
                                        background: VxTheme.header-accent-left;
                                    }
                                    Rectangle {
                                        x: parent.width * 0.33;
                                        width: parent.width * 0.34;
                                        height: parent.height;
                                        background: VxTheme.header-accent-mid;
                                    }
                                    Rectangle {
                                        x: parent.width * 0.67;
                                        width: parent.width * 0.33;
                                        height: parent.height;
                                        background: VxTheme.header-accent-right;
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 20px;
                                    padding-right: 20px;
                                    spacing: 16px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 52px; height: 52px; border-radius: 14px;
                                            background: VxTheme.accent;
                                            border-color: VxTheme.accent-glow;
                                            border-width: 2px;
                                            Text {
                                                text: "VX";
                                                color: #f0f0f8;
                                                font-size: 18px; font-weight: 800; letter-spacing: 0.5px;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 5px;
                                        horizontal-stretch: 1;
                                        Text {
                                            text: root.user-name != "" && root.user-name != "User" ?
                                                  "Hey, " + root.user-name : "Voxlink";
                                            color: VxTheme.text-primary;
                                            font-size: 22px;
                                            font-weight: 700;
                                        }
                                        HorizontalLayout {
                                            spacing: 6px;
                                            alignment: start;
                                            Rectangle {
                                                width: 7px; height: 7px; y: 3px;
                                                border-radius: 3.5px;
                                                background: root.is-connected ? VxTheme.success :
                                                           root.status-text == "Connecting..." ? VxTheme.warning : VxTheme.text-muted;
                                                border-color: root.is-connected ? VxTheme.success-dim : transparent;
                                                border-width: root.is-connected ? 2px : 0px;
                                                animate background { duration: 200ms; }
                                                animate border-color { duration: 200ms; }
                                            }
                                            Text {
                                                text: root.status-text;
                                                color: root.is-connected ? VxTheme.success :
                                                       root.status-text == "Connecting..." ? VxTheme.warning : VxTheme.text-muted;
                                                font-size: 11px; font-weight: 500;
                                                animate color { duration: 200ms; }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Connection & Identity ──
                            VxCard {
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 12px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F310}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "CONNECTION"; vertical-alignment: center; }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Server address"; }
                                        VxInput {
                                            text <=> root.server-address;
                                            horizontal-stretch: 1;
                                            accepted => { if !root.is-connected { root.connect-server(); } }
                                        }
                                    }

                                    if !root.is-connected : VxButton {
                                        label: root.status-text == "Connecting..." ? "Connecting..." : "Connect";
                                        accent: true;
                                        enabled: root.status-text != "Connecting...";
                                        horizontal-stretch: 1;
                                        clicked => { root.connect-server(); }
                                    }
                                    if root.is-connected : VxButton {
                                        label: "Disconnect";
                                        danger: true;
                                        horizontal-stretch: 1;
                                        clicked => { root.disconnect-server(); }
                                    }

                                    if !root.is-connected : HorizontalLayout {
                                        alignment: end;
                                        VxButton {
                                            label: "Find on LAN";
                                            small: true; ghost: true;
                                            clicked => { root.find-server(); }
                                        }
                                    }

                                    Divider {}

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Display name"; }
                                        VxInput {
                                            text <=> root.user-name;
                                            placeholder: "Enter your name";
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }

                            // ── Your Spaces ──
                            if root.spaces.length > 0 : VerticalLayout {
                                spacing: 6px;

                                SectionLabel { text: "YOUR SPACES"; }

                                for space in root.spaces : Rectangle {
                                    height: 52px;
                                    border-radius: 8px;
                                    background: space-touch.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-card;
                                    border-color: space-touch.has-hover ? VxTheme.card-hover-border : VxTheme.border-subtle;
                                    border-width: 1px;
                                    animate background { duration: 80ms; }

                                    space-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.select-space(space.id); }
                                    }

                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 10px;

                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 32px; height: 32px; border-radius: 16px;
                                                background: VxTheme.avatar-color(space.color-index);
                                                Text {
                                                    text: space.initial;
                                                    color: #f0f0f8;
                                                    font-size: 12px; font-weight: 700;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            horizontal-stretch: 1;
                                            spacing: 2px;
                                            Text {
                                                text: space.name;
                                                color: VxTheme.text-primary;
                                                font-size: 13px; font-weight: 600;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: space.member-count + " members \u{2022} " + space.channel-count + " channels";
                                                color: VxTheme.text-muted;
                                                font-size: 9px;
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: "\u{203A}";
                                                color: VxTheme.text-muted;
                                                font-size: 16px;
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Create / Join Space ──
                            VxCard {
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 12px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F680}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "SPACE"; vertical-alignment: center; }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Space name"; }
                                        VxInput {
                                            placeholder: "My Space";
                                            text <=> root.space-name;
                                            horizontal-stretch: 1;
                                            accepted => {
                                                if root.is-connected && root.space-name != "" {
                                                    root.create-space();
                                                }
                                            }
                                        }
                                    }
                                    VxButton {
                                        label: "Create Space";
                                        accent: root.is-connected;
                                        enabled: root.is-connected && root.space-name != "";
                                        horizontal-stretch: 1;
                                        clicked => { root.create-space(); }
                                    }

                                    HorizontalLayout {
                                        spacing: 12px;
                                        alignment: center;
                                        Divider { horizontal-stretch: 1; }
                                        Rectangle {
                                            height: 18px; border-radius: 9px;
                                            background: VxTheme.bg-elevated;
                                            HorizontalLayout {
                                                padding-left: 10px; padding-right: 10px;
                                                Text { text: "or join existing"; color: VxTheme.text-muted; font-size: 8px; font-weight: 500; vertical-alignment: center; }
                                            }
                                        }
                                        Divider { horizontal-stretch: 1; }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Invite code"; }
                                        VxInput {
                                            placeholder: "Enter invite code";
                                            text <=> root.space-invite-code;
                                            horizontal-stretch: 1;
                                            accepted => {
                                                if root.is-connected && root.space-invite-code != "" {
                                                    root.join-space();
                                                }
                                            }
                                        }
                                    }
                                    VxButton {
                                        label: "Join Space";
                                        accent: true;
                                        enabled: root.is-connected && root.space-invite-code != "";
                                        horizontal-stretch: 1;
                                        clicked => { root.join-space(); }
                                    }
                                }
                            }

                            // ── Quick Call (collapsible) ──
                            Rectangle {
                                height: 34px;
                                border-radius: 8px;
                                background: qc-toggle.has-hover ? VxTheme.card-hover-bg : VxTheme.bg-card;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                animate background { duration: 80ms; }

                                qc-toggle := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.show-quick-call = !root.show-quick-call; }
                                }

                                HorizontalLayout {
                                    padding-left: 16px;
                                    padding-right: 16px;
                                    alignment: space-between;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: center;
                                        Text { text: "\u{1F4DE}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "QUICK CALL"; vertical-alignment: center; }
                                        Text {
                                            text: "join by code";
                                            color: VxTheme.text-muted;
                                            font-size: 8px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: root.show-quick-call ? "\u{2212}" : "+";
                                        color: root.show-quick-call ? VxTheme.accent : VxTheme.text-muted;
                                        font-size: 14px; font-weight: 600;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            if root.show-quick-call : VxCard {
                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 12px;

                                    VxButton {
                                        label: root.status-text == "Starting call..." ? "Starting..." :
                                               root.is-connected ? "Start Call" : "Connect first";
                                        accent: root.is-connected;
                                        enabled: root.is-connected && root.status-text != "Starting call..." && root.status-text != "Joining call...";
                                        horizontal-stretch: 1;
                                        clicked => { root.create-room(); }
                                    }

                                    HorizontalLayout {
                                        spacing: 12px;
                                        alignment: center;
                                        Divider { horizontal-stretch: 1; }
                                        Rectangle {
                                            height: 18px; border-radius: 9px;
                                            background: VxTheme.bg-elevated;
                                            HorizontalLayout {
                                                padding-left: 10px; padding-right: 10px;
                                                Text { text: "or join"; color: VxTheme.text-muted; font-size: 8px; font-weight: 500; vertical-alignment: center; }
                                            }
                                        }
                                        Divider { horizontal-stretch: 1; }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        VxInput {
                                            placeholder: "Call code";
                                            text <=> root.join-code;
                                            horizontal-stretch: 1;
                                            accepted => {
                                                if root.is-connected && root.join-code != "" {
                                                    root.join-room(root.join-code);
                                                }
                                            }
                                        }
                                        VxButton {
                                            label: "Join";
                                            accent: true;
                                            enabled: root.is-connected && root.join-code != "";
                                            clicked => { root.join-room(root.join-code); }
                                        }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Password (optional)"; }
                                        VxInput {
                                            placeholder: "Leave blank if none";
                                            text <=> root.room-password;
                                            horizontal-stretch: 1;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ═══════════════════════════════
                //  ROOM VIEW
                // ═══════════════════════════════
                if current-view == 1 : VerticalLayout {
                    spacing: 0px;

                    // Room header
                    Rectangle {
                        height: 50px;
                        background: VxTheme.bg-surface;
                        Divider { y: parent.height - 1px; }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 12px;
                            alignment: space-between;

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;

                                    // Stylized room code badge
                                    Rectangle {
                                        height: 26px;
                                        border-radius: 6px;
                                        background: VxTheme.accent-subtle;
                                        border-color: VxTheme.accent-glow;
                                        border-width: 1px;
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            spacing: 6px;
                                            alignment: center;
                                            Text {
                                                text: root.room-code;
                                                color: VxTheme.accent;
                                                font-size: 14px; font-weight: 800; letter-spacing: 3px;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        width: 28px; height: 20px; border-radius: 10px;
                                        background: VxTheme.bg-elevated;
                                        border-color: VxTheme.border-subtle;
                                        border-width: 1px;
                                        Text {
                                            text: root.participants.length + "";
                                            color: VxTheme.text-secondary;
                                            font-size: 10px; font-weight: 700;
                                            horizontal-alignment: center; vertical-alignment: center;
                                        }
                                    }

                                    Rectangle {
                                        height: 24px; border-radius: 6px;
                                        background: copy-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                        border-color: root.show-copied ? VxTheme.success : VxTheme.border-subtle;
                                        border-width: 1px;
                                        animate background { duration: 80ms; }
                                        animate border-color { duration: 200ms; }

                                        copy-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.copy-room-code(); root.show-copied = true; }
                                        }
                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 10px;
                                            Text {
                                                text: root.show-copied ? "\u{2713} Copied" : "Copy Code";
                                                color: root.show-copied ? VxTheme.success : VxTheme.text-secondary;
                                                font-size: 10px; font-weight: 600;
                                                vertical-alignment: center;
                                                animate color { duration: 200ms; }
                                            }
                                        }
                                    }
                                }

                                Text {
                                    text: root.room-status != "" ? root.room-status :
                                          !root.is-connected ? "Reconnecting..." :
                                          root.is-deafened ? "Deafened" :
                                          root.is-muted ? "Muted" :
                                          root.is-open-mic ? "Open mic" :
                                          root.ptt-key-display != "" ? "PTT (" + root.ptt-key-display + ")" : "Push-to-talk";
                                    color: root.room-status != "" ? VxTheme.text-secondary :
                                           !root.is-connected ? VxTheme.danger :
                                           root.is-deafened || root.is-muted ? VxTheme.danger : VxTheme.success;
                                    font-size: 9px; font-weight: 500;
                                }
                            }

                            HorizontalLayout {
                                alignment: center;
                                if root.in-space-channel : Rectangle {
                                    width: 90px; height: 32px; border-radius: 8px;
                                    background: back-ch-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                    border-color: VxTheme.border-subtle; border-width: 1px;
                                    animate background { duration: 80ms; }
                                    back-ch-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.leave-channel(); }
                                    }
                                    HorizontalLayout {
                                        alignment: center; spacing: 4px;
                                        Text { text: "\u{2190}"; color: VxTheme.text-secondary; font-size: 13px; vertical-alignment: center; }
                                        Text { text: "Leave"; color: VxTheme.text-secondary; font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                    }
                                }
                                if !root.in-space-channel : VxButton {
                                    label: "Leave Call";
                                    danger: true;
                                    clicked => { root.leave-room(); }
                                }
                            }
                        }
                    }

                    // Connection lost banner
                    if !root.is-connected : Rectangle {
                        height: 30px;
                        background: VxTheme.connection-lost-bg;
                        border-color: VxTheme.danger;
                        border-width: 0px;
                        // Bottom accent line
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: VxTheme.danger;
                            opacity: 0.5;
                        }
                        HorizontalLayout {
                            padding-left: 14px; padding-right: 14px;
                            alignment: center; spacing: 8px;
                            // Pulsing dot
                            Rectangle {
                                width: 8px; height: 8px; border-radius: 4px;
                                background: VxTheme.danger;
                                border-color: VxTheme.mic-glow-red;
                                border-width: 3px;
                            }
                            Text {
                                text: root.status-text;
                                color: VxTheme.danger;
                                font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Participants
                    VerticalLayout {
                        padding-left: 12px; padding-right: 12px;
                        padding-top: 8px; padding-bottom: 2px;
                        spacing: 2px;
                        vertical-stretch: 1;

                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            Text { text: "\u{1F465}"; font-size: 11px; vertical-alignment: center; }
                            SectionLabel { text: "PARTICIPANTS"; vertical-alignment: center; }
                        }

                        if root.participants.length <= 1 : VerticalLayout {
                            alignment: center;
                            vertical-stretch: 1;
                            spacing: 10px;

                            // Visual empty state
                            HorizontalLayout {
                                alignment: center;
                                spacing: 8px;
                                Rectangle {
                                    width: 28px; height: 28px; border-radius: 14px;
                                    background: VxTheme.bg-card;
                                    border-color: VxTheme.border-subtle; border-width: 1px;
                                    opacity: 0.5;
                                    Text { text: "?"; color: VxTheme.text-muted; font-size: 11px;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                                Rectangle {
                                    width: 40px; height: 40px; border-radius: 20px;
                                    background: VxTheme.accent-subtle;
                                    border-color: VxTheme.accent-glow; border-width: 2px;
                                    Text { text: "\u{1F3A4}"; font-size: 16px;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                                Rectangle {
                                    width: 28px; height: 28px; border-radius: 14px;
                                    background: VxTheme.bg-card;
                                    border-color: VxTheme.border-subtle; border-width: 1px;
                                    opacity: 0.5;
                                    Text { text: "?"; color: VxTheme.text-muted; font-size: 11px;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }

                            Text {
                                text: "Waiting for others...";
                                color: VxTheme.text-secondary;
                                font-size: 13px; font-weight: 600;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: root.in-space-channel ? "Invite others to join this channel" :
                                      "Share code " + root.room-code + " to invite friends";
                                color: VxTheme.text-muted;
                                font-size: 10px;
                                horizontal-alignment: center;
                            }
                        }

                        ListView {
                            vertical-stretch: 1;

                            for p[idx] in root.participants : Rectangle {
                                height: 52px;
                                background: p.is-speaking ? VxTheme.speaking-glow :
                                            row-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                                border-radius: 10px;
                                border-width: p.is-speaking ? 1.5px : 0px;
                                border-color: p.is-speaking ? VxTheme.speaking-border : transparent;
                                animate background { duration: 120ms; }
                                animate border-color { duration: 120ms; }
                                animate border-width { duration: 120ms; }

                                row-touch := TouchArea { mouse-cursor: p.id != "self" ? pointer : default; }

                                HorizontalLayout {
                                    padding-left: 8px; padding-right: 10px; spacing: 10px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 30px; height: 30px; border-radius: 15px;
                                            background: p.is-speaking ? VxTheme.accent : VxTheme.avatar-color(p.color-index);
                                            animate background { duration: 80ms; }
                                            Text {
                                                text: p.initial; color: #f0f0f8;
                                                font-size: 11px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        horizontal-stretch: 1;
                                        alignment: center;
                                        spacing: 2px;

                                        Text {
                                            text: p.id == "self" ? p.name + " (You)" : p.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px; font-weight: p.id == "self" ? 600 : 500;
                                            overflow: elide;
                                        }

                                        if p.id == "self" : Rectangle {
                                            height: 3px; border-radius: 1.5px;
                                            background: VxTheme.border-subtle;
                                            Rectangle {
                                                width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                                                height: parent.height; border-radius: 1.5px;
                                                background: root.is-muted ? VxTheme.danger : VxTheme.success;
                                                animate width { duration: 40ms; }
                                            }
                                        }

                                        if p.id != "self" : VxSlider {
                                            value: p.volume; height: 12px;
                                            changed(val) => { root.volume-changed(p.id, val); }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 3px;
                                        if (p.id == "self" && root.is-deafened) || (p.id != "self" && p.is-deafened) : Rectangle {
                                            width: 38px; height: 18px; border-radius: 9px;
                                            background: VxTheme.deafen-badge-bg;
                                            border-color: VxTheme.warning;
                                            border-width: 1px;
                                            HorizontalLayout {
                                                alignment: center; spacing: 3px;
                                                Text { text: "\u{1F515}"; font-size: 8px; vertical-alignment: center; }
                                                Text { text: "DEAF"; color: VxTheme.warning; font-size: 7px; font-weight: 700;
                                                       vertical-alignment: center; }
                                            }
                                        }
                                        if p.is-muted : Rectangle {
                                            width: 38px; height: 18px; border-radius: 9px;
                                            background: VxTheme.mute-badge-bg;
                                            border-color: VxTheme.danger;
                                            border-width: 1px;
                                            HorizontalLayout {
                                                alignment: center; spacing: 3px;
                                                Text { text: "\u{1F507}"; font-size: 8px; vertical-alignment: center; }
                                                Text { text: "MUTE"; color: VxTheme.danger; font-size: 7px; font-weight: 700;
                                                       vertical-alignment: center; }
                                            }
                                        }
                                        if p.is-speaking && !p.is-muted : Rectangle {
                                            width: 8px; height: 8px; border-radius: 4px;
                                            background: VxTheme.success;
                                            border-color: VxTheme.success-dim;
                                            border-width: 2px;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Mic level bar with glow
                    Rectangle {
                        height: 4px;
                        background: VxTheme.bg-surface;

                        // Glow layer (behind the bar)
                        Rectangle {
                            x: 0px;
                            width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                            height: 8px;
                            y: -2px;
                            background: root.is-muted ? VxTheme.mic-glow-red :
                                        root.mic-level > 0.15 ? VxTheme.mic-glow-yellow :
                                        root.mic-level > 0.03 ? VxTheme.mic-glow-green : transparent;
                            border-radius: 4px;
                            animate width { duration: 50ms; }
                            animate background { duration: 100ms; }
                        }

                        // Solid bar
                        Rectangle {
                            x: 0px;
                            width: parent.width * clamp(root.mic-level * 5.0, 0.0, 1.0);
                            height: parent.height;
                            border-radius: 2px;
                            background: root.is-muted ? VxTheme.danger :
                                        root.is-deafened ? VxTheme.text-muted :
                                        root.mic-level > 0.15 ? VxTheme.warning :
                                        root.mic-level > 0.05 ? VxTheme.success : VxTheme.border-subtle;
                            animate width { duration: 50ms; }
                        }
                    }

                    // Control bar
                    Rectangle {
                        height: 60px;
                        background: VxTheme.bg-surface;
                        Divider { y: 0px; }

                        HorizontalLayout {
                            padding-left: 12px; padding-right: 12px;
                            spacing: 8px;
                            alignment: center;

                            // Mute button
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 42px;
                                border-radius: 10px;
                                background: root.is-muted ? VxTheme.danger :
                                            mute-ctrl.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                border-color: root.is-muted ? VxTheme.danger : VxTheme.border-subtle;
                                border-width: 1px;
                                animate background { duration: 80ms; easing: ease-out; }
                                mute-ctrl := TouchArea { mouse-cursor: pointer; clicked => { root.toggle-mute(); } }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text {
                                        text: root.is-muted ? "\u{1F507}" : "\u{1F3A4}";
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: root.is-muted ? "Unmute" : "Mute";
                                        color: root.is-muted ? #f0f0f8 : VxTheme.text-secondary;
                                        font-size: 9px; font-weight: 600;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Deafen button
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 42px;
                                border-radius: 10px;
                                background: root.is-deafened ? VxTheme.danger :
                                            deafen-ctrl.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                border-color: root.is-deafened ? VxTheme.danger : VxTheme.border-subtle;
                                border-width: 1px;
                                animate background { duration: 80ms; easing: ease-out; }
                                deafen-ctrl := TouchArea { mouse-cursor: pointer; clicked => { root.toggle-deafen(); } }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text {
                                        text: root.is-deafened ? "\u{1F515}" : "\u{1F50A}";
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: root.is-deafened ? "Undeafen" : "Deafen";
                                        color: root.is-deafened ? #f0f0f8 : VxTheme.text-secondary;
                                        font-size: 9px; font-weight: 600;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Mic mode button
                            Rectangle {
                                horizontal-stretch: 1;
                                height: 42px;
                                border-radius: 10px;
                                background: mic-mode-ctrl.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                border-color: root.is-open-mic ? VxTheme.success : VxTheme.accent;
                                border-width: 1px;
                                animate background { duration: 80ms; easing: ease-out; }
                                mic-mode-ctrl := TouchArea { mouse-cursor: pointer; clicked => { root.toggle-mic-mode(); } }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text {
                                        text: root.is-open-mic ? "\u{1F399}" : "\u{270B}";
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: root.is-open-mic ? "Open Mic" : "PTT";
                                        color: root.is-open-mic ? VxTheme.success : VxTheme.accent;
                                        font-size: 9px; font-weight: 600;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Settings button
                            Rectangle {
                                width: 42px;
                                height: 42px;
                                border-radius: 10px;
                                background: settings-ctrl.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                border-color: VxTheme.border-subtle;
                                border-width: 1px;
                                animate background { duration: 80ms; easing: ease-out; }
                                settings-ctrl := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(2); } }
                                Text {
                                    text: "\u{2699}";
                                    color: VxTheme.text-secondary;
                                    font-size: 16px;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ═══════════════════════════════
                //  SETTINGS VIEW
                // ═══════════════════════════════
                if current-view == 2 : VerticalLayout {

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            alignment: start;

                            HorizontalLayout {
                                alignment: space-between;
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    Text { text: "\u{2699}"; font-size: 18px; vertical-alignment: center; }
                                    Text {
                                        text: "Settings";
                                        color: VxTheme.text-primary;
                                        font-size: 18px; font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                                if root.previous-view == 1 : Rectangle {
                                    width: 110px; height: 34px; border-radius: 8px;
                                    background: back-call-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                    border-color: VxTheme.accent; border-width: 1px;
                                    animate background { duration: 80ms; }
                                    back-call-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.navigate(root.previous-view); }
                                    }
                                    HorizontalLayout {
                                        alignment: center; spacing: 5px;
                                        Text { text: "\u{2190}"; color: VxTheme.accent; font-size: 13px; vertical-alignment: center; }
                                        Text { text: "Back to call"; color: VxTheme.accent; font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                    }
                                }
                            }

                            // ── Appearance ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;
                                    SectionLabel { text: "APPEARANCE"; }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 1;
                                            alignment: start;
                                            Text {
                                                text: VxTheme.dark-mode ? "\u{1F319}" : "\u{2600}";
                                                font-size: 14px;
                                                vertical-alignment: center;
                                            }
                                            FieldLabel { text: "Theme"; vertical-alignment: center; }
                                        }
                                        // Toggle pill
                                        Rectangle {
                                            width: 58px; height: 28px;
                                            border-radius: 14px;
                                            background: VxTheme.dark-mode ? VxTheme.accent : VxTheme.bg-elevated;
                                            border-color: VxTheme.dark-mode ? VxTheme.accent : VxTheme.border-subtle;
                                            border-width: 1px;
                                            animate background { duration: 150ms; easing: ease-out; }
                                            theme-toggle := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.toggle-dark-mode(); }
                                            }
                                            // Slider knob
                                            Rectangle {
                                                x: VxTheme.dark-mode ? parent.width - self.width - 3px : 3px;
                                                y: 3px;
                                                width: 22px; height: 22px;
                                                border-radius: 11px;
                                                background: #f0f0f8;
                                                animate x { duration: 150ms; easing: ease-out; }
                                            }
                                            // Label inside
                                            Text {
                                                x: VxTheme.dark-mode ? 8px : parent.width - self.width - 8px;
                                                text: VxTheme.dark-mode ? "ON" : "OFF";
                                                color: VxTheme.dark-mode ? #f0f0f8 : VxTheme.text-muted;
                                                font-size: 8px; font-weight: 700;
                                                vertical-alignment: center;
                                                animate x { duration: 150ms; easing: ease-out; }
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Audio Devices ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    HorizontalLayout {
                                        alignment: space-between;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            alignment: start;
                                            Text { text: "\u{1F3A7}"; font-size: 11px; vertical-alignment: center; }
                                            SectionLabel { text: "AUDIO DEVICES"; vertical-alignment: center; }
                                        }
                                        VxButton { label: "Refresh"; small: true; ghost: true; clicked => { root.refresh-devices(); } }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Input device"; }
                                        if root.input-devices.length > 0 : ComboBox {
                                            model: root.input-devices;
                                            current-index <=> root.selected-input;
                                        }
                                        if root.input-devices.length == 0 : Text { text: "No microphones found"; color: VxTheme.danger; font-size: 10px; }
                                    }

                                    VerticalLayout {
                                        spacing: 4px;
                                        FieldLabel { text: "Output device"; }
                                        if root.output-devices.length > 0 : ComboBox {
                                            model: root.output-devices;
                                            current-index <=> root.selected-output;
                                        }
                                        if root.output-devices.length == 0 : Text { text: "No speakers found"; color: VxTheme.danger; font-size: 10px; }
                                    }
                                }
                            }

                            // ── Voice Mode ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F3A4}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "VOICE MODE"; vertical-alignment: center; }
                                    }

                                    HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle {
                                            height: 28px; border-radius: 6px;
                                            background: VxTheme.bg-elevated;
                                            border-color: VxTheme.accent; border-width: 1px;
                                            horizontal-stretch: 1;
                                            Text {
                                                text: root.is-open-mic ? "Open Mic" : "Push-to-Talk";
                                                color: VxTheme.accent;
                                                font-size: 11px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                        VxButton { label: "Switch"; small: true; clicked => { root.toggle-mic-mode(); } }
                                    }
                                }
                            }

                            // ── Noise Suppression ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F50A}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "NOISE SUPPRESSION"; vertical-alignment: center; }
                                    }
                                    Text {
                                        text: "Filters background noise when using open mic";
                                        color: VxTheme.text-muted; font-size: 9px;
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        alignment: center;
                                        Text { text: "Less"; color: VxTheme.text-muted; font-size: 9px; vertical-alignment: center; }
                                        VxSlider {
                                            horizontal-stretch: 1;
                                            value: root.noise-suppression;
                                            changed(val) => {
                                                root.noise-suppression = val;
                                                root.noise-suppression-changed(val);
                                            }
                                        }
                                        Text { text: "More"; color: VxTheme.text-muted; font-size: 9px; vertical-alignment: center; }
                                    }
                                    // Level indicator
                                    HorizontalLayout {
                                        alignment: center;
                                        Rectangle {
                                            height: 18px;
                                            min-width: 50px;
                                            border-radius: 4px;
                                            background: VxTheme.bg-elevated;
                                            border-color: VxTheme.border-subtle;
                                            border-width: 1px;
                                            Text {
                                                text: root.noise-suppression < 0.2 ? "Off" :
                                                      root.noise-suppression < 0.4 ? "Low" :
                                                      root.noise-suppression < 0.6 ? "Medium" :
                                                      root.noise-suppression < 0.8 ? "High" : "Max";
                                                color: root.noise-suppression < 0.2 ? VxTheme.text-muted : VxTheme.accent;
                                                font-size: 9px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            // ── Feedback Sound ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F514}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "KEYBIND FEEDBACK"; vertical-alignment: center; }
                                    }
                                    HorizontalLayout {
                                        spacing: 8px;
                                        HorizontalLayout {
                                            spacing: 6px;
                                            horizontal-stretch: 1;
                                            alignment: start;
                                            FieldLabel { text: "Play sound on mute/deafen"; vertical-alignment: center; }
                                        }
                                        // Toggle pill (same style as dark mode toggle)
                                        Rectangle {
                                            width: 58px; height: 28px;
                                            border-radius: 14px;
                                            background: root.feedback-sound ? VxTheme.accent : VxTheme.bg-elevated;
                                            border-color: root.feedback-sound ? VxTheme.accent : VxTheme.border-subtle;
                                            border-width: 1px;
                                            animate background { duration: 150ms; easing: ease-out; }
                                            feedback-toggle := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.toggle-feedback-sound(); }
                                            }
                                            Rectangle {
                                                x: root.feedback-sound ? parent.width - self.width - 3px : 3px;
                                                y: 3px;
                                                width: 22px; height: 22px;
                                                border-radius: 11px;
                                                background: #f0f0f8;
                                                animate x { duration: 150ms; easing: ease-out; }
                                            }
                                            Text {
                                                x: root.feedback-sound ? 8px : parent.width - self.width - 8px;
                                                text: root.feedback-sound ? "ON" : "OFF";
                                                color: root.feedback-sound ? #f0f0f8 : VxTheme.text-muted;
                                                font-size: 8px; font-weight: 700;
                                                vertical-alignment: center;
                                                animate x { duration: 150ms; easing: ease-out; }
                                            }
                                        }
                                    }
                                    Text {
                                        text: "Plays a distinct tone when you mute, unmute, deafen, or undeafen";
                                        color: VxTheme.text-muted; font-size: 9px;
                                    }
                                }
                            }

                            // ── Keybinds ──
                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 8px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{2328}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "KEYBINDS"; vertical-alignment: center; }
                                    }
                                    Text { text: "Hold modifier + press key for combos"; color: VxTheme.text-muted; font-size: 9px; }

                                    // PTT
                                    HorizontalLayout {
                                        spacing: 6px;
                                        FieldLabel { text: "Push-to-talk"; vertical-alignment: center; horizontal-stretch: 1; }
                                        if root.listening-keybind == "ptt" : Text { text: "Press key(s)..."; color: VxTheme.accent; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                                        if root.listening-keybind != "ptt" : KeyPill { key-text: root.ptt-key-display != "" ? root.ptt-key-display : "None"; }
                                        VxButton { label: root.listening-keybind == "ptt" ? "Cancel" : "Set"; small: true; ghost: true;
                                            clicked => { root.listening-keybind = root.listening-keybind == "ptt" ? "" : "ptt"; } }
                                        if root.ptt-key-display != "" && root.listening-keybind != "ptt" : VxButton {
                                            label: "x"; small: true; ghost: true; clicked => { root.clear-keybind("ptt"); } }
                                    }
                                    Divider {}

                                    // Mute
                                    HorizontalLayout {
                                        spacing: 6px;
                                        FieldLabel { text: "Toggle mute"; vertical-alignment: center; horizontal-stretch: 1; }
                                        if root.listening-keybind == "mute" : Text { text: "Press key(s)..."; color: VxTheme.accent; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                                        if root.listening-keybind != "mute" : KeyPill { key-text: root.mute-key-display != "" ? root.mute-key-display : "None"; }
                                        VxButton { label: root.listening-keybind == "mute" ? "Cancel" : "Set"; small: true; ghost: true;
                                            clicked => { root.listening-keybind = root.listening-keybind == "mute" ? "" : "mute"; } }
                                        if root.mute-key-display != "" && root.listening-keybind != "mute" : VxButton {
                                            label: "x"; small: true; ghost: true; clicked => { root.clear-keybind("mute"); } }
                                    }
                                    Divider {}

                                    // Deafen
                                    HorizontalLayout {
                                        spacing: 6px;
                                        FieldLabel { text: "Toggle deafen"; vertical-alignment: center; horizontal-stretch: 1; }
                                        if root.listening-keybind == "deafen" : Text { text: "Press key(s)..."; color: VxTheme.accent; font-size: 10px; font-weight: 600; vertical-alignment: center; }
                                        if root.listening-keybind != "deafen" : KeyPill { key-text: root.deafen-key-display != "" ? root.deafen-key-display : "None"; }
                                        VxButton { label: root.listening-keybind == "deafen" ? "Cancel" : "Set"; small: true; ghost: true;
                                            clicked => { root.listening-keybind = root.listening-keybind == "deafen" ? "" : "deafen"; } }
                                        if root.deafen-key-display != "" && root.listening-keybind != "deafen" : VxButton {
                                            label: "x"; small: true; ghost: true; clicked => { root.clear-keybind("deafen"); } }
                                    }
                                    Divider {}

                                    HorizontalLayout {
                                        spacing: 6px;
                                        FieldLabel { text: "Go back"; vertical-alignment: center; horizontal-stretch: 1; }
                                        KeyPill { key-text: "Esc"; }
                                    }
                                }
                            }

                            HorizontalLayout {
                                alignment: center;
                                Text { text: "Settings save automatically"; color: VxTheme.text-muted; font-size: 8px; }
                            }
                        }
                    }
                }

                // ═══════════════════════════════
                //  SPACE VIEW
                // ═══════════════════════════════
                if current-view == 4 : VerticalLayout {
                    spacing: 0px;

                    // Space header
                    Rectangle {
                        height: 50px;
                        background: VxTheme.bg-surface;
                        Divider { y: parent.height - 1px; }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            alignment: space-between;

                            HorizontalLayout {
                                spacing: 6px;
                                alignment: center;

                                Rectangle {
                                    width: 64px; height: 32px; border-radius: 8px;
                                    background: back-sp-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                    border-color: VxTheme.border-subtle; border-width: 1px;
                                    animate background { duration: 80ms; }
                                    back-sp-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.navigate(0); }
                                    }
                                    HorizontalLayout {
                                        alignment: center; spacing: 4px;
                                        Text { text: "\u{2190}"; color: VxTheme.text-secondary; font-size: 13px; vertical-alignment: center; }
                                        Text { text: "Back"; color: VxTheme.text-secondary; font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                    }
                                }

                                Text {
                                    text: root.current-space-name;
                                    color: VxTheme.text-primary;
                                    font-size: 15px; font-weight: 700;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            HorizontalLayout {
                                spacing: 6px;
                                alignment: center;

                                Rectangle {
                                    height: 28px; border-radius: 6px;
                                    background: invite-copy-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                    border-color: VxTheme.border-subtle;
                                    border-width: 1px;
                                    animate background { duration: 80ms; }

                                    invite-copy-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.copy-invite-code(); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 6px;
                                        alignment: center;
                                        Text {
                                            text: root.current-space-invite;
                                            color: VxTheme.text-muted;
                                            font-size: 10px; font-weight: 600; letter-spacing: 0.5px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Copy";
                                            color: VxTheme.accent;
                                            font-size: 10px; font-weight: 600;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Space content
                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            alignment: start;

                            // Text Channels
                            SectionLabel { text: "TEXT CHANNELS"; }

                            for channel in root.channels : Rectangle {
                                height: channel.is-voice ? 0px : 36px;
                                visible: !channel.is-voice;
                                border-radius: 6px;
                                background: txt-ch-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                                animate background { duration: 80ms; }

                                txt-ch-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.select-text-channel(channel.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "#";
                                            color: VxTheme.text-muted;
                                            font-size: 14px; font-weight: 700;
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        Text {
                                            text: channel.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px; font-weight: 500;
                                            overflow: elide;
                                        }
                                    }
                                }
                            }

                            // Voice Channels
                            SectionLabel { text: "VOICE CHANNELS"; }

                            for channel in root.channels : Rectangle {
                                height: channel.is-voice ? 40px : 0px;
                                visible: channel.is-voice;
                                border-radius: 6px;
                                background: channel.peer-count > 0 ? VxTheme.speaking-row-bg :
                                            vc-touch.has-hover ? VxTheme.row-hover-bg : transparent;
                                animate background { duration: 80ms; }

                                vc-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.join-channel(channel.id); }
                                }

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: "\u{1F50A}";
                                            color: channel.peer-count > 0 ? VxTheme.accent : VxTheme.text-muted;
                                            font-size: 12px;
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        Text {
                                            text: channel.name;
                                            color: VxTheme.text-primary;
                                            font-size: 12px; font-weight: 500;
                                            overflow: elide;
                                        }
                                    }

                                    if channel.peer-count > 0 : VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 20px; height: 16px; border-radius: 8px;
                                            background: VxTheme.bg-elevated;
                                            Text {
                                                text: channel.peer-count + "";
                                                color: VxTheme.accent;
                                                font-size: 9px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }

                            // Create channel
                            VxCard {
                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    HorizontalLayout {
                                        spacing: 6px;
                                        FieldLabel { text: "New Channel"; vertical-alignment: center; horizontal-stretch: 1; }
                                        Rectangle {
                                            width: 60px; height: 24px; border-radius: 4px;
                                            background: VxTheme.bg-elevated;
                                            border-color: VxTheme.border-subtle; border-width: 1px;
                                            type-toggle := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => { root.new-channel-is-voice = !root.new-channel-is-voice; }
                                            }
                                            Text {
                                                text: root.new-channel-is-voice ? "Voice" : "Text";
                                                color: VxTheme.accent;
                                                font-size: 9px; font-weight: 600;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        VxInput {
                                            text <=> root.new-channel-name;
                                            placeholder: "channel-name";
                                            horizontal-stretch: 1;
                                            accepted => {
                                                if root.new-channel-name != "" {
                                                    root.create-channel();
                                                }
                                            }
                                        }
                                        VxButton {
                                            label: "+";
                                            accent: true;
                                            small: true;
                                            enabled: root.new-channel-name != "";
                                            clicked => { root.create-channel(); }
                                        }
                                    }
                                }
                            }

                            // Online members
                            SectionLabel { text: "ONLINE"; }

                            for member in root.members : Rectangle {
                                height: 36px;
                                border-radius: 6px;

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 8px;

                                    VerticalLayout {
                                        alignment: center;
                                        Rectangle {
                                            width: 24px; height: 24px; border-radius: 12px;
                                            background: VxTheme.avatar-color(member.color-index);
                                            Text {
                                                text: member.initial;
                                                color: #f0f0f8;
                                                font-size: 9px; font-weight: 700;
                                                horizontal-alignment: center; vertical-alignment: center;
                                            }
                                        }
                                    }

                                    VerticalLayout {
                                        alignment: center;
                                        horizontal-stretch: 1;
                                        Text {
                                            text: member.name;
                                            color: VxTheme.text-primary;
                                            font-size: 11px; font-weight: 500;
                                            overflow: elide;
                                        }
                                    }

                                    if member.is-in-voice : VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: member.channel-name;
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                        }
                                    }
                                }
                            }

                            // Spacer
                            Rectangle { height: 8px; }
                        }
                    }

                    // Bottom: Leave / Delete Space
                    Rectangle {
                        height: root.confirm-delete-visible ? 96px : 56px;
                        background: VxTheme.bg-surface;
                        animate height { duration: 120ms; easing: ease-out; }
                        Divider { y: 0px; }
                        VerticalLayout {
                            spacing: 0px;
                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 10px;
                                padding-bottom: root.confirm-delete-visible ? 4px : 10px;
                                spacing: 10px;
                                alignment: center;
                                VxButton {
                                    label: "Leave Space";
                                    horizontal-stretch: 1;
                                    clicked => { root.leave-space(); }
                                }
                                VxButton {
                                    label: "Delete Space";
                                    danger: true;
                                    clicked => { root.confirm-delete-visible = true; }
                                }
                            }
                            if root.confirm-delete-visible : HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-bottom: 10px;
                                spacing: 8px;
                                alignment: center;
                                Text {
                                    text: "Are you sure?";
                                    color: VxTheme.danger;
                                    font-size: 11px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                                VxButton {
                                    label: "Yes, Delete";
                                    danger: true;
                                    small: true;
                                    clicked => {
                                        root.confirm-delete-visible = false;
                                        root.delete-space();
                                    }
                                }
                                VxButton {
                                    label: "Cancel";
                                    small: true;
                                    clicked => { root.confirm-delete-visible = false; }
                                }
                            }
                        }
                    }
                }

                // ═══════════════════════════════
                //  TEXT CHAT VIEW
                // ═══════════════════════════════
                if current-view == 5 : VerticalLayout {
                    // Header
                    Rectangle {
                        height: 44px;
                        background: VxTheme.bg-surface;
                        Divider { y: self.height - 1px; }
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 14px;
                            spacing: 10px;
                            alignment: start;

                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 64px; height: 32px; border-radius: 8px;
                                    background: back-chat-touch.has-hover ? VxTheme.btn-hover-bg : VxTheme.bg-elevated;
                                    border-color: VxTheme.border-subtle; border-width: 1px;
                                    animate background { duration: 80ms; }
                                    back-chat-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.current-view = 4; }
                                    }
                                    HorizontalLayout {
                                        alignment: center; spacing: 4px;
                                        Text { text: "\u{2190}"; color: VxTheme.text-secondary; font-size: 13px; vertical-alignment: center; }
                                        Text { text: "Back"; color: VxTheme.text-secondary; font-size: 11px; font-weight: 600; vertical-alignment: center; }
                                    }
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                Text {
                                    text: "# " + root.chat-channel-name;
                                    color: VxTheme.text-primary;
                                    font-size: 14px; font-weight: 600;
                                }
                            }
                        }
                    }

                    // Messages
                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            alignment: end;

                            for msg in root.chat-messages : Rectangle {
                                border-radius: 10px;
                                background: msg.is-self ? VxTheme.msg-self-bg : VxTheme.msg-other-bg;

                                VerticalLayout {
                                    padding: 10px;
                                    padding-top: 7px;
                                    padding-bottom: 7px;
                                    spacing: 2px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        Text {
                                            text: msg.sender-name;
                                            color: msg.is-self ? VxTheme.accent : VxTheme.avatar-color(msg.color-index);
                                            font-size: 10px; font-weight: 600;
                                        }
                                        Text {
                                            text: msg.timestamp;
                                            color: VxTheme.text-muted;
                                            font-size: 9px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    Text {
                                        text: msg.content;
                                        color: VxTheme.text-primary;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    // Input bar
                    Rectangle {
                        height: 54px;
                        background: VxTheme.bg-surface;
                        Divider { y: 0px; }
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 8px;
                            alignment: center;
                            VxInput {
                                text <=> root.chat-input;
                                placeholder: "Message #" + root.chat-channel-name;
                                horizontal-stretch: 1;
                                accepted => {
                                    if root.chat-input != "" {
                                        root.send-text-message();
                                    }
                                }
                            }
                            VxButton {
                                label: "Send";
                                accent: true;
                                enabled: root.chat-input != "";
                                clicked => { root.send-text-message(); }
                            }
                        }
                    }
                }

                // ═══════════════════════════════
                //  SYSTEM VIEW
                // ═══════════════════════════════
                if current-view == 3 : VerticalLayout {

                    ScrollView {
                        vertical-stretch: 1;

                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            alignment: start;

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text { text: "\u{1F4CA}"; font-size: 18px; vertical-alignment: center; }
                                Text {
                                    text: "System";
                                    color: VxTheme.text-primary;
                                    font-size: 18px; font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }

                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 3px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F4BB}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "RESOURCES"; vertical-alignment: center; }
                                    }
                                    Rectangle { height: 3px; }
                                    MetricRow { metric-label: "CPU"; metric-value: round(root.perf.cpu-percent) + "%";
                                        indicator-color: root.perf.cpu-percent < 50 ? VxTheme.success : root.perf.cpu-percent < 80 ? VxTheme.warning : VxTheme.danger; }
                                    MetricRow { metric-label: "Memory"; metric-value: round(root.perf.memory-mb * 10) / 10 + " MB";
                                        indicator-color: root.perf.memory-mb < 100 ? VxTheme.success : root.perf.memory-mb < 250 ? VxTheme.warning : VxTheme.danger; }
                                    MetricRow { metric-label: "Uptime"; metric-value: root.uptime-text; indicator-color: VxTheme.accent; }
                                }
                            }

                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 3px;
                                    HorizontalLayout {
                                        spacing: 6px;
                                        alignment: start;
                                        Text { text: "\u{1F6A6}"; font-size: 11px; vertical-alignment: center; }
                                        SectionLabel { text: "STATUS"; vertical-alignment: center; }
                                    }
                                    Rectangle { height: 3px; }
                                    MetricRow { metric-label: "Audio"; metric-value: root.perf.audio-active ? "Active" : "Idle";
                                        indicator-color: root.perf.audio-active ? VxTheme.success : VxTheme.text-muted; }
                                    MetricRow { metric-label: "Network"; metric-value: root.perf.network-connected ? "Connected" : "Offline";
                                        indicator-color: root.perf.network-connected ? VxTheme.success : VxTheme.danger; }
                                    MetricRow { metric-label: "Dropped"; metric-value: root.perf.dropped-frames + "";
                                        indicator-color: root.perf.dropped-frames == 0 ? VxTheme.success : root.perf.dropped-frames < 10 ? VxTheme.warning : VxTheme.danger; }
                                    MetricRow { metric-label: "Call"; metric-value: root.room-code != "" ? root.room-code + " (" + root.participants.length + ")" : "\u{2014}";
                                        indicator-color: root.room-code != "" ? VxTheme.accent : VxTheme.text-muted; }
                                    MetricRow { metric-label: "Mic"; metric-value: root.is-open-mic ? "Open Mic" : "Push-to-Talk";
                                        indicator-color: VxTheme.accent; }
                                }
                            }

                            VxCard {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 8px;
                                    SectionLabel { text: "ABOUT VOXLINK"; }

                                    // Brand header inside About
                                    HorizontalLayout {
                                        spacing: 12px;
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 36px; height: 36px; border-radius: 10px;
                                                background: VxTheme.accent;
                                                border-color: VxTheme.accent-glow;
                                                border-width: 2px;
                                                Text {
                                                    text: "VX";
                                                    color: #f0f0f8;
                                                    font-size: 12px; font-weight: 800; letter-spacing: 0.3px;
                                                    horizontal-alignment: center; vertical-alignment: center;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            spacing: 2px;
                                            horizontal-stretch: 1;
                                            HorizontalLayout {
                                                spacing: 0px;
                                                Text { text: "Vox"; color: VxTheme.accent; font-size: 15px; font-weight: 800; vertical-alignment: center; }
                                                Text { text: "link"; color: VxTheme.text-primary; font-size: 15px; font-weight: 600; vertical-alignment: center; }
                                            }
                                            Text { text: "Voice without limits"; color: VxTheme.text-muted; font-size: 9px; font-weight: 500; }
                                        }
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                height: 22px; border-radius: 11px;
                                                background: VxTheme.accent-subtle;
                                                border-color: VxTheme.accent-glow;
                                                border-width: 1px;
                                                HorizontalLayout {
                                                    padding-left: 10px;
                                                    padding-right: 10px;
                                                    Text { text: "v" + root.version-text; color: VxTheme.accent; font-size: 10px; font-weight: 700;
                                                           vertical-alignment: center; }
                                                }
                                            }
                                        }
                                    }

                                    Divider {}

                                    // Specs grid
                                    HorizontalLayout {
                                        spacing: 8px;
                                        // Engine
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            height: 48px;
                                            border-radius: 8px;
                                            background: VxTheme.bg-surface;
                                            border-color: VxTheme.border-subtle;
                                            border-width: 1px;
                                            VerticalLayout {
                                                alignment: center; spacing: 2px;
                                                Text { text: "\u{2699}"; font-size: 14px; horizontal-alignment: center; }
                                                Text { text: "Rust + Slint"; color: VxTheme.text-primary; font-size: 9px; font-weight: 600; horizontal-alignment: center; }
                                            }
                                        }
                                        // Audio
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            height: 48px;
                                            border-radius: 8px;
                                            background: VxTheme.bg-surface;
                                            border-color: VxTheme.border-subtle;
                                            border-width: 1px;
                                            VerticalLayout {
                                                alignment: center; spacing: 2px;
                                                Text { text: "\u{1F3B5}"; font-size: 14px; horizontal-alignment: center; }
                                                Text { text: "48kHz / 20ms"; color: VxTheme.text-primary; font-size: 9px; font-weight: 600; horizontal-alignment: center; }
                                            }
                                        }
                                        // Codec
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            height: 48px;
                                            border-radius: 8px;
                                            background: VxTheme.bg-surface;
                                            border-color: VxTheme.border-subtle;
                                            border-width: 1px;
                                            VerticalLayout {
                                                alignment: center; spacing: 2px;
                                                Text { text: "\u{1F4E1}"; font-size: 14px; horizontal-alignment: center; }
                                                Text { text: "Opus"; color: VxTheme.text-primary; font-size: 9px; font-weight: 600; horizontal-alignment: center; }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ─── Bottom Tab Bar ───
        if current-view != 1 && current-view != 4 && current-view != 5 : Rectangle {
            height: 54px;
            background: VxTheme.bg-surface;
            // Top accent line
            AccentBar { y: 0px; opacity: 0.3; }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 4px;

                // Home
                Rectangle {
                    horizontal-stretch: 1;
                    background: current-view == 0 ? VxTheme.tab-active-bg : tab-home.has-hover ? VxTheme.row-hover-bg : transparent;
                    border-radius: 8px;
                    animate background { duration: 80ms; }
                    tab-home := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(0); } }
                    VerticalLayout {
                        alignment: center; spacing: 2px;
                        Text { text: "\u{2302}"; color: current-view == 0 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 16px; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        Text { text: "Home"; color: current-view == 0 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 9px; font-weight: current-view == 0 ? 700 : 500; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: current-view == 0 ? 16px : 0px; height: 2px;
                                border-radius: 1px;
                                background: VxTheme.accent;
                                animate width { duration: 150ms; easing: ease-out; }
                            }
                        }
                    }
                }
                // Settings
                Rectangle {
                    horizontal-stretch: 1;
                    background: current-view == 2 ? VxTheme.tab-active-bg : tab-settings.has-hover ? VxTheme.row-hover-bg : transparent;
                    border-radius: 8px;
                    animate background { duration: 80ms; }
                    tab-settings := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(2); } }
                    VerticalLayout {
                        alignment: center; spacing: 2px;
                        Text { text: "\u{2699}"; color: current-view == 2 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 16px; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        Text { text: "Settings"; color: current-view == 2 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 9px; font-weight: current-view == 2 ? 700 : 500; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: current-view == 2 ? 16px : 0px; height: 2px;
                                border-radius: 1px;
                                background: VxTheme.accent;
                                animate width { duration: 150ms; easing: ease-out; }
                            }
                        }
                    }
                }
                // System
                Rectangle {
                    horizontal-stretch: 1;
                    background: current-view == 3 ? VxTheme.tab-active-bg : tab-perf.has-hover ? VxTheme.row-hover-bg : transparent;
                    border-radius: 8px;
                    animate background { duration: 80ms; }
                    tab-perf := TouchArea { mouse-cursor: pointer; clicked => { root.navigate(3); } }
                    VerticalLayout {
                        alignment: center; spacing: 2px;
                        Text { text: "\u{2261}"; color: current-view == 3 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 16px; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        Text { text: "System"; color: current-view == 3 ? VxTheme.accent : VxTheme.text-muted;
                            font-size: 9px; font-weight: current-view == 3 ? 700 : 500; horizontal-alignment: center;
                            animate color { duration: 150ms; } }
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: current-view == 3 ? 16px : 0px; height: 2px;
                                border-radius: 1px;
                                background: VxTheme.accent;
                                animate width { duration: 150ms; easing: ease-out; }
                            }
                        }
                    }
                }
            }
        }
    }
}
